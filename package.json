    "generate:character-images": "node scripts/convert-character-images.mjs",
    "upload:r2": "node --env-file-if-exists=.env scripts/upload-to-r2.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "db:init": "node scripts/init-predictions-db.mjs",
    "db:check": "node scripts/check-predictions-db.mjs",
    "db:recount": "node scripts/recount-predictions.mjs",
    "db:test": "node scripts/test-predictions.mjs"
