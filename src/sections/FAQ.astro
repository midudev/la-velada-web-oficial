---
import SectionHeader from '@/components/SectionHeader.astro'
import { EVENT_DATE_TIME } from '@/consts/event'
import type { HomeFaqItem } from '@/consts/home-faq'

interface Props {
  faqs: readonly HomeFaqItem[]
}

const { faqs } = Astro.props

const EVENT_TIMESTAMP = new Date(EVENT_DATE_TIME).getTime()
---

<section
  id="faq"
  class="faq-section relative w-full overflow-hidden px-4 py-20 sm:px-6 lg:py-28"
  aria-labelledby="faq-title"
  itemscope
  itemtype="https://schema.org/FAQPage"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-theme-gold/30 to-transparent"
  >
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-72 bg-[radial-gradient(ellipse_at_top,_var(--color-theme-gold)_0%,_transparent_70%)] opacity-[0.05]"
  >
  </div>

  <div class="relative mx-auto flex max-w-4xl flex-col items-center">
    <SectionHeader
      titleId="faq-title"
      eyebrow="INFORMACIÓN OFICIAL"
      title="PREGUNTAS FRECUENTES"
      subtitle="Respuestas rápidas sobre fecha, sede, directo, combates, entradas y anuncios de La Velada del Año VI."
      titleClass="mb-4"
      subtitleClass="mb-10 max-w-2xl tracking-[0.16em] sm:mb-14 sm:text-sm"
    />

    <ul class="w-full divide-y divide-white/10 border-y border-white/10">
      {
        faqs.map(({ question, answer, channels, battles, mainEventBattle }, index) => (
          <li>
            <details
              class="faq-item group bg-theme-midnight/35 transition duration-300 open:bg-theme-navy/35 hover:bg-theme-navy/25"
              name="faq"
              itemprop="mainEntity"
              itemscope
              itemtype="https://schema.org/Question"
            >
              <summary class="flex min-h-20 cursor-pointer list-none items-center justify-between gap-5 px-2.5 py-5 outline-none marker:hidden focus-visible:ring-2 focus-visible:ring-theme-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-theme-midnight sm:min-h-24 sm:px-4 sm:py-6 [&::-webkit-details-marker]:hidden">
                <h3
                  itemprop="name"
                  class="font-cinzel text-xl leading-tight font-black tracking-[0.02em] text-balance text-theme-cream transition duration-300 group-open:text-theme-gold sm:text-2xl"
                >
                  {question}
                </h3>
                <span
                  class="relative flex size-10.25 shrink-0 items-center justify-center rounded-full border border-theme-gold/30 bg-black/25 text-theme-gold transition duration-300 group-open:rotate-45 group-open:border-theme-gold/70 group-open:bg-theme-gold/15 sm:size-11.25"
                  aria-hidden="true"
                >
                  <span class="absolute h-px w-4.25 bg-current" />
                  <span class="absolute h-4.25 w-px bg-current" />
                </span>
              </summary>

              <div
                class="faq-answer-shell px-2.5 pb-6 pr-14 sm:px-4 sm:pr-20"
                itemprop="acceptedAnswer"
                itemscope
                itemtype="https://schema.org/Answer"
              >
                <p
                  itemprop="text"
                  class="faq-answer-body max-w-3xl text-base leading-7 text-pretty text-white/75 sm:text-lg sm:leading-8"
                >
                  {answer}
                </p>
                {index === 0 && (
                  <p
                    id="faq-local-times"
                    data-timestamp={EVENT_TIMESTAMP}
                    class="mt-4 hidden w-fit items-center gap-2 rounded-lg border border-theme-gold/25 bg-theme-gold/5 px-3 py-2 text-sm text-white/80"
                  />
                )}
                {channels && (
                  <ul class="mt-4 flex list-none flex-col gap-2 pl-0 text-base leading-7 text-white/75 sm:text-lg sm:leading-8">
                    {channels.map(({ platform, href, label }) => (
                      <li>
                        <a
                          href={href}
                          target="_blank"
                          rel="noopener noreferrer"
                          aria-label={`Ver en ${platform}: ${label}`}
                          class="font-medium text-theme-gold/90 underline decoration-theme-gold/35 decoration-dotted underline-offset-[0.2em] transition-colors hover:text-theme-cream focus-visible:text-theme-cream focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold/70"
                        >
                          {label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
                {battles && (
                  <ol class="mt-4 grid list-none gap-2 pl-0 text-base leading-7 text-white/75 sm:grid-cols-2 sm:text-lg sm:leading-8">
                    {battles.map(({ number, title }) => (
                      <li class="grid grid-cols-[2rem_minmax(0,1fr)] gap-2">
                        <span aria-hidden="true" class="font-bold text-theme-gold/80 tabular-nums">
                          {number}
                        </span>
                        <span>{title}</span>
                      </li>
                    ))}
                  </ol>
                )}
                {mainEventBattle && (
                  <p class="mt-3 max-w-3xl text-base leading-7 font-medium text-pretty text-white/85 sm:text-lg sm:leading-8">
                    {mainEventBattle.title}
                  </p>
                )}
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    const container = document.getElementById('faq-local-times')
    if (!container) return

    try {
      const target = Number(container.dataset.timestamp)
      if (!Number.isFinite(target)) return

      const eventDate = new Date(target)
      const userTz = Intl.DateTimeFormat().resolvedOptions().timeZone

      // El evento se anuncia en horario de España: si el usuario ya está ahí,
      // no hace falta repetir la conversión.
      if (userTz === 'Europe/Madrid') return

      const time = eventDate.toLocaleTimeString('es', {
        hour: '2-digit',
        minute: '2-digit',
        timeZone: userTz,
      })

      // Etiqueta amistosa para las zonas más habituales del público.
      const regionMap: Record<string, string> = {
        'Europe/Lisbon': 'Portugal',
        'Atlantic/Canary': 'Canarias',
        'America/Mexico_City': 'México',
        'America/Monterrey': 'México (Noreste)',
        'America/Merida': 'México (Sureste)',
        'America/Tijuana': 'México (Pacífico)',
        'America/New_York': 'EE.UU. (Este)',
        'America/Chicago': 'EE.UU. (Centro)',
        'America/Denver': 'EE.UU. (Montaña)',
        'America/Los_Angeles': 'EE.UU. (Pacífico)',
        'America/Bogota': 'Colombia',
        'America/Lima': 'Perú',
        'America/Santiago': 'Chile',
        'America/Argentina/Buenos_Aires': 'Argentina',
        'America/Caracas': 'Venezuela',
        'America/Guayaquil': 'Ecuador',
        'America/La_Paz': 'Bolivia',
        'America/Asuncion': 'Paraguay',
        'America/Montevideo': 'Uruguay',
        'America/Havana': 'Cuba',
        'America/Santo_Domingo': 'Rep. Dominicana',
        'America/Panama': 'Panamá',
        'America/Costa_Rica': 'Costa Rica',
        'America/Guatemala': 'Guatemala',
        'America/Tegucigalpa': 'Honduras',
        'America/El_Salvador': 'El Salvador',
        'America/Managua': 'Nicaragua',
        'America/Puerto_Rico': 'Puerto Rico',
      }

      const userLabel = regionMap[userTz] ?? userTz.replace(/_/g, ' ').split('/').pop() ?? userTz

      const labelElement = document.createElement('span')
      labelElement.textContent = `En tu zona (${userLabel}):`

      const timeElement = document.createElement('time')
      timeElement.className = 'font-cinzel font-black text-theme-gold tabular-nums'
      timeElement.textContent = `${time}h`

      container.replaceChildren(labelElement, timeElement)
      container.classList.remove('hidden')
      container.classList.add('inline-flex')
    } catch {
      // Silently fail
    }
  })
</script>

<style>
  .faq-section {
    --faq-ease-out: cubic-bezier(0.23, 1, 0.32, 1);
    interpolate-size: allow-keywords;
  }

  .faq-item {
    position: relative;
  }

  .faq-item::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: -1px;
    height: 1px;
    background-color: var(--color-theme-gold);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 220ms var(--faq-ease-out);
  }

  .faq-item[open]::before {
    transform: scaleX(1);
  }

  .faq-item::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size 280ms var(--faq-ease-out),
      content-visibility 280ms var(--faq-ease-out);
    transition-behavior: allow-discrete;
  }

  .faq-item[open]::details-content {
    block-size: auto;
  }

  .faq-answer-body {
    opacity: 0;
    transform: translateY(-0.25rem);
    transition:
      opacity 180ms var(--faq-ease-out),
      transform 220ms var(--faq-ease-out);
  }

  .faq-item[open] .faq-answer-body {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item::before,
    .faq-item::details-content,
    .faq-answer-body {
      transition: none;
    }

    .faq-answer-body {
      transform: none;
    }
  }
</style>
