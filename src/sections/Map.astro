---
import SectionHeader from '@/components/SectionHeader.astro'

const VENUE_NAME = 'Estadio de La Cartuja'
const VENUE_CITY = 'Sevilla, España'
const VENUE_COORDINATES = {
  latitude: 37.41745253261154,
  longitude: -6.004464222177984,
  zoom: 15,
}
const VENUE_LOCATION = `${VENUE_COORDINATES.latitude},${VENUE_COORDINATES.longitude}`
const VENUE_GEO_LABEL = encodeURIComponent(`${VENUE_NAME}, ${VENUE_CITY}`)
const VENUE_GEO_URL = `geo:0,0?q=${VENUE_LOCATION}(${VENUE_GEO_LABEL})`
const VENUE_WEB_MAP_URL = `https://www.google.com/maps/search/?api=1&query=${VENUE_LOCATION}`
---

<link
  rel="stylesheet"
  href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
  crossorigin=""
/>

<section
  id="sede"
  class="relative w-full overflow-hidden px-4 py-20 sm:px-6 lg:py-28"
  aria-labelledby="map-title"
>
  <div class="relative mx-auto flex max-w-6xl flex-col items-center">
    <SectionHeader
      titleId="map-title"
      eyebrow="SEDE DEL EVENTO"
      title="ESTADIO DE LA CARTUJA"
      subtitle="Sevilla, España — 25 de julio de 2026"
      subtitleClass="mb-10 max-w-xl tracking-[0.25em] sm:mb-12 sm:text-sm"
    />

    <!-- Grid: panel info + mapa -->
    <div
      class="grid w-full grid-cols-1 items-stretch gap-6 md:grid-cols-[320px_1fr] md:gap-8 lg:grid-cols-[360px_1fr] lg:gap-10"
    >
      <!-- Panel de información -->
      <div class="flex flex-col">
        <div
          class="group relative flex-1 rounded-lg border border-theme-gold/20 bg-theme-navy/50 p-6 shadow-[0_8px_32px_rgba(0,0,0,0.35)] transition-colors duration-300 hover:border-theme-gold/40 lg:p-7"
        >
          <!-- Icono + etiqueta recinto -->
          <div class="mb-5 flex items-center gap-3">
            <span
              class="flex items-center justify-center text-theme-gold drop-shadow-[0_0_6px_rgba(199,168,107,0.5)]"
              aria-hidden="true"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="22"
                height="22"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.07-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-2.003 3.5-4.697 3.5-8.327a8 8 0 10-16 0c0 3.63 1.556 6.326 3.5 8.327a19.583 19.583 0 002.682 2.282 16.975 16.975 0 001.144.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z"
                  clip-rule="evenodd"></path>
              </svg>
            </span>
            <p class="text-[0.6rem] leading-normal font-bold tracking-[0.4em] text-theme-gold/75">
              Recinto
            </p>
          </div>

          <h3
            class="mb-2text-xl leading-snug font-bold tracking-wider text-theme-cream uppercase lg:text-[1.35rem]"
          >
            Estadio de La Cartuja
          </h3>
          <p class="text-[0.7rem] leading-[1.8] tracking-[0.06em] text-white/50 uppercase">
            Av. de la Palmera, s/n<br />41012 Sevilla, España
          </p>

          <!-- Separador dorado -->
          <div class="my-5 h-px bg-linear-to-r from-transparent via-theme-gold/30 to-transparent">
          </div>

          <!-- Fecha -->
          <div class="mb-4 flex items-start gap-3">
            <span class="mt-[0.15rem] flex shrink-0 text-theme-gold/65" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="16"
                height="16"
              >
                <path
                  fill-rule="evenodd"
                  d="M6.75 2.25A.75.75 0 017.5 3v1.5h9V3A.75.75 0 0118 3v1.5h.75a3 3 0 013 3v11.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V7.5a3 3 0 013-3H6V3a.75.75 0 01.75-.75zm13.5 9a1.5 1.5 0 00-1.5-1.5H5.25a1.5 1.5 0 00-1.5 1.5v7.5a1.5 1.5 0 001.5 1.5h13.5a1.5 1.5 0 001.5-1.5v-7.5z"
                  clip-rule="evenodd"></path>
              </svg>
            </span>
            <div>
              <p
                class="mb-[0.2rem] text-[0.55rem] font-bold tracking-[0.35em] text-theme-gold/75 uppercase"
              >
                Fecha
              </p>
              <p class="text-[0.75rem] font-semibold tracking-[0.08em] text-white/75 uppercase">
                25 de julio de 2026
              </p>
            </div>
          </div>

          <!-- Hora -->
          <div class="mb-4 flex items-start gap-3">
            <span class="mt-[0.15rem] flex shrink-0 text-theme-gold/65" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="16"
                height="16"
              >
                <path
                  fill-rule="evenodd"
                  d="M12 2.25c-5.385 0-9.75 4.365-9.75 9.75s4.365 9.75 9.75 9.75 9.75-4.365 9.75-9.75S17.385 2.25 12 2.25zM12.75 6a.75.75 0 00-1.5 0v6c0 .414.336.75.75.75h4.5a.75.75 0 000-1.5h-3.75V6z"
                  clip-rule="evenodd"></path>
              </svg>
            </span>
            <div>
              <p
                class="mb-[0.2rem] text-[0.55rem] font-bold tracking-[0.35em] text-theme-gold/75 uppercase"
              >
                Hora
              </p>
              <p class="text-[0.75rem] font-semibold tracking-[0.08em] text-white/75 uppercase">
                20:00h (hora peninsular)
              </p>
            </div>
          </div>

          <!-- Aforo -->
          <div class="flex items-start gap-3">
            <span class="mt-[0.15rem] flex shrink-0 text-theme-gold/65" aria-hidden="true">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="currentColor"
                width="16"
                height="16"
              >
                <path
                  d="M11.584 2.376a.75.75 0 01.832 0l9 6a.75.75 0 11-.832 1.248L12 3.901 3.416 9.624a.75.75 0 01-.832-1.248l9-6z"
                ></path>
                <path
                  fill-rule="evenodd"
                  d="M20.25 10.332v9.918H21a.75.75 0 010 1.5H3a.75.75 0 010-1.5h.75v-9.918a.75.75 0 01.634-.74A49.109 49.109 0 0112 9c2.59 0 5.134.202 7.616.592a.75.75 0 01.634.74zm-7.5 2.418a.75.75 0 00-1.5 0v6.75a.75.75 0 001.5 0v-6.75zm3-.75a.75.75 0 01.75.75v6.75a.75.75 0 01-1.5 0v-6.75a.75.75 0 01.75-.75zM9 12.75a.75.75 0 00-1.5 0v6.75a.75.75 0 001.5 0v-6.75z"
                  clip-rule="evenodd"></path>
              </svg>
            </span>
            <div>
              <p
                class="mb-[0.2rem] font-cinzel text-[0.55rem] font-bold tracking-[0.35em] text-theme-gold/75 uppercase"
              >
                Aforo
              </p>
              <p
                class="font-cinzel text-[0.75rem] font-semibold tracking-[0.08em] text-white/75 uppercase"
              >
                80.000 espectadores
              </p>
            </div>
          </div>

          <div class="my-5 h-px bg-linear-to-r from-transparent via-theme-gold/30 to-transparent">
          </div>

          <a
            href={VENUE_WEB_MAP_URL}
            data-geo-href={VENUE_GEO_URL}
            class="flex items-center justify-center gap-2 rounded border border-theme-gold/35 py-[0.6rem] text-[0.65rem] font-bold tracking-[0.25em] text-theme-gold transition-[translate,border-color,background-color,color] duration-300 outline-none hover:-translate-y-px hover:border-theme-gold hover:bg-theme-gold/10 hover:text-theme-cream focus-visible:-translate-y-px focus-visible:border-theme-gold focus-visible:bg-theme-gold/10 focus-visible:text-theme-cream focus-visible:ring-2 focus-visible:ring-theme-gold/60 focus-visible:ring-offset-2 focus-visible:ring-offset-theme-midnight motion-reduce:transition-none motion-reduce:hover:translate-y-0"
            aria-label="Abrir la ubicación del Estadio de La Cartuja en la aplicación de mapas"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="currentColor"
              width="14"
              height="14"
              aria-hidden="true"
            >
              <path
                fill-rule="evenodd"
                d="M15.75 2.25H21a.75.75 0 01.75.75v5.25a.75.75 0 01-1.5 0V4.81L8.03 17.03a.75.75 0 01-1.06-1.06L19.19 3.75h-3.44a.75.75 0 010-1.5zm-10.5 4.5a1.5 1.5 0 00-1.5 1.5v10.5a1.5 1.5 0 001.5 1.5h10.5a1.5 1.5 0 001.5-1.5V10.5a.75.75 0 011.5 0v8.25a3 3 0 01-3 3H5.25a3 3 0 01-3-3V8.25a3 3 0 013-3H13.5a.75.75 0 010 1.5H5.25z"
                clip-rule="evenodd"></path>
            </svg>
            Abrir ubicación
          </a>
        </div>
      </div>

      <!-- Contenedor del mapa Leaflet -->
      <div
        class="relative isolate min-h-[360px] overflow-hidden rounded-lg border border-theme-gold/20 bg-theme-navy shadow-[0_20px_60px_rgba(0,0,0,0.5)] md:min-h-[480px]"
      >
        <div
          id="velada-map"
          class="h-full min-h-[360px] w-full md:min-h-[480px]"
          data-latitude={VENUE_COORDINATES.latitude}
          data-longitude={VENUE_COORDINATES.longitude}
          data-zoom={VENUE_COORDINATES.zoom}
          aria-label="Mapa con la ubicación del Estadio de La Cartuja en Sevilla"
        >
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /*
    Solo overrides de Leaflet — apuntan a clases externas que Tailwind
    no puede alcanzar desde el markup.
  */
  :global(.velada-marker) {
    background: none !important;
    border: none !important;
  }

  :global(.leaflet-container) {
    background: var(--color-theme-navy) !important;
    font-family: 'Cinzel', serif !important;
  }

  :global(.leaflet-popup-content-wrapper) {
    background: var(--color-theme-midnight) !important;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 45%, transparent) !important;
    border-radius: 0.375rem !important;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.6) !important;
    color: var(--color-theme-cream) !important;
  }

  :global(.leaflet-popup-tip) {
    background: var(--color-theme-midnight) !important;
  }

  :global(.leaflet-popup-content) {
    margin: 0.75rem 1rem !important;
    font-family: 'Cinzel', serif !important;
    font-size: 0.7rem !important;
    letter-spacing: 0.05em !important;
    text-transform: uppercase !important;
    line-height: 1.6 !important;
  }

  :global(.leaflet-popup-close-button) {
    color: color-mix(in srgb, var(--color-theme-gold) 70%, transparent) !important;
    font-size: 1.1rem !important;
    padding: 0.25rem 0.4rem !important;
  }
  :global(.leaflet-popup-close-button:hover) {
    color: var(--color-theme-gold) !important;
  }

  :global(.leaflet-control-zoom a) {
    background: var(--color-theme-midnight) !important;
    color: var(--color-theme-gold) !important;
    border-color: color-mix(in srgb, var(--color-theme-gold) 25%, transparent) !important;
    font-weight: 700 !important;
  }
  :global(.leaflet-control-zoom a:hover) {
    background: var(--color-theme-navy) !important;
    color: var(--color-theme-cream) !important;
  }

  :global(.leaflet-control-attribution) {
    background: rgba(10, 16, 36, 0.75) !important;
    color: rgba(255, 255, 255, 0.3) !important;
    font-size: 0.55rem !important;
  }
  :global(.leaflet-control-attribution a) {
    color: color-mix(in srgb, var(--color-theme-gold) 60%, transparent) !important;
  }
</style>

<script>
  import { $ } from '@/lib/dom-selector'

  const PIN_SVG = `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 54" width="40" height="54">
      <defs>
        <filter id="pin-shadow" x="-40%" y="-10%" width="180%" height="130%">
          <feDropShadow dx="0" dy="3" stdDeviation="3" flood-color="rgba(0,0,0,0.55)"/>
        </filter>
        <radialGradient id="pin-grad" cx="38%" cy="30%" r="65%">
          <stop offset="0%" stop-color="#e8c97a"/>
          <stop offset="100%" stop-color="#8a6a2e"/>
        </radialGradient>
      </defs>
      <path d="M20 2C11.163 2 4 9.163 4 18c0 10.627 14.133 29.553 15.295 31.076a.875.875 0 001.41 0C21.867 47.553 36 28.627 36 18 36 9.163 28.837 2 20 2z"
            fill="url(#pin-grad)" filter="url(#pin-shadow)"/>
      <path d="M20 3C11.716 3 5 9.716 5 18c0 10.1 13.5 28.4 15 30.3C21.5 46.4 35 28.1 35 18 35 9.716 28.284 3 20 3z"
            fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1"/>
      <circle cx="20" cy="18" r="7" fill="rgba(10,16,36,0.85)" />
      <circle cx="20" cy="18" r="4.5" fill="#c7a86b" opacity="0.9"/>
      <circle cx="20" cy="18" r="2" fill="#f4e4c9"/>
    </svg>
  `

  let mapInstance: any = null

  function isAndroid() {
    return /android/i.test(navigator.userAgent)
  }

  function updateVenueMapLink() {
    const link = $<HTMLAnchorElement>('[data-geo-href]')
    if (!link || !isAndroid()) return

    link.href = link.dataset.geoHref ?? link.href
  }

  function destroyMap() {
    if (mapInstance) {
      mapInstance.remove()
      mapInstance = null
    }
  }

  async function initMap() {
    try {
      destroyMap()

      const container = $<HTMLElement>('#velada-map')
      if (!container) return

      const latitude = Number(container.dataset.latitude)
      const longitude = Number(container.dataset.longitude)
      const zoom = Number(container.dataset.zoom)

      if (!(window as any).L) {
        await new Promise<void>((resolve, reject) => {
          const s = document.createElement('script')
          s.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js'
          s.integrity = 'sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo='
          s.crossOrigin = ''
          s.onload = () => resolve()
          s.onerror = () => reject(new Error('No se pudo cargar Leaflet'))
          document.head.appendChild(s)
        })
      }

      const L = (window as any).L

      mapInstance = L.map(container, {
        center: [latitude, longitude],
        zoom,
        zoomControl: true,
        scrollWheelZoom: false,
        attributionControl: true,
      })

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 19,
      }).addTo(mapInstance)

      const customIcon = L.divIcon({
        html: PIN_SVG,
        className: 'velada-marker',
        iconSize: [40, 54],
        iconAnchor: [20, 54],
        popupAnchor: [0, -58],
      })

      const popup = L.popup({
        closeButton: true,
        maxWidth: 220,
      }).setContent(
        `<strong style="color:#c7a86b;display:block;margin-bottom:0.35rem;">Estadio de La Cartuja</strong>
      <span style="color:rgba(244,228,201,0.7);">Sevilla, España</span><br/>
      <span style="color:rgba(255,255,255,0.5);">25 · 07 · 2026 — 20:00h</span>`,
      )

      L.marker([latitude, longitude], { icon: customIcon })
        .addTo(mapInstance)
        .bindPopup(popup)
        .openPopup()

      setTimeout(() => mapInstance?.invalidateSize(), 200)
    } catch (error) {
      console.error('No se pudo inicializar el mapa:', error)
    }
  }

  document.addEventListener('astro:page-load', () => {
    updateVenueMapLink()
    initMap()
  })

  document.addEventListener('astro:before-preparation', destroyMap)
</script>
