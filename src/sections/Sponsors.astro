---
import SectionHeader from '@/components/SectionHeader.astro'
import AlsaLogo from '@/assets/sponsors/alsa.svg'
import CeraveLogo from '@/assets/sponsors/cerave.svg'
import CocaColaLogo from '@/assets/sponsors/cocacola.svg'
import GrefusaLogo from '@/assets/sponsors/grefusa.svg'
import IdealoLogo from '@/assets/sponsors/idealo.svg'
import InfojobsLogo from '@/assets/sponsors/infojobs.svg'
import MahouLogo from '@/assets/sponsors/mahou.svg'
import MaxibonLogo from '@/assets/sponsors/maxibon.svg'
import McDonaldsLogo from '@/assets/sponsors/mcdonalds.svg'
import RevolutLogo from '@/assets/sponsors/revolut.svg'
import SpotifyLogo from '@/assets/sponsors/spotify.svg'

interface Sponsor {
  name: string
  url: string
  label: string
  Logo: typeof MaxibonLogo
  /** Tailwind classes para ajustar el tamaño óptico del logo dentro de la tarjeta. */
  logoClass: string
}

interface PromoBanner {
  name: string
  url: string
  label: string
  alt: string
  avifSrc: string
  webpSrc: string
  mobileAvifSrc: string
  mobileWebpSrc: string
  width: number
  height: number
}

const PROMO_BANNERS: PromoBanner[] = [
  {
    name: 'Revolut',
    url: 'https://www.revolut.com/en-ES/velada-6-web-velada/',
    label: 'Ir al sorteo de entradas de La Velada VI con Revolut',
    alt: 'Únete a Revolut y entra en el sorteo de 4 entradas y 1.000 euros',
    avifSrc: '/sponsor-banners/revolut-la-velada-vi.avif',
    webpSrc: '/sponsor-banners/revolut-la-velada-vi.webp',
    mobileAvifSrc: '/sponsor-banners/revolut-la-velada-vi-mobile.avif',
    mobileWebpSrc: '/sponsor-banners/revolut-la-velada-vi-mobile.webp',
    width: 1024,
    height: 151,
  },
  {
    name: 'Alsa',
    url: 'https://buslavelada.alsa.es/',
    label: 'Comprar buses directos a La Velada VI con Alsa',
    alt: 'Buses directos a La Velada VI con Alsa',
    avifSrc: '/sponsor-banners/alsa-la-velada-vi.avif',
    webpSrc: '/sponsor-banners/alsa-la-velada-vi.webp',
    mobileAvifSrc: '/sponsor-banners/alsa-la-velada-vi-mobile.avif',
    mobileWebpSrc: '/sponsor-banners/alsa-la-velada-vi-mobile.webp',
    width: 1024,
    height: 104,
  },
]

const SPONSORS: Sponsor[] = [
  {
    name: 'Maxibon',
    url: 'https://froneri.es/nuestras-marcas/maxibon',
    label: 'Ir a la página web de Maxibon',
    Logo: MaxibonLogo,
    logoClass: 'w-[62%] max-w-[130px]',
  },
  {
    name: 'Coca-Cola',
    url: 'https://www.cocacola.es/',
    label: 'Ir a la página web de Coca-Cola',
    Logo: CocaColaLogo,
    logoClass: 'w-[72%] max-w-[155px]',
  },
  {
    name: 'Revolut',
    url: 'https://www.revolut.com/',
    label: 'Ir a la página web de Revolut',
    Logo: RevolutLogo,
    logoClass: 'w-[74%] max-w-[160px]',
  },
  {
    name: 'Spotify',
    url: 'https://www.spotify.com/',
    label: 'Ir a la página web de Spotify',
    Logo: SpotifyLogo,
    logoClass: 'w-[70%] max-w-[150px]',
  },
  {
    name: 'InfoJobs',
    url: 'https://www.infojobs.net/',
    label: 'Ir a la página web de InfoJobs',
    Logo: InfojobsLogo,
    logoClass: 'w-[68%] max-w-[145px]',
  },
  {
    name: 'Mahou',
    url: 'https://www.mahou.es/',
    label: 'Ir a la página web de Mahou',
    Logo: MahouLogo,
    logoClass: 'w-[54%] max-w-[95px]',
  },
  {
    name: 'idealo',
    url: 'https://www.idealo.es/',
    label: 'Ir a la página web de idealo',
    Logo: IdealoLogo,
    logoClass: 'w-[60%] max-w-[110px]',
  },
  {
    name: "McDonald's",
    url: 'https://www.mcdonalds.es/',
    label: "Ir a la página web de McDonald's",
    Logo: McDonaldsLogo,
    logoClass: 'w-[32%] max-w-[60px]',
  },
  {
    name: 'Grefusa',
    url: 'https://www.grefusa.com/',
    label: 'Ir a la página web de Grefusa',
    Logo: GrefusaLogo,
    logoClass: 'w-[50%] max-w-[90px]',
  },
  {
    name: 'CeraVe',
    url: 'https://www.cerave.es/',
    label: 'Ir a la página web de CeraVe',
    Logo: CeraveLogo,
    logoClass: 'w-[68%] max-w-[120px]',
  },
  {
    name: 'Alsa',
    url: 'https://www.alsa.es/',
    label: 'Ir a la página web de Alsa',
    Logo: AlsaLogo,
    logoClass: 'w-[60%] max-w-[110px]',
  },
]
---

<section
  id="sponsors"
  class="relative w-full overflow-hidden px-4 py-20 sm:px-6 lg:py-28"
  aria-labelledby="sponsors-title"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-theme-gold/30 to-transparent"
  >
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-72 bg-[radial-gradient(ellipse_at_top,_#c7a86b_0%,_transparent_70%)] opacity-[0.05]"
  >
  </div>

  <div class="relative mx-auto flex max-w-6xl flex-col items-center">
    <SectionHeader
      titleId="sponsors-title"
      title="PATROCINADORES"
      subtitle="Las marcas que hacen posible La Velada del Año VI"
      subtitleClass="mb-10 max-w-xl tracking-[0.25em] sm:mb-12 sm:text-sm"
      hideDivider
    />

    <div class="mb-16 flex w-full max-w-[760px] flex-col gap-5 sm:mb-20">
      {
        PROMO_BANNERS.map(
          (
            {
              name,
              url,
              label,
              alt,
              avifSrc,
              webpSrc,
              mobileAvifSrc,
              mobileWebpSrc,
              width,
              height,
            },
            index
          ) => (
            <a
              href={url}
              target="_blank"
              rel="sponsored noopener noreferrer"
              aria-label={label}
              title={name}
               class="promo-banner group relative block w-full overflow-hidden rounded-md ring-1 ring-theme-gold/25 outline-none transition duration-300 animate-fade-in-up hover:ring-theme-gold/45 focus-visible:ring-2 focus-visible:ring-theme-gold/70 focus-visible:ring-offset-2 focus-visible:ring-offset-theme-midnight"
              style={`animation-delay:${850 + index * 90}ms`}
            >
              <picture>
                <source srcset={mobileAvifSrc} media="(max-width: 639px)" type="image/avif" />
                <source srcset={mobileWebpSrc} media="(max-width: 639px)" type="image/webp" />
                <source srcset={avifSrc} type="image/avif" />
                <source srcset={webpSrc} type="image/webp" />
                <img
                  src={webpSrc}
                  alt={alt}
                  width={width}
                  height={height}
                  loading="lazy"
                  decoding="async"
                  class="block h-auto w-full origin-center scale-[1.01] transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)] group-hover:scale-100 group-focus-visible:scale-100"
                />
              </picture>
            </a>
          )
        )
      }
    </div>

    <div class="relative w-full">
      <ul class="sponsors-grid" role="list">
        {
          SPONSORS.map(({ name, url, label, Logo, logoClass }, index) => (
            <li class="animate-fade-in-up" style={`animation-delay:${1100 + index * 65}ms`}>
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={label}
                title={name}
                class="sponsor-card group relative isolate flex aspect-[16/10] w-full items-center justify-center rounded-md text-white outline-none transition-transform duration-300 hover:-translate-y-1 focus-visible:-translate-y-1 focus-visible:ring-2 focus-visible:ring-theme-gold/60 focus-visible:ring-offset-2 focus-visible:ring-offset-theme-midnight"
              >
                <Logo
                  aria-hidden="true"
                  class:list={[
                    'h-auto drop-shadow-[0_8px_18px_rgba(0,0,0,0.45)] transition-transform duration-300',
                    logoClass,
                  ]}
                />

                <span class="sr-only">{name}</span>
              </a>
            </li>
          ))
        }
      </ul>

      <div class="pointer-events-none absolute inset-0" aria-hidden="true">
        <svg class="corner-tl absolute size-3 opacity-0 sm:size-4" viewBox="0 0 12 12" style="left: 0; top: 0;"><path d="M 1 9 L 1 1 L 9 1" fill="none" stroke="#c7a86b" stroke-width="1.5" stroke-linecap="square" /></svg>
        <svg class="corner-tr absolute size-3 opacity-0 sm:size-4" viewBox="0 0 12 12" style="left: 0; top: 0;"><path d="M 11 9 L 11 1 L 3 1" fill="none" stroke="#c7a86b" stroke-width="1.5" stroke-linecap="square" /></svg>
        <svg class="corner-bl absolute size-3 opacity-0 sm:size-4" viewBox="0 0 12 12" style="left: 0; top: 0;"><path d="M 1 3 L 1 11 L 9 11" fill="none" stroke="#c7a86b" stroke-width="1.5" stroke-linecap="square" /></svg>
        <svg class="corner-br absolute size-3 opacity-0 sm:size-4" viewBox="0 0 12 12" style="left: 0; top: 0;"><path d="M 11 3 L 11 11 L 3 11" fill="none" stroke="#c7a86b" stroke-width="1.5" stroke-linecap="square" /></svg>
      </div>
    </div>

  </div>
</section>

<style>
  .sponsors-grid {
    display: grid;
    width: 100%;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .sponsors-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .sponsors-grid {
      grid-template-columns: repeat(30, minmax(0, 1fr));
      gap: 1rem;
    }

    .sponsors-grid > li {
      grid-column: span 6;
    }

    .sponsors-grid > li:nth-child(n + 6) {
      grid-column: span 5;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .promo-banner,
    .sponsor-card {
      transition: none;
    }

    .sponsor-card:hover,
    .sponsor-card:focus-visible {
      transform: none;
    }

    .promo-banner img {
      scale: 1;
    }

    [class*='animate-fade-in-up'] {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  @media (hover: none) and (pointer: coarse) {
    .sponsor-card:hover,
    .sponsor-card:focus-visible {
      transform: none;
    }
  }
</style>

<script>
  import { animate, hover } from 'motion'

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)')
  const smQuery = window.matchMedia('(min-width: 640px)')
  const grid = document.querySelector('.sponsors-grid')?.parentElement

  if (!reducedMotion.matches && grid) {
    const corners = [
      document.querySelector('.corner-tl'),
      document.querySelector('.corner-tr'),
      document.querySelector('.corner-bl'),
      document.querySelector('.corner-br'),
    ]

    let activeCard = null
    let fadeTimer = null
    let cornerAnims = [null, null, null, null]
    let logoAnim = null

    function stopAnims() {
      cornerAnims.forEach((a) => a?.stop())
      logoAnim?.stop()
    }

    hover('.sponsor-card', (card) => {
      if (fadeTimer) { clearTimeout(fadeTimer); fadeTimer = null }
      activeCard = card
      stopAnims()

      const gridRect = grid.getBoundingClientRect()
      const cardRect = card.getBoundingClientRect()
      const sm = smQuery.matches
      const inset = sm ? 6 : 4
      const size = sm ? 16 : 12

      const x0 = cardRect.left - gridRect.left + inset
      const y0 = cardRect.top - gridRect.top + inset
      const x1 = cardRect.right - gridRect.left - inset - size
      const y1 = cardRect.bottom - gridRect.top - inset - size

      const coords = [[x0, y0], [x1, y0], [x0, y1], [x1, y1]]

      corners.forEach((corner, i) => {
        if (!corner) return
        corner.style.opacity = '1'
        cornerAnims[i] = animate(corner, { x: coords[i][0], y: coords[i][1] }, {
          type: 'spring',
          bounce: 0,
          duration: 0.2,
        })
      })

      const logo = card.querySelector('svg[aria-hidden="true"]')
      if (logo) logoAnim = animate(logo, { scale: 0.96 }, { duration: 0.05, ease: 'ease-out' })

      return () => {
        if (logo) logoAnim = animate(logo, { scale: 1 }, { duration: 0.04, ease: 'ease-out' })

        fadeTimer = setTimeout(() => {
          if (activeCard !== card) return
          stopAnims()
          corners.forEach((corner, i) => {
            if (!corner) return
            cornerAnims[i] = animate(corner, { opacity: 0, x: 0, y: 0 }, { duration: 0.15, ease: 'ease-out' })
          })
          fadeTimer = null
        }, 100)
      }
    })
  }
</script>
