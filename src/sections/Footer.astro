---
import InfojobsLogo from '@/assets/sponsors/infojobs.svg'

const PREVIOUS_EDITIONS = [
  {
    year: '2025',
    url: 'https://2025.infolavelada.com/',
  },
  {
    year: '2024',
    url: 'https://2024.infolavelada.com/',
  },
]
---

<footer class="relative w-full px-4 pb-16 pt-12 sm:px-6 sm:pb-20 sm:pt-16">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-40 bg-[radial-gradient(ellipse_at_top,_var(--color-theme-gold)_0%,_transparent_70%)] opacity-[0.05]"
  >
  </div>

  <div class="relative flex flex-col items-center justify-center">
    <div class="animate-fade-in animate-delay-1100 mb-10 flex items-center gap-4 sm:mb-14" aria-hidden="true">
      <span class="h-px w-16 bg-linear-to-r from-transparent to-theme-gold/40 sm:w-28"></span>
      <span class="size-1.5 rotate-45 bg-theme-gold/70"></span>
      <span class="h-px w-16 bg-linear-to-l from-transparent to-theme-gold/40 sm:w-28"></span>
    </div>

    <div class="mb-12 flex w-full flex-row items-center justify-center sm:mb-14">
      <nav
        class="animate-fade-in animate-delay-1100 relative z-10 mx-auto grid w-full max-w-4xl grid-cols-1 gap-3 py-6 sm:grid-cols-3 sm:gap-6 lg:gap-10"
        aria-label="Redes sociales de Ibai Llanos"
      >
        <a
          href="https://twitch.tv/ibai"
          target="_blank"
          rel="noopener noreferrer"
          style="--brand: #a970ff;"
          class="group relative flex min-h-11 w-full items-center justify-center gap-2 px-4 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
          aria-label="Seguir a Ibai en Twitch"
        >
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-8 top-1/2 -z-10 h-10 -translate-y-1/2 rounded-full bg-[var(--brand)] opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-30 group-focus-visible:opacity-30"
          ></span>
          <svg
            class="size-6 text-[#a970ff] transition-transform duration-300 ease-out group-hover:-translate-y-0.5 group-hover:scale-110 group-hover:[filter:drop-shadow(0_0_12px_var(--brand))] sm:size-7"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z"
            ></path>
          </svg>
          <span
            class="relative font-cinzel text-sm font-semibold tracking-wider text-white/95 transition-colors duration-300 after:absolute after:-bottom-1.5 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-[var(--brand)] after:transition-all after:duration-300 group-hover:text-white group-hover:after:w-full sm:text-base"
            >/IBAI</span
          >
        </a>

        <a
          href="https://tiktok.com/@ibaillanos"
          target="_blank"
          rel="noopener noreferrer"
          style="--brand: #25f4ee;"
          class="group relative flex min-h-11 w-full items-center justify-center gap-2 px-4 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
          aria-label="Seguir a Ibai Llanos en TikTok"
        >
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-8 top-1/2 -z-10 h-10 -translate-y-1/2 rounded-full bg-[var(--brand)] opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-30 group-focus-visible:opacity-30"
          ></span>
          <svg
            class="size-6 text-white transition-transform duration-300 ease-out group-hover:-translate-y-0.5 group-hover:scale-110 group-hover:[filter:drop-shadow(0_0_12px_var(--brand))] sm:size-7"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15.2a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V8.78a8.28 8.28 0 0 0 4.82 1.54V6.87a4.84 4.84 0 0 1-1.06-.18z"
            ></path>
          </svg>
          <span
            class="relative font-cinzel text-sm font-semibold tracking-wider text-white/95 transition-colors duration-300 after:absolute after:-bottom-1.5 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-[var(--brand)] after:transition-all after:duration-300 group-hover:text-white group-hover:after:w-full sm:text-base"
            >/IBAILLANOS</span
          >
        </a>

        <a
          href="https://youtube.com/@IbaiLlanos"
          target="_blank"
          rel="noopener noreferrer"
          style="--brand: #ff0000;"
          class="group relative flex min-h-11 w-full items-center justify-center gap-2 px-4 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
          aria-label="Seguir a Ibai Llanos en YouTube"
        >
          <span
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-8 top-1/2 -z-10 h-10 -translate-y-1/2 rounded-full bg-[var(--brand)] opacity-0 blur-2xl transition-opacity duration-500 group-hover:opacity-30 group-focus-visible:opacity-30"
          ></span>
          <svg
            class="size-6 text-[#ff0000] transition-transform duration-300 ease-out group-hover:-translate-y-0.5 group-hover:scale-110 group-hover:[filter:drop-shadow(0_0_12px_var(--brand))] sm:size-7"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
            ></path>
          </svg>
          <span
            class="relative font-cinzel text-sm font-semibold tracking-wider text-white/95 transition-colors duration-300 after:absolute after:-bottom-1.5 after:left-1/2 after:h-px after:w-0 after:-translate-x-1/2 after:bg-[var(--brand)] after:transition-all after:duration-300 group-hover:text-white group-hover:after:w-full sm:text-base"
            >/IBAILLANOS</span
          >
        </a>
      </nav>
    </div>

    <div
      class="animate-fade-in animate-delay-1100 mb-10 flex flex-col items-center gap-6 text-xs sm:mb-14 sm:flex-row sm:gap-10 sm:text-sm"
    >
      <div class="flex items-center gap-x-3 text-white/75">
        <span class="font-cinzel tracking-[0.25em] text-white/55">WEB PATROCINADA POR</span>
        <a
          href="https://www.infojobs.net/"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Ir a la página web de InfoJobs"
          class="inline-flex items-center text-white transition hover:opacity-75 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
        >
          <InfojobsLogo class="h-4 w-auto sm:h-5" />
        </a>
      </div>

      <span aria-hidden="true" class="hidden h-5 w-px bg-theme-gold/30 sm:block"></span>

      <nav
        class="flex items-center gap-x-4 font-cinzel tracking-[0.25em]"
        aria-label="Versiones pasadas de La Velada del Año"
      >
        <span class="text-white/55">EDICIONES ANTERIORES</span>
        <ul class="flex items-center gap-x-2 text-white/75">
          {
            PREVIOUS_EDITIONS.map(({ year, url }, index) => (
              <>
                {index > 0 && (
                  <li aria-hidden="true" class="text-theme-gold/40">
                    ·
                  </li>
                )}
                <li>
                  <a
                    href={url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex min-h-8 items-center justify-center px-1 underline-offset-4 transition hover:text-theme-cream hover:underline focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
                    aria-label={`Ir a la web de La Velada del Año ${year}`}
                  >
                    {year}
                  </a>
                </li>
              </>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="mb-8 flex items-center gap-3 sm:mb-10" aria-hidden="true">
      <span class="h-px w-12 bg-linear-to-r from-transparent to-theme-gold/25 sm:w-20"></span>
      <span class="size-1 rotate-45 bg-theme-gold/50"></span>
      <span class="h-px w-12 bg-linear-to-l from-transparent to-theme-gold/25 sm:w-20"></span>
    </div>

    <div class="pb-2 font-cinzel">
      <p class="text-center text-[0.7rem] tracking-[0.2em] text-white/60 sm:text-xs">
        <span>© 2026 LA VELADA DEL AÑO</span>
        <span aria-hidden="true" class="mx-2 text-theme-gold/40">·</span>
        <span class="text-white/45">TODOS LOS DERECHOS RESERVADOS</span>
      </p>
      <p class="mt-3 text-center text-[0.7rem] tracking-[0.15em] text-white/55 sm:text-xs">
        DESARROLLADO POR <a
          href="https://midu.dev"
          target="_blank"
          rel="noopener noreferrer"
          class="text-theme-cream/90 underline underline-offset-4 transition hover:text-theme-cream focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-white/80"
          >MIDU.DEV</a
        > Y SU COMUNIDAD
      </p>
    </div>
  </div>
</footer>
