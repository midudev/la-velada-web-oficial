---
import SectionHeader from '@/components/SectionHeader.astro'
import TimetableCards from '@/components/TimetableCards.astro'
---

<section
  id="orden-combates"
  class="relative w-full overflow-hidden px-4 py-20 sm:px-6 lg:py-28"
  aria-labelledby="timetable-title"
>
  <div class="relative mx-auto flex max-w-3xl flex-col items-center">
    <SectionHeader
      titleId="timetable-title"
      eyebrow="LA CARTELERA, EN ORDEN"
      title="ORDEN DE COMBATES"
      subtitle="Así sube cada pareja al ring, del primer combate al Main Event"
      subtitleClass="mb-8 max-w-xl tracking-[0.25em] sm:mb-10 sm:text-sm"
    />

    <TimetableCards class="w-full" />
  </div>
</section>
