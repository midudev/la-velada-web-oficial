---
import { battles } from '@/consts/battles'
import { BOXERS, BOXERS_BY_ID, COUNTRY_NAMES } from '@/consts/boxers'
import { EVENT_HOUR } from '@/consts/event'

// Bloque informativo accesible (lectores de pantalla) y rastreable por
// motores de búsqueda. Aporta el texto completo del evento que el resto
// de la home expresa visualmente con imágenes (logo, selector, fondos).
---

<aside class="sr-only" aria-labelledby="event-details-title">
  <h2 id="event-details-title">Información de La Velada del Año VI</h2>
  <p>
    La Velada del Año VI es la sexta edición del mayor evento de boxeo amateur entre streamers y
    creadores de contenido en habla hispana, organizado por el streamer Ibai Llanos. El evento se
    celebra el sábado 25 de julio de 2026 a partir de las {EVENT_HOUR} horas (horario peninsular español)
    en el Estadio de La Cartuja de Sevilla, España, y se retransmite en directo y de forma gratuita
    en el canal oficial de Ibai Llanos en Twitch.
  </p>

  <h3>Cartelera de combates</h3>
  <p>
    Esta edición cuenta con {battles.length} combates de boxeo entre {BOXERS.length}
    contendientes procedentes de España, México, Argentina, Colombia, El Salvador y Puerto Rico.
  </p>
  <ol>
    {
      battles.map((battle) => {
        const [aId, bId] = battle.boxerIds
        const a = BOXERS_BY_ID[aId]
        const b = BOXERS_BY_ID[bId]
        return (
          <li>
            Combate {battle.number}:{' '}
            <a href={`/boxeadores/${a.id}`} tabindex="-1">
              {a.name}
            </a>{' '}
            ({COUNTRY_NAMES[a.country] ?? a.country}){' vs '}
            <a href={`/boxeadores/${b.id}`} tabindex="-1">
              {b.name}
            </a>{' '}
            ({COUNTRY_NAMES[b.country] ?? b.country})
          </li>
        )
      })
    }
  </ol>

  <h3>Boxeadores y boxeadoras</h3>
  <ul>
    {
      BOXERS.map((boxer) => (
        <li>
          <a href={`/boxeadores/${boxer.id}`} tabindex="-1">
            {boxer.name}
          </a>{' '}
          — {COUNTRY_NAMES[boxer.country] ?? boxer.country}
        </li>
      ))
    }
  </ul>
</aside>
