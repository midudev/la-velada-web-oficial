---
import BoxerSelector from '@/components/BoxerSelector.astro'

const EVENT_DATE = new Date('2026-07-25T20:00:00+02:00')
const timestamp = EVENT_DATE.getTime()
---

<section
    data-hero
    class="relative w-full overflow-hidden bg-theme-midnight"
    aria-label="Presentación de La Velada del Año VI"
  >
    <picture data-hero-background class="absolute inset-0 z-0">
      <source
        type="image/avif"
        srcset="/background-1280.avif 1280w, /background-2048.avif 2048w, /background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
      />
      <img
        data-bg
        src="/background.webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
        alt=""
        role="presentation"
        class="h-full w-full object-cover object-center will-change-transform"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <div class="absolute inset-0 z-1 bg-linear-to-b from-black/40 via-transparent to-theme-midnight/80" aria-hidden="true"></div>

    {/*
      El "hero principal" (logo + selector + CTA + grid) ocupa siempre
      AL MENOS 100vh. El countdown vive como hermano debajo, así que
      cuando el contenido del header crece más allá del viewport sigue
      siendo cómodo y no queda apretado contra el countdown.

      Padding inferior reducido (`pb-3 lg:pb-5`) para que la cuadrícula
      de boxers, anclada al bottom del hero, quede más cerca del
      countdown sin pegarse al borde.
    */}
    <header class="relative z-10 flex min-h-screen w-full flex-col items-center justify-start px-4 pt-14 pb-3 text-center sm:pt-16 lg:pb-5">
      <h1 class="sr-only">
        La Velada del Año VI — Evento de boxeo amateur entre streamers organizado por Ibai
        Llanos el sábado 25 de julio de 2026 en el Estadio de La Cartuja de Sevilla
      </h1>

      <BoxerSelector />
    </header>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-4 pb-6 lg:pt-8">
      <div
        class="animate-fade-in-up animate-delay-1300 flex select-none items-center justify-center gap-3 sm:gap-5 md:gap-7"
        id="countdown-hero"
        data-date={timestamp}
        role="timer"
        aria-label="Cuenta atrás para La Velada del Año VI"
      >
        <div class="flex flex-col items-center gap-1">
          <span data-days class="countdown-digit font-cinzel text-3xl font-black tabular-nums text-theme-cream sm:text-4xl md:text-5xl">---</span>
          <span class="font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-white/40 sm:text-[0.65rem]">DÍAS</span>
        </div>
        <span class="self-start mt-1 font-cinzel text-2xl font-medium text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1">
          <span data-hours class="countdown-digit font-cinzel text-3xl font-black tabular-nums text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-white/40 sm:text-[0.65rem]">HORAS</span>
        </div>
        <span class="self-start mt-1 font-cinzel text-2xl font-medium text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1">
          <span data-minutes class="countdown-digit font-cinzel text-3xl font-black tabular-nums text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-white/40 sm:text-[0.65rem]">MIN</span>
        </div>
        <span class="self-start mt-1 font-cinzel text-2xl font-medium text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1">
          <span data-seconds class="countdown-digit font-cinzel text-3xl font-black tabular-nums text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-white/40 sm:text-[0.65rem]">SEG</span>
        </div>
      </div>
    </div>
  </section>

  <style>
    [data-hero-background] {
      mask-image: linear-gradient(to bottom, #000 0%, #000 68%, transparent 100%);
    }

    [data-bg] {
      transform-origin: center center;
      transform: scale(var(--hero-bg-scale, 1));
    }

    @media (prefers-reduced-motion: reduce) {
      [data-bg] {
        transform: none;
      }
    }

    .countdown-digit {
      text-shadow: 0 0 30px rgba(199, 168, 107, 0.2);
      min-width: 1.8em;
      text-align: center;
    }

  </style>

  <script>
    import createCountdown, { type TimeParts } from '@/lib/countdown'
    import { $ } from '@/lib/dom-selector'

    function initCountdown() {
      const $countdown = $<HTMLElement>('#countdown-hero')
      if (!$countdown) return

      const $days = $('[data-days]', $countdown)
      const $hours = $('[data-hours]', $countdown)
      const $minutes = $('[data-minutes]', $countdown)
      const $seconds = $('[data-seconds]', $countdown)

      const timestamp = Number($countdown.getAttribute('data-date') ?? 0)
      return createCountdown(timestamp, {
        onTick({ days, hours, minutes, seconds }: TimeParts) {
          if ($days) $days.textContent = days
          if ($hours) $hours.textContent = hours
          if ($minutes) $minutes.textContent = minutes
          if ($seconds) $seconds.textContent = seconds
        },
        onComplete() {},
      })
    }

    document.addEventListener('astro:page-load', () => {
      const hero = $<HTMLElement>('[data-hero]')
      if (!hero) return

      initCountdown()?.start()

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      if (!reduceMotion) {
        const controller = new AbortController()
        const { signal } = controller

        const MAX_SCALE = 0.18
        let ticking = false

        const update = () => {
          ticking = false
          const heroHeight = hero.offsetHeight || window.innerHeight
          const progress = Math.min(Math.max(window.scrollY / heroHeight, 0), 1)
          hero.style.setProperty('--hero-bg-scale', String(1 + progress * MAX_SCALE))
        }

        const onScroll = () => {
          if (ticking) return
          ticking = true
          requestAnimationFrame(update)
        }

        update()
        window.addEventListener('scroll', onScroll, { passive: true, signal })
        window.addEventListener('resize', update, { passive: true, signal })

        document.addEventListener(
          'astro:before-preparation',
          () => controller.abort(),
          { once: true },
        )
      }
    })
  </script>