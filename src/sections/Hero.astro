---
import BoxerSelector from '@/components/BoxerSelector.astro'

const EVENT_DATE = new Date('2026-07-25T20:00:00+02:00')
const timestamp = EVENT_DATE.getTime()
---

<section
    data-hero
    class="relative w-full overflow-hidden bg-theme-midnight"
    aria-label="Presentación de La Velada del Año VI"
  >
    <picture data-hero-background class="absolute inset-0 z-0">
      <source
        type="image/avif"
        srcset="/background-1280.avif 1280w, /background-2048.avif 2048w, /background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
      />
      <img
        data-bg
        src="/background.webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
        alt=""
        role="presentation"
        class="h-full w-full object-cover object-center will-change-transform"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <div class="absolute inset-0 z-1 bg-linear-to-b from-black/40 via-transparent to-theme-midnight/80" aria-hidden="true"></div>

    {/*
      El "hero principal" (logo + selector + CTA + grid) ocupa siempre
      AL MENOS 100vh. El countdown vive como hermano debajo, así que
      cuando el contenido del header crece más allá del viewport sigue
      siendo cómodo y no queda apretado contra el countdown.

      Padding inferior reducido (`pb-3 lg:pb-5`) para que la cuadrícula
      de boxers, anclada al bottom del hero, quede más cerca del
      countdown sin pegarse al borde.
    */}
    <header class="relative z-10 flex min-h-screen w-full flex-col items-center justify-start px-4 pt-14 pb-3 text-center sm:pt-16 lg:pb-5">
      <h1 class="sr-only">
        La Velada del Año VI — Evento de boxeo amateur entre streamers organizado por Ibai
        Llanos el sábado 25 de julio de 2026 en el Estadio de La Cartuja de Sevilla
      </h1>

      <BoxerSelector />
    </header>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-1 pb-6">
      <div
        class="animate-fade-in-up animate-delay-1300 flex select-none items-center justify-center gap-3 sm:gap-5 md:gap-7"
        id="countdown-hero"
        data-date={timestamp}
        role="timer"
        aria-label="Cuenta atrás para La Velada del Año VI"
      >
        <div class="flex flex-col items-center gap-1 [--countdown-width:3ch]">
          <span data-days class="countdown-digit font-cinzel text-3xl font-bold text-theme-cream sm:text-4xl md:text-5xl">---</span>
          <span class="w-full text-center font-cinzel text-[0.55rem] font-bold tracking-[0.3em] text-theme-cream sm:text-[0.65rem]">DÍAS</span>
        </div>
        <span class="countdown-separator font-cinzel text-2xl font-bold text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1 [--countdown-width:2ch]">
          <span data-hours class="countdown-digit font-cinzel text-3xl font-bold text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="w-full text-center font-cinzel text-[0.55rem] font-bold tracking-[0.3em] text-theme-cream sm:text-[0.65rem]">HORAS</span>
        </div>
        <span class="countdown-separator font-cinzel text-2xl font-bold text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1 [--countdown-width:2ch]">
          <span data-minutes class="countdown-digit font-cinzel text-3xl font-bold text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="w-full text-center font-cinzel text-[0.55rem] font-bold tracking-[0.3em] text-theme-cream sm:text-[0.65rem]">MIN</span>
        </div>
        <span class="countdown-separator font-cinzel text-2xl font-bold text-theme-gold/30 sm:text-3xl md:text-4xl" aria-hidden="true">:</span>
        <div class="flex flex-col items-center gap-1 [--countdown-width:2ch]">
          <span data-seconds class="countdown-digit font-cinzel text-3xl font-bold text-theme-cream sm:text-4xl md:text-5xl">--</span>
          <span class="w-full text-center font-cinzel text-[0.55rem] font-bold tracking-[0.3em] text-theme-cream sm:text-[0.65rem]">SEG</span>
        </div>
      </div>
    </div>
  </section>

  <style>
    [data-hero-background] {
      mask-image: linear-gradient(to bottom, #000 0%, #000 68%, transparent 100%);
    }

    [data-bg] {
      transform-origin: center center;
      transform: scale(var(--hero-bg-scale, 1));
    }

    @media (prefers-reduced-motion: reduce) {
      [data-bg] {
        transform: none;
      }
    }

    .countdown-digit {
      display: inline-flex;
      justify-content: center;
      width: var(--countdown-width);
      text-shadow: 0 0 30px rgba(199, 168, 107, 0.2);
      line-height: 1;
      font-variant-numeric: tabular-nums lining-nums;
    }

    .countdown-digit :global([data-countdown-slot]) {
      width: 1ch;
      text-align: center;
    }

    .countdown-separator {
      align-self: flex-start;
      line-height: 1;
      margin-top: 0.18em;
    }
  </style>

  <script>
    import { $ } from '@/lib/dom-selector'

    const SECOND = 1000
    const MINUTE = SECOND * 60
    const HOUR = MINUTE * 60
    const DAY = HOUR * 24

    const formatTime = (time: number) => Math.floor(time).toString().padStart(2, '0')

    function initCountdown() {
      const $countdown = $<HTMLElement>('#countdown-hero')
      if (!$countdown) return

      const $days = $('[data-days]', $countdown)
      const $hours = $('[data-hours]', $countdown)
      const $minutes = $('[data-minutes]', $countdown)
      const $seconds = $('[data-seconds]', $countdown)

      const timestamp = Number($countdown.dataset.date)
      if (!Number.isFinite(timestamp)) return
      const countdownParts = [
        [$days, (diff: number) => diff / DAY],
        [$hours, (diff: number) => (diff % DAY) / HOUR],
        [$minutes, (diff: number) => (diff % HOUR) / MINUTE],
        [$seconds, (diff: number) => (diff % MINUTE) / SECOND],
      ] as const

      const updateDigits = (node: Element | null, value: string) => {
        if (!node || node.textContent === value) return

        if (node.children.length !== value.length) {
          node.replaceChildren(
            ...Array.from(value, (digit) => {
              const slot = node.ownerDocument.createElement('span')
              slot.dataset.countdownSlot = ''
              slot.textContent = digit
              return slot
            }),
          )

          return
        }

        for (let index = 0; index < value.length; index++) {
          const slot = node.children[index]
          const digit = value[index]
          if (slot.textContent !== digit) slot.textContent = digit
        }
      }

      const updateCountdown = (diff: number) => {
        countdownParts.forEach(([node, resolveValue]) => {
          updateDigits(node, formatTime(resolveValue(diff)))
        })
      }

      let intervalId = 0

      const tick = () => {
        const diff = timestamp - Date.now()
        if (diff <= 0) return window.clearInterval(intervalId)

        updateCountdown(diff)
      }

      intervalId = window.setInterval(tick, SECOND)
      tick()

      return () => window.clearInterval(intervalId)
    }

    document.addEventListener('astro:page-load', () => {
      const hero = $<HTMLElement>('[data-hero]')
      if (!hero) return

      const cleanups: Array<() => void> = []
      const stopCountdown = initCountdown()
      if (stopCountdown) cleanups.push(stopCountdown)
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches

      if (!reduceMotion) {
        const controller = new AbortController()
        const { signal } = controller

        const MAX_SCALE = 0.18
        let ticking = false

        const update = () => {
          ticking = false
          const heroHeight = hero.offsetHeight || window.innerHeight
          const progress = Math.min(Math.max(window.scrollY / heroHeight, 0), 1)
          hero.style.setProperty('--hero-bg-scale', String(1 + progress * MAX_SCALE))
        }

        const onScroll = () => {
          if (ticking) return
          ticking = true
          requestAnimationFrame(update)
        }

        update()
        window.addEventListener('scroll', onScroll, { passive: true, signal })
        window.addEventListener('resize', update, { passive: true, signal })
        cleanups.push(() => controller.abort())
      }

      document.addEventListener(
        'astro:before-preparation',
        () => cleanups.forEach((cleanup) => cleanup()),
        { once: true },
      )
    })
  </script>
