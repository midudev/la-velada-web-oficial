---
import BoxerSelector from '@/components/BoxerSelector.astro'
import { EVENT_DATE } from '@/consts/event'

const timestamp = EVENT_DATE.getTime()
---

<section
  data-hero
  class="relative w-full overflow-hidden bg-theme-midnight"
  aria-label="Presentación de La Velada del Año VI"
>
  <picture data-hero-background class="absolute inset-0 opacity-90 saturate-130">
    <source
      type="image/avif"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.avif 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.avif 2048w, https://cdn.infolavelada.com/hero-bg/background.avif 3840w"
      sizes="100vw"
    />
    <source
      type="image/webp"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
      sizes="100vw"
    />
    <img
      data-bg
      src="https://cdn.infolavelada.com/hero-bg/background.webp"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
      sizes="100vw"
      alt=""
      role="presentation"
      class="h-full w-full object-cover object-center will-change-transform"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <div
    class="absolute inset-0 z-1 bg-linear-to-b from-black/40 via-transparent to-theme-midnight/80"
    aria-hidden="true"
  >
  </div>

  <header
    class="relative z-10 flex min-h-svh w-full flex-col items-center justify-start px-4 pt-14 pb-4 text-center sm:pt-16 lg:pb-5"
  >
    <h1 class="sr-only">
      La Velada del Año VI — Evento de boxeo amateur entre streamers organizado por Ibai Llanos el
      sábado 25 de julio de 2026 en el Estadio de La Cartuja de Sevilla
    </h1>

    <BoxerSelector />
  </header>

  <div class="relative z-10 mx-auto w-full max-w-7xl px-4 pt-4 pb-10 lg:pt-8 lg:pb-12">
    <div
      class="flex animate-fade-in-up items-start justify-center gap-x-2 select-none animate-delay-1300 sm:gap-x-3 md:gap-x-4"
      id="countdown-hero"
      data-date={timestamp}
      role="timer"
      aria-label="Cuenta atrás para La Velada del Año VI"
    >
      <div class="relative">
        <span
          data-days
          class="countdown-digit font-cinzel text-3xl font-black text-theme-cream sm:text-4xl md:text-5xl"
          ><span></span><span></span><span></span></span
        >
        <span
          class="absolute top-full right-0 left-0 mt-1 text-center font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-theme-cream sm:text-[0.65rem]"
          >DÍAS</span
        >
      </div>
      <span
        class="countdown-separator self-center font-cinzel text-2xl font-black text-theme-cream sm:text-3xl md:text-4xl"
        aria-hidden="true">:</span
      >
      <div class="relative">
        <span
          data-hours
          class="countdown-digit font-cinzel text-3xl font-black text-theme-cream sm:text-4xl md:text-5xl"
          ><span></span><span></span></span
        >
        <span
          class="absolute top-full right-0 left-0 mt-1 text-center font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-theme-cream sm:text-[0.65rem]"
          >HORAS</span
        >
      </div>
      <span
        class="countdown-separator self-center font-cinzel text-2xl font-black text-theme-cream sm:text-3xl md:text-4xl"
        aria-hidden="true">:</span
      >
      <div class="relative">
        <span
          data-minutes
          class="countdown-digit font-cinzel text-3xl font-black text-theme-cream sm:text-4xl md:text-5xl"
          ><span></span><span></span></span
        >
        <span
          class="absolute top-full right-0 left-0 mt-1 text-center font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-theme-cream sm:text-[0.65rem]"
          >MIN</span
        >
      </div>
      <span
        class="countdown-separator self-center font-cinzel text-2xl font-black text-theme-cream sm:text-3xl md:text-4xl"
        aria-hidden="true">:</span
      >
      <div class="relative">
        <span
          data-seconds
          class="countdown-digit font-cinzel text-3xl font-black text-theme-cream sm:text-4xl md:text-5xl"
          ><span></span><span></span></span
        >
        <span
          class="absolute top-full right-0 left-0 mt-1 text-center font-cinzel text-[0.55rem] font-black tracking-[0.16em] text-theme-cream sm:text-[0.65rem]"
          >SEG</span
        >
      </div>
    </div>
  </div>
</section>

<style>
  [data-hero-background] {
    mask-image: linear-gradient(to bottom, #000 0%, #000 68%, transparent 100%);
  }

  [data-bg] {
    transform-origin: center center;
  }

  /* Zoom del fondo controlado por el scroll usando scroll-driven animations.
     Si el navegador no soporta animation-timeline, no se aplica nada (el fondo
     se queda estático) gracias al @supports. */
  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      [data-bg] {
        animation: hero-bg-zoom linear both;
        animation-timeline: scroll(root block);
        /* La cabecera mide min-h-svh (~100vh), así el zoom completa su recorrido
           justo cuando se ha hecho scroll de una altura de viewport. */
        animation-range: 0 100vh;
      }
    }
  }

  @keyframes hero-bg-zoom {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.18);
    }
  }

  .countdown-digit {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    line-height: 1;
  }

  .countdown-digit span {
    flex: 0 0 auto;
    width: 1ch;
    text-align: center;
  }

  .countdown-digit span:empty {
    width: 0;
  }

  .countdown-separator {
    line-height: 1;
  }
</style>

<script>
  import { $ } from '@/lib/dom-selector'

  document.addEventListener('astro:page-load', () => {
    const hero = $<HTMLElement>('[data-hero]')
    if (!hero) return

    let intervalId = 0
    const countdown = $<HTMLElement>('#countdown-hero')
    if (countdown) {
      const days = $('[data-days]', countdown)
      const hours = $('[data-hours]', countdown)
      const minutes = $('[data-minutes]', countdown)
      const seconds = $('[data-seconds]', countdown)
      const target = Number(countdown.dataset.date)

      if (Number.isFinite(target)) {
        const tick = () => {
          const ms = target - Date.now()
          if (ms <= 0) return clearInterval(intervalId)
          const d = String(Math.floor(ms / 86400000))
          const h = String(Math.floor((ms % 86400000) / 3600000)).padStart(2, '0')
          const m = String(Math.floor((ms % 3600000) / 60000)).padStart(2, '0')
          const s = String(Math.floor((ms % 60000) / 1000)).padStart(2, '0')
          if (days) for (let i = 0; i < 3; i++) days.children[i].textContent = d[i] ?? ''
          if (hours) for (let i = 0; i < 2; i++) hours.children[i].textContent = h[i]
          if (minutes) for (let i = 0; i < 2; i++) minutes.children[i].textContent = m[i]
          if (seconds) for (let i = 0; i < 2; i++) seconds.children[i].textContent = s[i]
        }

        intervalId = window.setInterval(tick, 1000)
        tick()
      }
    }

    document.addEventListener(
      'astro:before-preparation',
      () => {
        clearInterval(intervalId)
      },
      { once: true },
    )
  })
</script>
