---
import LogoHomeLink from '@/components/LogoHomeLink.tsx'

const NAV_ITEMS = [
  {
    label: 'BOXEADORES',
    href: '/boxeadores',
    disabled: false,
  },
  {
    label: 'COMBATES',
    href: '/#cartelera',
    disabled: true,
    note: 'PRÓXIMAMENTE',
  },
  {
    label: 'PRONÓSTICOS',
    href: '/pronosticos',
    disabled: true,
    note: 'PRÓXIMAMENTE',
  },
] as const

const currentPath = Astro.url.pathname
const shouldReloadNavItem = (href: string) => currentPath === '/' && href === '/boxeadores'

const navColClass =
  'flex flex-col items-center justify-center gap-1 px-3 sm:px-4'
const navLabelClass =
  'relative inline-flex items-center font-cinzel text-[0.65rem] font-bold leading-none tracking-[0.25em] sm:text-xs'
const navNoteClass =
  'inline-flex items-center whitespace-nowrap rounded-full border border-theme-gold/55 bg-theme-midnight/90 px-2 py-0.5 font-cinzel text-[0.5rem] font-semibold leading-none tracking-[0.22em] text-theme-gold sm:text-[0.55rem]'

const navItemId = (label: string) =>
  label
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .toLowerCase()

const frost = 'backdrop-saturate-150 backdrop-contrast-125'
const scrolledBar =
  'data-[scrolled=true]:border-white/5 data-[scrolled=true]:bg-theme-midnight/40 data-[scrolled=true]:backdrop-blur-md data-[scrolled=true]:backdrop-saturate-150 data-[scrolled=true]:backdrop-contrast-125'

---

<header
  data-header
  class:list={[
    'fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent transition-[background-color,backdrop-filter,border-color] duration-500 ease-out',
    scrolledBar,
  ]}
>
  <div
    class="relative z-50 mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-3 sm:px-6 sm:py-4"
  >
    <LogoHomeLink client:visible>
      <span
        class="hidden font-cinzel text-[0.6rem] font-bold leading-none tracking-[0.32em] text-theme-cream/85 sm:inline sm:text-xs"
      >
        LA VELADA <span class="text-theme-gold">VI</span>
      </span>
    </LogoHomeLink>

    <nav class="hidden md:block" aria-label="Navegación principal" data-testid="header-nav">
      <ul class="flex items-stretch gap-1 sm:gap-2">
        {
          NAV_ITEMS.map((item) => (
            <li class={navColClass} data-nav-item={navItemId(item.label)}>
              {item.disabled ? (
                <>
                  <span
                    role="link"
                    aria-disabled="true"
                    class:list={[navLabelClass, 'select-none text-white/40']}
                    title="Próximamente"
                  >
                    {item.label}
                  </span>
                  {item.note && <span class={navNoteClass}>{item.note}</span>}
                </>
              ) : (
                <a
                  href={item.href}
                  data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                  class:list={[
                    navLabelClass,
                    'group/nav text-white/85 outline-none transition-colors duration-150 ease-out [@media(hover:hover)_and_(pointer:fine)]:hover:text-theme-cream [@media(hover:hover)_and_(pointer:fine)]:hover:delay-125 focus-visible:text-theme-cream',
                  ]}
                >
                  <span
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-x-0 -bottom-1.5 h-px origin-center scale-x-0 bg-theme-gold transition-transform duration-150 ease-out delay-0 [@media(hover:hover)_and_(pointer:fine)]:group-hover/nav:scale-x-100 [@media(hover:hover)_and_(pointer:fine)]:group-hover/nav:delay-125"
                  />
                  {item.label}
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      type="button"
      data-mobile-menu-button
      class:list={[
        'group relative inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/15 bg-black/20 text-theme-cream shadow-[0_0_30px_rgba(255,255,255,0.06)] outline-none backdrop-blur-md transition duration-300 hover:border-theme-gold/60 hover:bg-theme-midnight/90 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold md:hidden',
        frost,
      ]}
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menú"
    >
      <span class="sr-only">Abrir menú</span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 -translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:rotate-45"
      ></span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 bg-current transition duration-300 group-data-[open=true]:opacity-0"
      ></span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:-rotate-45"
      ></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    data-mobile-menu
    aria-hidden="true"
    inert
    class:list={[
      'fixed inset-0 z-40 flex min-h-dvh translate-y-[-8px] items-center justify-center overflow-y-auto bg-black/95 px-6 py-28 opacity-0 backdrop-blur-2xl transition duration-300 ease-out pointer-events-none data-[open=true]:translate-y-0 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto md:hidden',
      frost,
    ]}
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-[radial-gradient(circle_at_50%_0%,color-mix(in_srgb,var(--color-theme-gold)_18%,transparent),transparent_62%)]"
    ></div>
    <nav aria-label="Menú principal móvil" class="relative w-full max-w-sm">
      <ul class="flex flex-col items-center gap-6">
        {
          NAV_ITEMS.map((item) =>
            item.disabled ? (
              <li class="w-full">
                <span
                  role="link"
                  aria-disabled="true"
                  class="flex flex-col items-center gap-2 rounded-2xl border border-white/10 bg-white/[0.03] px-5 py-5 text-center font-cinzel text-lg font-bold tracking-[0.28em] text-white/35"
                  title="Próximamente"
                >
                  {item.label}
                  {item.note && (
                    <span class="rounded-full border border-theme-gold/55 bg-theme-midnight/90 px-3 py-1 text-[0.55rem] font-semibold tracking-[0.24em] text-theme-gold">
                      {item.note}
                    </span>
                  )}
                </span>
              </li>
            ) : (
              <li class="w-full">
                <a
                  href={item.href}
                  data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                  data-mobile-menu-link
                  class="flex items-center justify-center rounded-2xl border border-theme-gold/55 bg-theme-midnight/80 px-5 py-5 text-center font-cinzel text-lg font-bold tracking-[0.28em] text-theme-cream outline-none transition duration-300 active:border-theme-gold active:bg-theme-midnight focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold"
                >
                  {item.label}
                </a>
              </li>
            )
          )
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  import { $, $$ } from '@/lib/dom-selector'

  let headerAbort: AbortController | null = null

  function setupHeaderScroll(header: HTMLElement, signal: AbortSignal) {
    const update = () => {
      if (window.scrollY > 24) header.setAttribute('data-scrolled', 'true')
      else header.removeAttribute('data-scrolled')
    }
    update()
    window.addEventListener('scroll', update, { passive: true, signal })
  }

  function setupMobileMenu(signal: AbortSignal) {
    const menu = $<HTMLElement>('[data-mobile-menu]')
    const button = $<HTMLButtonElement>('[data-mobile-menu-button]')
    const links = $$<HTMLAnchorElement>('[data-mobile-menu-link]')
    if (!menu || !button) return

    const header = $<HTMLElement>('[data-header]')

    const setMenuOpen = (open: boolean) => {
      menu.dataset.open = String(open)
      button.dataset.open = String(open)
      menu.toggleAttribute('aria-hidden', !open)
      menu.inert = !open
      button.setAttribute('aria-expanded', String(open))
      button.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú')
      const label = $<HTMLElement>('.sr-only', button)
      if (label) label.textContent = open ? 'Cerrar menú' : 'Abrir menú'
      document.documentElement.classList.toggle('overflow-hidden', open)
      if (header) {
        if (open) header.setAttribute('data-mobile-menu-open', 'true')
        else header.removeAttribute('data-mobile-menu-open')
      }
    }

    setMenuOpen(false)

    button.addEventListener('click', () => setMenuOpen(button.ariaExpanded !== 'true'), {
      signal,
    })
    links.forEach((link) => link.addEventListener('click', () => setMenuOpen(false), { signal }))
    window.addEventListener('keydown', (e) => e.key === 'Escape' && setMenuOpen(false), {
      signal,
    })
  }

  document.addEventListener('astro:page-load', () => {
    headerAbort?.abort()
    headerAbort = new AbortController()
    const { signal } = headerAbort

    const header = $<HTMLElement>('[data-header]')
    if (header) setupHeaderScroll(header, signal)
    setupMobileMenu(signal)
  })
</script>

