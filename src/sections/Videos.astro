---
import { VIDEOS } from '@/consts/videos'
import { existsSync } from 'node:fs'

const PANEL_MARK = '/logo.svg'

const publicAssetExists = (path: string | undefined) => {
  if (!path?.startsWith('/')) return false
  return existsSync(new URL(`../../public${path}`, import.meta.url))
}

const getTileStyle = (video: (typeof VIDEOS)[number]) => {
  const poster = video.poster ?? '/logo-mark.png'
  const hasPreviewSheet = publicAssetExists(video.previewSheet)
  const previewSheet = hasPreviewSheet ? video.previewSheet : poster
  const previewSize = hasPreviewSheet && video.preview
    ? `${video.preview.columns * 100}% ${video.preview.rows * 100}%`
    : 'cover'
  const frameCount = hasPreviewSheet ? video.preview?.frameCount ?? 0 : 0

  return {
    style: [
      `--video-poster: url('${poster}')`,
      `--video-preview-sheet: url('${previewSheet}')`,
      `--video-preview-size: ${previewSize}`,
    ].join(';'),
    frameCount,
  }
}

const mainVideo = VIDEOS.find((video) => video.status === 'available') ?? VIDEOS[0]
const carouselVideos = [
  VIDEOS.find((video) => video.id === 'cara-a-cara'),
  mainVideo,
  VIDEOS.find((video) => video.id === 'pesaje'),
].filter((video): video is (typeof VIDEOS)[number] => Boolean(video))
const getNavLabel = (video: (typeof VIDEOS)[number]) =>
  video.id === 'pesaje' ? 'PESAJE' : video.title.toUpperCase()
const getPanelStyle = (video: (typeof VIDEOS)[number]) =>
  [
    `--carousel-panel-poster: ${video.poster ? `url('${video.poster}')` : 'none'}`,
    `--carousel-panel-mark: url('${PANEL_MARK}')`,
  ].join(';')
const activeVideoIndex = carouselVideos.findIndex((video) => video.status === 'available')
const initialVideo = carouselVideos[activeVideoIndex] ?? mainVideo
const initialPrevVideo = carouselVideos.at(activeVideoIndex - 1) ?? carouselVideos[0]
const initialNextVideo =
  carouselVideos.at((activeVideoIndex + 1) % carouselVideos.length) ?? carouselVideos[0]
const initialTileStyle = getTileStyle(initialVideo)
const getCarouselItem = (video: (typeof VIDEOS)[number]) => {
  const tileStyle = getTileStyle(video)

  return {
    id: video.id,
    title: video.title,
    cta: video.cta,
    status: video.status,
    videoId: video.videoId,
    duration: video.duration,
    poster: video.poster ?? '/logo-mark.png',
    previewVideo: video.previewVideo,
    previewSheet: tileStyle.frameCount > 0 ? video.previewSheet : (video.poster ?? '/logo-mark.png'),
    previewSize: video.preview && tileStyle.frameCount > 0
      ? `${video.preview.columns * 100}% ${video.preview.rows * 100}%`
      : 'cover',
    frameCount: tileStyle.frameCount,
    columns: video.preview?.columns ?? 0,
    rows: video.preview?.rows ?? 0,
    fps: video.preview?.fps ?? 0,
  }
}
const carouselState = {
  activeIndex: Math.max(activeVideoIndex, 0),
  videos: carouselVideos.map(getCarouselItem),
}
---

<section
  id="videos"
  class="videos-section relative flex min-h-[95svh] w-full overflow-hidden px-4 py-16 sm:px-6 lg:px-0 lg:py-6"
  aria-labelledby="videos-title"
  data-videos-section
>
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(199,168,107,0.12),_transparent_58%),linear-gradient(180deg,_rgba(10,16,36,0)_0%,_rgba(10,16,36,0.92)_88%)]"
    aria-hidden="true"
  >
  </div>
  <div class="relative z-10 mx-auto flex w-full max-w-[100rem] flex-col justify-center">
    <header class="videos-header mb-6 flex flex-col items-center gap-2 text-center lg:mb-4">
      <div class="flex flex-col items-center gap-2">
        <h2
          id="videos-title"
          class="font-cinzel text-xl font-bold tracking-[0.26em] text-theme-cream sm:text-2xl"
        >
          VÍDEOS
        </h2>
        <p class="max-w-xl font-cinzel text-[0.62rem] font-medium tracking-[0.25em] text-white/55 sm:text-xs">
          Todo lo que rodea a La Velada del Año VI
        </p>
      </div>
    </header>

    <div class="videos-stage relative flex min-h-0 w-full flex-col items-center justify-start gap-5 pt-8 lg:min-h-[68svh] lg:justify-center lg:gap-4 lg:pt-0" data-video-stage>
      <canvas class="video-carousel-canvas pointer-events-none absolute inset-0 z-[1] hidden h-full w-full lg:block" data-video-webgl aria-hidden="true"></canvas>

      <button
        type="button"
        class="video-side-rail video-side-rail-left group relative order-2 flex min-h-16 w-full items-center justify-center px-4 py-5 text-center outline-none transition duration-500 focus-visible:ring-2 focus-visible:ring-theme-gold/45 lg:absolute lg:left-0 lg:top-1/2 lg:z-20 lg:h-[72svh] lg:w-[clamp(8rem,13vw,14rem)] lg:-translate-y-1/2 lg:px-0 lg:py-0"
        data-video-nav
        data-carousel-direction="prev"
        aria-label="Ver vídeo anterior"
      >
        <span
          class="video-nav-label video-nav-label-left font-cinzel text-2xl font-black tracking-[0.24em] text-theme-gold/70 transition duration-500 group-hover:text-theme-gold/90 group-focus-visible:text-theme-gold/90 sm:text-3xl lg:absolute lg:top-1/2 lg:whitespace-nowrap lg:text-[clamp(3.5rem,6.8vw,6.8rem)] lg:tracking-[0.12em]"
          data-carousel-slot="prev"
        >
          {getNavLabel(carouselVideos.at(activeVideoIndex - 1) ?? carouselVideos[0])}
        </span>
      </button>

      <button
        type="button"
        class="video-side-rail video-side-rail-right group relative order-2 flex min-h-16 w-full items-center justify-center px-4 py-5 text-center outline-none transition duration-500 focus-visible:ring-2 focus-visible:ring-theme-gold/45 lg:absolute lg:right-0 lg:top-1/2 lg:z-20 lg:h-[72svh] lg:w-[clamp(8rem,13vw,14rem)] lg:-translate-y-1/2 lg:px-0 lg:py-0"
        data-video-nav
        data-carousel-direction="next"
        aria-label="Ver vídeo siguiente"
      >
        <span
          class="video-nav-label video-nav-label-right font-cinzel text-2xl font-black tracking-[0.24em] text-theme-gold/70 transition duration-500 group-hover:text-theme-gold/90 group-focus-visible:text-theme-gold/90 sm:text-3xl lg:absolute lg:top-1/2 lg:whitespace-nowrap lg:text-[clamp(3.5rem,6.8vw,6.8rem)] lg:tracking-[0.12em]"
          data-carousel-slot="next"
        >
          {getNavLabel(carouselVideos.at((activeVideoIndex + 1) % carouselVideos.length) ?? carouselVideos[0])}
        </span>
      </button>

      {
        (() => {
          const video = initialVideo
          const tileStyle = initialTileStyle

          return (
            <>
            <div class="video-carousel-belt pointer-events-none absolute inset-x-0 top-1/2 z-0 hidden -translate-y-1/2 lg:block" aria-hidden="true">
              <div
                class="video-carousel-panel video-carousel-panel-prev"
                data-carousel-panel="prev"
                data-panel-status={initialPrevVideo.status}
                style={getPanelStyle(initialPrevVideo)}
              >
                <span data-carousel-panel-title="prev">{getNavLabel(initialPrevVideo)}</span>
                <small data-carousel-panel-cta="prev">{initialPrevVideo.cta}</small>
              </div>
              <div
                class="video-carousel-panel video-carousel-panel-next"
                data-carousel-panel="next"
                data-panel-status={initialNextVideo.status}
                style={getPanelStyle(initialNextVideo)}
              >
                <span data-carousel-panel-title="next">{getNavLabel(initialNextVideo)}</span>
                <small data-carousel-panel-cta="next">{initialNextVideo.cta}</small>
              </div>
            </div>
            <article
              class="video-main-tile video-tile video-tile-active group relative order-1 isolate mx-auto flex aspect-video min-h-0 w-full max-w-6xl overflow-hidden rounded-xl border border-theme-gold/45 bg-theme-navy/40 text-left outline-none transition duration-500 hover:border-theme-gold/70 focus-within:border-theme-gold/70 lg:z-10 lg:w-[68%] lg:max-w-[70rem] xl:w-[66%]"
              data-video-carousel
              data-video-tile
              data-video-status={video.status}
              data-video-id={video.videoId}
              data-video-title={video.title}
              data-preview-frame-count={tileStyle.frameCount}
              data-preview-columns={video.preview?.columns ?? 0}
              data-preview-rows={video.preview?.rows ?? 0}
              data-preview-fps={video.preview?.fps ?? 0}
              data-preview-sheet={tileStyle.frameCount > 0 ? video.previewSheet : ''}
              aria-label={`Reproducir vídeo: ${video.title}`}
              style={tileStyle.style}
            >
            <div class="video-preview absolute inset-0 -z-10">
              {
                video.previewVideo && (
                  <video
                    class="video-preview-motion absolute inset-0 h-full w-full object-cover opacity-0"
                    data-video-preview-video
                    src={video.previewVideo}
                    poster={video.poster}
                    muted
                    loop
                    playsinline
                    preload="metadata"
                    aria-hidden="true"
                  />
                )
              }
            </div>
            <div aria-hidden="true" class="video-hover-wash absolute inset-0 -z-10"></div>
            <div class="video-locked-layer absolute inset-0 z-30 flex items-center justify-center opacity-0 transition duration-500" data-video-locked-layer aria-hidden={video.status === 'available' ? 'true' : 'false'}>
              <span class="rounded-full border border-theme-gold/35 bg-theme-midnight/65 px-4 py-2 font-cinzel text-[0.62rem] font-black tracking-[0.28em] text-theme-gold backdrop-blur">
                PRÓXIMAMENTE
              </span>
            </div>

            {
              video.status === 'locked' && (
                <>
                  <div
                    aria-hidden="true"
                    class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_center,_rgba(199,168,107,0.08),_transparent_60%)]"
                  />
                  <div
                    aria-hidden="true"
                    class="pointer-events-none absolute inset-3 -z-10 rounded-lg border border-theme-gold/10"
                  />
                </>
              )
            }

            <div data-video-frame class="absolute inset-0 z-20"></div>

            <div class="video-control-shell pointer-events-none absolute z-30">
              <div class="video-control-dock pointer-events-auto inline-flex flex-col items-center text-theme-cream transition duration-300">
                <button
                  type="button"
                  data-video-play
                  aria-label={`Reproducir ${video.title}`}
                  class="video-play-button group/play inline-flex shrink-0 items-center justify-center rounded-full text-theme-gold outline-none transition duration-300 hover:scale-[1.035] focus-visible:scale-[1.035] focus-visible:ring-2 focus-visible:ring-theme-gold/65 focus-visible:ring-offset-2 focus-visible:ring-offset-theme-midnight"
                >
                  <span class="video-button-glyph" aria-hidden="true"></span>
                </button>
                {
                  video.duration && (
                    <span class="video-duration-badge inline-flex shrink-0 items-center justify-center font-cinzel font-black text-theme-cream" data-video-duration>
                      <span>{video.duration}</span>
                    </span>
                  )
                }
              </div>
            </div>
            </article>
            </>
          )
        })()
      }
    </div>

  </div>
  <script type="application/json" data-video-carousel-json set:html={JSON.stringify(carouselState)} />
</section>

<script>
  import { initVideoPreview } from '@/lib/video-preview'

  document.addEventListener('astro:page-load', () => initVideoPreview())
</script>

<style>
  .videos-section {
    background:
      radial-gradient(ellipse at 50% 10%, rgba(199, 168, 107, 0.08), transparent 50%),
      var(--color-theme-midnight);
  }

  .videos-section::before,
  .videos-section::after {
    position: absolute;
    top: 0;
    bottom: 0;
    z-index: 1;
    width: min(32vw, 30rem);
    pointer-events: none;
    content: '';
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .videos-section::before {
    left: 0;
    background: linear-gradient(
      90deg,
      color-mix(in srgb, var(--color-theme-midnight) 92%, transparent) 0%,
      color-mix(in srgb, var(--color-theme-gold) 13%, transparent) 42%,
      transparent 100%
    );
  }

  .videos-section::after {
    right: 0;
    background: linear-gradient(
      270deg,
      color-mix(in srgb, var(--color-theme-midnight) 92%, transparent) 0%,
      color-mix(in srgb, var(--color-theme-gold) 13%, transparent) 42%,
      transparent 100%
    );
  }

  .videos-section:has(.video-side-rail-left:hover)::before,
  .videos-section:has(.video-side-rail-left:focus-visible)::before,
  .videos-section:has(.video-side-rail-right:hover)::after,
  .videos-section:has(.video-side-rail-right:focus-visible)::after {
    opacity: 1;
  }

  .videos-stage {
    min-height: min(68svh, 48rem);
    perspective: 1600px;
    transform-style: preserve-3d;
  }

  .video-carousel-belt {
    left: 50%;
    width: min(54vw, 44rem);
    height: min(76svh, 52rem);
    transform: translate3d(-50%, -50%, -260px);
    transform-style: preserve-3d;
  }

  .video-carousel-panel {
    position: absolute;
    left: 50%;
    width: clamp(10rem, 13vw, 15rem);
    aspect-ratio: 9 / 14;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    gap: 0.35rem;
    overflow: hidden;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 54%, transparent);
    border-radius: 0.75rem;
    background:
      linear-gradient(180deg, rgba(4, 6, 14, 0.08), rgba(4, 6, 14, 0.92)),
      var(--carousel-panel-poster),
      radial-gradient(
        ellipse at 50% 26%,
        color-mix(in srgb, var(--color-theme-gold) 24%, transparent),
        transparent 48%
      ),
      linear-gradient(135deg, rgba(199, 168, 107, 0.16), rgba(4, 6, 14, 0.94) 72%);
    background-position: center;
    background-size: cover, cover, cover, cover;
    box-shadow: 0 24px 60px -48px rgba(0, 0, 0, 0.98);
    color: var(--color-theme-cream);
    opacity: 0.5;
    padding: 1.25rem;
    transform-style: preserve-3d;
    transition:
      opacity 0.42s ease,
      transform 0.78s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.5s ease;
    will-change: transform, opacity;
  }

  .video-carousel-panel::before {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(180deg, rgba(244, 228, 201, 0.08), transparent 36%),
      repeating-linear-gradient(
        0deg,
        color-mix(in srgb, var(--color-theme-gold) 10%, transparent) 0 1px,
        transparent 1px 18px
      );
    opacity: 0.22;
  }

  .video-carousel-panel[data-panel-status='locked'] {
    background:
      radial-gradient(
        ellipse at 50% 28%,
        color-mix(in srgb, var(--color-theme-gold) 24%, transparent),
        transparent 44%
      ),
      linear-gradient(160deg, rgba(199, 168, 107, 0.2), rgba(4, 6, 14, 0.94) 56%),
      linear-gradient(180deg, rgba(8, 11, 21, 0.92), rgba(2, 4, 10, 0.98));
    filter: none;
  }

  .video-carousel-panel[data-panel-status='locked']::after {
    position: absolute;
    inset: 0;
    content: '';
    background:
      linear-gradient(180deg, transparent 0%, rgba(4, 6, 14, 0.88) 100%),
      var(--carousel-panel-mark);
    background-position:
      center,
      center 28%;
    background-repeat: no-repeat;
    background-size:
      cover,
      58% auto;
    opacity: 0.72;
  }

  .video-carousel-panel span,
  .video-carousel-panel small {
    position: relative;
    z-index: 2;
    font-family: var(--font-cinzel);
    text-transform: uppercase;
  }

  .video-carousel-panel span {
    max-width: 8ch;
    font-size: clamp(1.35rem, 2.35vw, 2.65rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: 0.04em;
  }

  .video-carousel-panel small {
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.24em;
    color: var(--color-theme-gold);
  }

  .video-carousel-panel-prev {
    top: 0;
    transform: translate3d(-50%, -18%, -180px) rotateX(-44deg) rotateZ(-4deg);
    transform-origin: center bottom;
  }

  .video-carousel-panel-next {
    top: 100%;
    align-items: flex-start;
    transform: translate3d(-50%, -82%, -180px) rotateX(44deg) rotateZ(4deg);
    transform-origin: center top;
  }

  .videos-stage:has(.video-side-rail-left:hover) .video-carousel-panel-prev,
  .videos-stage:has(.video-side-rail-left:focus-visible) .video-carousel-panel-prev,
  .videos-stage:has(.video-side-rail-right:hover) .video-carousel-panel-next,
  .videos-stage:has(.video-side-rail-right:focus-visible) .video-carousel-panel-next {
    opacity: 0.82;
  }

  .videos-stage[data-carousel-moving='true'] .video-carousel-panel {
    transition:
      opacity 0.34s ease,
      transform 0.46s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.34s ease;
  }

  .videos-stage[data-carousel-direction='next'][data-carousel-phase='exit'] .video-carousel-panel-next {
    opacity: 0.96;
    transform: translate3d(-50%, -118%, -24px) rotateX(6deg) rotateZ(1deg) scale(1.04);
  }

  .videos-stage[data-carousel-direction='next'][data-carousel-phase='exit'] .video-carousel-panel-prev {
    opacity: 0.14;
    transform: translate3d(-50%, -48%, -340px) rotateX(-64deg) rotateZ(-6deg) scale(0.82);
  }

  .videos-stage[data-carousel-direction='prev'][data-carousel-phase='exit'] .video-carousel-panel-prev {
    opacity: 0.9;
    transform: translate3d(-50%, 18%, -24px) rotateX(-6deg) rotateZ(-1deg) scale(1.04);
  }

  .videos-stage[data-carousel-direction='prev'][data-carousel-phase='exit'] .video-carousel-panel-next {
    opacity: 0.14;
    transform: translate3d(-50%, -52%, -340px) rotateX(64deg) rotateZ(6deg) scale(0.82);
  }

  .videos-stage[data-carousel-direction='next'][data-carousel-phase='enter'] .video-carousel-panel-prev {
    opacity: 0.9;
    transform: translate3d(-50%, 10%, -72px) rotateX(-18deg) rotateZ(-1deg);
  }

  .videos-stage[data-carousel-direction='next'][data-carousel-phase='enter'] .video-carousel-panel-next {
    opacity: 0.38;
    transform: translate3d(-50%, -98%, -240px) rotateX(52deg) rotateZ(5deg) scale(0.94);
  }

  .videos-stage[data-carousel-direction='prev'][data-carousel-phase='enter'] .video-carousel-panel-prev {
    opacity: 0.38;
    transform: translate3d(-50%, -2%, -240px) rotateX(-52deg) rotateZ(-5deg) scale(0.94);
  }

  .videos-stage[data-carousel-direction='prev'][data-carousel-phase='enter'] .video-carousel-panel-next {
    opacity: 0.9;
    transform: translate3d(-50%, -110%, -72px) rotateX(18deg) rotateZ(1deg);
  }

  .video-preview {
    overflow: hidden;
    background-color: color-mix(in srgb, var(--color-theme-midnight) 92%, black);
    background-image:
      linear-gradient(to top, rgba(0, 0, 0, 0.46), rgba(0, 0, 0, 0.1) 42%, transparent 74%),
      var(--video-poster);
    background-position:
      center,
      center;
    background-repeat: no-repeat;
    background-size:
      cover,
      contain;
    contain: paint;
    filter: saturate(0.98) brightness(0.94);
    transition:
      filter 0.7s ease;
  }

  .video-preview::after {
    position: absolute;
    inset: 0;
    content: '';
    background-image:
      linear-gradient(to top, rgba(0, 0, 0, 0.42), rgba(0, 0, 0, 0.04) 62%, transparent),
      var(--video-preview-sheet);
    background-position:
      center,
      var(--video-preview-position, 0% 0%);
    background-repeat: no-repeat;
    background-size:
      cover,
      var(--video-preview-size);
    opacity: 0;
    transition: opacity 0.26s ease;
    will-change: opacity;
  }

  .video-tile[data-preview-mode='sprite'] .video-preview::after {
    opacity: 1;
  }

  .video-preview-motion {
    filter: saturate(1.08) brightness(1.08);
    transition: opacity 0.22s ease;
  }

  .video-tile[data-preview-mode='video'] .video-preview-motion {
    opacity: 1;
  }

  .video-carousel-canvas {
    mix-blend-mode: screen;
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.45s ease,
      transform 0.65s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .videos-stage[data-carousel-moving='true'] .video-carousel-canvas,
  .videos-stage[data-unwrapping='true'] .video-carousel-canvas {
    opacity: 0.46;
    transform: scaleX(1.035);
  }

  .video-tile[data-unwrapping='true'] {
    transform: perspective(1400px) rotateX(0deg) scale(1.018);
  }

  .video-tile[data-video-status='locked'] .video-locked-layer {
    opacity: 1;
  }

  .video-tile[data-video-status='locked'] .video-play-button,
  .video-tile[data-video-status='locked'] [data-video-duration] {
    opacity: 0;
    pointer-events: none;
  }

  .video-tile-active:hover .video-preview,
  .video-tile-active:focus-within .video-preview,
  .video-tile-active[data-preview-mode='video'] .video-preview,
  .video-tile-active[data-preview-mode='sprite'] .video-preview {
    filter: saturate(1.08) brightness(1.04);
  }

  .video-hover-wash {
    background:
      radial-gradient(
        ellipse at 34% 70%,
        color-mix(in srgb, var(--color-theme-gold) 18%, transparent),
        transparent 46%
      ),
      linear-gradient(
        180deg,
        transparent 0%,
        color-mix(in srgb, var(--color-theme-midnight) 24%, transparent) 100%
      );
    opacity: 0;
    transition: opacity 0.45s ease;
  }

  .video-tile-active:hover .video-hover-wash,
  .video-tile-active:focus-within .video-hover-wash {
    opacity: 0.32;
  }

  .video-control-shell {
    top: 50%;
    left: 52.5%;
    transform: translate(-50%, -50%);
    --video-control-gold: var(--color-theme-gold);
  }

  .video-control-dock {
    gap: clamp(1rem, 1.6vw, 1.35rem);
    opacity: 0.94;
  }

  .video-tile-active:hover .video-control-dock,
  .video-tile-active:focus-within .video-control-dock {
    opacity: 1;
  }

  .video-play-button {
    width: clamp(6.4rem, 10vw, 7.75rem);
    height: clamp(6.4rem, 10vw, 7.75rem);
    border: 2px solid var(--video-control-gold);
    background: color-mix(in srgb, var(--color-theme-midnight) 82%, black);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-cream) 13%, transparent),
      0 16px 36px -24px rgba(0, 0, 0, 0.95),
      0 0 26px -18px color-mix(in srgb, var(--video-control-gold) 80%, transparent);
  }

  .video-play-button:hover,
