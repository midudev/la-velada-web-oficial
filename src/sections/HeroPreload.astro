---
// Preload del fondo del hero: es el LCP de la home, por eso vive aquí y no
// en el Layout (donde se descargaría en rutas que no tienen hero).
//
// Usamos imagesrcset/imagesizes (mismo criterio que el <picture> del Hero)
// para que el navegador precargue exactamente la variante que luego usa,
// y no dispare el warning de "preloaded but not used".
---

<link
  rel="preload"
  as="image"
  type="image/avif"
  imagesrcset="https://cdn.infolavelada.com/hero-bg/background-1280.avif 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.avif 2048w, https://cdn.infolavelada.com/hero-bg/background.avif 3840w"
  imagesizes="100vw"
  fetchpriority="high"
/>
