---
import { getCollection } from 'astro:content'
import SectionHeader from '@/components/SectionHeader.astro'
import ArrowRightIcon from '@/assets/svg/arrow-right.svg'
import ChevronRightIcon from '@/assets/svg/chevron-right.svg'
import PlayIcon from '@/assets/svg/play.svg'
import YoutubeIcon from '@/assets/svg/youtube.svg'

const CHANNEL_URL = 'https://www.youtube.com/@PodcastdeLuzu'

interface PodcastEpisode {
  videoId: string
  title: string
  published: Date
  thumbnail: {
    avif: string
    webp: string
  }
}

const rawEpisodes = await getCollection('podcast')
const episodes: PodcastEpisode[] = rawEpisodes
  .map(({ data }) => ({
    videoId: data.videoId,
    title: data.title,
    published: new Date(data.published),
    thumbnail: {
      avif: `/podcast/thumbnails/${data.videoId}.avif`,
      webp: `/podcast/thumbnails/${data.videoId}.webp`,
    },
  }))
  .sort((a, b) => b.published.getTime() - a.published.getTime())

const [featuredEpisode, ...secondaryEpisodes] = episodes

const rtf = new Intl.RelativeTimeFormat('es', { numeric: 'auto' })
const dateFormatter = new Intl.DateTimeFormat('es', {
  day: '2-digit',
  month: 'short',
  year: 'numeric',
})

function formatRelative(date: Date) {
  const diffMs = date.getTime() - Date.now()
  const diffHours = Math.round(diffMs / (1000 * 60 * 60))
  const diffDays = Math.round(diffHours / 24)
  if (Math.abs(diffHours) < 24) {
    return rtf.format(diffHours, 'hour')
  }
  if (Math.abs(diffDays) < 30) {
    return rtf.format(diffDays, 'day')
  }
  return rtf.format(Math.round(diffDays / 30), 'month')
}
---

<section
  id="podcast"
  class="relative w-full px-4 pb-20 sm:px-6 lg:pb-28"
  aria-labelledby="podcast-title"
>
  <div class="mx-auto flex max-w-7xl flex-col items-center">
    <SectionHeader
      titleId="podcast-title"
      title="EL PODCAST PIRATA"
      subtitle="Últimos episodios sobre La Velada del Año VI"
      dividerClass="sm:mb-10"
    />

    <div
      class="relative w-full overflow-hidden rounded-2xl border border-white/10 bg-theme-navy/30 shadow-[0_25px_60px_-30px_rgba(0,0,0,0.8)]"
    >
      <header
        class="flex items-center justify-between gap-3 border-b border-white/10 bg-black/30 px-4 py-3 sm:px-6"
      >
        <div class="flex items-center gap-3">
          <span
            class="flex size-8 items-center justify-center rounded-full bg-theme-gold/15 text-theme-gold sm:size-9"
            aria-hidden="true"
          >
            <YoutubeIcon class="size-4 sm:size-5" aria-hidden="true" />
          </span>
          <div class="flex flex-col">
            <span
              class="font-cinzel text-xs font-black tracking-[0.2em] text-theme-cream sm:text-sm"
            >
              EL PODCAST PIRATA DE LA VELADA 6
            </span>
            <a
              href={CHANNEL_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="font-cinzel text-[0.6rem] tracking-[0.25em] text-white/50 transition hover:text-theme-gold focus-visible:text-theme-gold sm:text-[0.65rem]"
            >
              VER CANAL EN YOUTUBE
            </a>
          </div>
        </div>

        <span
          class="hidden font-cinzel text-[0.6rem] tracking-[0.25em] text-white/45 sm:inline-block"
        >
          {episodes.length} EPISODIO{episodes.length === 1 ? '' : 'S'}
        </span>
      </header>

      {
        episodes.length === 0 ? (
          <div class="flex h-[28rem] items-center justify-center px-6 text-center font-cinzel text-xs tracking-[0.2em] text-white/55 sm:h-[32rem] sm:text-sm">
            No hay episodios publicados en los últimos 2 meses.
          </div>
        ) : (
          <div
            class:list={[
              '@container grid gap-px bg-white/10',
              secondaryEpisodes.length > 0
                ? 'lg:grid-cols-[minmax(0,1.12fr)_minmax(320px,0.88fr)]'
                : 'lg:grid-cols-1',
            ]}
          >
            {featuredEpisode && (
              <button
                type="button"
                data-video-tile
                data-video-id={featuredEpisode.videoId}
                data-video-title={featuredEpisode.title}
                aria-label={`Reproducir episodio destacado: ${featuredEpisode.title}`}
                class="group relative isolate flex aspect-video w-full cursor-pointer self-start overflow-hidden border border-white/10 bg-theme-navy/40 text-left transition duration-500 outline-none hover:border-theme-gold/50 hover:shadow-[0_18px_60px_-20px_rgba(199,168,107,0.55)] focus-visible:border-theme-gold/70 focus-visible:ring-2 focus-visible:ring-theme-gold/60 lg:aspect-auto lg:h-[31.5cqw]"
              >
                <picture class="absolute inset-0 -z-10 scale-105 brightness-90 transition duration-700 ease-out group-hover:scale-110 group-hover:brightness-110 group-focus-visible:scale-110 group-focus-visible:brightness-110">
                  <source srcset={featuredEpisode.thumbnail.avif} type="image/avif" />
                  <source srcset={featuredEpisode.thumbnail.webp} type="image/webp" />
                  <img
                    src={featuredEpisode.thumbnail.webp}
                    alt=""
                    aria-hidden="true"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                    class="h-full w-full object-cover"
                  />
                </picture>
                <div
                  aria-hidden="true"
                  class="absolute inset-0 -z-10 bg-linear-to-t from-black/85 via-black/40 to-black/20"
                />
                <div
                  aria-hidden="true"
                  class="absolute inset-0 -z-10 bg-[radial-gradient(ellipse_at_top_left,_rgba(199,168,107,0.18),_transparent_55%)] opacity-0 transition duration-500 group-hover:opacity-100 group-focus-visible:opacity-100"
                />

                <span
                  class="absolute top-5 right-5 z-10 rounded-full border border-theme-gold/35 bg-black/35 px-3 py-1 font-cinzel text-[0.58rem] font-black tracking-[0.24em] text-theme-gold backdrop-blur"
                  aria-hidden="true"
                >
                  ÚLTIMO EPISODIO
                </span>

                <span
                  aria-hidden="true"
                  class="absolute inset-0 -z-10 flex items-center justify-center"
                >
                  <span class="flex size-14 items-center justify-center rounded-full border border-white/30 bg-black/40 backdrop-blur-md transition duration-500 group-hover:scale-110 group-hover:border-theme-gold/70 group-hover:bg-theme-gold/20 group-focus-visible:scale-110 group-focus-visible:border-theme-gold/70 group-focus-visible:bg-theme-gold/20 sm:size-16">
                    <PlayIcon
                      class="size-6 translate-x-[1px] text-white transition duration-500 group-hover:text-theme-cream group-focus-visible:text-theme-cream sm:size-7"
                      aria-hidden="true"
                    />
                  </span>
                </span>

                <div class="relative mt-auto flex w-full flex-col gap-2 p-5 sm:p-8">
                  <time
                    datetime={featuredEpisode.published.toISOString()}
                    title={dateFormatter.format(featuredEpisode.published)}
                    class="font-cinzel text-[0.65rem] font-black tracking-[0.3em] text-theme-gold"
                  >
                    {formatRelative(featuredEpisode.published)}
                  </time>
                  <h3 class="max-w-2xl font-cinzel text-2xl leading-tight font-black tracking-[0.05em] text-balance text-white drop-shadow-[0_4px_24px_rgba(0,0,0,0.65)] transition duration-500 group-hover:text-theme-cream group-focus-visible:text-theme-cream sm:text-3xl lg:text-4xl">
                    {featuredEpisode.title}
                  </h3>
                  <span class="mt-2 inline-flex w-fit items-center gap-2 font-cinzel text-[0.6rem] font-black tracking-[0.3em] text-white/70 transition duration-500 group-hover:text-theme-gold group-focus-visible:text-theme-gold sm:text-xs">
                    VER EPISODIO
                    <ArrowRightIcon
                      class="size-3 transition-transform duration-500 group-hover:translate-x-1 group-focus-visible:translate-x-1"
                      stroke-width="2.5"
                      aria-hidden="true"
                    />
                  </span>
                </div>
              </button>
            )}

            {secondaryEpisodes.length > 0 && (
              <ul
                class="podcast-scroll grid max-h-[34rem] gap-px overflow-y-auto sm:grid-cols-2 lg:max-h-[31.5cqw] lg:grid-cols-1"
                data-podcast-list
              >
                {secondaryEpisodes.map((episode, index) => (
                  <li>
                    <button
                      type="button"
                      data-video-tile
                      data-video-id={episode.videoId}
                      data-video-title={episode.title}
                      aria-label={`Reproducir episodio: ${episode.title}`}
                      class="group grid h-full w-full grid-cols-[5rem_1fr] gap-3 bg-theme-midnight/60 p-3 text-left transition duration-300 outline-none hover:bg-theme-navy/55 focus-visible:bg-theme-navy/55 focus-visible:ring-2 focus-visible:ring-theme-gold/60 focus-visible:ring-inset sm:grid-cols-[6rem_1fr] sm:p-4 lg:grid-cols-[7.5rem_1fr] cursor-pointer"
                    >
                      <span class="relative block aspect-video overflow-hidden rounded-lg border border-white/10 bg-black/30">
                        <picture class="absolute inset-0 transition duration-500 group-hover:scale-105 group-focus-visible:scale-105">
                          <source srcset={episode.thumbnail.avif} type="image/avif" />
                          <source srcset={episode.thumbnail.webp} type="image/webp" />
                          <img
                            src={episode.thumbnail.webp}
                            alt=""
                            aria-hidden="true"
                            loading="lazy"
                            decoding="async"
                            class="h-full w-full object-cover"
                          />
                        </picture>
                        <span
                          aria-hidden="true"
                          class="absolute inset-0 flex items-center justify-center bg-black/30 opacity-0 transition duration-300 group-hover:opacity-100 group-focus-visible:opacity-100"
                        >
                          <span class="flex size-7 items-center justify-center rounded-full bg-theme-gold/90 text-theme-midnight">
                            <PlayIcon class="size-3.5 translate-x-[1px]" aria-hidden="true" />
                          </span>
                        </span>
                      </span>

                      <div class="flex min-w-0 flex-col justify-between gap-3">
                        <span class="flex items-start justify-between gap-3">
                          <span class="font-cinzel text-[0.62rem] font-black tracking-[0.22em] text-theme-gold/75">
                            E{String(secondaryEpisodes.length - index).padStart(2, '0')}
                          </span>
                          <ChevronRightIcon
                            aria-hidden="true"
                            class="size-4 shrink-0 text-white/30 transition duration-300 group-hover:translate-x-1 group-hover:text-theme-gold group-focus-visible:translate-x-1 group-focus-visible:text-theme-gold"
                          />
                        </span>

                        <div class="flex flex-col gap-1">
                          <h3 class="line-clamp-2 font-cinzel text-sm leading-tight font-black tracking-[0.04em] text-balance text-white transition duration-300 group-hover:text-theme-cream group-focus-visible:text-theme-cream sm:text-base">
                            {episode.title}
                          </h3>
                          <time
                            datetime={episode.published.toISOString()}
                            title={dateFormatter.format(episode.published)}
                            class="font-cinzel text-[0.58rem] tracking-[0.24em] text-white/45"
                          >
                            {formatRelative(episode.published)}
                          </time>
                        </div>
                      </div>
                    </button>
                  </li>
                ))}
              </ul>
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .podcast-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-theme-gold) transparent;
    scrollbar-gutter: stable;
  }

  .podcast-scroll::-webkit-scrollbar {
    width: 10px;
  }

  .podcast-scroll::-webkit-scrollbar-track {
    background: transparent;
    border-left: 1px solid color-mix(in srgb, white 6%, transparent);
  }

  .podcast-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-theme-gold);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: content-box;
  }

  .podcast-scroll::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-theme-cream);
  }
</style>
