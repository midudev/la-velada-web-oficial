---
import type { GetStaticPaths } from 'astro'

import ArrowLeftIcon from '@/assets/svg/arrow-left.svg'
import ArrowRightIcon from '@/assets/svg/arrow-right.svg'
import VeladaLogoIcon from '@/assets/svg/logo.svg'
import BoxerGallery from '@/components/BoxerGallery.astro'
import BoxerHeroStatsCard from '@/components/BoxerHeroStatsCard.astro'
import BoxerSocials from '@/components/BoxerSocials.astro'
import BoxerWinsBadge from '@/components/BoxerWinsBadge.astro'
import BoxerWorkoutVideos from '@/components/BoxerWorkoutVideos.astro'
import CombatFaceToFaceVideoSection from '@/components/combat/CombatFaceToFaceVideoSection.astro'
import LivePrediction from '@/components/LivePrediction.astro'
import { battles } from '@/consts/battles'
import { EVENT_DATE_TIME } from '@/consts/event'
import {
  BOXERS,
  BOXERS_BY_ID,
  COUNTRY_NAMES,
  GENDER_LABELS,
  getBoxerHeroImages,
  getBoxerPhoto,
  getBoxerSelectImages,
} from '@/consts/boxers'
import { formatFollowers } from '@/lib/socials'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { serializeJsonLd } from '@/utils/serialize-json-ld'

export const prerender = true

export const getStaticPaths = (() => {
  return BOXERS.map((boxer) => ({
    params: { id: boxer.id },
    props: { boxerId: boxer.id },
  }))
}) satisfies GetStaticPaths

interface Props {
  boxerId: string
}

interface WorkoutVideo {
  videoId: string
  title: string
  eyebrow?: string
}

function getYouTubeVideoId(url: string) {
  try {
    const parsedUrl = new URL(url)
    const hostname = parsedUrl.hostname.replace(/^www\./, '')

    if (hostname === 'youtu.be') {
      return parsedUrl.pathname.split('/').filter(Boolean)[0] ?? null
    }

    if (hostname === 'youtube.com' || hostname === 'm.youtube.com') {
      return parsedUrl.searchParams.get('v')
    }
  } catch {
    return null
  }

  return null
}

function createFaceToFaceVideo(videoUrl: string, battleTitle: string): WorkoutVideo | null {
  const videoId = getYouTubeVideoId(videoUrl)
  if (!videoId) return null

  return {
    videoId,
    title: `Cara a cara: ${battleTitle}`,
    eyebrow: 'CARA A CARA',
  }
}

const { boxerId } = Astro.props
const boxer = BOXERS_BY_ID[boxerId]

if (!boxer) return Astro.redirect('/404')

const heroImages = getBoxerHeroImages(boxer)
const photo = getBoxerPhoto(boxer)
const countryName = COUNTRY_NAMES[boxer.country] ?? boxer.country
const genderLabel = GENDER_LABELS[boxer.gender]

// Fecha de nacimiento formateada en español (p. ej. "28 de agosto de 2004").
// Se construye con hora local para evitar desfases de día por zona horaria.
const birthDateLabel = boxer.birthDate
  ? new Intl.DateTimeFormat('es-ES', {
      day: 'numeric',
      month: 'long',
      year: 'numeric',
    }).format(new Date(`${boxer.birthDate}T00:00:00`))
  : null

// Buscamos su combate para enlazar y mostrar el número.
const battle = battles.find((b) => b.boxerIds.includes(boxer.id))
const opponentId = battle?.boxerIds.find((id) => id !== boxer.id)
const opponent = opponentId ? BOXERS_BY_ID[opponentId] : null
const opponentSelectImages = opponent ? getBoxerSelectImages(opponent) : null

const boxerWorkoutVideos: WorkoutVideo[] = boxer.workout ?? []
const hasBoxerWorkoutVideos = boxerWorkoutVideos.length > 0
const faceToFaceVideoUrl = battle?.faceToFaceVideoUrl ?? null
const faceToFaceVideo =
  hasBoxerWorkoutVideos && faceToFaceVideoUrl && battle
    ? createFaceToFaceVideo(faceToFaceVideoUrl, battle.title)
    : null
const workoutVideos = faceToFaceVideo
  ? [...boxerWorkoutVideos, faceToFaceVideo]
  : boxerWorkoutVideos

const SITE_URL = 'https://www.infolavelada.com'
const canonical = `${SITE_URL}/boxeadores/${boxer.id}`
const isFemale = boxer.gender === 'f'
const role = isFemale ? 'boxeadora' : 'boxeador'
const roleCapitalized = role.charAt(0).toUpperCase() + role.slice(1)

const title = `${boxer.name} — ${roleCapitalized} de La Velada del Año VI`
const description = opponent
  ? `Conoce a ${boxer.name}, ${role} de ${countryName} en La Velada del Año VI. Se enfrenta a ${opponent.name} en el combate ${String(battle!.number).padStart(2, '0')} el 25 de julio de 2026.`
  : `Conoce a ${boxer.name}, ${role} de ${countryName} en La Velada del Año VI, el 25 de julio de 2026.`

const fightWeight = boxer.fightWeightKg ?? boxer.weightKg
const fightWeightLabel = fightWeight != null ? `${fightWeight} kg` : null
const totalFollowers = boxer.socials.reduce((sum, social) => sum + (social.followers ?? 0), 0)
const totalFollowersLabel = formatFollowers(totalFollowers)

// Usamos la foto principal del boxeador como og:image cuando exista,
// con fallback al hero recortado.
const ogImage = `${SITE_URL}${photo}`
const ogImageAlt = `${boxer.name}, ${role} de La Velada del Año VI`

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: boxer.name,
  image: ogImage,
  url: canonical,
  nationality: {
    '@type': 'Country',
    name: countryName,
  },
  gender: isFemale ? 'Female' : 'Male',
  performerIn: {
    '@type': 'SportsEvent',
    name: 'La Velada del Año VI',
    startDate: EVENT_DATE_TIME,
    location: {
      '@type': 'Place',
      name: 'Estadio de La Cartuja',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Sevilla',
        addressCountry: 'ES',
      },
    },
    organizer: {
      '@type': 'Person',
      name: 'Ibai Llanos',
    },
  },
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Inicio',
      item: SITE_URL,
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Boxeadores',
      item: `${SITE_URL}/boxeadores`,
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: boxer.name,
      item: canonical,
    },
  ],
}
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  ogUrl={canonical}
  ogType="profile"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={serializeJsonLd(personJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={serializeJsonLd(breadcrumbJsonLd)}
    slot="head"
  />

  <section
    class="boxer-detail relative isolate w-full overflow-x-clip bg-theme-midnight px-4 pt-24 pb-24 text-theme-cream sm:px-6 sm:pt-28 md:pt-32"
    aria-labelledby="boxer-name"
  >
    <picture
      data-boxer-detail-bg
      class="pointer-events-none absolute inset-0 -z-20 max-h-svh"
      aria-hidden="true"
    >
      <source
        type="image/avif"
        srcset="https://cdn.infolavelada.com/hero-bg/background-1280.avif 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.avif 2048w, https://cdn.infolavelada.com/hero-bg/background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
        sizes="100vw"
      />
      <img
        src="https://cdn.infolavelada.com/hero-bg/background.webp"
        alt=""
        role="presentation"
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-linear-to-b from-black/55 via-theme-midnight/65 to-theme-midnight"
    >
    </div>

    <div class="mx-auto flex w-full max-w-6xl flex-col">
      <a href="/boxeadores" class="boxer-back group inline-flex w-fit items-center gap-2">
        <ArrowLeftIcon class="boxer-back-arrow size-3" aria-hidden="true" />
        <span class="boxer-back-label">Volver a boxeadores</span>
      </a>

      <div
        class="boxer-hero mt-8 grid items-center gap-10 sm:mt-10 md:grid-cols-[minmax(0,0.82fr)_minmax(0,1fr)] md:items-start md:gap-10 lg:gap-14"
      >
        <div class="boxer-portrait-wrap relative flex flex-col items-center md:order-1">
          <span aria-hidden="true" class="boxer-detail-aura"></span>

          <BoxerWinsBadge
            wins={boxer.previousVeladaWins}
            boxerName={boxer.name}
            variant="detail"
            defaultExpanded
            class="boxer-detail-wins"
          />

          <picture
            class="boxer-detail-portrait-picture relative z-10 flex w-full items-start justify-center"
          >
            <source type="image/avif" srcset={heroImages.avif} />
            <source type="image/webp" srcset={heroImages.webp} />
            <img
              src={heroImages.webp}
              alt={`Foto principal de ${boxer.name}`}
              transition:name={`boxer-hero-${boxer.id}`}
              class="boxer-detail-portrait relative z-10 h-auto w-auto max-w-full object-contain object-top"
              decoding="async"
              fetchpriority="high"
              width="640"
              height="800"
            />
          </picture>

          <div
            class="boxer-detail-socias relative z-10 mt-6 w-full animate-fade-in-up animate-delay-300"
          >
            <BoxerSocials boxer={boxer} />
          </div>
        </div>

        <div class="boxer-info relative flex flex-col items-start md:order-2 md:mt-8 lg:mt-12">
          <h1
            id="boxer-name"
            class="boxer-detail-name animate-fade-in-up font-cinzel leading-[0.92] font-black tracking-[0.02em] text-balance uppercase sm:text-6xl md:text-[clamp(2.5rem,5.6vw,4.5rem)] hyphens-auto"
            class:list={[boxer.name === 'Fernanfloo' ? 'text-[2.688rem]' : 'text-5xl']}
          >
            {boxer.name}
          </h1>

          <BoxerHeroStatsCard
            class="mt-6 animate-fade-in-up animate-delay-200"
            fightWeightLabel={fightWeightLabel}
            countryName={countryName}
            countryCode={boxer.country}
            totalFollowers={totalFollowersLabel}
            genderLabel={genderLabel}
            birthDateLabel={birthDateLabel}
          />

          {
            opponent && opponentSelectImages && battle && (
              <>
              <div class="boxer-versus-card mt-8 animate-fade-in-up animate-delay-500">
                <a
                  href={`/boxeadores/${opponent.id}`}
                  class="boxer-versus-half group"
                  aria-label={`Ver el perfil de ${opponent.name}, su rival`}
                >
                  <span class="boxer-versus-tag" aria-hidden="true">
                    VS
                  </span>
                  <span class="boxer-versus-photo relative inline-flex size-11 shrink-0 overflow-hidden rounded-full sm:size-12">
                    <picture class="absolute inset-0">
                      <source type="image/avif" srcset={opponentSelectImages.avif} />
                      <source type="image/webp" srcset={opponentSelectImages.webp} />
                      <img
                        src={opponentSelectImages.webp}
                        alt=""
                        role="presentation"
                        transition:name={`boxer-hero-${opponent.id}`}
                        decoding="async"
                        loading="lazy"
                        width="80"
                        height="80"
                        class="size-full object-cover object-top"
                      />
                    </picture>
                  </span>
                  <span class="boxer-versus-text">
                    <span class="boxer-versus-label">Su rival</span>
                    <span class="boxer-versus-name">{opponent.name}</span>
                  </span>
                </a>

                <a
                  href={battle.url}
                  class="boxer-versus-half group"
                  aria-label={`Ver el combate ${String(battle.number).padStart(2, '0')}: ${battle.title}`}
                >
                  <VeladaLogoIcon class="boxer-combat-icon" aria-hidden="true" />
                  <span class="boxer-versus-text">
                    <span class="boxer-versus-label">
                      Combate {String(battle.number).padStart(2, '0')}
                    </span>
                    <span class="boxer-versus-name">Ver el combate</span>
                  </span>
                  <ArrowRightIcon
                    class="boxer-versus-arrow size-4 text-theme-gold/70"
                    aria-hidden="true"
                  />
                </a>
              </div>

              <LivePrediction
                class="mt-4 w-full max-w-[34rem] animate-fade-in-up animate-delay-700"
                battleId={battle.id}
                boxerA={{
                  id: battle.boxerIds[0],
                  name: BOXERS_BY_ID[battle.boxerIds[0]].name,
                }}
                boxerB={{
                  id: battle.boxerIds[1],
                  name: BOXERS_BY_ID[battle.boxerIds[1]].name,
                }}
              />
              </>
            )
          }
        </div>
      </div>

      <BoxerGallery boxerId={boxer.id} boxerName={boxer.name} />
    </div>
  </section>

  {hasBoxerWorkoutVideos && (
    <BoxerWorkoutVideos boxerId={boxer.id} boxerName={boxer.name} videos={workoutVideos} />
  )}
  {!hasBoxerWorkoutVideos && battle && faceToFaceVideoUrl && (
    <CombatFaceToFaceVideoSection
      sectionId="workout"
      title={`${battle.title} | Cara a cara`}
      videoUrl={faceToFaceVideoUrl}
    />
  )}

  <Sponsors />
  <Footer />
</Layout>

<style>
  /* ---------- Layout base ---------- */
  .boxer-detail {
    min-height: 100svh;
  }

  [data-boxer-detail-bg] {
    mask-image: linear-gradient(to bottom, #000 0%, #000 55%, transparent 100%);
  }

  [data-boxer-detail-bg] img {
    filter: saturate(0.8) brightness(0.6);
  }

  /* ---------- Volver (sutil) ---------- */
  .boxer-back {
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 50%, transparent);
    transition: color 250ms ease;
  }

  @media (min-width: 640px) {
    .boxer-back {
      font-size: 0.7rem;
    }
  }

  .boxer-back:hover,
  .boxer-back:focus-visible {
    color: color-mix(in srgb, var(--color-theme-cream) 90%, transparent);
    outline: none;
  }

  .boxer-back-arrow {
    color: color-mix(in srgb, var(--color-theme-cream) 42%, transparent);
    transition:
      transform 250ms ease,
      color 250ms ease;
  }

  .boxer-back:hover .boxer-back-arrow,
  .boxer-back:focus-visible .boxer-back-arrow {
    transform: translateX(-3px);
    color: var(--color-theme-gold);
  }

  .boxer-back-label {
    position: relative;
  }

  /* Subrayado fino que aparece solo al interactuar */
  .boxer-back-label::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    height: 1px;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left;
    background: color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
    transition: transform 280ms var(--ease-out-expo, cubic-bezier(0.16, 1, 0.3, 1));
  }

  .boxer-back:hover .boxer-back-label::after,
  .boxer-back:focus-visible .boxer-back-label::after {
    transform: scaleX(1);
  }

  /* ---------- Eyebrow de sección ---------- */
  .boxer-eyebrow {
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.55rem;
    font-weight: 900;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 82%, transparent);
    text-shadow:
      0 1px 0 rgba(0, 0, 0, 0.5),
      0 0 12px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
  }

  @media (min-width: 640px) {
    .boxer-eyebrow {
      font-size: 0.65rem;
    }
  }

  /* ---------- Nombre del boxer ---------- */
  .boxer-detail-name {
    color: var(--color-theme-cream);
    background: linear-gradient(
      180deg,
      var(--color-theme-cream) 0%,
      var(--color-theme-cream) 48%,
      color-mix(in srgb, var(--color-theme-gold) 95%, var(--color-theme-cream)) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    text-shadow:
      0 0 1px color-mix(in srgb, var(--color-theme-cream) 60%, transparent),
      0 2px 18px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 6px 40px color-mix(in srgb, var(--color-theme-gold) 25%, transparent);
  }

  /* ---------- Meta (tira editorial) ---------- */
  /* ---------- Rival (VS) ---------- */
  .boxer-versus-card {
    display: flex;
    flex-direction: column;
    width: min(100%, 34rem);
    border-radius: 1.4rem;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(15, 18, 36, 0.5) 0%, rgba(7, 10, 21, 0.62) 100%);
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 24%, transparent);
    transition: border-color 250ms ease;
  }

  .boxer-versus-card:hover {
    border-color: color-mix(in srgb, var(--color-theme-gold) 40%, transparent);
  }

  .boxer-versus-half {
    display: flex;
    flex: 1 1 0;
    min-width: 0;
    align-items: center;
    gap: 0.7rem;
    padding: 0.7rem 1rem;
    transition: background-color 250ms ease;
  }

  .boxer-versus-half:hover,
  .boxer-versus-half:focus-visible {
    background-color: color-mix(in srgb, var(--color-theme-gold) 9%, transparent);
    outline: none;
  }

  /* Separador entre las dos mitades */
  .boxer-versus-card > .boxer-versus-half + .boxer-versus-half {
    border-top: 1px solid color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
  }

  @media (min-width: 640px) {
    .boxer-versus-card {
      flex-direction: row;
      align-items: stretch;
    }

    .boxer-versus-card > .boxer-versus-half + .boxer-versus-half {
      border-top: none;
      border-left: 1px solid color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    }
  }

  .boxer-combat-icon {
    width: 1.45rem;
    height: 1.45rem;
    flex-shrink: 0;
    color: color-mix(in srgb, var(--color-theme-gold) 82%, transparent);
    filter: drop-shadow(0 0 8px color-mix(in srgb, var(--color-theme-gold) 30%, transparent));
    transition: transform 250ms ease;
  }

  .boxer-versus-half:hover .boxer-combat-icon,
  .boxer-versus-half:focus-visible .boxer-combat-icon {
    transform: scale(1.08);
  }

  .boxer-versus-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.5rem;
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--color-theme-gold) 90%, transparent);
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.55);
  }

  .boxer-versus-photo {
    background: linear-gradient(180deg, #0c1330 0%, #060a1d 100%);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 32%, transparent);
    transition: box-shadow 300ms ease;
  }

  .boxer-versus-half:hover .boxer-versus-photo,
  .boxer-versus-half:focus-visible .boxer-versus-photo {
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent);
  }

  .boxer-versus-text {
    display: flex;
    flex-direction: column;
    gap: 0.12rem;
    line-height: 1.1;
  }

  .boxer-versus-label {
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
  }

  .boxer-versus-name {
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.85rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    color: var(--color-theme-cream);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.55);
    transition: color 250ms ease;
  }

  .boxer-versus-half:hover .boxer-versus-name,
  .boxer-versus-half:focus-visible .boxer-versus-name {
    color: var(--color-theme-gold);
  }

  .boxer-versus-arrow {
    margin-left: auto;
    transition: transform 250ms ease;
  }

  .boxer-versus-half:hover .boxer-versus-arrow,
  .boxer-versus-half:focus-visible .boxer-versus-arrow {
    transform: translateX(3px);
  }

  /* ---------- Bloque "Ficha en preparación" ---------- */
  .boxer-detail-coming-soon-text {
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.5);
  }

  /* ---------- CTA ---------- */
  .boxer-detail-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.3rem;
    border-radius: 9999px;
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.6rem;
    font-weight: 900;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 250ms ease,
      color 250ms ease,
      box-shadow 250ms ease;
  }

  @media (min-width: 640px) {
    .boxer-detail-cta {
      font-size: 0.7rem;
      padding: 0.8rem 1.5rem;
    }
  }

  .boxer-detail-cta-ghost {
    background: transparent;
    color: color-mix(in srgb, var(--color-theme-cream) 80%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .boxer-detail-cta-ghost:hover,
  .boxer-detail-cta-ghost:focus-visible {
    color: var(--color-theme-cream);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent);
    transform: translateY(-1px);
    outline: none;
  }

  /* ---------- Retrato del boxer ---------- */
  .boxer-portrait-wrap {
    position: relative;
    display: flex;
    align-items: start;
    justify-content: center;
    filter: drop-shadow(0 24px 40px rgba(0, 0, 0, 0.55));
  }

  /* Badge de "Campeón previo": arriba a la izquierda del retrato,
     por encima del aura dorada. El componente ya es position:absolute. */
  :global(.boxer-detail-wins) {
    top: 0;
    left: 0;
    z-index: 20;
  }

  @media (min-width: 640px) {
    :global(.boxer-detail-wins) {
      top: 4px;
      left: 8px;
    }
  }

