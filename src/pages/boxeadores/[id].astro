---
import type { GetStaticPaths } from 'astro'

import ArrowLeftIcon from '@/assets/svg/arrow-left.svg'
import ArrowRightIcon from '@/assets/svg/arrow-right.svg'
import InstagramIcon from '@/assets/svg/instagram.svg'
import TiktokIcon from '@/assets/svg/tiktok.svg'
import TwitchIcon from '@/assets/svg/twitch.svg'
import XIcon from '@/assets/svg/x.svg'
import YoutubeIcon from '@/assets/svg/youtube.svg'
import KickIcon from '@/assets/svg/kick.svg'
import { battles } from '@/consts/battles'
import {
  BOXERS,
  BOXERS_BY_ID,
  COUNTRY_FLAGS,
  COUNTRY_NAMES,
  GENDER_LABELS,
  getBoxerHeroImages,
  getBoxerPhoto,
  getBoxerSelectImages,
} from '@/consts/boxers'
import Layout from '@/layouts/Layout.astro'
import Header from '@/sections/Header.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { formatCount } from '@/lib/socials/format'
import { resolveSocials, totalFollowers as sumFollowers } from '@/lib/socials/resolve'
import type { SocialPlatform } from '@/lib/socials/types'
import { fetchVeladaVideos } from '@/lib/youtube/velada'

export const prerender = true

export const getStaticPaths = (() => {
  return BOXERS.map((boxer) => ({
    params: { id: boxer.id },
    props: { boxerId: boxer.id },
  }))
}) satisfies GetStaticPaths

interface Props {
  boxerId: string
}

const { boxerId } = Astro.props
const boxer = BOXERS_BY_ID[boxerId]

if (!boxer) return Astro.redirect('/404')

const heroImages = getBoxerHeroImages(boxer)
const photo = getBoxerPhoto(boxer)
const flag = COUNTRY_FLAGS[boxer.country] ?? ''
const countryName = COUNTRY_NAMES[boxer.country] ?? boxer.country
const genderLabel = GENDER_LABELS[boxer.gender]

const battle = battles.find((b) => b.boxerIds.includes(boxer.id))
const opponentId = battle?.boxerIds.find((id) => id !== boxer.id)
const opponent = opponentId ? BOXERS_BY_ID[opponentId] : null
const opponentSelectImages = opponent ? getBoxerSelectImages(opponent) : null

const SOCIAL_ICONS: Record<SocialPlatform, typeof InstagramIcon | null> = {
  instagram: InstagramIcon,
  tiktok: TiktokIcon,
  twitch: TwitchIcon,
  youtube: YoutubeIcon,
  x: XIcon,
  kick: KickIcon,
  spotify: null,
}

const SOCIAL_LABELS: Record<SocialPlatform, string> = {
  instagram: 'Instagram',
  tiktok: 'TikTok',
  twitch: 'Twitch',
  youtube: 'YouTube',
  x: 'X',
  kick: 'Kick',
  spotify: 'Spotify',
}

function socialUrl(platform: string, username: string): string | null {
  const handle = encodeURIComponent(username)
  switch (platform) {
    case 'instagram':
      return `https://www.instagram.com/${handle}`
    case 'tiktok':
      return `https://www.tiktok.com/@${handle}`
    case 'twitch':
      return `https://www.twitch.tv/${handle}`
    case 'youtube':
      return `https://www.youtube.com/@${handle}`
    case 'x':
      return `https://x.com/${handle}`
    case 'kick':
      return `https://kick.com/${handle}`
    case 'spotify':
      return `https://open.spotify.com/search/${handle}`
    default:
      return null
  }
}

const resolved = resolveSocials(boxer)
const socials = resolved.map((entry) => ({
  ...entry,
  countLabel: entry.metric === 'monthlyListeners' ? 'oyentes/mes' : 'seguidores',
  url: socialUrl(entry.platform, entry.username),
}))
const totalFollowers = sumFollowers(resolved)

const veladaVideos = await fetchVeladaVideos(boxer.youtubeChannelId)

function formatVideoDate(iso: string): string {
  const date = new Date(iso)
  if (Number.isNaN(date.getTime())) return ''
  return new Intl.DateTimeFormat('es-ES', { day: 'numeric', month: 'short' }).format(date)
}

function formatBirthDate(value: string | null): string | null {
  if (!value) return null
  if (/^\d{4}$/.test(value)) return value
  const date = new Date(value)
  if (Number.isNaN(date.getTime())) return null
  return new Intl.DateTimeFormat('es-ES', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(date)
}

const birthFormatted = formatBirthDate(boxer.birthDate)

const techSheet: Array<{ label: string; value: string }> = []
if (boxer.realName && boxer.realName !== boxer.name) {
  techSheet.push({ label: 'Nombre real', value: boxer.realName })
}
techSheet.push({ label: 'Origen', value: `${flag} ${countryName}`.trim() })
if (boxer.age) techSheet.push({ label: 'Edad', value: `${boxer.age} años` })
if (birthFormatted) techSheet.push({ label: 'Nacimiento', value: birthFormatted })
techSheet.push({ label: 'Categoría', value: genderLabel })
if (battle) {
  techSheet.push({ label: 'Combate', value: `N.º ${String(battle.number).padStart(2, '0')}` })
}

const SITE_URL = 'https://www.infolavelada.com'
const canonical = `${SITE_URL}/boxeadores/${boxer.id}`
const isFemale = boxer.gender === 'f'
const role = isFemale ? 'boxeadora' : 'boxeador'
const roleCapitalized = role.charAt(0).toUpperCase() + role.slice(1)

const title = `${boxer.name} — ${roleCapitalized} de La Velada del Año VI`
const description = opponent
  ? `Conoce a ${boxer.name}, ${role} de ${countryName} en La Velada del Año VI. Se enfrenta a ${opponent.name} en el combate ${String(battle!.number).padStart(2, '0')} el 25 de julio de 2026.`
  : `Conoce a ${boxer.name}, ${role} de ${countryName} en La Velada del Año VI, el 25 de julio de 2026.`

const ogImage = `${SITE_URL}${photo}`
const ogImageAlt = `${boxer.name}, ${role} de La Velada del Año VI`

const personJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: boxer.name,
  image: ogImage,
  url: canonical,
  nationality: {
    '@type': 'Country',
    name: countryName,
  },
  gender: isFemale ? 'Female' : 'Male',
  performerIn: {
    '@type': 'SportsEvent',
    name: 'La Velada del Año VI',
    startDate: '2026-07-25T20:00:00+02:00',
    location: {
      '@type': 'Place',
      name: 'Estadio de La Cartuja',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Sevilla',
        addressCountry: 'ES',
      },
    },
    organizer: {
      '@type': 'Person',
      name: 'Ibai Llanos',
    },
  },
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: SITE_URL },
    { '@type': 'ListItem', position: 2, name: 'Boxeadores', item: `${SITE_URL}/boxeadores` },
    { '@type': 'ListItem', position: 3, name: boxer.name, item: canonical },
  ],
}
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogImageAlt={ogImageAlt}
  ogUrl={canonical}
  ogType="profile"
>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(personJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />

  <Header />

  <section
    class="boxer-detail relative isolate w-full overflow-x-clip bg-theme-midnight px-4 pb-24 pt-24 text-theme-cream sm:px-6 sm:pt-28 md:pt-32"
    aria-labelledby="boxer-name"
  >
    <picture
      data-boxer-detail-bg
      class="pointer-events-none absolute inset-0 -z-20"
      aria-hidden="true"
    >
      <source
        type="image/avif"
        srcset="/background-1280.avif 1280w, /background-2048.avif 2048w, /background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
      />
      <img
        src="/background.webp"
        alt=""
        role="presentation"
        class="h-full w-full object-cover object-center"
        fetchpriority="high"
        decoding="async"
      />
    </picture>

    <div
      aria-hidden="true"
      class="absolute inset-0 -z-10 bg-linear-to-b from-black/55 via-theme-midnight/65 to-theme-midnight"
    >
    </div>

    <div class="mx-auto flex w-full max-w-6xl flex-col">
      <a
        href="/boxeadores"
        class="boxer-detail-back inline-flex w-fit items-center gap-2 font-cinzel text-[0.6rem] font-bold tracking-[0.18em] text-theme-cream/65 sm:text-xs"
      >
        <ArrowLeftIcon class="size-3.5" aria-hidden="true" />
        Boxeadores
      </a>

      <div class="boxer-detail-grid relative mt-6 grid gap-8 sm:mt-8 md:gap-10 lg:grid-cols-[1.05fr_1fr] lg:items-start lg:gap-14">
        <div class="boxer-detail-portrait-wrap relative">
          {battle && (
            <span
              aria-hidden="true"
              class="boxer-detail-watermark font-cinzel"
            >
              {String(battle.number).padStart(2, '0')}
            </span>
          )}
          <span aria-hidden="true" class="boxer-detail-aura"></span>
          <span aria-hidden="true" class="boxer-detail-rule boxer-detail-rule-v"></span>

          <picture class="boxer-detail-portrait-picture relative z-10 flex w-full items-start justify-center">
            <source type="image/avif" srcset={heroImages.avif} />
            <source type="image/webp" srcset={heroImages.webp} />
            <img
              src={heroImages.png}
              alt={`Foto principal de ${boxer.name}`}
              transition:name={`boxer-hero-${boxer.id}`}
              class="boxer-detail-portrait relative z-10 h-auto w-auto max-w-full object-contain object-top"
              decoding="async"
              fetchpriority="high"
              width="640"
              height="800"
            />
          </picture>

          <div class="boxer-detail-portrait-meta">
            <span class="boxer-detail-portrait-meta-num font-cinzel">
              N.º {battle ? String(battle.number).padStart(2, '0') : '—'}
            </span>
            <span aria-hidden="true" class="boxer-detail-portrait-meta-rule"></span>
            <span class="boxer-detail-portrait-meta-loc font-cinzel">
              Sevilla · 25.07.26
            </span>
          </div>
        </div>

        <div class="boxer-detail-info relative flex flex-col items-start">
          <p
            class="boxer-detail-eyebrow animate-fade-in-up font-cinzel"
            aria-hidden="true"
          >
            <span class="boxer-detail-eyebrow-mark">{flag}</span>
            <span class="boxer-detail-eyebrow-text">
              {countryName} · {genderLabel}
            </span>
          </p>

          <h1
            id="boxer-name"
            data-boxer-name={boxer.name}
            class="boxer-detail-name animate-fade-in-up animate-delay-150 mt-3 text-balance font-cinzel font-black uppercase leading-[0.92] tracking-[0.02em]"
          >
            {boxer.name}
          </h1>

          {boxer.realName && boxer.realName !== boxer.name && (
            <p
              class="boxer-detail-realname animate-fade-in-up animate-delay-300 mt-4 font-cinzel text-xs font-medium normal-case tracking-[0.02em] text-theme-cream/65 sm:text-sm"
            >
              <span class="boxer-detail-realname-mark" aria-hidden="true">«</span>
              {boxer.realName}
              <span class="boxer-detail-realname-mark" aria-hidden="true">»</span>
            </p>
          )}

          {opponent && opponentSelectImages && (
            <a
              href={`/boxeadores/${opponent.id}`}
              class="boxer-detail-vs animate-fade-in-up animate-delay-400 group mt-8 inline-flex items-stretch gap-4"
              aria-label={`Ver el perfil de ${opponent.name}`}
            >
              <span class="boxer-detail-vs-mark font-cinzel" aria-hidden="true">
                VS
              </span>
              <span class="boxer-detail-vs-body">
                <span class="boxer-detail-vs-label font-cinzel">
                  Próximo rival
                </span>
                <span class="boxer-detail-vs-row">
                  <span class="boxer-detail-vs-photo">
                    <picture class="absolute inset-0">
                      <source type="image/avif" srcset={opponentSelectImages.avif} />
                      <source type="image/webp" srcset={opponentSelectImages.webp} />
                      <img
                        src={opponentSelectImages.png}
                        alt=""
                        role="presentation"
                        decoding="async"
                        loading="lazy"
                        width="80"
                        height="80"
                        class="size-full object-cover object-top"
                      />
                    </picture>
                  </span>
                  <span class="boxer-detail-vs-name font-cinzel">
                    {opponent.name}
                  </span>
                  <ArrowRightIcon
                    class="boxer-detail-vs-arrow size-3.5"
                    aria-hidden="true"
                  />
                </span>
              </span>
            </a>
          )}

          <section
            class="boxer-detail-sheet animate-fade-in-up animate-delay-500 mt-10 w-full"
            aria-labelledby="boxer-sheet-title"
          >
            <header class="boxer-detail-section-header">
              <span class="boxer-detail-section-index font-cinzel" aria-hidden="true">
                01
              </span>
              <h2
                id="boxer-sheet-title"
                class="boxer-detail-section-title font-cinzel"
              >
                Ficha técnica
              </h2>
            </header>
            <dl class="boxer-detail-sheet-list">
              {techSheet.map((item, i) => (
                <div class="boxer-detail-sheet-row">
                  <span
                    class="boxer-detail-sheet-num font-cinzel"
                    aria-hidden="true"
                  >
                    {String(i + 1).padStart(2, '0')}
                  </span>
                  <dt class="boxer-detail-sheet-label font-cinzel">
                    {item.label}
                  </dt>
                  <dd class="boxer-detail-sheet-value font-cinzel">
                    {item.value}
                  </dd>
                </div>
              ))}
            </dl>
          </section>

          {socials.length > 0 && (
            <section
              class="boxer-detail-socials animate-fade-in-up animate-delay-600 mt-10 w-full"
              aria-labelledby="boxer-socials-title"
            >
              <header class="boxer-detail-section-header">
                <span class="boxer-detail-section-index font-cinzel" aria-hidden="true">
                  02
                </span>
                <h2
                  id="boxer-socials-title"
                  class="boxer-detail-section-title font-cinzel"
                >
                  Presencia digital
                </h2>
                {totalFollowers > 0 && (
                  <span class="boxer-detail-section-total font-cinzel">
                    {formatCount(totalFollowers)} seguidores
                  </span>
                )}
              </header>

              <ul class="boxer-detail-socials-list">
                {socials.map((s) => {
                  const Icon = SOCIAL_ICONS[s.platform]
                  const label = SOCIAL_LABELS[s.platform] ?? s.platform
                  const inner = (
                    <>
                      <span class="boxer-detail-social-icon" aria-hidden="true">
                        {Icon ? (
                          <Icon class="size-4" />
                        ) : (
                          <span class="boxer-detail-social-icon-fallback">●</span>
                        )}
                      </span>
                      <span class="boxer-detail-social-platform font-cinzel">
                        {label}
                      </span>
                      <span class="boxer-detail-social-handle font-cinzel">
                        @{s.username}
                      </span>
                      <span class="boxer-detail-social-count font-cinzel">
                        <span class="boxer-detail-social-count-value">
                          {formatCount(s.count)}
                        </span>
                        <span class="boxer-detail-social-count-label">
                          {s.countLabel}
                        </span>
                      </span>
                    </>
                  )
                  return (
                    <li class="boxer-detail-social-row">
                      {s.url ? (
                        <a
                          href={s.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="boxer-detail-social-link"
                          aria-label={`Ver perfil de ${boxer.name} en ${label} (@${s.username})`}
                        >
                          {inner}
                        </a>
                      ) : (
                        <span class="boxer-detail-social-link">{inner}</span>
                      )}
                    </li>
                  )
                })}
              </ul>
            </section>
          )}

          {veladaVideos.length > 0 && (
            <section
              class="boxer-detail-videos animate-fade-in-up animate-delay-700 mt-10 w-full"
              aria-labelledby="boxer-videos-title"
            >
              <header class="boxer-detail-section-header">
                <span class="boxer-detail-section-index font-cinzel" aria-hidden="true">
                  03
                </span>
                <h2
                  id="boxer-videos-title"
                  class="boxer-detail-section-title font-cinzel"
                >
                  Vídeos de La Velada
                </h2>
                <span class="boxer-detail-section-total font-cinzel">
                  Últimos {veladaVideos.length}
                </span>
              </header>

              <ul class="boxer-detail-videos-grid">
                {veladaVideos.map((video) => (
                  <li class="boxer-detail-video-card">
                    <a
                      href={video.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="boxer-detail-video-link"
                      aria-label={`Ver "${video.title}" en YouTube`}
                    >
                      <span class="boxer-detail-video-thumb">
                        <img
                          src={video.thumbnail}
                          alt=""
                          role="presentation"
                          loading="lazy"
                          decoding="async"
                          width="320"
                          height="180"
                        />
                        <span class="boxer-detail-video-play" aria-hidden="true">▶</span>
                      </span>
                      <span class="boxer-detail-video-meta">
                        <span class="boxer-detail-video-title font-cinzel">
                          {video.title}
                        </span>
                        <span class="boxer-detail-video-date font-cinzel">
                          {formatVideoDate(video.publishedAt)}
                        </span>
                      </span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>
      </div>
    </div>
  </section>

  <Sponsors />
  <Footer />
</Layout>

<style>
  .boxer-detail {
    min-height: 100svh;
  }

  [data-boxer-detail-bg] {
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 65%,
      transparent 100%
    );
    mask-image: linear-gradient(to bottom, #000 0%, #000 65%, transparent 100%);
  }

  [data-boxer-detail-bg] img {
    filter: saturate(0.7) brightness(0.45);
  }

  .boxer-detail-back {
    transition:
      color 200ms ease,
      transform 200ms ease;
  }

  .boxer-detail-back:hover,
  .boxer-detail-back:focus-visible {
    color: var(--color-theme-cream);
    transform: translateX(-2px);
    outline: none;
  }

  .boxer-detail-grid {
    position: relative;
    isolation: isolate;
  }

  .boxer-detail-watermark {
    pointer-events: none;
    position: absolute;
    top: -2.5rem;
    left: -3rem;
    z-index: 0;
    font-weight: 900;
    font-size: clamp(11rem, 28vw, 24rem);
    line-height: 0.78;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-theme-gold) 38%, transparent);
    user-select: none;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 1023px) {
    .boxer-detail-watermark {
      top: -1rem;
      left: -1rem;
      opacity: 0.55;
    }
  }

  .boxer-detail-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 60%, transparent);
  }

  @media (min-width: 640px) {
    .boxer-detail-eyebrow {
      font-size: 0.7rem;
    }
  }

  .boxer-detail-eyebrow-mark {
    font-size: 1rem;
    line-height: 1;
  }

  .boxer-detail-eyebrow::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
  }

  .boxer-detail-name {
    color: var(--color-theme-cream);
    font-size: clamp(3rem, 9vw, 6.5rem);
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.45);
  }

  .boxer-detail-realname {
    color: color-mix(in srgb, var(--color-theme-cream) 70%, transparent);
    font-style: italic;
  }

  .boxer-detail-realname-mark {
    color: var(--color-theme-gold);
    font-style: normal;
    font-weight: 700;
    margin: 0 0.25rem;
  }

  .boxer-detail-vs {
    text-decoration: none;
    color: inherit;
    transition: transform 200ms ease;
  }

  .boxer-detail-vs:hover,
  .boxer-detail-vs:focus-visible {
    transform: translateX(2px);
    outline: none;
  }

  .boxer-detail-vs-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 3rem;
    background: var(--color-theme-gold);
    color: var(--color-theme-midnight);
    font-weight: 900;
    letter-spacing: 0.02em;
    font-size: 1.05rem;
    box-shadow: 0 8px 24px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
  }

  .boxer-detail-vs-body {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.35rem;
    border-left: 1px solid color-mix(in srgb, var(--color-theme-cream) 12%, transparent);
    padding-left: 1rem;
  }

  .boxer-detail-vs-label {
    font-size: 0.6rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
  }

  .boxer-detail-vs-row {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
  }

  .boxer-detail-vs-photo {
    position: relative;
    display: inline-flex;
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    overflow: hidden;
    background: linear-gradient(180deg, #0c1330 0%, #060a1d 100%);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 38%, transparent);
  }

  .boxer-detail-vs:hover .boxer-detail-vs-photo,
  .boxer-detail-vs:focus-visible .boxer-detail-vs-photo {
    box-shadow: inset 0 0 0 1px var(--color-theme-gold);
  }

  .boxer-detail-vs-name {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-theme-cream);
    transition: color 200ms ease;
  }

  .boxer-detail-vs:hover .boxer-detail-vs-name,
  .boxer-detail-vs:focus-visible .boxer-detail-vs-name {
    color: var(--color-theme-gold);
  }

  .boxer-detail-vs-arrow {
    color: color-mix(in srgb, var(--color-theme-cream) 50%, transparent);
    transition:
      transform 200ms ease,
      color 200ms ease;
  }

  .boxer-detail-vs:hover .boxer-detail-vs-arrow,
