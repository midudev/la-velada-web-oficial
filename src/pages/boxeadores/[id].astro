<script>
  import { resetHeaderContext, setupHeaderContext } from '@/lib/header-context/setup'

  function initBoxerHeaderContext() {
    const target = document.querySelector<HTMLElement>('#boxer-name[data-boxer-name]')
    if (!target) {
      resetHeaderContext()
      return
    }
    const name = target.dataset.boxerName ?? ''
    if (!name) return
    setupHeaderContext({
      targetSelector: '#boxer-name[data-boxer-name]',
      title: name,
    })
  }

  initBoxerHeaderContext()
  document.addEventListener('astro:page-load', initBoxerHeaderContext)
  document.addEventListener('astro:before-swap', resetHeaderContext)
</script>

