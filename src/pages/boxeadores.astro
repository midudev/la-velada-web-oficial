---
import ResetIcon from '@/assets/svg/reset.svg'
import BoxerWinsBadge from '@/components/BoxerWinsBadge.astro'
import CountryFlag from '@/components/CountryFlag.astro'
import SectionDivider from '@/components/SectionDivider.astro'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { battles } from '@/consts/battles'
import {
  BOXERS,
  COUNTRY_NAMES,
  GENDER_LABELS,
  getBoxerHeroImages,
  type BoxerGender,
} from '@/consts/boxers'

const SITE_URL = 'https://www.infolavelada.com'
const title = 'Boxeadores y boxeadoras | La Velada del Año VI'
const description =
  'Descubre a los boxeadores y boxeadoras de La Velada del Año VI. Conoce los participantes, combates y países del evento de Ibai Llanos en Sevilla.'
const canonical = `${SITE_URL}/boxeadores`

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Boxeadores', item: canonical },
  ],
}

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Boxeadores de La Velada del Año VI',
  numberOfItems: BOXERS.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: BOXERS.map((boxer, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${SITE_URL}/boxeadores/${boxer.id}`,
    name: boxer.name,
  })),
}

export const prerender = true

// Mapa id-boxeador → combate, para enlazar cada card a su pelea y para
// poder mostrar el número de combate como detalle decorativo.
const battleByBoxer: Record<string, { number: number; battleId: string }> = {}
for (const battle of battles) {
  for (const id of battle.boxerIds) {
    battleByBoxer[id] = { number: battle.number, battleId: battle.id }
  }
}

const boxerCards = BOXERS.map((boxer) => {
  const battle = battleByBoxer[boxer.id]
  // Suma de seguidores reales (excluimos `monthlyListeners` de Spotify
  // porque no es una métrica de seguidores comparable).
  const totalFollowers = boxer.socials.reduce((sum, s) => sum + (s.followers ?? 0), 0)
  return {
    ...boxer,
    heroImages: getBoxerHeroImages(boxer),
    battleNumber: battle?.number ?? 0,
    battleId: battle?.battleId ?? '',
    countryName: COUNTRY_NAMES[boxer.country] ?? boxer.country,
    totalFollowers,
  }
})

// Orden por número de combate (cartelera real) y, dentro del mismo
// combate, por el orden definido en `battlePairs`.
boxerCards.sort((a, b) => a.battleNumber - b.battleNumber)

// Países presentes en el cartel, con conteo de boxeadores por cada uno,
// para construir los filtros sin opciones vacías. Se ordenan por número
// de boxeadores descendente y, a igualdad, por nombre alfabético.
const countryCounts = new Map<string, number>()
for (const boxer of BOXERS) {
  countryCounts.set(boxer.country, (countryCounts.get(boxer.country) ?? 0) + 1)
}
const countryFilters = Array.from(countryCounts.entries())
  .map(([code, count]) => ({
    code,
    count,
    name: COUNTRY_NAMES[code] ?? code,
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'es'))

// Conteo por género, para mostrar el total junto a cada pill.
const genderCounts: Record<BoxerGender, number> = { f: 0, m: 0 }
for (const boxer of BOXERS) genderCounts[boxer.gender]++

const genderFilters: Array<{ code: BoxerGender; name: string; count: number }> = (
  ['f', 'm'] as const
).map((code) => ({
  code,
  name: GENDER_LABELS[code],
  count: genderCounts[code],
}))

const totalBoxers = BOXERS.length

const cardImageEagerAmount = 4
---

<Layout title={title} description={description} canonical={canonical}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListJsonLd)}
    slot="head"
  />
  <script is:inline>
    document.documentElement.classList.add('js')
  </script>

  <section
    class="boxers-page relative isolate w-full overflow-x-clip bg-theme-midnight px-3 pt-24 pb-20 text-theme-cream sm:px-6 sm:pt-32 sm:pb-24 md:pt-36"
  >
    <div aria-hidden="true" class="boxers-bg absolute inset-0 -z-20"></div>
    <div aria-hidden="true" class="boxers-grain pointer-events-none absolute inset-0 -z-10"></div>

    <div class="boxers-layout mx-auto w-full max-w-7xl">
      <header class="boxers-page-header">
        <h1
          class="boxers-page-title mb-3 font-cinzel text-3xl font-black tracking-[0.12em] text-theme-cream not-motion-reduce:animate-fade-in-up sm:text-4xl sm:tracking-[0.16em] md:text-6xl"
        >
          <SectionDivider class="boxers-page-header-ornament mb-8 w-full sm:mb-12" />

          BOXEADORES
        </h1>
        <p
          class="boxers-page-lead mb-8 font-cinzel text-xs font-medium tracking-[0.14em] text-balance text-white/55 animate-delay-200 not-motion-reduce:animate-fade-in-up sm:mb-12 sm:text-sm"
        >
          Los {totalBoxers} contendientes de La Velada del Año VI
        </p>
      </header>

      <form
        data-boxers-filters
        class="boxer-filters-panel relative w-full not-motion-reduce:animate-fade-in-up not-motion-reduce:animate-delay-300"
        aria-label="Filtros de boxeadores"
        onsubmit="return false"
      >
        <span aria-hidden="true" class="boxer-filters-corner boxer-filters-corner-tl"></span>
        <span aria-hidden="true" class="boxer-filters-corner boxer-filters-corner-tr"></span>
        <span aria-hidden="true" class="boxer-filters-corner boxer-filters-corner-bl"></span>
        <span aria-hidden="true" class="boxer-filters-corner boxer-filters-corner-br"></span>

        <div
          class="boxer-filters-eyebrow absolute -top-3 left-1/2 flex -translate-x-1/2 items-center gap-2 px-3 py-1"
          aria-hidden="true"
        >
          <span class="size-1 rotate-45 bg-theme-gold/85"></span>
          <span
            class="font-cinzel text-[0.55rem] font-black tracking-[0.26em] text-theme-gold/95 sm:text-[0.65rem]"
          >
            FILTROS
          </span>
          <span class="size-1 rotate-45 bg-theme-gold/85"></span>
        </div>

        <div class="boxer-filters-body relative flex flex-col">
          <fieldset class="boxer-filter-row" data-filter-row="country">
            <legend class="boxer-filter-row-label">
              <span aria-hidden="true" class="boxer-filter-row-label-mark"></span>
              País
            </legend>
            <div class="boxer-filter-row-pills" role="group" aria-label="Filtrar por país">
              <button
                type="button"
                data-filter="country"
                data-value=""
                aria-pressed="true"
                class="boxer-filter-pill boxer-filter-pill-all"
              >
                <span class="boxer-filter-pill-label">Todos</span>
                <span class="boxer-filter-pill-count" aria-hidden="true">{totalBoxers}</span>
              </button>
              {
                countryFilters.map(({ code, name, count }) => (
                  <button
                    type="button"
                    data-filter="country"
                    data-value={code}
                    aria-pressed="false"
                    aria-label={`Filtrar por ${name}`}
                    class="boxer-filter-pill"
                  >
                    <CountryFlag
                      country={code}
                      size={16}
                      decorative
                      class="boxer-filter-pill-flag"
                    />
                    <span class="boxer-filter-pill-label">{name}</span>
                    <span class="boxer-filter-pill-count" aria-hidden="true">
                      {count}
                    </span>
                  </button>
                ))
              }
            </div>
          </fieldset>

          <fieldset class="boxer-filter-row" data-filter-row="gender">
            <legend class="boxer-filter-row-label">
              <span aria-hidden="true" class="boxer-filter-row-label-mark"></span>
              Género
            </legend>
            <div class="boxer-filter-row-pills" role="group" aria-label="Filtrar por género">
              <button
                type="button"
                data-filter="gender"
                data-value=""
                aria-pressed="true"
                class="boxer-filter-pill boxer-filter-pill-all"
              >
                <span class="boxer-filter-pill-label">Todos</span>
                <span class="boxer-filter-pill-count" aria-hidden="true">{totalBoxers}</span>
              </button>
              {
                genderFilters.map(({ code, name, count }) => (
                  <button
                    type="button"
                    data-filter="gender"
                    data-value={code}
                    aria-pressed="false"
                    aria-label={`Filtrar por género ${name}`}
                    class="boxer-filter-pill"
                  >
                    <span class="boxer-filter-pill-label">{name}</span>
                    <span class="boxer-filter-pill-count" aria-hidden="true">
                      {count}
                    </span>
                  </button>
                ))
              }
            </div>
          </fieldset>

          <div data-boxers-footer hidden>
            <span aria-hidden="true" class="boxer-filters-rule"></span>
            <div class="boxer-filters-footer">
              <button
                type="button"
                data-boxers-reset
                class="boxer-filter-reset"
                aria-label="Restablecer filtros"
              >
                <ResetIcon class="size-3.5" aria-hidden="true" />
                Limpiar filtros
              </button>
            </div>
          </div>
        </div>
      </form>

      <div class="boxers-results w-full">
        <div
          data-boxers-sort
          class="boxer-sort-bar relative not-motion-reduce:animate-fade-in-up not-motion-reduce:animate-delay-300"
          role="region"
          aria-label="Ordenar boxeadores"
        >
          <span aria-hidden="true" class="boxer-sort-corner boxer-sort-corner-tl"></span>
          <span aria-hidden="true" class="boxer-sort-corner boxer-sort-corner-tr"></span>
          <span aria-hidden="true" class="boxer-sort-corner boxer-sort-corner-bl"></span>
          <span aria-hidden="true" class="boxer-sort-corner boxer-sort-corner-br"></span>

          <div class="boxer-sort-label">
            <span aria-hidden="true" class="boxer-sort-label-mark"></span>
            <span>Ordenar por</span>
          </div>

          <div class="boxer-sort-pills" role="group" aria-label="Modo de ordenación">
            <button
              type="button"
              data-sort="cartel"
              aria-pressed="true"
              class="boxer-filter-pill boxer-sort-pill"
            >
              <span class="boxer-filter-pill-label">Cartelera</span>
            </button>
            <button
              type="button"
              data-sort="followers-desc"
              aria-pressed="false"
              aria-label="Ordenar por más seguidores en redes sociales"
              class="boxer-filter-pill boxer-sort-pill"
            >
              <span aria-hidden="true" class="boxer-sort-pill-icon">▾</span>
              <span class="boxer-filter-pill-label">Más seguidores</span>
            </button>
            <button
              type="button"
              data-sort="followers-asc"
              aria-pressed="false"
              aria-label="Ordenar por menos seguidores en redes sociales"
              class="boxer-filter-pill boxer-sort-pill"
            >
              <span aria-hidden="true" class="boxer-sort-pill-icon">▴</span>
              <span class="boxer-filter-pill-label">Menos seguidores</span>
            </button>
          </div>
        </div>

        <ul
          data-boxers-grid
          class="boxers-grid grid w-full grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-3 lg:gap-5 xl:grid-cols-4"
          role="list"
        >
          {
            boxerCards.map((b, index) => (
              <li
                class="boxer-card-wrap"
                data-boxer-card
                data-country={b.country}
                data-gender={b.gender}
                data-default-order={index}
                data-followers={b.totalFollowers}
                data-battle={b.battleNumber}
              >
                <a
                  href={`/boxeadores/${b.id}`}
                  class="boxer-card group relative block aspect-[3/4] w-full overflow-hidden rounded-md focus-visible:outline-none"
                  aria-label={`Ver ficha de ${b.name}`}
                >
                  <span
                    aria-hidden="true"
                    class="boxer-card-bg-gold pointer-events-none absolute inset-0 -z-10"
                  />

                  <picture>
                    <source type="image/avif" srcset={b.heroImages.avif} />
                    <source type="image/webp" srcset={b.heroImages.webp} />
                    <img
                      src={b.heroImages.webp}
                      alt={`Recorte fotográfico de ${b.name}`}
                      width="1066"
                      height="1600"
                      loading={index < cardImageEagerAmount ? 'eager' : 'lazy'}
                      decoding={index < cardImageEagerAmount ? 'auto' : 'async'}
                      fetchpriority={index < cardImageEagerAmount ? 'high' : 'auto'}
                      transition:name={`boxer-hero-${b.id}`}
                      class="boxer-card-img h-full w-full object-cover object-top"
                    />
                  </picture>

                  <span
                    aria-hidden="true"
                    class="boxer-card-veil pointer-events-none absolute inset-0"
                  />

                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-tl" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-tr" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-bl" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-br" />

                  {b.battleNumber > 0 && (
                    <span
                      aria-hidden="true"
                      class="boxer-card-number pointer-events-none absolute top-3.5 right-3 font-cinzel text-[0.42rem] font-black tracking-[0.16em] text-theme-gold/90 sm:top-4 sm:right-4 sm:text-[0.55rem] sm:tracking-[0.2em]"
                    >
                      COMBATE · {String(b.battleNumber).padStart(2, '0')}
                    </span>
                  )}

                  <BoxerWinsBadge
                    wins={b.previousVeladaWins}
                    boxerName={b.name}
                    variant="card"
                    class="boxer-card-wins"
                  />

                  <div class="boxer-card-caption absolute inset-x-0 bottom-0 z-10 flex flex-col items-center gap-1 px-2.5 pt-12 pb-4 text-center sm:gap-1.5 sm:px-3 sm:pt-14 sm:pb-6">
                    <span
                      aria-hidden="true"
                      class="boxer-card-divider mb-1 h-px w-8 bg-theme-gold/60 transition-all duration-500"
                    />
                    <h2 class="boxer-card-name font-cinzel text-[0.78rem] leading-[1.1] font-black tracking-[0.1em] text-balance text-theme-cream uppercase sm:text-base sm:tracking-[0.16em] md:text-lg">
                      {b.name}
                    </h2>
                    <p class="boxer-card-country flex max-w-full items-center gap-1 font-cinzel text-[0.5rem] font-black tracking-[0.18em] text-theme-cream/80 sm:gap-1.5 sm:text-[0.65rem] sm:tracking-[0.22em]">
                      <CountryFlag
                        country={b.country}
                        size={14}
                        decorative
                        class="boxer-card-flag"
                      />
                      <span class="boxer-card-country-name">{b.countryName}</span>
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>

        <div
          data-boxers-empty
          class="mx-auto mt-16 hidden max-w-md flex-col items-center gap-4 text-center"
          role="status"
        >
          <SectionDivider size="sm" />
          <p class="font-cinzel text-base font-black tracking-[0.16em] text-theme-cream sm:text-lg">
            Sin boxeadores
          </p>
          <p
            class="font-cinzel text-[0.65rem] font-medium tracking-[0.14em] text-theme-cream/65 sm:text-xs"
          >
            Ningún contendiente coincide con los filtros seleccionados.
          </p>
          <button
            type="button"
            data-boxers-reset
            class="boxer-filter-reset boxer-filter-reset-strong"
          >
            Limpiar filtros
          </button>
        </div>
      </div>
    </div>
  </section>

  <Sponsors />
  <Footer />
</Layout>

<style>
  .boxers-page {
    min-height: 100svh;
  }

  .boxers-page-header {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .boxers-page-header-ornament,
  .boxers-page-title,
  .boxers-page-lead {
    width: 100%;
    text-align: center;
  }

  .boxers-page-lead {
    max-width: 42rem;
    margin-inline: auto;
  }

  /* Fondo de la página: un radial dorado sutil en la cabecera + un
     degradado vertical para anclar visualmente la sección al theme. */
  .boxers-bg {
    background:
      radial-gradient(
        ellipse 70% 45% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 16%, transparent) 0%,
        transparent 65%
      ),
      linear-gradient(180deg, var(--color-theme-midnight) 0%, #050816 100%);
  }

  /* Grano fino dorado para dar textura sin ruido visual. */
  .boxers-grain {
    background-image: radial-gradient(rgba(199, 168, 107, 0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%);
  }

  /* ---------- Card ---------- */
  .boxer-card {
    background: linear-gradient(180deg, #0c1330 0%, #060a1d 100%);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
      0 12px 30px rgba(0, 0, 0, 0.4);
    transition:
      box-shadow 400ms ease,
      transform 400ms ease;
    will-change: transform;
  }

  .boxer-card:hover,
  .boxer-card:focus-visible {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent),
      0 28px 60px rgba(0, 0, 0, 0.6),
      0 0 30px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
    transform: translateY(-4px);
  }

  /* Iluminación dorada por detrás del boxeador, intensifica en hover. */
  .boxer-card-bg-gold {
    background: radial-gradient(
      ellipse 90% 65% at 50% 35%,
      color-mix(in srgb, var(--color-theme-gold) 28%, transparent) 0%,
      transparent 70%
    );
    opacity: 0.45;
    transition: opacity 500ms ease;
  }

  .boxer-card:hover .boxer-card-bg-gold,
  .boxer-card:focus-visible .boxer-card-bg-gold {
    opacity: 1;
  }

  /* Imagen del boxer: ocupa toda la card, recortada en el top para
     priorizar la cara. En hover se acerca y se satura. */
  .boxer-card-img {
    transition:
      scale 600ms ease,
      filter 500ms ease;
    filter: saturate(0.9) brightness(0.95);
  }

  .boxer-card:hover .boxer-card-img,
  .boxer-card:focus-visible .boxer-card-img {
    scale: 1.04;
    filter: saturate(1.1) brightness(1.04);
  }

  /* Velo inferior para garantizar contraste del nombre y la bandera. */
  .boxer-card-veil {
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 38%,
      rgba(0, 0, 0, 0.55) 72%,
      rgba(0, 0, 0, 0.95) 100%
    );
    transition: opacity 500ms ease;
  }

  /* Esquinas decorativas estilo "trading card". */
  .boxer-card-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-style: solid;
    border-width: 1.5px;
    border-color: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
    transition:
      width 400ms ease,
      height 400ms ease,
      border-color 400ms ease;
  }

  .boxer-card-corner-tl {
    top: 10px;
    left: 10px;
    border-right-width: 0;
    border-bottom-width: 0;
  }
  .boxer-card-corner-tr {
    top: 10px;
    right: 10px;
    border-left-width: 0;
    border-bottom-width: 0;
  }
  .boxer-card-corner-bl {
    bottom: 10px;
    left: 10px;
    border-right-width: 0;
    border-top-width: 0;
  }
  .boxer-card-corner-br {
    bottom: 10px;
    right: 10px;
    border-left-width: 0;
    border-top-width: 0;
  }

  .boxer-card:hover .boxer-card-corner,
  .boxer-card:focus-visible .boxer-card-corner {
    width: 24px;
    height: 24px;
    border-color: var(--color-theme-gold);
  }

  /* Etiqueta del número de combate. */
  .boxer-card-number {
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.9),
      0 0 12px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  /* Badge de "Campeón previo" anclado a la esquina superior-izquierda
     de la card. El propio componente ya es `position: absolute`, aquí
     sólo fijamos la posición. */
  :global(.boxer-card-wins) {
    top: 14px;
    left: 14px;
  }

  @media (max-width: 639px) {
    :global(.boxer-card-wins) {
      top: 12px;
      left: 12px;
    }
  }

  /* Cuando la card tiene un badge de campeón, escondemos la esquina
     decorativa superior-izquierda para que no se cruce con el badge
     dorado. La esquina inferior-izquierda y las dos de la derecha
     siguen visibles como marco visual. */
  .boxer-card:has(:global(.wins-badge)) .boxer-card-corner-tl {
    display: none;
  }

  /* Al hacer hover/focus sobre la card entera (no sólo sobre el
     badge) también se despliegan los años. Usamos `:global` porque
     las clases viven dentro del componente scoped y Astro las
     "hashifica" al ser importadas. */
  .boxer-card:hover :global(.wins-badge) :global(.win-year),
  .boxer-card:focus-visible :global(.wins-badge) :global(.win-year) {
    max-width: 3rem;
    opacity: 1;
    margin-left: 4px;
    margin-right: 4px;
    transition-delay: var(--win-delay, 0ms);
  }

  .boxer-card:hover :global(.wins-badge) :global(.win-pill),
  .boxer-card:focus-visible :global(.wins-badge) :global(.win-pill) {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.6),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 0 22px color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
    transition-delay: var(--win-delay, 0ms);
  }

  @media (max-width: 639px) {
    .boxer-card:hover :global(.wins-badge) :global(.win-year),
    .boxer-card:focus-visible :global(.wins-badge) :global(.win-year) {
      max-width: 2.5rem;
      margin-left: 3px;
      margin-right: 3px;
    }
  }

  /* Línea decorativa encima del nombre que se amplía en hover. */
  .boxer-card:hover .boxer-card-divider,
  .boxer-card:focus-visible .boxer-card-divider {
    width: 3rem;
    background-color: var(--color-theme-gold);
  }

  /* Nombre del boxer con sombra robusta para legibilidad sobre
     cualquier color de la imagen. */
  .boxer-card-name {
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.95),
