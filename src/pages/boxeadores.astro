---
import ResetIcon from '@/assets/svg/reset.svg'
import Layout from '@/layouts/Layout.astro'
import Header from '@/sections/Header.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { battles } from '@/consts/battles'
import {
  BOXERS,
  COUNTRY_FLAGS,
  COUNTRY_NAMES,
  GENDER_LABELS,
  getBoxerHeroImages,
  type BoxerGender,
} from '@/consts/boxers'

const SITE_URL = 'https://www.infolavelada.com'
const title = `Boxeadores y boxeadoras de La Velada del Año VI (${BOXERS.length} contendientes)`
const description = `Conoce a los ${BOXERS.length} boxeadores y boxeadoras que se subirán al ring en La Velada del Año VI el 25 de julio de 2026 en el Estadio de La Cartuja de Sevilla: nombre, nacionalidad y combate asignado.`
const canonical = `${SITE_URL}/boxeadores`

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Boxeadores', item: canonical },
  ],
}

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Boxeadores de La Velada del Año VI',
  numberOfItems: BOXERS.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: BOXERS.map((boxer, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${SITE_URL}/boxeadores/${boxer.id}`,
    name: boxer.name,
  })),
}

export const prerender = true

// Mapa id-boxeador → combate, para enlazar cada card a su pelea y para
// poder mostrar el número de combate como detalle decorativo.
const battleByBoxer: Record<string, { number: number; battleId: string }> = {}
for (const battle of battles) {
  for (const id of battle.boxerIds) {
    battleByBoxer[id] = { number: battle.number, battleId: battle.id }
  }
}

const boxerCards = BOXERS.map((boxer) => {
  const battle = battleByBoxer[boxer.id]
  return {
    ...boxer,
    heroImages: getBoxerHeroImages(boxer),
    battleNumber: battle?.number ?? 0,
    battleId: battle?.battleId ?? '',
    flag: COUNTRY_FLAGS[boxer.country] ?? '',
    countryName: COUNTRY_NAMES[boxer.country] ?? boxer.country,
  }
})

// Orden por número de combate (cartelera real) y, dentro del mismo
// combate, por el orden definido en `battlePairs`.
boxerCards.sort((a, b) => a.battleNumber - b.battleNumber)

// Países presentes en el cartel, con conteo de boxeadores por cada uno,
// para construir los filtros sin opciones vacías. Se ordenan por número
// de boxeadores descendente y, a igualdad, por nombre alfabético.
const countryCounts = new Map<string, number>()
for (const boxer of BOXERS) {
  countryCounts.set(boxer.country, (countryCounts.get(boxer.country) ?? 0) + 1)
}
const countryFilters = Array.from(countryCounts.entries())
  .map(([code, count]) => ({
    code,
    count,
    name: COUNTRY_NAMES[code] ?? code,
    flag: COUNTRY_FLAGS[code] ?? '',
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'es'))

// Conteo por género, para mostrar el total junto a cada pill.
const genderCounts: Record<BoxerGender, number> = { f: 0, m: 0 }
for (const boxer of BOXERS) genderCounts[boxer.gender]++

const genderFilters: Array<{ code: BoxerGender; name: string; count: number }> = (
  ['f', 'm'] as const
).map((code) => ({
  code,
  name: GENDER_LABELS[code],
  count: genderCounts[code],
}))

const totalBoxers = BOXERS.length
const totalBattles = battles.length
const totalCountries = countryCounts.size
---

<Layout title={title} description={description} canonical={canonical}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListJsonLd)}
    slot="head"
  />

  <Header />

  <section
    class="boxers-page relative isolate w-full overflow-x-clip bg-theme-midnight px-3 pb-20 pt-24 text-theme-cream sm:px-6 sm:pb-24 sm:pt-32 md:pt-36"
  >
    <div aria-hidden="true" class="boxers-bg absolute inset-0 -z-20"></div>
    <div aria-hidden="true" class="boxers-grain pointer-events-none absolute inset-0 -z-10"></div>

    <div class="mx-auto flex w-full max-w-7xl flex-col">
      <header class="boxers-header relative">
        <span
          aria-hidden="true"
          class="boxers-header-count font-cinzel"
        >{totalBoxers}</span>

        <div class="boxers-header-text">
          <p class="boxers-header-eyebrow font-cinzel">
            <span class="boxers-header-eyebrow-rule" aria-hidden="true"></span>
            <span>Cartelera · VI</span>
          </p>

          <h1 class="boxers-header-title animate-fade-in-up font-cinzel">
            Boxeadores
          </h1>

          <p
            class="boxers-header-sub animate-fade-in-up animate-delay-200 font-cinzel"
          >
            Conoce a los contendientes que se subirán al ring el 25 de julio de
            2026 en Sevilla.
          </p>

          <dl class="boxers-header-stats" aria-label="Resumen del cartel">
            <div class="boxers-header-stat">
              <dt class="boxers-header-stat-label font-cinzel">Boxeadores</dt>
              <dd class="boxers-header-stat-value font-cinzel">{totalBoxers}</dd>
            </div>
            <div class="boxers-header-stat">
              <dt class="boxers-header-stat-label font-cinzel">Combates</dt>
              <dd class="boxers-header-stat-value font-cinzel">{totalBattles}</dd>
            </div>
            <div class="boxers-header-stat">
              <dt class="boxers-header-stat-label font-cinzel">Países</dt>
              <dd class="boxers-header-stat-value font-cinzel">{totalCountries}</dd>
            </div>
            <div class="boxers-header-stat">
              <dt class="boxers-header-stat-label font-cinzel">Sede</dt>
              <dd class="boxers-header-stat-value font-cinzel">Sevilla</dd>
            </div>
          </dl>
        </div>
      </header>

      <form
        data-boxers-filters
        class="boxer-filters-bar animate-fade-in-up animate-delay-300 mt-10 w-full sm:mt-14"
        aria-label="Filtros de boxeadores"
        onsubmit="return false"
      >
        <fieldset class="boxer-filter-row" data-filter-row="country">
          <legend class="boxer-filter-row-label font-cinzel">
            <span class="boxer-filter-row-label-num font-cinzel" aria-hidden="true">01</span>
            País
          </legend>
          <div
            class="boxer-filter-tiles"
            role="group"
            aria-label="Filtrar por país"
            style={`--tiles-count: ${countryFilters.length + 1}`}
          >
            <button
              type="button"
              data-filter="country"
              data-value=""
              aria-pressed="true"
              class="boxer-filter-tile boxer-filter-tile-all"
            >
              <span class="boxer-filter-tile-label font-cinzel">Todos</span>
              <span class="boxer-filter-tile-count font-cinzel" aria-hidden="true">{totalBoxers}</span>
            </button>
            {
              countryFilters.map(({ code, name, flag, count }) => (
                <button
                  type="button"
                  data-filter="country"
                  data-value={code}
                  aria-pressed="false"
                  aria-label={`Filtrar por ${name}`}
                  class="boxer-filter-tile"
                >
                  <span class="boxer-filter-tile-label font-cinzel">
                    <span class="boxer-filter-tile-flag" aria-hidden="true">{flag}</span>
                    {name}
                  </span>
                  <span class="boxer-filter-tile-count font-cinzel" aria-hidden="true">
                    {count}
                  </span>
                </button>
              ))
            }
          </div>
        </fieldset>

        <fieldset class="boxer-filter-row" data-filter-row="gender">
          <legend class="boxer-filter-row-label font-cinzel">
            <span class="boxer-filter-row-label-num font-cinzel" aria-hidden="true">02</span>
            Género
          </legend>
          <div
            class="boxer-filter-tiles boxer-filter-tiles-gender"
            role="group"
            aria-label="Filtrar por género"
            style={`--tiles-count: ${genderFilters.length + 1}`}
          >
            <button
              type="button"
              data-filter="gender"
              data-value=""
              aria-pressed="true"
              class="boxer-filter-tile boxer-filter-tile-all"
            >
              <span class="boxer-filter-tile-label font-cinzel">Todos</span>
              <span class="boxer-filter-tile-count font-cinzel" aria-hidden="true">{totalBoxers}</span>
            </button>
            {
              genderFilters.map(({ code, name, count }) => (
                <button
                  type="button"
                  data-filter="gender"
                  data-value={code}
                  aria-pressed="false"
                  aria-label={`Filtrar por género ${name}`}
                  class="boxer-filter-tile"
                >
                  <span class="boxer-filter-tile-label font-cinzel">{name}</span>
                  <span class="boxer-filter-tile-count font-cinzel" aria-hidden="true">
                    {count}
                  </span>
                </button>
              ))
            }
          </div>
        </fieldset>

        <div data-boxers-footer class="boxer-filters-reset-wrap" hidden>
          <button
            type="button"
            data-boxers-reset
            class="boxer-filter-reset font-cinzel"
            aria-label="Restablecer filtros"
          >
            <ResetIcon class="size-3.5" aria-hidden="true" />
            Limpiar
          </button>
        </div>
      </form>

      <div class="boxers-results mt-8 w-full sm:mt-10">
      <ul
        data-boxers-grid
        class="boxers-grid grid w-full grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-3 lg:gap-5 xl:grid-cols-4 2xl:grid-cols-5"
        role="list"
      >
        {
          boxerCards.map((b, index) => (
            <li
              class="boxer-card-wrap animate-fade-in-up"
              data-boxer-card
              data-country={b.country}
              data-gender={b.gender}
              style={`animation-delay: ${index * 35}ms`}
            >
              <a
                href={`/boxeadores/${b.id}`}
                class="boxer-card group relative block aspect-[3/4] w-full overflow-hidden focus-visible:outline-none"
                aria-label={`Ver ficha de ${b.name}`}
              >
                <picture>
                  <source type="image/avif" srcset={b.heroImages.avif} />
                  <source type="image/webp" srcset={b.heroImages.webp} />
                  <img
                    src={b.heroImages.png}
                    alt={`Recorte fotográfico de ${b.name}`}
                    loading="lazy"
                    decoding="async"
                    transition:name={`boxer-hero-${b.id}`}
                    class="boxer-card-img absolute inset-0 h-full w-full object-cover object-top"
                  />
                </picture>

                <span aria-hidden="true" class="boxer-card-veil pointer-events-none absolute inset-0" />

                {b.battleNumber > 0 && (
                  <span
                    class="boxer-card-num font-cinzel pointer-events-none absolute left-3 top-3 sm:left-4 sm:top-4"
                    aria-hidden="true"
                  >
                    <span class="boxer-card-num-prefix">N.º</span>
                    <span class="boxer-card-num-value">{String(b.battleNumber).padStart(2, '0')}</span>
                  </span>
                )}

                <div class="boxer-card-caption absolute inset-x-0 bottom-0 z-10 flex flex-col items-start gap-1 px-3 pb-3.5 pt-12 sm:gap-1.5 sm:px-4 sm:pb-5 sm:pt-14">
                  <span aria-hidden="true" class="boxer-card-rule"></span>
                  <h2 class="boxer-card-name font-cinzel text-balance">
                    {b.name}
                  </h2>
                  {b.realName && b.realName !== b.name && (
                    <p class="boxer-card-realname font-cinzel">
                      <span class="boxer-card-realname-mark" aria-hidden="true">«</span>
                      {b.realName}
                      <span class="boxer-card-realname-mark" aria-hidden="true">»</span>
                    </p>
                  )}
                  <p class="boxer-card-country font-cinzel">
                    <span class="boxer-card-country-flag" aria-hidden="true">
                      {b.flag}
                    </span>
                    <span class="boxer-card-country-name">{b.countryName}</span>
                  </p>
                </div>
              </a>
            </li>
          ))
        }
      </ul>

      <div
        data-boxers-empty
        class="boxer-empty mx-auto mt-20 hidden max-w-md flex-col items-start gap-4 text-left"
        role="status"
      >
        <p class="boxer-empty-eyebrow font-cinzel">
          <span class="boxer-empty-eyebrow-rule" aria-hidden="true"></span>
          Sin resultados
        </p>
        <p class="boxer-empty-title font-cinzel">
          Ningún contendiente coincide con los filtros seleccionados.
        </p>
        <button
          type="button"
          data-boxers-reset
          class="boxer-filter-reset font-cinzel"
        >
          <ResetIcon class="size-3.5" aria-hidden="true" />
          Limpiar
        </button>
      </div>
      </div>
    </div>
  </section>

  <Sponsors />
  <Footer />
</Layout>

<style>
  .boxers-page {
    min-height: 100svh;
  }

  .boxers-header {
    position: relative;
    isolation: isolate;
  }

  .boxers-header-count {
    position: absolute;
    top: -2.5rem;
    right: -0.5rem;
    z-index: -1;
    font-weight: 900;
    font-size: clamp(8rem, 22vw, 20rem);
    line-height: 0.78;
    letter-spacing: -0.05em;
    color: transparent;
    -webkit-text-stroke: 1.5px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    user-select: none;
    pointer-events: none;
    font-variant-numeric: tabular-nums;
  }

  @media (max-width: 639px) {
    .boxers-header-count {
      top: -1.5rem;
      right: -1rem;
      opacity: 0.7;
    }
  }

  .boxers-header-text {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    max-width: 38rem;
  }

  .boxers-header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 90%, transparent);
  }

  .boxers-header-eyebrow-rule {
    display: inline-block;
    width: 2rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-theme-gold) 70%, transparent);
  }

  .boxers-header-title {
    margin-top: 0.65rem;
    font-size: clamp(2.5rem, 8vw, 5rem);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-theme-cream);
    text-transform: uppercase;
    line-height: 0.95;
  }

  .boxers-header-sub {
    margin-top: 1.1rem;
    font-size: 0.8rem;
    font-weight: 500;
    line-height: 1.65;
    letter-spacing: 0.02em;
    color: color-mix(in srgb, var(--color-theme-cream) 65%, transparent);
    text-transform: none;
    text-wrap: balance;
  }

  @media (min-width: 640px) {
    .boxers-header-sub {
      font-size: 0.95rem;
    }
  }

  .boxers-header-stats {
    margin: 1.75rem 0 0;
    padding: 1rem 0 0;
    width: 100%;
    border-top: 1px solid color-mix(in srgb, var(--color-theme-cream) 10%, transparent);
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.75rem;
  }

  @media (max-width: 519px) {
    .boxers-header-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem 0.75rem;
    }
  }

  .boxers-header-stat {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-left: 0.85rem;
    border-left: 1px solid color-mix(in srgb, var(--color-theme-cream) 10%, transparent);
  }

  .boxers-header-stat-label {
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
  }

  .boxers-header-stat-value {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--color-theme-cream);
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 640px) {
    .boxers-header-stat-value {
      font-size: 1.5rem;
    }
  }

  /* Fondo de la página: un radial dorado sutil en la cabecera + un
     degradado vertical para anclar visualmente la sección al theme. */
  .boxers-bg {
    background:
      radial-gradient(
        ellipse 65% 35% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 10%, transparent) 0%,
        transparent 65%
      ),
      linear-gradient(180deg, var(--color-theme-midnight) 0%, #050816 100%);
  }

  /* Grano fino dorado para dar textura sin ruido visual. */
  .boxers-grain {
    background-image: radial-gradient(
      rgba(199, 168, 107, 0.04) 1px,
      transparent 1px
    );
    background-size: 22px 22px;
    -webkit-mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 85%
    );
    mask-image: radial-gradient(
      ellipse at center,
      black 30%,
      transparent 85%
    );
  }

  .boxer-filters-bar {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.5rem;
    padding: 0;
  }

  @media (min-width: 1024px) {
    .boxer-filters-bar {
      grid-template-columns: minmax(0, 7fr) minmax(0, 3fr);
      column-gap: 2rem;
    }
  }

  .boxer-filter-row {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    padding: 0;
  }

  @media (max-width: 1023px) {
    .boxer-filter-row + .boxer-filter-row {
      margin-top: 0.5rem;
    }
  }

  @media (max-width: 639px) {
    .boxer-filter-row {
      gap: 0.55rem;
    }
  }

  .boxer-filter-row-label {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-theme-cream);
  }

  .boxer-filter-row-label-num {
    font-size: 0.62rem;
    font-weight: 700;
    color: var(--color-theme-gold);
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
  }

  @media (max-width: 639px) {
    .boxer-filter-row-label {
      font-size: 0.56rem;
      letter-spacing: 0.18em;
    }
    .boxer-filter-row-label-num {
      font-size: 0.56rem;
    }
  }

  .boxer-filter-tiles {
    min-width: 0;
    display: grid;
    grid-template-columns: repeat(var(--tiles-count, 7), minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid color-mix(in srgb, var(--color-theme-cream) 8%, transparent);
    border-bottom: 1px solid color-mix(in srgb, var(--color-theme-cream) 8%, transparent);
  }

  @media (max-width: 1023px) {
    .boxer-filter-tiles {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .boxer-filter-tiles-gender {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .boxer-filter-tiles {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .boxer-filter-tiles-gender {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .boxer-filters-reset-wrap {
    display: flex;
    justify-content: flex-end;
    padding-top: 0.6rem;
  }

  .boxer-filter-tile {
    appearance: none;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.55rem;
    padding: 0.8rem 0.95rem 0.85rem;
    min-height: 4.5rem;
    background: transparent;
    border: 0;
    border-left: 1px solid color-mix(in srgb, var(--color-theme-cream) 8%, transparent);
    color: color-mix(in srgb, var(--color-theme-cream) 75%, transparent);
    text-align: left;
    cursor: pointer;
    transition:
      background-color 180ms ease,
      color 180ms ease;
  }

  .boxer-filter-tile:first-child {
    border-left-color: transparent;
  }

  .boxer-filter-tile:hover,
  .boxer-filter-tile:focus-visible {
    background: color-mix(in srgb, var(--color-theme-cream) 4%, transparent);
    color: var(--color-theme-cream);
    outline: none;
  }

  .boxer-filter-tile[aria-pressed='true'] {
    background: var(--color-theme-cream);
    color: var(--color-theme-midnight);
    border-left-color: var(--color-theme-cream);
  }

  .boxer-filter-tile[aria-pressed='true'] + .boxer-filter-tile {
    border-left-color: color-mix(in srgb, var(--color-theme-cream) 20%, transparent);
  }

  .boxer-filter-tile:disabled,
  .boxer-filter-tile[data-disabled='true'] {
    opacity: 0.28;
    cursor: not-allowed;
  }

  .boxer-filter-tile:disabled:hover,
  .boxer-filter-tile[data-disabled='true']:hover {
    background: transparent;
    color: color-mix(in srgb, var(--color-theme-cream) 75%, transparent);
  }

  .boxer-filter-tile-label {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 60%, transparent);
    line-height: 1.2;
    transition: color 180ms ease;
  }

  .boxer-filter-tile:hover .boxer-filter-tile-label,
  .boxer-filter-tile:focus-visible .boxer-filter-tile-label {
    color: var(--color-theme-cream);
  }

  .boxer-filter-tile[aria-pressed='true'] .boxer-filter-tile-label {
    color: color-mix(in srgb, var(--color-theme-midnight) 65%, transparent);
  }

  .boxer-filter-tile-flag {
    font-size: 0.9rem;
    line-height: 1;
    filter: drop-shadow(0 1px 0 rgba(0, 0, 0, 0.35));
  }

  .boxer-filter-tile-count {
    font-size: 1.3rem;
    font-weight: 800;
    letter-spacing: 0.02em;
    color: var(--color-theme-cream);
    font-variant-numeric: tabular-nums;
    line-height: 1;
    transition:
      transform 250ms ease,
      color 180ms ease;
  }

  @media (min-width: 640px) {
    .boxer-filter-tile-count {
      font-size: 1.5rem;
    }
  }

  .boxer-filter-tile-count.is-bumping {
    transform: scale(1.18);
  }

  .boxer-filter-tile[aria-pressed='true'] .boxer-filter-tile-count {
    color: var(--color-theme-midnight);
  }

  @media (max-width: 639px) {
    .boxer-filter-tile {
      padding: 0.6rem 0.7rem 0.7rem;
      min-height: 3.8rem;
      gap: 0.4rem;
    }
    .boxer-filter-tile-label {
      font-size: 0.48rem;
      letter-spacing: 0.16em;
    }
    .boxer-filter-tile-count {
      font-size: 1.1rem;
    }
    .boxer-filter-tile-flag {
      font-size: 0.78rem;
    }
  }

  /* ---------- Reset ---------- */
  .boxer-filter-reset {
    appearance: none;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: transparent;
    border: 0;
    padding: 0.4rem 0.2rem;
    color: color-mix(in srgb, var(--color-theme-cream) 65%, transparent);
    font-family: 'Cinzel', var(--font-fallback);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    transition: color 180ms ease;
  }

  .boxer-filter-reset:hover,
  .boxer-filter-reset:focus-visible {
    color: var(--color-theme-gold);
    outline: none;
  }

  /* Contenedor de resultados con animación al filtrar (queda atado al
     grid del lado derecho). */
  .boxers-results {
    min-width: 0;
  }

  /* En mobile forzamos 2 columnas reales, independientes del ancho del
     dispositivo. Sin esto pantallas estrechas reciben demasiado ancho
     por card y la página se vuelve inusable (1 boxeador por pantalla). */
  @media (max-width: 639px) {
    .boxers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  /* ---------- Card ---------- */
  .boxer-card {
    position: relative;
    background: color-mix(in srgb, var(--color-theme-midnight) 90%, black);
    border: 1px solid color-mix(in srgb, var(--color-theme-cream) 8%, transparent);
    transition:
      border-color 250ms ease,
      transform 350ms ease;
    will-change: transform;
    isolation: isolate;
  }

  .boxer-card:hover,
  .boxer-card:focus-visible {
    border-color: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
    transform: translateY(-3px);
  }

  .boxer-card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: repeating-linear-gradient(
      0deg,
      rgba(255, 255, 255, 0.045) 0,
      rgba(255, 255, 255, 0.045) 1px,
      transparent 1px,
      transparent 3px
    );
    mix-blend-mode: overlay;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease;
  }

  .boxer-card:hover::after,
  .boxer-card:focus-visible::after {
    opacity: 1;
  }

  .boxer-card::before {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    top: -40%;
    height: 22%;
    z-index: 3;
    background: linear-gradient(
      180deg,
      transparent 0%,
      color-mix(in srgb, var(--color-theme-gold) 22%, transparent) 50%,
      transparent 100%
    );
    pointer-events: none;
    opacity: 0;
    transition: opacity 220ms ease;
  }

  .boxer-card:hover::before,
  .boxer-card:focus-visible::before {
    opacity: 1;
    animation: boxer-card-scan 1.8s ease-in-out infinite;
  }

  @keyframes boxer-card-scan {
    0% {
      transform: translateY(-20%);
      opacity: 0;
    }
    20% {
      opacity: 0.9;
    }
    80% {
      opacity: 0.9;
    }
    100% {
      transform: translateY(620%);
      opacity: 0;
    }
  }

  /* Imagen del boxer: ocupa toda la card, recortada en el top para
     priorizar la cara. En hover se acerca y se satura. */
  .boxer-card-img {
    transition:
      scale 600ms ease,
      filter 320ms ease;
    filter: saturate(0.95) brightness(0.94) contrast(1.02);
  }

  .boxer-card:hover .boxer-card-img,
  .boxer-card:focus-visible .boxer-card-img {
    scale: 1.03;
    filter:
      saturate(1.08) brightness(1.02) contrast(1.06)
      drop-shadow(1.5px 0 0 rgba(0, 220, 255, 0.45))
      drop-shadow(-1.5px 0 0 rgba(255, 40, 110, 0.45));
    animation: boxer-card-glitch 0.55s steps(2, end);
  }

  @keyframes boxer-card-glitch {
    0% {
      transform: translate(0, 0);
      filter:
        saturate(0.95) brightness(0.94) contrast(1.02)
        drop-shadow(0 0 0 rgba(0, 220, 255, 0))
        drop-shadow(0 0 0 rgba(255, 40, 110, 0));
    }
    20% {
      transform: translate(-2px, 1px);
      filter:
        saturate(1.15) brightness(1.05) contrast(1.1)
        drop-shadow(4px 0 0 rgba(0, 220, 255, 0.5))
        drop-shadow(-4px 0 0 rgba(255, 40, 110, 0.5));
    }
    40% {
      transform: translate(2px, -1px);
      filter:
        saturate(1.1) brightness(1) contrast(1.08)
        drop-shadow(-3px 0 0 rgba(0, 220, 255, 0.5))
        drop-shadow(3px 0 0 rgba(255, 40, 110, 0.5));
    }
    60% {
      transform: translate(-1px, 0);
      filter:
        saturate(1.05) brightness(1) contrast(1.04)
        drop-shadow(2px 0 0 rgba(0, 220, 255, 0.45))
        drop-shadow(-2px 0 0 rgba(255, 40, 110, 0.45));
    }
    100% {
      transform: translate(0, 0);
      filter:
        saturate(1.08) brightness(1.02) contrast(1.06)
        drop-shadow(1.5px 0 0 rgba(0, 220, 255, 0.45))
        drop-shadow(-1.5px 0 0 rgba(255, 40, 110, 0.45));
    }
  }

  /* Velo inferior para garantizar contraste del nombre y la bandera. */
  .boxer-card-veil {
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 32%,
      rgba(5, 8, 22, 0.6) 58%,
      rgba(5, 8, 22, 0.94) 82%,
      rgba(5, 8, 22, 1) 100%
    );
  }

  /* Línea decorativa encima del nombre que se amplía en hover. */
  .boxer-card-rule {
    display: block;
    width: 100%;
    height: 1px;
    margin-bottom: 0.5rem;
    background: var(--color-theme-gold);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 500ms ease;
  }

  .boxer-card:hover .boxer-card-rule,
  .boxer-card:focus-visible .boxer-card-rule {
    transform: scaleX(1);
  }

  /* Etiqueta del número de combate. */
  .boxer-card-num {
    z-index: 5;
    display: inline-flex;
    align-items: baseline;
    gap: 0.3rem;
    color: var(--color-theme-cream);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.85),
      0 0 10px rgba(0, 0, 0, 0.55);
  }

  .boxer-card-num-prefix {
    color: color-mix(in srgb, var(--color-theme-gold) 95%, transparent);
    font-weight: 700;
    letter-spacing: 0.04em;
  }

  .boxer-card-num-value {
    color: var(--color-theme-cream);
    font-variant-numeric: tabular-nums;
    font-weight: 800;
    letter-spacing: 0;
    font-size: 0.78rem;
  }

  @media (max-width: 639px) {
    .boxer-card-num {
      font-size: 0.55rem;
    }
    .boxer-card-num-value {
      font-size: 0.68rem;
    }
  }

  /* Nombre del boxer con sombra robusta para legibilidad sobre
     cualquier color de la imagen. */
  .boxer-card-name {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1.05;
    color: var(--color-theme-cream);
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.85),
      0 2px 8px rgba(0, 0, 0, 0.55);
  }

  @media (min-width: 640px) {
    .boxer-card-name {
      font-size: 1.1rem;
    }
  }

  .boxer-card-realname {
    font-size: 0.62rem;
    font-style: italic;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0.01em;
    color: color-mix(in srgb, var(--color-theme-cream) 60%, transparent);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    max-width: 100%;
  }

  @media (min-width: 640px) {
    .boxer-card-realname {
      font-size: 0.68rem;
    }
  }

  .boxer-card-realname-mark {
    color: var(--color-theme-gold);
    font-style: normal;
    font-weight: 700;
    margin: 0 0.15rem;
  }

  .boxer-card-country {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 70%, transparent);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.7);
  }

  @media (min-width: 640px) {
    .boxer-card-country {
      font-size: 0.62rem;
    }
  }

  .boxer-card-country-flag {
    font-size: 0.95rem;
    line-height: 1;
  }

  .boxer-card-country-name {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 639px) {
    .boxer-card {
      aspect-ratio: 4 / 5;
    }
    .boxer-card-veil {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 30%,
        rgba(5, 8, 22, 0.65) 58%,
        rgba(5, 8, 22, 0.96) 82%,
        rgba(5, 8, 22, 1) 100%
      );
    }
  }

  /* Card ocultada por los filtros: la sacamos del flow para que el grid
     compacte sin huecos. Mantenemos un fade para que no sea brusco.
     El `min-width: 0` es clave para que en 2 columnas en mobile las
     cards puedan encogerse y nunca desborden el viewport. */
  .boxer-card-wrap {
    min-width: 0;
    transition: opacity 220ms ease;
  }

  .boxer-card-wrap[data-hidden='true'] {
    display: none;
  }

  .boxer-empty-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 90%, transparent);
  }

  .boxer-empty-eyebrow-rule {
    display: inline-block;
    width: 1.5rem;
    height: 1px;
    background: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
  }

  .boxer-empty-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.5;
    letter-spacing: 0.01em;
    color: var(--color-theme-cream);
    text-transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-card,
    .boxer-card-img,
    .boxer-card-rule,
    .boxer-filter-tile,
    .boxer-filter-tile-count,
    .boxer-filter-reset,
    .boxer-card-wrap {
      transition: none;
    }
    .boxer-card:hover,
    .boxer-card:focus-visible {
      transform: none;
    }
    .boxer-card:hover .boxer-card-img,
    .boxer-card:focus-visible .boxer-card-img {
      scale: 1;
      animation: none;
      filter: saturate(1.05) brightness(1) contrast(1.04);
    }
    .boxer-card:hover .boxer-card-rule,
    .boxer-card:focus-visible .boxer-card-rule {
      transform: scaleX(1);
    }
    .boxer-card:hover::before,
    .boxer-card:focus-visible::before {
      animation: none;
      opacity: 0;
    }
    .boxer-card:hover::after,
    .boxer-card:focus-visible::after {
      opacity: 0.4;
    }
  }
</style>

<script>
  import { setupBoxersFilters } from '@/lib/boxers-filter/setup'

  setupBoxersFilters()
  document.addEventListener('astro:page-load', setupBoxersFilters)
</script>
