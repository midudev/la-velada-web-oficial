---
import BoxerWinsBadge from '@/components/BoxerWinsBadge.astro'
import BoxersFilterBar from '@/components/BoxersFilterBar.astro'
import CountryFlag from '@/components/CountryFlag.astro'
import SectionDivider from '@/components/SectionDivider.astro'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { battles } from '@/consts/battles'
import {
  BOXERS,
  COUNTRY_NAMES,
  GENDER_LABELS,
  getBoxerHeroImages,
  type BoxerGender,
} from '@/consts/boxers'

const SITE_URL = 'https://www.infolavelada.com'
const title = 'Boxeadores y boxeadoras | La Velada del Año VI'
const description =
  'Descubre a los boxeadores y boxeadoras de La Velada del Año VI. Conoce los participantes, combates y países del evento de Ibai Llanos en Sevilla.'
const canonical = `${SITE_URL}/boxeadores`

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Boxeadores', item: canonical },
  ],
}

const itemListJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Boxeadores de La Velada del Año VI',
  numberOfItems: BOXERS.length,
  itemListOrder: 'https://schema.org/ItemListOrderAscending',
  itemListElement: BOXERS.map((boxer, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${SITE_URL}/boxeadores/${boxer.id}`,
    name: boxer.name,
  })),
}

export const prerender = true

// Mapa id-boxeador → combate, para enlazar cada card a su pelea y para
// poder mostrar el número de combate como detalle decorativo.
const battleByBoxer: Record<string, { number: number; battleId: string }> = {}
for (const battle of battles) {
  for (const id of battle.boxerIds) {
    battleByBoxer[id] = { number: battle.number, battleId: battle.id }
  }
}

const boxerCards = BOXERS.map((boxer) => {
  const battle = battleByBoxer[boxer.id]
  // Suma de seguidores reales (excluimos `monthlyListeners` de Spotify
  // porque no es una métrica de seguidores comparable).
  const totalFollowers = boxer.socials.reduce((sum, s) => sum + (s.followers ?? 0), 0)
  return {
    ...boxer,
    heroImages: getBoxerHeroImages(boxer),
    battleNumber: battle?.number ?? 0,
    battleId: battle?.battleId ?? '',
    countryName: COUNTRY_NAMES[boxer.country] ?? boxer.country,
    totalFollowers,
  }
})

// Orden por número de combate (cartelera real) y, dentro del mismo
// combate, por el orden definido en `battlePairs`.
boxerCards.sort((a, b) => a.battleNumber - b.battleNumber)

// Países presentes en el cartel, con conteo de boxeadores por cada uno,
// para construir los filtros sin opciones vacías. Se ordenan por número
// de boxeadores descendente y, a igualdad, por nombre alfabético.
const countryCounts = new Map<string, number>()
for (const boxer of BOXERS) {
  countryCounts.set(boxer.country, (countryCounts.get(boxer.country) ?? 0) + 1)
}
const countryFilters = Array.from(countryCounts.entries())
  .map(([code, count]) => ({
    code,
    count,
    name: COUNTRY_NAMES[code] ?? code,
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'es'))

// Conteo por género, para mostrar el total junto a cada pill.
const genderCounts: Record<BoxerGender, number> = { f: 0, m: 0 }
for (const boxer of BOXERS) genderCounts[boxer.gender]++

const genderFilters: Array<{ code: BoxerGender; name: string; count: number }> = (
  ['f', 'm'] as const
).map((code) => ({
  code,
  name: GENDER_LABELS[code],
  count: genderCounts[code],
}))

const totalBoxers = BOXERS.length

const cardImageEagerAmount = 4
---

<Layout title={title} description={description} canonical={canonical}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(itemListJsonLd)}
    slot="head"
  />
  <script is:inline>
    document.documentElement.classList.add('js')
  </script>

  <section
    class="boxers-page relative isolate w-full overflow-x-clip bg-theme-midnight px-3 pt-24 pb-20 text-theme-cream sm:px-6 sm:pt-32 sm:pb-24 md:pt-36"
  >
    <div aria-hidden="true" class="boxers-bg absolute inset-0 -z-20"></div>
    <div aria-hidden="true" class="boxers-grain pointer-events-none absolute inset-0 -z-10"></div>

    <div class="boxers-layout mx-auto w-full max-w-[88rem]">
      <header class="boxers-page-header">
        <h1
          class="boxers-page-title mb-3 font-cinzel text-3xl font-black tracking-[0.12em] text-theme-cream not-motion-reduce:animate-fade-in-up sm:text-4xl sm:tracking-[0.16em] md:text-6xl"
        >
          <SectionDivider class="boxers-page-header-ornament mb-8 w-full sm:mb-12" />

          BOXEADORES
        </h1>
        <p
          class="boxers-page-lead mb-8 font-cinzel text-xs font-medium tracking-[0.14em] text-balance text-white/55 animate-delay-200 not-motion-reduce:animate-fade-in-up sm:mb-12 sm:text-sm"
        >
          Los {totalBoxers} contendientes de La Velada del Año VI
        </p>
      </header>

      <BoxersFilterBar
        countryFilters={countryFilters}
        genderFilters={genderFilters}
        totalBoxers={totalBoxers}
      />

      <div class="boxers-results w-full">
        <ul
          data-boxers-grid
          class="boxers-grid grid w-full grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3 lg:grid-cols-4 lg:gap-5"
          role="list"
        >
          {
            boxerCards.map((b, index) => (
              <li
                class="boxer-card-wrap"
                data-boxer-card
                data-country={b.country}
                data-gender={b.gender}
                data-default-order={index}
                data-followers={b.totalFollowers}
                data-battle={b.battleNumber}
              >
                <a
                  href={`/boxeadores/${b.id}`}
                  class="boxer-card group relative block aspect-[3/4] w-full overflow-hidden rounded-md focus-visible:outline-none"
                  aria-label={`Ver ficha de ${b.name}`}
                >
                  <span
                    aria-hidden="true"
                    class="boxer-card-bg-gold pointer-events-none absolute inset-0 -z-10"
                  />

                  <picture>
                    <source type="image/avif" srcset={b.heroImages.avif} />
                    <source type="image/webp" srcset={b.heroImages.webp} />
                    <img
                      src={b.heroImages.webp}
                      alt={`Recorte fotográfico de ${b.name}`}
                      width="1066"
                      height="1600"
                      loading={index < cardImageEagerAmount ? 'eager' : 'lazy'}
                      decoding={index < cardImageEagerAmount ? 'auto' : 'async'}
                      fetchpriority={index < cardImageEagerAmount ? 'high' : 'auto'}
                      transition:name={`boxer-hero-${b.id}`}
                      class="boxer-card-img h-full w-full object-cover object-top"
                    />
                  </picture>

                  <span
                    aria-hidden="true"
                    class="boxer-card-veil pointer-events-none absolute inset-0"
                  />

                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-tl" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-tr" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-bl" />
                  <span aria-hidden="true" class="boxer-card-corner boxer-card-corner-br" />

                  {b.battleNumber > 0 && (
                    <span
                      aria-hidden="true"
                      class="boxer-card-number pointer-events-none absolute top-3.5 right-3 font-cinzel text-[0.42rem] font-black tracking-[0.16em] text-theme-gold/90 sm:top-4 sm:right-4 sm:text-[0.55rem] sm:tracking-[0.2em]"
                    >
                      COMBATE · {String(b.battleNumber).padStart(2, '0')}
                    </span>
                  )}

                  <BoxerWinsBadge
                    wins={b.previousVeladaWins}
                    boxerName={b.name}
                    variant="card"
                    class="boxer-card-wins"
                  />

                  <div class="boxer-card-caption absolute inset-x-0 bottom-0 z-10 flex flex-col items-center gap-1 px-2.5 pt-12 pb-4 text-center sm:gap-1.5 sm:px-3 sm:pt-14 sm:pb-6">
                    <span
                      aria-hidden="true"
                      class="boxer-card-divider mb-1 h-px w-8 bg-theme-gold/60 transition-all duration-500"
                    />
                    <h2 class="boxer-card-name font-cinzel text-[0.78rem] leading-[1.1] font-black tracking-[0.1em] text-balance text-theme-cream uppercase sm:text-base sm:tracking-[0.16em] md:text-lg">
                      {b.name}
                    </h2>
                    <p class="boxer-card-country flex max-w-full items-center gap-1 font-cinzel text-[0.5rem] font-black tracking-[0.18em] text-theme-cream/80 sm:gap-1.5 sm:text-[0.65rem] sm:tracking-[0.22em]">
                      <CountryFlag
                        country={b.country}
                        size={14}
                        decorative
                        class="boxer-card-flag"
                      />
                      <span class="boxer-card-country-name">{b.countryName}</span>
                    </p>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>

        <div
          data-boxers-empty
          class="mx-auto mt-16 hidden max-w-md flex-col items-center gap-4 text-center"
          role="status"
        >
          <SectionDivider size="sm" />
          <p class="font-cinzel text-base font-black tracking-[0.16em] text-theme-cream sm:text-lg">
            Sin boxeadores
          </p>
          <p
            class="font-cinzel text-[0.65rem] font-medium tracking-[0.14em] text-theme-cream/65 sm:text-xs"
          >
            Ningún contendiente coincide con los filtros seleccionados.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Sponsors />
  <Footer />
</Layout>

<style>
  .boxers-page {
    min-height: 100svh;
  }

  .boxers-page-header {
    grid-column: 1 / -1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .boxers-page-header-ornament,
  .boxers-page-title,
  .boxers-page-lead {
    width: 100%;
    text-align: center;
  }

  .boxers-page-lead {
    max-width: 42rem;
    margin-inline: auto;
  }

  /* Fondo de la página: un radial dorado sutil en la cabecera + un
     degradado vertical para anclar visualmente la sección al theme. */
  .boxers-bg {
    background:
      radial-gradient(
        ellipse 70% 45% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 16%, transparent) 0%,
        transparent 65%
      ),
      linear-gradient(180deg, var(--color-theme-midnight) 0%, #050816 100%);
  }

  /* Grano fino dorado para dar textura sin ruido visual. */
  .boxers-grain {
    background-image: radial-gradient(rgba(199, 168, 107, 0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%);
  }

  /* ---------- Card ---------- */
  .boxer-card {
    background: linear-gradient(180deg, #0c1330 0%, #060a1d 100%);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
      0 12px 30px rgba(0, 0, 0, 0.4);
    transition:
      box-shadow 400ms ease,
      transform 400ms ease;
    will-change: transform;
  }

  .boxer-card:hover,
  .boxer-card:focus-visible {
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent),
      0 28px 60px rgba(0, 0, 0, 0.6),
      0 0 30px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
    transform: translateY(-4px);
  }

  /* Iluminación dorada por detrás del boxeador, intensifica en hover. */
  .boxer-card-bg-gold {
    background: radial-gradient(
      ellipse 90% 65% at 50% 35%,
      color-mix(in srgb, var(--color-theme-gold) 28%, transparent) 0%,
      transparent 70%
    );
    opacity: 0.45;
    transition: opacity 500ms ease;
  }

  .boxer-card:hover .boxer-card-bg-gold,
  .boxer-card:focus-visible .boxer-card-bg-gold {
    opacity: 1;
  }

  /* Imagen del boxer: ocupa toda la card, recortada en el top para
     priorizar la cara. En hover se acerca y se satura. */
  .boxer-card-img {
    transition:
      scale 600ms ease,
      filter 500ms ease;
    filter: saturate(0.9) brightness(0.95);
  }

  .boxer-card:hover .boxer-card-img,
  .boxer-card:focus-visible .boxer-card-img {
    scale: 1.04;
    filter: saturate(1.1) brightness(1.04);
  }

  /* Velo inferior para garantizar contraste del nombre y la bandera. */
  .boxer-card-veil {
    background: linear-gradient(
      180deg,
      transparent 0%,
      transparent 38%,
      rgba(0, 0, 0, 0.55) 72%,
      rgba(0, 0, 0, 0.95) 100%
    );
    transition: opacity 500ms ease;
  }

  /* Esquinas decorativas estilo "trading card". */
  .boxer-card-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-style: solid;
    border-width: 1.5px;
    border-color: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
    transition:
      width 400ms ease,
      height 400ms ease,
      border-color 400ms ease;
  }

  .boxer-card-corner-tl {
    top: 10px;
    left: 10px;
    border-right-width: 0;
    border-bottom-width: 0;
  }
  .boxer-card-corner-tr {
    top: 10px;
    right: 10px;
    border-left-width: 0;
    border-bottom-width: 0;
  }
  .boxer-card-corner-bl {
    bottom: 10px;
    left: 10px;
    border-right-width: 0;
    border-top-width: 0;
  }
  .boxer-card-corner-br {
    bottom: 10px;
    right: 10px;
    border-left-width: 0;
    border-top-width: 0;
  }

  .boxer-card:hover .boxer-card-corner,
  .boxer-card:focus-visible .boxer-card-corner {
    width: 24px;
    height: 24px;
    border-color: var(--color-theme-gold);
  }

  /* Etiqueta del número de combate. */
  .boxer-card-number {
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.9),
      0 0 12px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  /* Badge de "Campeón previo" anclado a la esquina superior-izquierda
     de la card. El propio componente ya es `position: absolute`, aquí
     sólo fijamos la posición. */
  :global(.boxer-card-wins) {
    top: 14px;
    left: 14px;
  }

  @media (max-width: 639px) {
    :global(.boxer-card-wins) {
      top: 12px;
      left: 12px;
    }
  }

  /* Cuando la card tiene un badge de campeón, escondemos la esquina
     decorativa superior-izquierda para que no se cruce con el badge
     dorado. La esquina inferior-izquierda y las dos de la derecha
     siguen visibles como marco visual. */
  .boxer-card:has(:global(.wins-badge)) .boxer-card-corner-tl {
    display: none;
  }

  /* Al hacer hover/focus sobre la card entera (no sólo sobre el
     badge) también se despliegan los años. Usamos `:global` porque
     las clases viven dentro del componente scoped y Astro las
     "hashifica" al ser importadas. */
  .boxer-card:hover :global(.wins-badge) :global(.win-year),
  .boxer-card:focus-visible :global(.wins-badge) :global(.win-year) {
    max-width: 3rem;
    opacity: 1;
    margin-left: 4px;
    margin-right: 4px;
    transition-delay: var(--win-delay, 0ms);
  }

  .boxer-card:hover :global(.wins-badge) :global(.win-pill),
  .boxer-card:focus-visible :global(.wins-badge) :global(.win-pill) {
    box-shadow:
      0 4px 16px rgba(0, 0, 0, 0.6),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 0 22px color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
    transition-delay: var(--win-delay, 0ms);
  }

  @media (max-width: 639px) {
    .boxer-card:hover :global(.wins-badge) :global(.win-year),
    .boxer-card:focus-visible :global(.wins-badge) :global(.win-year) {
      max-width: 2.5rem;
      margin-left: 3px;
      margin-right: 3px;
    }
  }

  /* Línea decorativa encima del nombre que se amplía en hover. */
  .boxer-card:hover .boxer-card-divider,
  .boxer-card:focus-visible .boxer-card-divider {
    width: 3rem;
    background-color: var(--color-theme-gold);
  }

  /* Nombre del boxer con sombra robusta para legibilidad sobre
     cualquier color de la imagen. */
  .boxer-card-name {
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.95),
      0 1px 2px rgba(0, 0, 0, 0.9),
      0 2px 10px rgba(0, 0, 0, 0.65);
  }

  .boxer-card-country {
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.85),
      0 0 8px rgba(0, 0, 0, 0.65);
  }

  .boxer-card-country-name {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 639px) {
    .boxer-card {
      aspect-ratio: 4 / 5;
    }

    .boxer-card-veil {
      background: linear-gradient(
        180deg,
        transparent 0%,
        transparent 34%,
        rgba(0, 0, 0, 0.6) 70%,
        rgba(0, 0, 0, 0.96) 100%
      );
    }

    .boxer-card-caption {
      background: linear-gradient(180deg, transparent 0%, rgba(0, 0, 0, 0.2) 100%);
    }

    .boxer-card-corner {
      width: 12px;
      height: 12px;
    }

    .boxer-card-corner-tl {
      top: 8px;
      left: 8px;
    }
    .boxer-card-corner-tr {
      top: 8px;
      right: 8px;
    }
    .boxer-card-corner-bl {
      bottom: 8px;
      left: 8px;
    }
    .boxer-card-corner-br {
      bottom: 8px;
      right: 8px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-card,
    .boxer-card-img,
    .boxer-card-bg-gold,
    .boxer-card-corner,
    .boxer-card-divider {
      transition: none;
    }
    .boxer-card:hover,
    .boxer-card:focus-visible {
      transform: none;
    }
    .boxer-card:hover .boxer-card-img,
    .boxer-card:focus-visible .boxer-card-img {
      scale: 1;
    }
  }

  /* ---------- Layout: top command bar + resultados ---------- */
  .boxers-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .boxers-layout {
      gap: 1.75rem;
    }
  }

  @media (min-width: 1024px) {
    .boxers-layout {
      gap: 2rem;
    }
  }

  @media (min-width: 1280px) {
    .boxers-layout {
      gap: 2.5rem;
    }
  }

  /* Contenedor de resultados con animación al filtrar (queda atado al
     grid del lado derecho). */
  .boxers-results {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  /* En mobile forzamos 2 columnas reales, independientes del ancho del
     dispositivo. Sin esto pantallas estrechas reciben demasiado ancho
     por card y la página se vuelve inusable (1 boxeador por pantalla). */
  @media (max-width: 639px) {
    .boxers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  :global(.boxer-card-flag) {
    width: 0.9rem;
    height: 0.9rem;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    :global(.boxer-card-flag) {
      width: 1rem;
      height: 1rem;
    }
  }

  :global(.js) .boxer-card-wrap {
    opacity: 0;
  }

  :global(.js) .boxer-card-wrap[data-ready='true'] {
    opacity: 1;
  }

  .boxer-card-wrap {
    animation-delay: var(--animation-delay);
  }

  .boxer-card-wrap[data-hidden='true'] {
    display: none;
  }

  .boxers-grid {
    --cards-gap: calc(var(--spacing) * 3);
  }

  @media (width >= 64rem) {
    .boxers-grid {
      --cards-gap: calc(var(--spacing) * 5);
    }
  }

  .boxers-grid[data-state='default'] > .boxer-card-wrap:nth-child(even) {
    position: relative;
  }

  .boxers-grid[data-state='default'] > .boxer-card-wrap:nth-child(even)::after {
    --inline-size: 2.3em;
    --block-size: 2.05em;
    content: 'VS';
    position: absolute;
    inset-block: 0;
    inset-inline-start: calc((var(--inline-size) + var(--cards-gap)) / 2 * -1);
    display: grid;
    place-items: center;
    margin-block: auto;
    inline-size: var(--inline-size);
    block-size: var(--block-size);
    font-family: var(--font-cinzel);
    font-weight: 900;
    font-size: 1.125rem;
    color: var(--color-theme-gold);
    background-color: var(--color-theme-midnight);
    background-image: radial-gradient(
      ellipse at top,
      color-mix(in srgb, var(--color-theme-gold), transparent 88%) 0%,
      transparent 80%
    );
    border-radius: 2px;
    line-height: normal;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 30%, transparent);
    animation: blurred-fade-in 0.4s ease-in-out both calc(var(--animation-delay) + 0.6s);
  }

  @media (width <= 48rem) {
    .boxers-grid[data-state='default'] > .boxer-card-wrap:nth-child(even)::after {
      font-size: clamp(1rem, 0.641rem + 1.531vw, 1.375rem);
    }
  }

  @media (width >= 48rem) and (width <= 79.999rem) {
    .boxers-grid[data-state='default'] > .boxer-card-wrap:nth-child(even)::after {
      content: none;
    }
  }

  html[data-skip-boxers-enter] .boxer-card-wrap {
    animation: none;
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-card-wrap,
    .boxers-grid[data-state='default'] > .boxer-card-wrap:nth-child(even)::after {
      animation: none;
    }

    .boxer-card-wrap {
      transition: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'

  type SortMode = 'cartel' | 'followers-desc' | 'followers-asc'

  function setupBoxersFilters() {
    const form = $<HTMLFormElement>('[data-boxers-filters]')
    const grid = $<HTMLElement>('[data-boxers-grid]')
    const empty = $<HTMLElement>('[data-boxers-empty]')
    const sortBar = $<HTMLElement>('[data-boxers-sort]')
    if (!form || !grid) return
    if (form.dataset.boxersFiltersReady === 'true') return
    form.dataset.boxersFiltersReady = 'true'

    const gridEl: HTMLElement = grid

    const cards = Array.from($$<HTMLElement>('[data-boxer-card]', grid))
    const countrySelect = $<HTMLSelectElement>('[data-country-select]', form)
    const countrySelectedLabel = $<HTMLElement>('[data-country-selected-label]', form)
    const countrySelectedFlags = Array.from($$<HTMLElement>('[data-country-selected-flag]', form))
    const countryCount = $<HTMLElement>('[data-country-count]', form)
    const genderSegmented = $<HTMLElement>('[data-gender-segmented]', form)
    const filterButtons = Array.from($$<HTMLButtonElement>('[data-filter]', form))
    const sortCycleButton = sortBar ? $<HTMLButtonElement>('[data-sort-cycle]', sortBar) : null
    const sortCycleLabel = sortCycleButton
      ? $<HTMLElement>('[data-sort-cycle-label]', sortCycleButton)
      : null

    const reduceMotionQuery = window.matchMedia('(prefers-reduced-motion: reduce)')
    const SORT_MODES: SortMode[] = ['cartel', 'followers-desc', 'followers-asc']
    const SORT_META: Record<SortMode, { label: string; aria: string }> = {
      cartel: {
        label: 'Cartelera',
        aria: 'Ordenar por cartelera. Pulsa para ordenar por más seguidores.',
      },
      'followers-desc': {
        label: 'Más seguidores',
        aria: 'Ordenar por más seguidores. Pulsa para ordenar por menos seguidores.',
      },
      'followers-asc': {
        label: 'Menos seguidores',
        aria: 'Ordenar por menos seguidores. Pulsa para ordenar por cartelera.',
      },
    }

    // Lee el estado inicial desde la URL
    function getStateFromURL(buttons: HTMLButtonElement[]) {
      const validCountries = new Set(
        countrySelect ? Array.from(countrySelect.options).map((option) => option.value) : [''],
      )
      const validGenders = new Set(
        buttons.filter((b) => b.dataset.filter === 'gender').map((b) => b.dataset.value ?? ''),
      )
      const params = new URLSearchParams(window.location.search)
      const rawCountry = params.get('country') ?? ''
      const rawGender = params.get('gender') ?? ''
      const sort = params.get('sort') as SortMode | null
      return {
        country: validCountries.has(rawCountry) ? rawCountry : '',
        gender: validGenders.has(rawGender) ? rawGender : '',
        sort:
          sort && ['cartel', 'followers-desc', 'followers-asc'].includes(sort) ? sort : 'cartel',
      }
    }

    function syncStateToURL() {
      const params = new URLSearchParams(window.location.search)
      if (state.country) {
        params.set('country', state.country)
      } else {
        params.delete('country')
      }
      if (state.gender) {
        params.set('gender', state.gender)
      } else {
        params.delete('gender')
      }
      if (sortMode !== 'cartel') {
        params.set('sort', sortMode)
      } else {
        params.delete('sort')
      }
      const qs = params.toString()
      const url = qs ? `${window.location.pathname}?${qs}` : window.location.pathname
      window.history.replaceState(null, '', url)
    }

    // Estado inicial desde la URL (debe ir antes de sortMode)
    const urlState = getStateFromURL(filterButtons)
    const state: { country: string; gender: string } = {
      country: urlState.country,
      gender: urlState.gender,
    }
    let sortMode: SortMode = urlState.sort

    function setGridState(state: 'default' | 'modified') {
      gridEl.dataset.state = state
    }

    const HEADER_HEIGHT = 70
    const SCROLL_OFFSET = 110

    function keepContentInView(anchor: HTMLElement | null) {
      if (!anchor) return

      const { top: anchorTop } = anchor.getBoundingClientRect()

      if (anchorTop > HEADER_HEIGHT) return

      const scrollTop = anchor.getBoundingClientRect().top + window.scrollY - SCROLL_OFFSET

      window.scrollTo({
        top: scrollTop,
        behavior: 'instant',
      })
    }

    const ANIM_CLASS = 'animate-fade-in-up'
    const ANIM_DELAY = 35
    let cardsReady = false

    function prepareCardsForLayoutChange() {
      if (!cardsReady) return

      for (const card of cards) {
        card.classList.remove(ANIM_CLASS)
        card.dataset.ready = 'true'
      }
    }

    function revealInitialCards() {
      let visibleIndex = 0
      allowBoxerCardAnimations()

      if (reduceMotionQuery.matches) {
        cardsReady = true
        for (const card of cards) card.dataset.ready = 'true'
        return
      }

      for (const card of Array.from(gridEl.children) as HTMLElement[]) {
        if (card.dataset.hidden === 'true') continue

        card.classList.remove(ANIM_CLASS)

        void card.offsetWidth

        card.style.setProperty('--animation-delay', `${visibleIndex * ANIM_DELAY}ms`)

        card.classList.add(ANIM_CLASS)

        visibleIndex++
      }

      cardsReady = true
    }

    function allowBoxerCardAnimations() {
      document.documentElement.removeAttribute('data-skip-boxers-enter')
    }

    function updateGridState() {
      const hasActiveFilter = state.country !== '' || state.gender !== ''
      const isDefaultSortMode = sortMode === 'cartel'
      setGridState(!hasActiveFilter && isDefaultSortMode ? 'default' : 'modified')
    }

    function updateSortOrder() {
      const ordered = [...cards]
      if (sortMode === 'followers-desc') {
        ordered.sort(
          (a, b) => Number(b.dataset.followers ?? '0') - Number(a.dataset.followers ?? '0'),
        )
      } else if (sortMode === 'followers-asc') {
        ordered.sort(
          (a, b) => Number(a.dataset.followers ?? '0') - Number(b.dataset.followers ?? '0'),
        )
      } else {
        // Both 'cartel' and 'combates' use default order (by battle number).
        ordered.sort(
          (a, b) => Number(a.dataset.defaultOrder ?? '0') - Number(b.dataset.defaultOrder ?? '0'),
        )
      }

      for (const card of ordered) gridEl.appendChild(card)

      syncSortCycleControl()
    }

    function applySort() {
      prepareCardsForLayoutChange()
      updateGridState()
      updateSortOrder()
    }

    // Cuenta cards que coinciden con un par (country, gender). Pasar '' en
    // cualquiera de los dos significa "sin restricción en ese grupo".
    function countMatching(country: string, gender: string) {
      let n = 0
      for (const card of cards) {
        if (country !== '' && card.dataset.country !== country) continue
        if (gender !== '' && card.dataset.gender !== gender) continue
        n++
      }
      return n
    }

    // Animación visual al presionar un filtro.
    function bump(el: HTMLElement | null) {
      if (!el || reduceMotionQuery.matches) return
      el.classList.remove('is-bumping')
      // Forzamos reflow para reiniciar la transición si se está pulsando rápido.
      void el.offsetWidth
      el.classList.add('is-bumping')
      window.setTimeout(() => el.classList.remove('is-bumping'), 260)
    }

    function setCountText(el: HTMLElement, value: string) {
      const countValue = $<HTMLElement>('.boxer-filter-pill-count-value', el)
      if (countValue) {
        countValue.textContent = value
        return
      }

      el.textContent = ''
      const valueNode = document.createElement('span')
      valueNode.className = 'boxer-filter-pill-count-value'
      valueNode.textContent = value
      el.appendChild(valueNode)
    }

    function getCountText(el: HTMLElement) {
      return (
        $<HTMLElement>('.boxer-filter-pill-count-value', el)?.textContent?.trim() ??
        el.textContent?.trim()
      )
    }

    function syncCountryControl() {
      if (!countrySelect) return

      countrySelect.value = state.country
      const selectedOption = countrySelect.selectedOptions[0]
      if (countrySelectedLabel) {
        countrySelectedLabel.textContent =
          selectedOption?.dataset.label ??
          selectedOption?.textContent?.split('·')[0]?.trim() ??
          'Todos'
      }

      for (const flag of countrySelectedFlags) {
        flag.hidden = (flag.dataset.countrySelectedFlag ?? '') !== state.country
      }

      for (const option of Array.from(countrySelect.options)) {
        const value = option.value
        const label = option.dataset.label ?? option.textContent?.split('·')[0]?.trim() ?? ''
        const projectedCount = countMatching(value, state.gender)
        option.textContent = `${label} · ${projectedCount}`
        option.disabled = projectedCount === 0 && state.country !== value
      }

      if (countryCount) {
        const selectedCount = countMatching(state.country, state.gender)
        const next = String(selectedCount)
        if (getCountText(countryCount) !== next) {
          setCountText(countryCount, next)
          bump(countryCount)
        }
      }
    }

    function syncSortCycleControl() {
      if (!sortCycleButton) return

      const meta = SORT_META[sortMode]
      sortCycleButton.dataset.sort = sortMode
      sortCycleButton.setAttribute('aria-label', meta.aria)
      if (sortCycleLabel) sortCycleLabel.textContent = meta.label
    }

    function updateFilters() {
      updateGridState()
      // Keep the grid anchored when filtering changes page height.
      keepContentInView(sortBar)

      let visible = 0
      for (const card of cards) {
        const country = card.dataset.country ?? ''
        const gender = card.dataset.gender ?? ''
        const matches =
          (state.country === '' || state.country === country) &&
          (state.gender === '' || state.gender === gender)
        card.dataset.hidden = matches ? 'false' : 'true'
        if (matches) visible++
      }

      if (empty) empty.classList.toggle('hidden', visible !== 0)
      if (empty) empty.classList.toggle('flex', visible === 0)

      syncCountryControl()

      // Para cada pill: recalculamos su conteo SIN aplicar el filtro de su
      // propio grupo (así se muestra cuántos quedarían si se activase
      // sobre los filtros actuales del resto). Y sincronizamos aria-pressed.
      if (genderSegmented) genderSegmented.dataset.active = state.gender || 'all'

      for (const btn of filterButtons) {
        const group = btn.dataset.filter as 'country' | 'gender' | undefined
        const value = btn.dataset.value ?? ''
        if (!group) continue

        const isActive = state[group] === value
        btn.setAttribute('aria-pressed', String(isActive))

        const projectedCount =
          group === 'country'
            ? countMatching(value, state.gender)
            : countMatching(state.country, value)

        const countNode = $<HTMLElement>('.boxer-filter-pill-count', btn)
        if (countNode) {
          const next = String(projectedCount)
          if (getCountText(countNode) !== next) {
            setCountText(countNode, next)
            bump(countNode)
          }
        }

        // Deshabilitamos las pills que no aportarían resultados, salvo la
        // activa (para que el usuario siempre pueda salir de un filtro
        // que dejó la lista vacía).
        const shouldDisable = projectedCount === 0 && !isActive
        btn.disabled = shouldDisable
        btn.dataset.disabled = String(shouldDisable)
      }
    }

    function applyFilters() {
      prepareCardsForLayoutChange()
      updateFilters()
    }

    if (countrySelect) {
      countrySelect.addEventListener('change', () => {
        state.country = countrySelect.value
        applyFilters()
        syncStateToURL()
      })
    }

    for (const btn of filterButtons) {
      btn.addEventListener('click', () => {
        const group = btn.dataset.filter as 'country' | 'gender' | undefined
        if (!group) return
        const value = btn.dataset.value ?? ''
        // Re-pulsar la pill activa no la apaga, salvo que sea distinta de
        // "todos"; mantenemos la UX simple: una activa siempre por grupo.
        if (state[group] === value) return
        state[group] = value
        applyFilters()
        syncStateToURL()
      })
    }

    if (sortCycleButton) {
      sortCycleButton.addEventListener('click', () => {
        const currentIndex = SORT_MODES.indexOf(sortMode)
        sortMode = SORT_MODES[(currentIndex + 1) % SORT_MODES.length]
        applySort()
        syncStateToURL()
      })
    }

    updateFilters()
    updateSortOrder()
    revealInitialCards()
  }

  document.addEventListener('astro:page-load', setupBoxersFilters)
</script>
