---
import CombatFaceToFaceVideoSection from '@/components/combat/CombatFaceToFaceVideoSection.astro'
import CombatHero from '@/components/combat/CombatHero.astro'
import CombatStatsSection from '@/components/combat/CombatStatsSection.astro'
import LivePrediction from '@/components/LivePrediction.astro'
import { battles, battlesById } from '@/consts/battles'
import { EVENT_DATE_TIME } from '@/consts/event'
import {
  BOXERS_BY_ID,
  COUNTRY_NAMES,
  getBoxerHeroImages,
  getBoxerSelectImages,
} from '@/consts/boxers'
import { getBoxerMainPhotoUrl } from '@/consts/boxer-gallery'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { serializeJsonLd } from '@/utils/serialize-json-ld'
import type { GetStaticPaths } from 'astro'

// La ficha de combate solo usa datos estáticos (battlesById/BOXERS_BY_ID) y los
// pronósticos se cargan en cliente vía <LivePrediction>. No hay nada por usuario
// ni consultas a BD en el servidor, así que la prerenderizamos: se sirve desde
// el CDN en lugar de renderizarse on-demand en cada visita.
export const prerender = true

export const getStaticPaths = (() => {
  return battles.map((battle) => ({ params: { id: battle.id } }))
}) satisfies GetStaticPaths

const { id = '' } = Astro.params
const battle = battlesById[id]

if (!battle) return Astro.redirect('/404')

const SITE_URL = 'https://www.infolavelada.com'
const [boxer1Id, boxer2Id] = battle.boxerIds
const boxer1 = BOXERS_BY_ID[boxer1Id]
const boxer2 = BOXERS_BY_ID[boxer2Id]
const battleVideo = battle.video
const boxer1Hero = getBoxerHeroImages(boxer1)
const boxer2Hero = getBoxerHeroImages(boxer2)
const boxer1Select = getBoxerSelectImages(boxer1)
const boxer2Select = getBoxerSelectImages(boxer2)

const title = `${battle.title} — Combate ${String(battle.number).padStart(2, '0')} de La Velada del Año VI`
const description = `Toda la información del combate ${battle.number} de La Velada del Año VI: ${boxer1.name} contra ${boxer2.name}. Fecha, horario y detalles en Sevilla.`
const canonical = `${SITE_URL}${battle.url}`

const fmt = {
  weight: (kg?: number | null) => (kg != null ? `${kg} kg` : '—'),
  height: (cm?: number | null) => (cm != null ? `${(cm / 100).toFixed(2)} m` : '—'),
  age: (age?: number | null) => (age != null ? `${age} años` : '—'),
}

const stats = [
  {
    label: 'País',
    a: COUNTRY_NAMES[boxer1.country] ?? boxer1.country,
    b: COUNTRY_NAMES[boxer2.country] ?? boxer2.country,
    flagA: boxer1.country,
    flagB: boxer2.country,
  },
  {
    label: 'Peso pactado',
    a: fmt.weight(boxer1.fightWeightKg ?? boxer1.weightKg),
    b: fmt.weight(boxer2.fightWeightKg ?? boxer2.weightKg),
  },
  {
    label: 'Altura',
    a: fmt.height(boxer1.heightCm),
    b: fmt.height(boxer2.heightCm),
  },
  {
    label: 'Edad',
    a: fmt.age(boxer1.age),
    b: fmt.age(boxer2.age),
  },
]

const sportsEventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: `${battle.title} — La Velada del Año VI`,
  description,
  url: canonical,
  sport: 'Boxing',
  startDate: EVENT_DATE_TIME,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/MixedEventAttendanceMode',
  superEvent: { '@type': 'SportsEvent', name: 'La Velada del Año VI', url: `${SITE_URL}/` },
  location: {
    '@type': 'Place',
    name: 'Estadio La Cartuja',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Sevilla',
      addressRegion: 'Andalucía',
      addressCountry: 'ES',
    },
  },
  organizer: { '@type': 'Person', name: 'Ibai Llanos' },
  competitor: [
    {
      '@type': 'Person',
      name: boxer1.name,
      url: `${SITE_URL}/boxeadores/${boxer1.id}`,
      image: getBoxerMainPhotoUrl(boxer1.id),
    },
    {
      '@type': 'Person',
      name: boxer2.name,
      url: `${SITE_URL}/boxeadores/${boxer2.id}`,
      image: getBoxerMainPhotoUrl(boxer2.id),
    },
  ],
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: battle.title, item: canonical },
  ],
}
---

<Layout title={title} description={description} canonical={canonical} showHeader={true}>
  <script
    type="application/ld+json"
    is:inline
    set:html={serializeJsonLd(sportsEventJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={serializeJsonLd(breadcrumbJsonLd)}
    slot="head"
  />

  <CombatHero
    boxer1={boxer1}
    boxer2={boxer2}
    boxer1Hero={boxer1Hero}
    boxer2Hero={boxer2Hero}
    video={battleVideo}
  />

  <div class="combat-detail-content">
    <picture aria-hidden="true" class="combat-detail-bg">
      <source
        type="image/avif"
        srcset="https://cdn.infolavelada.com/hero-bg/background-1280.avif 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.avif 2048w, https://cdn.infolavelada.com/hero-bg/background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
        sizes="100vw"
      />
      <img
        src="https://cdn.infolavelada.com/hero-bg/background.webp"
        srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
        sizes="100vw"
        alt=""
        role="presentation"
        class="combat-detail-bg-img"
        loading="lazy"
        decoding="async"
      />
    </picture>
    <div aria-hidden="true" class="combat-detail-bg-veil"></div>

    <CombatStatsSection
      boxer1={boxer1}
      boxer2={boxer2}
      boxer1Select={boxer1Select}
      boxer2Select={boxer2Select}
      stats={stats}
    />

    <section class="combat-prediction" aria-labelledby="combat-prediction-title">
      <h2 id="combat-prediction-title" class="combat-prediction-title font-cinzel">
        ¿Quién ganará?
      </h2>
      <LivePrediction
        class="w-full max-w-3xl"
        battleId={battle.id}
        boxerA={{ id: boxer1.id, name: boxer1.name }}
        boxerB={{ id: boxer2.id, name: boxer2.name }}
      />
    </section>

    <CombatFaceToFaceVideoSection
      title={`${battle.title} | Cara a cara`}
      videoUrl={battle.faceToFaceVideoUrl}
    />
  </div>

  <div class="sponsors-and-footer">
    <Sponsors />
    <Footer />
  </div>
</Layout>

<style>
  .combat-detail-content {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-theme-midnight);
  }

  /* Costura definida entre la cabecera (hero) y el contenido: una fina
     línea dorada con un leve halo que marca con claridad dónde acaba el
     header y empieza la página, mejorando el contraste entre ambos. */
  .combat-detail-content::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    z-index: 3;
    height: 6rem;
    pointer-events: none;
    background:
      linear-gradient(
          to right,
          transparent 0%,
          color-mix(in srgb, var(--color-theme-gold) 60%, transparent) 50%,
          transparent 100%
        )
        top / 100% 1px no-repeat,
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-theme-gold) 12%, transparent),
        transparent 70%
      );
  }

  .combat-detail-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .combat-detail-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.42;
  }

  .combat-detail-bg-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(10, 16, 36, 0.92) 0%, rgba(10, 16, 36, 0.78) 34%, #050816 100%),
      radial-gradient(
        ellipse 62% 38% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 16%, transparent),
        transparent 68%
      );
  }

  .combat-prediction {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.4rem;
    /* Padding horizontal igual al de la sección de stats (px-4 sm:px-6) para
       que el ancho del bloque coincida con el de arriba. */
    padding: 0.5rem 1rem 3.5rem;
  }

  @media (min-width: 640px) {
    .combat-prediction {
      padding-inline: 1.5rem;
    }
  }

  .combat-prediction-title {
    font-size: clamp(1.1rem, 0.9rem + 1vw, 1.6rem);
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-align: center;
    color: var(--color-theme-cream);
    text-shadow: 0 2px 18px color-mix(in srgb, var(--color-theme-gold) 30%, transparent);
  }

  .sponsors-and-footer {
    position: relative;
    z-index: 2;
    background: var(--color-theme-midnight);
  }
</style>
