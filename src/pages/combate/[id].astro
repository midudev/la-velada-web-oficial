---
import CombatFaceToFaceVideoSection from '@/components/combat/CombatFaceToFaceVideoSection.astro'
import CombatHero from '@/components/combat/CombatHero.astro'
import CombatStatsSection from '@/components/combat/CombatStatsSection.astro'
import { battlesById } from '@/consts/battles'
import { EVENT_DATE_TIME } from '@/consts/event'
import {
  BOXERS_BY_ID,
  COUNTRY_NAMES,
  getBoxerHeroImages,
  getBoxerSelectImages,
  type Boxer,
} from '@/consts/boxers'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'

const { id = '' } = Astro.params
const battle = battlesById[id]

if (!battle) return Astro.redirect('/404')

const SITE_URL = 'https://www.infolavelada.com'
const [boxer1Id, boxer2Id] = battle.boxerIds
const boxer1 = BOXERS_BY_ID[boxer1Id]
const boxer2 = BOXERS_BY_ID[boxer2Id]
const battleVideo = battle.video
const boxer1Hero = getBoxerHeroImages(boxer1)
const boxer2Hero = getBoxerHeroImages(boxer2)
const boxer1Select = getBoxerSelectImages(boxer1)
const boxer2Select = getBoxerSelectImages(boxer2)

const title = `${battle.title} — Combate ${String(battle.number).padStart(2, '0')} de La Velada del Año VI`
const description = `Toda la información del combate ${battle.number} de La Velada del Año VI: ${boxer1.name} contra ${boxer2.name}. Fecha, horario y detalles en Sevilla.`
const canonical = `${SITE_URL}${battle.url}`

const fmt = {
  weight: (kg?: number | null) => (kg != null ? `${kg} kg` : '—'),
  height: (cm?: number | null) => (cm != null ? `${(cm / 100).toFixed(2)} m` : '—'),
  age: (age?: number | null) => (age != null ? `${age} años` : '—'),
  guard: (guard?: Boxer['guard']) =>
    guard === 'Derecha' ? 'Diestra' : guard === 'Izquierda' ? 'Izquierda' : '—',
}

const stats = [
  {
    label: 'País',
    a: COUNTRY_NAMES[boxer1.country] ?? boxer1.country,
    b: COUNTRY_NAMES[boxer2.country] ?? boxer2.country,
    flagA: boxer1.country,
    flagB: boxer2.country,
  },
  {
    label: 'Peso pactado',
    a: fmt.weight(boxer1.fightWeightKg ?? boxer1.weightKg),
    b: fmt.weight(boxer2.fightWeightKg ?? boxer2.weightKg),
  },
  {
    label: 'Altura',
    a: fmt.height(boxer1.heightCm),
    b: fmt.height(boxer2.heightCm),
  },
  {
    label: 'Edad',
    a: fmt.age(boxer1.age),
    b: fmt.age(boxer2.age),
  },
  {
    label: 'Guardia',
    a: fmt.guard(boxer1.guard),
    b: fmt.guard(boxer2.guard),
  },
]

const sportsEventJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SportsEvent',
  name: `${battle.title} — La Velada del Año VI`,
  description,
  url: canonical,
  sport: 'Boxing',
  startDate: EVENT_DATE_TIME,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/MixedEventAttendanceMode',
  superEvent: { '@type': 'SportsEvent', name: 'La Velada del Año VI', url: `${SITE_URL}/` },
  location: {
    '@type': 'Place',
    name: 'Estadio de La Cartuja',
    address: {
      '@type': 'PostalAddress',
      addressLocality: 'Sevilla',
      addressRegion: 'Andalucía',
      addressCountry: 'ES',
    },
  },
  organizer: { '@type': 'Person', name: 'Ibai Llanos' },
  competitor: [
    {
      '@type': 'Person',
      name: boxer1.name,
      url: `${SITE_URL}/boxeadores/${boxer1.id}`,
      image: `${SITE_URL}/photos/${boxer1.id}/01.webp`,
    },
    {
      '@type': 'Person',
      name: boxer2.name,
      url: `${SITE_URL}/boxeadores/${boxer2.id}`,
      image: `${SITE_URL}/photos/${boxer2.id}/01.webp`,
    },
  ],
}

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: battle.title, item: canonical },
  ],
}
---

<Layout title={title} description={description} canonical={canonical} showHeader={true}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(sportsEventJsonLd)}
    slot="head"
  />
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
  />

  <CombatHero
    boxer1={boxer1}
    boxer2={boxer2}
    boxer1Hero={boxer1Hero}
    boxer2Hero={boxer2Hero}
    video={battleVideo}
  />

  <div class="combat-detail-content">
    <picture aria-hidden="true" class="combat-detail-bg">
      <source
        type="image/avif"
        srcset="/background-1280.avif 1280w, /background-2048.avif 2048w, /background.avif 3840w"
        sizes="100vw"
      />
      <source
        type="image/webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
      />
      <img
        src="/background.webp"
        srcset="/background-1280.webp 1280w, /background-2048.webp 2048w, /background.webp 3840w"
        sizes="100vw"
        alt=""
        role="presentation"
        class="combat-detail-bg-img"
        loading="lazy"
        decoding="async"
      />
    </picture>
    <div aria-hidden="true" class="combat-detail-bg-veil"></div>

    <CombatStatsSection
      boxer1={boxer1}
      boxer2={boxer2}
      boxer1Select={boxer1Select}
      boxer2Select={boxer2Select}
      stats={stats}
    />
    <CombatFaceToFaceVideoSection
      title={`${battle.title} | Cara a cara`}
      videoUrl={battle.faceToFaceVideoUrl}
    />
  </div>

  <div class="sponsors-and-footer">
    <Sponsors />
    <Footer />
  </div>
</Layout>

<style>
  .combat-detail-content {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: var(--color-theme-midnight);
  }

  /* Costura definida entre la cabecera (hero) y el contenido: una fina
     línea dorada con un leve halo que marca con claridad dónde acaba el
     header y empieza la página, mejorando el contraste entre ambos. */
  .combat-detail-content::before {
    content: '';
    position: absolute;
    inset: 0 0 auto;
    z-index: 3;
    height: 6rem;
    pointer-events: none;
    background:
      linear-gradient(
          to right,
          transparent 0%,
          color-mix(in srgb, var(--color-theme-gold) 60%, transparent) 50%,
          transparent 100%
        )
        top / 100% 1px no-repeat,
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-theme-gold) 12%, transparent),
        transparent 70%
      );
  }

  .combat-detail-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .combat-detail-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.42;
  }

  .combat-detail-bg-veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(10, 16, 36, 0.92) 0%, rgba(10, 16, 36, 0.78) 34%, #050816 100%),
      radial-gradient(
        ellipse 62% 38% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 16%, transparent),
        transparent 68%
      );
  }

  .sponsors-and-footer {
    position: relative;
    z-index: 2;
    background: var(--color-theme-midnight);
  }
</style>
