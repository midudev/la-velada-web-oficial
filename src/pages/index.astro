---
import Layout from '@/layouts/Layout.astro'
import Header from '@/sections/Header.astro'
import Hero from '@/sections/Hero.astro'
import Videos from '@/sections/Videos.astro'
import Podcast from '@/sections/Podcast.astro'
import Sponsors from '@/sections/Sponsors.astro'
import Footer from '@/sections/Footer.astro'

const title = 'La Velada del Año VI - Evento de boxeo de Ibai Llanos'
const description =
  'La Velada del Año VI. 25 de julio, 20:00h CET. Evento de boxeo entre streamers organizado por Ibai Llanos.'
const canonical = 'https://www.infolavelada.com/'

const EVENT_DATE = new Date('2026-07-25T20:00:00+02:00')
const timestamp = EVENT_DATE.getTime()

export const prerender = true
---

<Layout title={title} description={description} canonical={canonical}>
  <Header />
  <Hero />
  <Sponsors />
  <Videos />
  <Podcast />
  <Footer />
</Layout>
