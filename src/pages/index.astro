---
import { HOME_FAQS } from '@/consts/home-faq'
import { HOME_CANONICAL, HOME_DESCRIPTION, HOME_TITLE } from '@/consts/home-seo'
import Layout from '@/layouts/Layout.astro'
import EventDetails from '@/sections/EventDetails.astro'
import FAQ from '@/sections/FAQ.astro'
import Footer from '@/sections/Footer.astro'
import HeroPreload from '@/sections/HeroPreload.astro'
import Hero from '@/sections/Hero.astro'
import HomeStructuredData from '@/sections/HomeStructuredData.astro'
import Map from '@/sections/Map.astro'
import Podcast from '@/sections/Podcast.astro'
import Predictions from '@/sections/Predictions.astro'
import Schedules from '@/sections/Schedules.astro'
import Sponsors from '@/sections/Sponsors.astro'
import Timetable from '@/sections/Timetable.astro'
import Videos from '@/sections/Videos.astro'

export const prerender = true
---

<Layout title={HOME_TITLE} description={HOME_DESCRIPTION} canonical={HOME_CANONICAL}>
  <HomeStructuredData slot="head" />
  <HeroPreload slot="head" />

  <Hero />
  <Predictions />
  <Sponsors />
  <Videos />
  <Podcast />
  <EventDetails />
  <Map />
  <Timetable />
  <Schedules />
  <FAQ faqs={HOME_FAQS} />
  <Footer />
</Layout>
