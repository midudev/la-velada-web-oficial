    transition: all 400ms ease;
  }

  .panel-corner-tl, .card-corner-tl { top: 8px; left: 8px; border-right-width: 0; border-bottom-width: 0; }
  .panel-corner-tr, .card-corner-tr { top: 8px; right: 8px; border-left-width: 0; border-bottom-width: 0; }
  .panel-corner-bl, .card-corner-bl { bottom: 8px; left: 8px; border-right-width: 0; border-top-width: 0; }
  .panel-corner-br, .card-corner-br { bottom: 8px; right: 8px; border-left-width: 0; border-top-width: 0; }

  .combat-prediction-card:hover .card-corner {
    width: 20px;
    height: 20px;
    border-color: var(--color-theme-gold);
  }

  /* Estilos interactivos de voto */
  .btn-vote {
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
    cursor: pointer;
  }

  .btn-vote:not(:disabled):hover {
    transform: scale(1.03) translateY(-1px);
    box-shadow: 0 5px 15px rgba(255, 255, 255, 0.05);
  }

  .btn-vote:not(:disabled):active {
    transform: scale(0.97);
  }

  /* Animación de carga de cards */
  .combat-prediction-card {
    will-change: transform, border-color;
  }
</style>
