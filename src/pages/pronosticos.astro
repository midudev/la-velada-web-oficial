---
import AuthButton from '@/components/AuthButton.astro'
import PredictionFight from '@/components/PredictionFight.astro'
import PredictionHero from '@/components/PredictionHero.astro'
import PredictionVoteController from '@/components/PredictionVoteController.astro'
import PredictionsBackground from '@/components/PredictionsBackground.astro'
import { createPredictionBattles } from '@/consts/predictions'
import Layout from '@/layouts/Layout.astro'
import { getAllPredictions, getUserVotes } from '@/lib/predictions'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'

export const prerender = false

const title = 'Pronósticos - La Velada del Año VI'
const description =
  'Pronostica los ganadores de los combates de La Velada del Año VI con una interfaz de votación por barras.'
const canonical = 'https://www.infolavelada.com/pronosticos'
const user = Astro.locals.user

let storedPredictions: Awaited<ReturnType<typeof getAllPredictions>> = []
let storedUserVotes: Awaited<ReturnType<typeof getUserVotes>> = []

try {
  storedPredictions = await getAllPredictions()
} catch (error) {
  console.error('Error al cargar predicciones:', error)
}

if (user?.id) {
  try {
    storedUserVotes = await getUserVotes(user.id)
  } catch (error) {
    console.error('Error al cargar votos del usuario:', error)
  }
}

const predictionBattles = createPredictionBattles(storedPredictions)
const totalVotes = predictionBattles.reduce((total, prediction) => total + prediction.totalVotes, 0)
const closeBattles = predictionBattles.filter(({ isClose }) => isClose).length
const userVotesByCombat = Object.fromEntries(
  storedUserVotes.map((vote) => [vote.combat_id, vote.fighter_id]),
)
---

<Layout title={title} description={description} canonical={canonical} robots="noindex, nofollow">
  <section
    class="predictions-page relative isolate w-full overflow-x-clip bg-theme-midnight px-4 pt-20 pb-20 text-theme-cream sm:px-6 sm:pt-24 sm:pb-24"
    aria-labelledby="predictions-title"
  >
    <PredictionsBackground />

    <div class="mx-auto flex w-full max-w-7xl flex-col">
      <PredictionHero
        totalCombats={predictionBattles.length}
        totalVotes={totalVotes}
        closeBattles={closeBattles}
      />

      <div id="predictions-auth" class="mt-6 flex justify-center" data-predictions-auth>
        <AuthButton user={user} />
      </div>

      <ol class="prediction-list mt-14 grid gap-5 sm:mt-16 md:gap-6" role="list" data-prediction-list>
        {
          predictionBattles
            .slice()
            .reverse()
            .map((prediction) => (
              <PredictionFight
                prediction={prediction}
                selectedBoxerId={userVotesByCombat[prediction.battle.id]}
              />
            ))
        }
      </ol>
    </div>
  </section>

  <PredictionVoteController isLoggedIn={Boolean(user)} userVotes={userVotesByCombat} user={user} />
  <Sponsors />
  <Footer />
</Layout>

<style>
  .predictions-page {
    min-height: 100svh;
  }
</style>
