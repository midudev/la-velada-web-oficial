---
import { Image } from 'astro:assets'
import SectionDivider from '@/components/SectionDivider.astro'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'
import { ARTISTS } from '@/consts/artists'
import { serializeJsonLd } from '@/utils/serialize-json-ld'

const SITE_URL = 'https://www.infolavelada.com'
const title = 'Artistas | La Velada del Año VI'
const description =
    'El cartel musical de La Velada del Año VI, el evento de boxeo de Ibai Llanos en Sevilla el 25 de julio de 2026: Yandel, Juanes, Lucho RK & La Pantera, Bad Gyal y Anuel AA y más artistas sorpresa.'
const canonical = `${SITE_URL}/artistas`

export const prerender = true

const breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Artistas', item: canonical },
    ],
}
---

<Layout title={title} description={description} canonical={canonical}>
    <script
    type="application/ld+json"
    is:inline
    set:html={serializeJsonLd(breadcrumbJsonLd)}
    slot="head"
    />

    <section
    class="relative isolate min-h-screen w-full overflow-x-clip bg-theme-midnight px-3 pt-24 pb-20 text-theme-cream sm:px-6 sm:pt-32 sm:pb-24 md:pt-36"
    >
    <div
      aria-hidden="true"
      class="absolute inset-0 -z-20 bg-[radial-gradient(ellipse_70%_45%_at_50%_0%,color-mix(in_srgb,var(--color-theme-gold)_16%,transparent)_0%,transparent_65%),linear-gradient(180deg,var(--color-theme-midnight)_0%,#050816_100%)]"
    ></div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(rgba(199,168,107,0.05)_1px,transparent_1px)] bg-[length:22px_22px] [mask-image:radial-gradient(ellipse_at_center,black_30%,transparent_85%)]"
    ></div>

    <div class="mx-auto w-full max-w-7xl">
        <header class="flex flex-col items-center text-center">
        <SectionDivider class="mb-7 w-full sm:mb-10" />

        <h1
            class="mb-3 animate-fade-in-up font-cinzel text-3xl font-bold tracking-[0.12em] text-theme-cream sm:text-4xl sm:tracking-[0.18em] md:text-6xl"
        >
            ARTISTAS
        </h1>
        <p
            class="relative mb-5 animate-fade-in-up rounded-full border border-theme-gold/45 bg-theme-gold/8 px-[1.1rem] py-[0.4rem] font-cinzel text-xs font-bold tracking-[0.3em] text-theme-gold uppercase shadow-[0_0_24px_color-mix(in_srgb,var(--color-theme-gold)_18%,transparent)] animate-delay-200 sm:text-sm"
        >
            Cartel confirmado
        </p>
        <p
            class="mb-12 max-w-xl animate-fade-in-up font-cinzel text-xs font-medium tracking-[0.16em] text-balance text-white/55 animate-delay-300 sm:mb-16 sm:text-sm sm:tracking-[0.25em]"
        >
            El cartel musical de La Velada del Año VI
        </p>
        </header>

        <ul
        class="artists-grid mx-auto flex w-full max-w-4xl flex-wrap justify-center gap-3 sm:gap-4 lg:gap-5"
        role="list"
        aria-label="Artistas confirmados"
        >
        {
            ARTISTS.map((artist, index) => (
            <li
                class="artist-card-wrap animate-fade-in-up basis-[calc(50%-0.375rem)] transition-[opacity,filter] duration-[400ms] sm:basis-[calc(33.333%-0.667rem)] lg:basis-[calc(33.333%-0.834rem)]"
                style={`animation-delay: ${index * 45}ms`}
            >
                <a
                    href={`/artistas/${artist.id}`}
                    aria-label={`Ver la ficha de ${artist.name}`}
                    class="group relative block aspect-[4/5] w-full outline-offset-4 focus-visible:outline-2 focus-visible:outline-theme-gold sm:aspect-[3/4]"
                >
                <span
                    aria-hidden="true"
                    class="absolute inset-0 grid [backface-visibility:hidden] place-items-end overflow-hidden rounded-md bg-[linear-gradient(180deg,#0c1330_0%,#060a1d_100%)] shadow-[0_0_0_1px_color-mix(in_srgb,var(--color-theme-gold)_22%,transparent),0_12px_30px_rgba(0,0,0,0.4)] transition-shadow duration-[400ms] group-hover:shadow-[0_0_0_1px_color-mix(in_srgb,var(--color-theme-gold)_70%,transparent),0_28px_60px_rgba(0,0,0,0.6),0_0_30px_color-mix(in_srgb,var(--color-theme-gold)_35%,transparent)]"
                >
                    <Image
                    src={artist.image}
                    alt=""
                    loading="lazy"
                    decoding="async"
                    class="absolute inset-0 size-full object-cover"
                    />
                    <span
                      class="pointer-events-none absolute inset-0 z-[1] bg-[linear-gradient(180deg,transparent_30%,rgba(3,5,15,0.55)_55%,rgba(3,5,15,0.88)_78%,rgba(3,5,15,0.97)_100%)]"
                    />
                    <span class="relative z-[2] w-full px-2 pb-2.5 text-center font-cinzel text-[0.65rem] font-bold tracking-[0.08em] text-theme-cream [text-shadow:0_1px_3px_rgba(0,0,0,0.9),0_0_10px_rgba(0,0,0,0.6)] sm:pb-3 sm:text-xs sm:tracking-[0.1em]">
                    {artist.name}
                    </span>
                    <span class="absolute top-2 left-2 z-[3] size-3 border-[1.5px] border-r-0 border-b-0 border-theme-gold/65 transition-[width,height,border-color] duration-[400ms] group-hover:size-6 group-hover:border-theme-gold sm:top-2.5 sm:left-2.5 sm:size-4" />
                    <span class="absolute top-2 right-2 z-[3] size-3 border-[1.5px] border-b-0 border-l-0 border-theme-gold/65 transition-[width,height,border-color] duration-[400ms] group-hover:size-6 group-hover:border-theme-gold sm:top-2.5 sm:right-2.5 sm:size-4" />
                    <span class="absolute bottom-2 left-2 z-[3] size-3 border-[1.5px] border-t-0 border-r-0 border-theme-gold/65 transition-[width,height,border-color] duration-[400ms] group-hover:size-6 group-hover:border-theme-gold sm:bottom-2.5 sm:left-2.5 sm:size-4" />
                    <span class="absolute right-2 bottom-2 z-[3] size-3 border-[1.5px] border-t-0 border-l-0 border-theme-gold/65 transition-[width,height,border-color] duration-[400ms] group-hover:size-6 group-hover:border-theme-gold sm:right-2.5 sm:bottom-2.5 sm:size-4" />
                </span>
                </a>
            </li>
            ))
        }
        </ul>
    </div>
    </section>

    <Sponsors />
    <Footer />
</Layout>

<style>
/*
  Único bloque que se queda en CSS: atenuar el resto de tarjetas cuando se
  pasa el ratón por una de ellas. Requiere `:has()` apuntando a un hermano
  desde el contenedor padre, algo que las variantes de Tailwind no cubren
  de forma fiable (no hay un equivalente directo a "atenúa mis hermanos
  menos a mí" sin arrastrar problemas de orden/especificidad).
*/
@media (hover: hover) and (pointer: fine) {
  .artists-grid:has(.artist-card-wrap:hover) > .artist-card-wrap {
    opacity: 0.45;
    filter: saturate(0.6) brightness(0.72);
  }

  .artists-grid:has(.artist-card-wrap:hover) > .artist-card-wrap:hover {
    opacity: 1;
    filter: saturate(1.08) brightness(1.05);
  }
}
</style>
