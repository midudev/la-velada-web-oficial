---
import SectionDivider from '@/components/SectionDivider.astro'
import Layout from '@/layouts/Layout.astro'
import Footer from '@/sections/Footer.astro'
import Sponsors from '@/sections/Sponsors.astro'

const SITE_URL = 'https://www.infolavelada.com'
const title = 'Artistas | La Velada del Año VI'
const description =
    'El cartel musical de La Velada del Año VI, el evento de boxeo de Ibai Llanos en Sevilla el 25 de julio de 2026, se anunciará muy pronto.'
const canonical = `${SITE_URL}/artistas`

export const prerender = true

// El cartel de artistas todavía no se ha anunciado: mostramos cards
// de marcador de posición que no revelan ningún nombre ni cantidad real.
const PLACEHOLDER_COUNT = 8

const breadcrumbJsonLd = {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE_URL}/` },
    { '@type': 'ListItem', position: 2, name: 'Artistas', item: canonical },
    ],
}
---

<Layout title={title} description={description} canonical={canonical}>
    <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbJsonLd)}
    slot="head"
    />

    <section
    class="artists-page relative isolate w-full overflow-x-clip bg-theme-midnight px-3 pt-24 pb-20 text-theme-cream sm:px-6 sm:pt-32 sm:pb-24 md:pt-36"
    >
    <div aria-hidden="true" class="artists-bg absolute inset-0 -z-20"></div>
    <div aria-hidden="true" class="artists-grain pointer-events-none absolute inset-0 -z-10"></div>

    <div class="mx-auto w-full max-w-7xl">
        <header class="flex flex-col items-center text-center">
        <SectionDivider class="mb-7 w-full sm:mb-10" />

        <h1
            class="mb-3 animate-fade-in-up font-cinzel text-3xl font-bold tracking-[0.12em] text-theme-cream sm:text-4xl sm:tracking-[0.18em] md:text-6xl"
        >
            ARTISTAS
        </h1>
        <p
            class="artists-soon-badge mb-5 animate-fade-in-up font-cinzel text-xs font-bold tracking-[0.3em] text-theme-gold uppercase animate-delay-200 sm:text-sm"
        >
            Muy pronto
        </p>
        <p
            class="mb-12 max-w-xl animate-fade-in-up font-cinzel text-xs font-medium tracking-[0.16em] text-balance text-white/55 animate-delay-300 sm:mb-16 sm:text-sm sm:tracking-[0.25em]"
        >
            El cartel musical de La Velada del Año VI se anunciará muy pronto
        </p>
        </header>

        <ul
        class="artists-grid grid w-full grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 lg:gap-5"
        role="list"
        aria-label="Artistas por anunciar"
        >
        {
            Array.from({ length: PLACEHOLDER_COUNT }).map((_, index) => (
            <li
                class="artist-card-wrap animate-fade-in-up"
                style={`animation-delay: ${index * 45}ms; --idx: ${index}`}
            >
                <div class="artist-flip relative block w-full">
                <span
                    aria-hidden="true"
                    class="artist-face artist-face-front absolute inset-0 grid place-items-center overflow-hidden rounded-md"
                >
                    <span class="artist-card-bg-gold pointer-events-none absolute inset-0" />
                    <span class="artist-front-mark font-cinzel">?</span>
                    <span class="artist-front-sheen pointer-events-none" />
                    <span class="artist-card-corner artist-card-corner-tl" />
                    <span class="artist-card-corner artist-card-corner-tr" />
                    <span class="artist-card-corner artist-card-corner-bl" />
                    <span class="artist-card-corner artist-card-corner-br" />
                    <span class="artist-front-flicker pointer-events-none" />
                </span>
                </div>
            </li>
            ))
        }
        </ul>
    </div>
    </section>

    <Sponsors />
    <Footer />
</Layout>

<style>
.artists-page {
    min-height: 100svh;
}

.artists-bg {
    background:
        radial-gradient(
        ellipse 70% 45% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 16%, transparent) 0%,
        transparent 65%
        ),
        linear-gradient(180deg, var(--color-theme-midnight) 0%, #050816 100%);
}

.artists-grain {
    background-image: radial-gradient(rgba(199, 168, 107, 0.05) 1px, transparent 1px);
    background-size: 22px 22px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 85%);
}

.artists-soon-badge {
    position: relative;
    padding: 0.4rem 1.1rem;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-theme-gold) 8%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
}

.artist-card-wrap {
    transition:
        opacity 400ms ease,
        filter 400ms ease;
}

.artist-flip {
    aspect-ratio: 3 / 4;
}

.artist-face {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
}

.artist-face-front {
    background: linear-gradient(180deg, #0c1330 0%, #060a1d 100%);
    box-shadow:
        0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
        0 12px 30px rgba(0, 0, 0, 0.4);
    transition: box-shadow 400ms ease;
}

.artist-front-mark {
    position: relative;
    z-index: 2;
    font-weight: 700;
    font-size: clamp(2.4rem, 1.4rem + 5vw, 4rem);
    line-height: 1;
    color: color-mix(in srgb, var(--color-theme-gold) 80%, var(--color-theme-cream));
    text-shadow: 0 0 22px color-mix(in srgb, var(--color-theme-gold) 42%, transparent);
}

.artist-front-sheen {
    position: absolute;
    inset: 0;
    z-index: 3;
    background: linear-gradient(
        105deg,
        transparent 38%,
        color-mix(in srgb, var(--color-theme-gold) 30%, transparent) 50%,
        transparent 62%
    );
    transform: translateX(-120%) rotate(8deg);
    animation: artistFrontSheen 6s ease-in-out infinite;
    animation-delay: calc(var(--idx, 0) * 600ms);
}

@keyframes artistCardFlicker {
    0%, 100% { opacity: 0; }
    2% { opacity: 0.38; }
    4% { opacity: 0; }
    6% { opacity: 0.22; }
    8% { opacity: 0; }
    52% { opacity: 0; }
    54% { opacity: 0.34; }
    56% { opacity: 0; }
    58% { opacity: 0.18; }
    60% { opacity: 0; }
}
@keyframes artistFrontSheen {
    0% { transform: translateX(-120%) rotate(8deg); opacity: 0; }
    6% { opacity: 0.5; }
    20% { transform: translateX(120%) rotate(8deg); opacity: 0; }
    100% { transform: translateX(120%) rotate(8deg); opacity: 0; }
}

.artist-flip:hover .artist-face-front {
    box-shadow:
        0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent),
        0 28px 60px rgba(0, 0, 0, 0.6),
        0 0 30px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
}

.artist-front-flicker {
    position: absolute;
    inset: 0;
    z-index: 5;
    background: #060a1d;
    opacity: 0;
    animation: artistCardFlicker 5s ease-in-out infinite;
    animation-delay: calc(var(--idx, 0) * -0.7s);
}

.artist-flip:hover .artist-face-front .artist-card-bg-gold {
    opacity: 1;
}

.artist-flip:hover .artist-front-flicker {
    animation: none;
    opacity: 0;
}

.artist-flip:hover .artist-face-front .artist-card-corner {
    width: 24px;
    height: 24px;
    border-color: var(--color-theme-gold);
}

.artist-card-bg-gold {
    background: radial-gradient(
        ellipse 90% 65% at 50% 38%,
        color-mix(in srgb, var(--color-theme-gold) 26%, transparent) 0%,
        transparent 70%
    );
    opacity: 0.5;
    transition: opacity 500ms ease;
}

.artist-card-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-style: solid;
    border-width: 1.5px;
    border-color: color-mix(in srgb, var(--color-theme-gold) 65%, transparent);
    transition:
    width 400ms ease,
    height 400ms ease,
    border-color 400ms ease;
}

.artist-card-corner-tl {
    top: 10px;
    left: 10px;
    border-right-width: 0;
    border-bottom-width: 0;
}
.artist-card-corner-tr {
    top: 10px;
    right: 10px;
    border-left-width: 0;
    border-bottom-width: 0;
}
.artist-card-corner-bl {
    bottom: 10px;
    left: 10px;
    border-right-width: 0;
    border-top-width: 0;
}
.artist-card-corner-br {
    bottom: 10px;
    right: 10px;
    border-left-width: 0;
    border-top-width: 0;
}

@media (max-width: 639px) {
    .artist-flip {
    aspect-ratio: 4 / 5;
    }

.artist-card-corner {
    width: 12px;
    height: 12px;
}
.artist-card-corner-tl {
    top: 8px;
    left: 8px;
}
.artist-card-corner-tr {
    top: 8px;
    right: 8px;
}
.artist-card-corner-bl {
    bottom: 8px;
    left: 8px;
}
.artist-card-corner-br {
    bottom: 8px;
    right: 8px;
}
}

@media (hover: hover) and (pointer: fine) {
.artists-grid:has(.artist-card-wrap:hover) > .artist-card-wrap {
    opacity: 0.45;
    filter: saturate(0.6) brightness(0.72);
}

.artists-grid:has(.artist-card-wrap:hover) > .artist-card-wrap:hover {
    opacity: 1;
    filter: saturate(1.08) brightness(1.05);
}
}

@media (prefers-reduced-motion: reduce) {
.artist-front-sheen,
.artist-front-flicker {
    animation: none !important;
}
.artist-front-flicker {
    display: none;
}
}
</style>
