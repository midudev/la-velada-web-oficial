---
import { ClientRouter } from 'astro:transitions'
import Analytics from '@vercel/analytics/astro'

import '@/styles/global.css'

import { fixedTitle } from '@/consts/pageTitles'

const SITE_URL = 'https://www.infolavelada.com'
const DEFAULT_OG_IMAGE = `${SITE_URL}/og.jpg`
const DEFAULT_OG_ALT = 'La Velada del Año VI — Evento de boxeo organizado por Ibai Llanos'

interface Props {
  title: string
  description?: string
  canonical?: string
  robots?: string
  ogImage?: string
  ogImageAlt?: string
  ogUrl?: string
  ogType?: 'website' | 'article' | 'profile'
}

const {
  title = fixedTitle,
  description = 'Evento de boxeo aficionado entre streamers y creadores de contenido, organizado por Ibai Llanos',
  canonical,
  robots,
  ogImage = DEFAULT_OG_IMAGE,
  ogImageAlt = DEFAULT_OG_ALT,
  ogUrl = canonical ?? SITE_URL,
  ogType = 'website',
} = Astro.props
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      {title}
    </title>

    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <link
      rel="preload"
      href="/fonts/cinzel-regular.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
      fetchpriority="low"
    />
    <link
      rel="preload"
      as="image"
      href="/background.avif"
      imagesrcset="/background-1280.avif 1280w, /background-2048.avif 2048w, /background.avif 3840w"
      imagesizes="100vw"
      type="image/avif"
      fetchpriority="high"
    />
    <meta name="description" content={description} />
    <meta name="author" content="Ibai Llanos" />
    <meta name="theme-color" content="#0a1024" />
    {canonical && <link rel="canonical" href={canonical} />}
    {robots && <meta name="robots" content={robots} />}

    <meta property="og:url" content={ogUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="La Velada del Año VI" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@infoLaVelada" />
    <meta name="twitter:creator" content="@ibaiLlanos" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Event",
        "name": "La Velada del Año VI",
        "description": "Evento de boxeo aficionado entre streamers y creadores de contenido, organizado por Ibai Llanos",
        "image": "https://www.infolavelada.com/og.jpg",
        "startDate": "2026-03-09T19:00:00+01:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/MixedEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Teatro Victoria",
          "address": {
            "@type": "PostalAddress",
            "addressLocality": "Barcelona",
            "addressRegion": "Cataluña",
            "addressCountry": "ES"
          }
        },
        "organizer": {
          "@type": "Person",
          "name": "Ibai Llanos"
        },
        "performer": {
          "@type": "PerformingGroup",
          "name": "Creadores de contenido"
        }
      }
    </script>
    <slot name="head" />
    <ClientRouter />
    <Analytics />
    <script>
      type AstroNavigationEvent = Event & {
        from: URL
        to: URL
      }

      type AstroBeforeSwapEvent = AstroNavigationEvent & {
        newDocument: Document
      }

      const SKIP_BOXERS_ENTER_ATTR = 'data-skip-boxers-enter'
      const BOXERS_INDEX_PATH = '/boxeadores'
      const BOXER_DETAIL_PATH_RE = /^\/boxeadores\/[^/]+$/

      const getNormalizedPathname = (url: URL | string) => {
        const pathname =
          url instanceof URL ? url.pathname : new URL(url, window.location.href).pathname
        return pathname === '/' ? pathname : pathname.replace(/\/$/, '')
      }

      const isReturningFromBoxerDetail = (event: AstroNavigationEvent) => {
        const fromPath = getNormalizedPathname(event.from)
        const toPath = getNormalizedPathname(event.to)

        return toPath === BOXERS_INDEX_PATH && BOXER_DETAIL_PATH_RE.test(fromPath)
      }

      document.addEventListener('astro:before-swap', (event) => {
        const transitionEvent = event as AstroBeforeSwapEvent
        const shouldSkipBoxersEnter = isReturningFromBoxerDetail(transitionEvent)

        transitionEvent.newDocument.documentElement.toggleAttribute(
          SKIP_BOXERS_ENTER_ATTR,
          shouldSkipBoxersEnter,
        )
      })
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-white focus:px-4 focus:py-2 focus:text-black focus:outline-none">
      Saltar al contenido principal
    </a>
    <main id="main-content">
      <slot />
    </main>
  </body>
</html>
