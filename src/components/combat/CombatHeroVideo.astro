---
import type { BattleVideoSources } from '@/consts/battle-videos'

interface Props {
  video: BattleVideoSources | null
}

const { video } = Astro.props
---

<div aria-hidden="true" class="combat-hero-video-wrap">
  <picture class="combat-hero-video-fallback">
    <source
      type="image/avif"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.avif 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.avif 2048w, https://cdn.infolavelada.com/hero-bg/background.avif 3840w"
      sizes="100vw"
    />
    <source
      type="image/webp"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
      sizes="100vw"
    />
    <img
      src="https://cdn.infolavelada.com/hero-bg/background.webp"
      srcset="https://cdn.infolavelada.com/hero-bg/background-1280.webp 1280w, https://cdn.infolavelada.com/hero-bg/background-2048.webp 2048w, https://cdn.infolavelada.com/hero-bg/background.webp 3840w"
      sizes="100vw"
      alt=""
      role="presentation"
      class="combat-hero-video-fallback-img"
      decoding="async"
    />
  </picture>

  {
    video && (
      <video
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        poster="https://cdn.infolavelada.com/hero-bg/background.webp"
        class="combat-hero-video"
      >
        <source src={video.desktop.webm} type="video/webm" media="(min-width: 768px)" />
        <source src={video.desktop.mp4} type="video/mp4" media="(min-width: 768px)" />
        <source src={video.mobile.webm} type="video/webm" />
        <source src={video.mobile.mp4} type="video/mp4" />
      </video>
    )
  }
</div>

<script>
  // Con el ClientRouter de Astro, el <video> entra en el DOM por swap (no por
  // parseo de la página), y el navegador no respeta el atributo `autoplay` en
  // ese caso. Lo arrancamos a mano en cada navegación.
  function playCombatHeroVideo() {
    const video = document.querySelector<HTMLVideoElement>('.combat-hero-video')
    if (!video) return

    // `muted` debe estar activo para que el autoplay sea permitido; el atributo
    // a veces no se refleja a la propiedad tras un swap, así que lo forzamos.
    video.muted = true

    const playback = video.play()
    if (!playback) return

    playback.catch(() => {
      // Tras un swap, las fuentes pueden quedar sin enganchar: recargamos y
      // reintentamos una sola vez cuando el navegador tenga datos.
      video.addEventListener(
        'loadeddata',
        () => {
          const retry = video.play()
          if (retry) retry.catch(() => {})
        },
        { once: true },
      )
      video.load()
    })
  }

  document.addEventListener('astro:page-load', playCombatHeroVideo)
</script>

<style>
  .combat-hero-video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--color-theme-midnight);
  }

  .combat-hero-video-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
  }

  .combat-hero-video-fallback-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.78;
  }

  .combat-hero-video {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.82) contrast(1.04) saturate(1.08);
    transform: scale(1.2);
  }

  @media (max-width: 767px) {
    .combat-hero-video {
      object-position: center top;
      transform: scale(1.01);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .combat-hero-video {
      transform: none;
    }
  }
</style>
