---
import type { BattleVideoSources } from '@/consts/battle-videos'

interface Props {
  video: BattleVideoSources | null
}

const { video } = Astro.props
---

{
  video ? (
    <>
      <div aria-hidden="true" class="combat-bg-video-wrap">
        <video autoplay loop muted playsinline preload="metadata" class="combat-bg-video">
          <source src={video.desktop} type="video/mp4" media="(min-width: 768px)" />
          <source src={video.mobile} type="video/mp4" />
        </video>
      </div>
      <div aria-hidden="true" class="combat-bg-overlay combat-bg-overlay-video" />
    </>
  ) : (
    <div aria-hidden="true" class="combat-bg-overlay combat-bg-overlay-static" />
  )
}

<style>
  .combat-bg-video-wrap {
    position: fixed;
    inset: 0;
    z-index: 0;
  }

  .combat-bg-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 25%;
  }

  .combat-bg-overlay {
    position: fixed;
    inset: 0;
    z-index: 1;
    pointer-events: none;
  }

  .combat-bg-overlay-video {
    background: linear-gradient(
      180deg,
      rgba(5, 8, 22, 0.42) 0%,
      rgba(5, 8, 22, 0.58) 40%,
      rgba(5, 8, 22, 0.74) 100%
    );
  }

  .combat-bg-overlay-static {
    background:
      radial-gradient(circle at 50% 18%, rgba(199, 168, 107, 0.18), transparent 32%),
      linear-gradient(180deg, var(--color-theme-midnight) 0%, #050816 100%);
  }
</style>
