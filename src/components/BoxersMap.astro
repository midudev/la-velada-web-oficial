---
import 'leaflet/dist/leaflet.css'
import SectionDivider from '@/components/SectionDivider.astro'
import { BOXERS, COUNTRY_NAMES } from '@/consts/boxers'

const countryCounts: Record<string, number> = {}
for (const boxer of BOXERS) {
  countryCounts[boxer.country] = (countryCounts[boxer.country] ?? 0) + 1
}

const ISO_TO_NUMERIC: Record<string, number> = {
  es: 724,
  ar: 32,
  mx: 484,
  co: 170,
  sv: 222,
  pr: 630,
}

const countryCount = Object.keys(countryCounts).length

const mapData = Object.entries(countryCounts).map(([code, count]) => ({
  code,
  numeric: ISO_TO_NUMERIC[code] ?? null,
  name: COUNTRY_NAMES[code] ?? code,
  count,
  boxers: BOXERS.filter((b) => b.country === code).map((b) => ({ id: b.id, name: b.name })),
}))
---

<section
  class="bg-linear-to-b from-[#050816] to-theme-midnight px-6 pt-16 pb-20 sm:px-8 sm:pt-20 sm:pb-24"
  aria-labelledby="boxers-map-title"
>
  <div class="mb-10 flex flex-col items-center text-center">
    <SectionDivider class="mb-8" />
    <h2
      id="boxers-map-title"
      class="max-w-xl text-center font-cinzel text-[clamp(0.875rem,2.5vw,1.125rem)] font-semibold tracking-[0.12em] text-theme-cream/85"
    >
      {countryCount} países representados en La Velada del Año VI
    </h2>
  </div>
  <div
    class="mx-auto max-w-[1000px] overflow-hidden rounded-lg shadow-[0_0_0_1px_color-mix(in_srgb,var(--color-theme-gold)_28%,transparent),0_24px_60px_rgba(0,0,0,0.6)]"
  >
    <!-- Los datos se pasan via data-attribute para poder usar import() en el script -->
    <div
      id="boxers-map"
      class="h-[420px] w-full bg-[#0a0e1f] sm:h-[480px]"
      data-map={JSON.stringify(mapData)}
      aria-label="Mapa de países de los boxeadores"
    >
    </div>
  </div>
</section>

<script>
  import L from 'leaflet'
  import { feature } from 'topojson-client'

  const GOLD = '#c7a86b'
  const GOLD_BRIGHT = '#e8c97a'

  let mapInstance: ReturnType<typeof L.map> | null = null

  function destroyMap() {
    if (mapInstance) {
      mapInstance.remove()
      mapInstance = null
    }
  }

  async function initMap() {
    try {
      destroyMap()

      const mapEl = document.getElementById('boxers-map') as HTMLElement | null
      if (!mapEl) return

      const mapData = JSON.parse(mapEl.dataset.map ?? '[]')
      const byNumeric: Record<number, (typeof mapData)[0]> = Object.fromEntries(
        mapData.filter((d: any) => d.numeric).map((d: any) => [d.numeric, d]),
      )

      mapInstance = L.map(mapEl, {
        center: [20, -30],
        zoom: 2,
        zoomControl: true,
        scrollWheelZoom: false,
        minZoom: 1,
        maxZoom: 6,
      })

      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png', {
        attribution:
          '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20,
      }).addTo(mapInstance)

      const topo = await fetch(
        'https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json',
      ).then((r) => r.json())
      const geojson = feature(topo, topo.objects.countries) as unknown as GeoJSON.FeatureCollection

      let fixedPopup: ReturnType<typeof L.popup> | null = null
      let fixedLayer: ReturnType<typeof L.geoJSON> | null = null

      const geolayer = L.geoJSON(geojson, {
        style(f) {
          return byNumeric[Number(f?.id)]
            ? { fillColor: GOLD, fillOpacity: 0.45, color: GOLD_BRIGHT, weight: 1.5 }
            : { fillColor: 'transparent', fillOpacity: 0, color: '#ffffff08', weight: 0.5 }
        },
        onEachFeature(f, layer) {
          const data = byNumeric[Number(f.id)]
          if (!data) return

          layer.bindTooltip(
            `<div class="font-cinzel text-[0.65rem] font-bold tracking-[0.18em] text-theme-gold uppercase">${data.name}</div>
             <div class="mt-0.5 font-cinzel text-[0.48rem] tracking-[0.12em] text-theme-cream/45">Pulsa para ver boxeadores</div>`,
            { sticky: true, className: 'boxers-map-tooltip', direction: 'top', offset: [0, -4] },
          )

          layer.on({
            mouseover(e: any) {
              if (fixedLayer === e.target) return
              e.target.setStyle({ fillOpacity: 0.7, color: GOLD_BRIGHT, weight: 2 })
              e.target.bringToFront()
            },
            mouseout(e: any) {
              if (fixedLayer === e.target) return
              geolayer.resetStyle(e.target)
            },
            click(e: any) {
              L.DomEvent.stopPropagation(e)

              if (fixedLayer === e.target) {
                fixedPopup?.remove()
                return
              }

              fixedPopup?.remove()
              if (fixedLayer) geolayer.resetStyle(fixedLayer)

              e.target.setStyle({ fillOpacity: 0.85, color: GOLD_BRIGHT, weight: 2.5 })
              e.target.bringToFront()
              fixedLayer = e.target

              const links = data.boxers
                .map(
                  (b: any) =>
                    `<a href="/boxeadores/${b.id}" class="group flex items-center gap-1.5 rounded-sm px-[0.3rem] py-1 font-cinzel text-[0.6rem] font-semibold tracking-[0.1em] text-theme-cream no-underline transition-colors duration-150 hover:bg-theme-gold/15 hover:text-theme-gold">
                      <span class="text-[0.8rem] text-theme-gold/55 transition-[transform,color] duration-150 group-hover:translate-x-0.5 group-hover:text-theme-gold">›</span>${b.name}
                    </a>`,
                )
                .join('')

              fixedPopup = L.popup({
                className: 'boxers-map-popup',
                autoPan: true,
                autoPanPadding: [32, 32],
                closeButton: true,
                closeOnClick: false,
              })
                .setLatLng(e.target.getBounds().getCenter())
                .setContent(
                  `<div class="min-w-40 px-[1.1rem] pt-[0.85rem] pb-[0.9rem]">
                    <div class="mb-0.5 font-cinzel text-xs font-bold tracking-[0.2em] text-theme-gold uppercase">${data.name}</div>
                    <div class="mb-2 border-b border-theme-gold/20 pb-2.5 font-cinzel text-[0.55rem] tracking-[0.18em] text-theme-cream/55 uppercase">${data.count} contendiente${data.count !== 1 ? 's' : ''}</div>
                    <div class="flex flex-col gap-0.5">${links}</div>
                  </div>`,
                )
                .addTo(mapInstance!)

              fixedPopup.on('remove', () => {
                if (fixedLayer) {
                  geolayer.resetStyle(fixedLayer)
                  fixedLayer = null
                }
                fixedPopup = null
              })
            },
          })
        },
      }).addTo(mapInstance)

      mapInstance.on('click', () => fixedPopup?.remove())

      const highlightedFc: GeoJSON.FeatureCollection = {
        type: 'FeatureCollection',
        features: geojson.features.filter((f) => byNumeric[Number(f.id)]),
      }
      if (highlightedFc.features.length) {
        mapInstance.fitBounds(L.geoJSON(highlightedFc).getBounds(), {
          padding: [40, 40],
          maxZoom: 4,
        })
      }
    } catch (err) {
      console.error('BoxersMap:', err)
    }
  }

  document.addEventListener('astro:page-load', initMap)
  document.addEventListener('astro:before-preparation', destroyMap)
</script>

<style>
  /*
    Solo overrides de Leaflet — apuntan a clases externas que Tailwind
    no puede alcanzar desde el markup.
  */
  :global(.leaflet-container) {
    background: #0a0e1f !important;
  }
  :global(.leaflet-control-attribution) {
    background: rgba(5, 8, 22, 0.8) !important;
    color: rgba(255, 255, 255, 0.3) !important;
    font-size: 0.5rem !important;
  }
  :global(.leaflet-control-attribution a) {
    color: color-mix(in srgb, var(--color-theme-gold) 60%, transparent) !important;
  }
  :global(.leaflet-control-zoom a) {
    background: rgba(10, 14, 31, 0.9) !important;
    color: var(--color-theme-gold) !important;
    border-color: color-mix(in srgb, var(--color-theme-gold) 30%, transparent) !important;
  }
  :global(.leaflet-control-zoom a:hover) {
    background: color-mix(in srgb, var(--color-theme-gold) 15%, rgba(10, 14, 31, 0.95)) !important;
  }

  :global(.boxers-map-tooltip.leaflet-tooltip) {
    background: rgba(8, 11, 28, 0.92) !important;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 35%, transparent) !important;
    border-radius: 4px !important;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.5) !important;
    padding: 0.5rem 0.75rem !important;
  }
  :global(.boxers-map-tooltip.leaflet-tooltip::before) {
    border-top-color: color-mix(in srgb, var(--color-theme-gold) 35%, transparent) !important;
  }

  :global(.boxers-map-popup .leaflet-popup-content-wrapper) {
    background: linear-gradient(180deg, #1a2040 0%, rgba(8, 11, 28, 0.98) 100%) !important;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 40%, transparent) !important;
    border-radius: 6px !important;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.7) !important;
    color: var(--color-theme-cream) !important;
    padding: 0 !important;
  }
  :global(.boxers-map-popup .leaflet-popup-content) {
    margin: 0 !important;
  }
  :global(.boxers-map-popup .leaflet-popup-tip-container) {
    display: none !important;
  }
  :global(.boxers-map-popup .leaflet-popup-close-button) {
    color: color-mix(in srgb, var(--color-theme-gold) 70%, transparent) !important;
    top: 6px !important;
    right: 8px !important;
  }
  :global(.boxers-map-popup .leaflet-popup-close-button:hover) {
    color: var(--color-theme-gold) !important;
  }
</style>
