---
import SpotifyIcon from '@/assets/svg/spotify.svg'
import { formatTrackDuration, formatTrackStreams, getTrackSpotifyUrl } from '@/lib/artists'
import type { ArtistTrack } from '@/types/artists'

interface Props {
  class?: string
  tracks: ArtistTrack[]
}

const { class: className, tracks } = Astro.props
---

<div class:list={['w-full sm:w-[min(100%,34rem)]', className]}>
  <p class="m-0 mb-[0.6rem] font-cinzel text-[0.65rem] font-black tracking-[0.2em] text-theme-cream/55">
    Canciones más populares
  </p>
  <ol class="m-0 flex list-none flex-col divide-y divide-theme-gold/12 overflow-hidden rounded-2xl p-0 ring-1 ring-inset ring-theme-gold/22">
    {
      tracks.sort((a, b) => b.streams - a.streams).map((track, index) => (
        <li>
          <a
            href={getTrackSpotifyUrl(track.id)}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-[0.85rem] bg-theme-midnight/55 px-[0.9rem] py-[0.65rem] no-underline transition-colors duration-200 ease-out outline-none hover:bg-theme-gold/8 focus-visible:bg-theme-gold/8"
            aria-label={`Escuchar ${track.name} en Spotify`}
          >
            <span class="w-[1.2rem] shrink-0 text-center font-cinzel text-[0.8rem] font-black text-theme-gold/85">
              {index + 1}
            </span>
            <span class="flex min-w-0 flex-1 flex-col gap-[0.1rem]">
              <span class="overflow-hidden text-ellipsis whitespace-nowrap font-cinzel text-[0.82rem] font-bold tracking-[0.02em] text-theme-cream normal-case group-hover:text-theme-gold">
                {track.name}
              </span>
              <span class="overflow-hidden text-ellipsis whitespace-nowrap text-[0.72rem] text-theme-cream/55">
                {track.album}
              </span>
            </span>
            <span class="flex min-w-0 shrink flex-col items-end gap-[0.1rem]">
              <span class="tabular-nums text-[0.75rem] text-theme-cream/60">
                {formatTrackDuration(track.durationMs)}
              </span>
              <span class="overflow-hidden text-ellipsis whitespace-nowrap tabular-nums text-[0.62rem] text-theme-cream/45">
                {formatTrackStreams(track.streams)} reproducciones
              </span>
            </span>
            <SpotifyIcon
              class="size-4 shrink-0 text-[#1db954] opacity-70 transition-opacity duration-200 ease-out group-hover:opacity-100"
              aria-hidden="true"
            />
          </a>
        </li>
      ))
    }
  </ol>
</div>
