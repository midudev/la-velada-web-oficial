---
interface Props {
  user?: {
    name: string
    image?: string | null
  } | null
  callbackURL?: string
}

const { user, callbackURL = '/pronosticos' } = Astro.props
---

{
  user ? (
    <div class="flex items-center gap-3" data-auth-button data-auth-callback-url={callbackURL}>
      {user.image && (
        <img
          src={user.image}
          alt={user.name}
          width={32}
          height={32}
          class="h-8 w-8 rounded-full border border-white/15 object-cover"
        />
      )}
      <span class="hidden font-cinzel text-[0.65rem] font-black tracking-[0.16em] text-theme-cream/85 sm:inline">
        {user.name}
      </span>
      <button
        type="button"
        data-auth-sign-out
        class="inline-flex min-h-11 cursor-pointer items-center rounded-full border border-white/15 bg-black/20 px-4 py-2 font-cinzel text-[0.6rem] font-black tracking-[0.14em] text-white/70 backdrop-blur-md transition duration-300 hover:border-theme-gold/60 hover:text-theme-cream focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold"
      >
        SALIR
      </button>
    </div>
  ) : (
    <div
      class="grid w-full max-w-xl gap-3 sm:grid-cols-2"
      data-auth-button
      data-auth-callback-url={callbackURL}
    >
      <button
        type="button"
        data-auth-provider="twitch"
        class="group inline-flex min-h-11 cursor-pointer items-center justify-center gap-2.5 rounded-md border border-theme-gold/35 bg-theme-gold/10 px-4 py-3 font-cinzel text-[0.62rem] font-black tracking-[0.14em] text-theme-cream transition duration-300 hover:border-theme-gold hover:bg-theme-gold/20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          class="shrink-0"
        >
          <path d="M11.571 4.714h1.715v5.143H11.57zm4.715 0H18v5.143h-1.714zM6 0L1.714 4.286v15.428h5.143V24l4.286-4.286h3.428L22.286 12V0zm14.571 11.143l-3.428 3.428h-3.429l-3 3v-3H6.857V1.714h13.714z" />
        </svg>
        INICIAR SESIÓN CON TWITCH
      </button>

      <button
        type="button"
        data-auth-provider="google"
        class="group inline-flex min-h-11 cursor-pointer items-center justify-center gap-2.5 rounded-md border border-white/20 bg-white px-4 py-3 font-cinzel text-[0.62rem] font-black tracking-[0.14em] text-theme-midnight transition duration-300 hover:border-theme-gold hover:bg-theme-cream focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-theme-gold"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="15"
          height="15"
          viewBox="0 0 24 24"
          aria-hidden="true"
          class="shrink-0"
        >
          <path
            fill="#4285F4"
            d="M23.49 12.27c0-.79-.07-1.54-.2-2.27H12v4.51h6.47a5.54 5.54 0 0 1-2.4 3.64v2.98h3.83c2.24-2.06 3.54-5.1 3.54-8.86Z"
          />
          <path
            fill="#34A853"
            d="M12 24c3.24 0 5.96-1.07 7.94-2.91l-3.83-2.98c-1.07.72-2.43 1.14-4.11 1.14-3.15 0-5.82-2.13-6.78-4.99H1.26v3.07A12 12 0 0 0 12 24Z"
          />
          <path
            fill="#FBBC05"
            d="M5.22 14.26a7.22 7.22 0 0 1 0-4.52V6.67H1.26a12 12 0 0 0 0 10.66l3.96-3.07Z"
          />
          <path
            fill="#EA4335"
            d="M12 4.75c1.76 0 3.34.61 4.58 1.8l3.44-3.44A11.56 11.56 0 0 0 12 0 12 12 0 0 0 1.26 6.67l3.96 3.07C6.18 6.87 8.85 4.75 12 4.75Z"
          />
        </svg>
        INICIAR SESIÓN CON GOOGLE
      </button>
    </div>
  )
}

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import { createAuthClient } from 'better-auth/client'

  const authClient = createAuthClient()

  function setupAuthButtons() {
    $$<HTMLElement>('[data-auth-button]').forEach((root) => {
      if (root.dataset.authReady === 'true') return

      root.dataset.authReady = 'true'
      const callbackURL = root.dataset.authCallbackUrl || window.location.pathname

      $$<HTMLButtonElement>('[data-auth-provider]', root).forEach((button) => {
        button.addEventListener('click', () => {
          const provider = button.dataset.authProvider
          if (provider !== 'twitch' && provider !== 'google') return

          void authClient.signIn.social({ provider, callbackURL })
        })
      })

      $<HTMLButtonElement>('[data-auth-sign-out]', root)?.addEventListener('click', async () => {
        await authClient.signOut()
        window.location.reload()
      })
    })
  }

  setupAuthButtons()
  document.addEventListener('astro:page-load', setupAuthButtons)
</script>
