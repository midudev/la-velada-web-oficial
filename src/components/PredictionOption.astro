---
import CountryFlag from '@/components/CountryFlag.astro'
import {
  formatPredictionPercent,
  formatPredictionSupport,
  type PredictionOption,
} from '@/consts/predictions'

interface Props {
  battleId: string
  option: PredictionOption
  selectedBoxerId?: string
}

const { battleId, option, selectedBoxerId } = Astro.props
const isSelected = selectedBoxerId === option.boxer.id
const isMuted = Boolean(selectedBoxerId) && !isSelected
---

<button
  type="button"
  class="poll-option group relative cursor-pointer overflow-hidden border-0 bg-theme-navy p-0 text-left text-theme-cream focus-visible:outline focus-visible:-outline-offset-4 focus-visible:outline-2 focus-visible:outline-theme-gold"
  data-battle-id={battleId}
  data-boxer-id={option.boxer.id}
  data-boxer-name={option.boxer.name}
  data-prediction-option
  data-selected={String(isSelected)}
  data-muted={String(isMuted)}
  data-side={option.side}
  data-vote-count={option.votes}
  data-vote-percentage={option.percentage}
  aria-label={`Pronosticar victoria de ${option.boxer.name}`}
  aria-pressed={String(isSelected)}
  style={`--vote-share: ${option.percentage.toFixed(2)}%; --vote-color: ${option.color};`}
>
  <picture class="poll-photo">
    <source type="image/avif" srcset={option.heroImages.avif} />
    <source type="image/webp" srcset={option.heroImages.webp} />
    <img
      src={option.heroImages.webp}
      alt={`Recorte de ${option.boxer.name}`}
      loading="lazy"
      decoding="async"
      width="320"
      height="420"
      class="poll-photo-img"
    />
  </picture>

  <span aria-hidden="true" class="poll-shade"></span>

  <span class="poll-meta">
    <span class="poll-tagrow">
      <span aria-hidden="true" class="poll-hint">Pronosticar</span>
      <span aria-hidden="true" class="poll-check">
        <svg viewBox="0 0 24 24" fill="none" class="size-3">
          <path
            d="M5 12.5 10 17.5 19 7"
            stroke="currentColor"
            stroke-width="2.8"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Tu voto
      </span>
    </span>
    <span class="poll-name">{option.boxer.name}</span>
    <span class="poll-country">
      <CountryFlag country={option.boxer.country} size={12} decorative />
      <span class="truncate">{option.countryName}</span>
    </span>
    <span class="poll-pct" data-prediction-percent>
      {formatPredictionPercent(option.percentage)}
    </span>
    <span class="poll-votes" data-prediction-votes>
      {formatPredictionSupport(option.votes)}
    </span>
  </span>

</button>

<style>
  .poll-option {
    isolation: isolate;
  }

  .poll-photo,
  .poll-photo-img {
    position: absolute;
    inset: 0;
    display: block;
    height: 100%;
    width: 100%;
  }

  .poll-photo-img {
    object-fit: contain;
    transition:
      transform 700ms cubic-bezier(0.16, 1, 0.3, 1),
      filter 400ms ease;
  }

  /* Cada figura se ancla hacia el centro (el VS) para que se enfrenten. */
  .poll-option[data-side='a'] .poll-photo-img {
    object-position: bottom right;
    transform-origin: bottom right;
  }
  .poll-option[data-side='b'] .poll-photo-img {
    object-position: bottom left;
    transform-origin: bottom left;
  }

  .poll-option:hover .poll-photo-img {
    transform: scale(1.04);
  }

  .poll-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      0deg,
      rgba(10, 16, 36, 0.97) 6%,
      rgba(10, 16, 36, 0.35) 42%,
      rgba(10, 16, 36, 0.1) 100%
    );
  }

  /* Oscurecido hacia la junta central para que el VS y la separación lean. */
  .poll-option[data-side='a'] .poll-shade {
    box-shadow: inset -60px 0 80px -40px rgba(10, 16, 36, 0.95);
  }
  .poll-option[data-side='b'] .poll-shade {
    box-shadow: inset 60px 0 80px -40px rgba(10, 16, 36, 0.95);
  }

  .poll-meta {
    position: absolute;
    inset: auto 0 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.05rem;
    padding: 1.1rem 1.2rem 1.25rem;
  }

  .poll-option[data-side='b'] .poll-meta {
    align-items: flex-end;
    text-align: right;
  }

  .poll-name {
    font-family: var(--font-cinzel);
    font-size: 1.4rem;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-theme-cream);
  }

  @media (min-width: 640px) {
    .poll-name {
      font-size: 1.7rem;
    }
  }

  .poll-country {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.35rem;
    font-family: var(--font-cinzel);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
  }

  .poll-option[data-side='b'] .poll-country {
    flex-direction: row-reverse;
  }

  .poll-pct {
    font-family: var(--font-cinzel);
    font-size: 3.4rem;
    font-weight: 900;
    line-height: 0.82;
    letter-spacing: -0.01em;
    font-variant-numeric: tabular-nums;
  }

  @media (min-width: 640px) {
    .poll-pct {
      font-size: 4.5rem;
    }
  }

  .poll-option[data-side='a'] .poll-pct {
    color: color-mix(in srgb, #e06b6b 72%, var(--color-theme-cream));
    text-shadow: 0 0 30px color-mix(in srgb, #c63030 50%, transparent);
  }

  .poll-option[data-side='b'] .poll-pct {
    color: var(--color-theme-gold);
    text-shadow: 0 0 30px color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
  }

  .poll-votes {
    margin-top: 0.3rem;
    font-family: var(--font-cinzel);
    font-size: 0.54rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-variant-numeric: tabular-nums;
    color: color-mix(in srgb, var(--color-theme-cream) 48%, transparent);
  }

  /* Estado seleccionado: aro dorado interior (no desplaza layout). */
  .poll-option[data-selected='true'] {
    box-shadow:
      inset 0 0 0 2px var(--color-theme-gold),
      inset 0 0 40px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
  }

  .poll-option[data-muted='true'] .poll-photo-img {
    filter: saturate(0.6) brightness(0.7);
  }

  .poll-option[data-muted='true'] .poll-meta {
    opacity: 0.7;
  }

  .poll-option[data-pending='true'] {
    cursor: progress;
  }

  /* Fila reservada sobre el nombre: aloja la pista de hover o el chip de voto
     sin desplazar el resto del contenido. */
  .poll-tagrow {
    display: flex;
    align-items: center;
    min-height: 1.1rem;
    margin-bottom: 0.15rem;
  }

  .poll-hint {
    font-family: var(--font-cinzel);
    font-size: 0.5rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-theme-gold);
    opacity: 0;
    transition:
      opacity 220ms ease,
      transform 220ms ease;
    transform: translateY(0.15rem);
  }

  .poll-option:hover .poll-hint,
  .poll-option:focus-visible .poll-hint {
    opacity: 1;
    transform: translateY(0);
  }

  .poll-option[data-selected='true'] .poll-hint,
  .poll-option[data-muted='true'] .poll-hint {
    display: none;
  }

  /* Chip "Tu voto" al seleccionar. */
  .poll-check {
    display: none;
    align-items: center;
    gap: 0.28rem;
    border-radius: 0.4rem;
    background: var(--color-theme-gold);
    padding: 0.22rem 0.5rem;
    color: var(--color-theme-midnight);
    font-family: var(--font-cinzel);
    font-size: 0.48rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .poll-option[data-selected='true'] .poll-check {
    display: inline-flex;
  }

  .poll-option[data-vote-changing] .poll-pct {
    animation: vote-number-pop 520ms cubic-bezier(0.18, 0.86, 0.24, 1);
  }

  @keyframes vote-number-pop {
    0%,
    100% {
      transform: scale(1);
    }
    40% {
      transform: scale(1.06);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .poll-photo-img,
    .poll-hint,
    .poll-check,
    .poll-pct {
      animation: none;
      transition: none;
    }
  }
</style>
