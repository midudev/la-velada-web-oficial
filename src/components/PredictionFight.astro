---
import ArrowRightIcon from '@/assets/svg/arrow-right.svg'
import PredictionOption from '@/components/PredictionOption.astro'
import { formatPredictionPercent, type PredictionBattle } from '@/consts/predictions'

interface Props {
  prediction: PredictionBattle
  selectedBoxerId?: string
}

const { prediction, selectedBoxerId } = Astro.props
const { battle, options, favorite } = prediction
const [optionA, optionB] = options
---

<li id={battle.id} class="scroll-mt-28">
  <article
    class="prediction-fight relative overflow-hidden rounded-2xl border border-theme-gold/25 bg-theme-midnight shadow-[0_30px_80px_rgba(0,0,0,0.5)]"
    data-battle-id={battle.id}
    data-prediction-fight
  >
    <span aria-hidden="true" class="fight-glow"></span>

    <header class="fight-head">
      <span class="fight-combat">
        COMBATE {String(battle.number).padStart(2, '0')}
      </span>
      <span
        data-prediction-badge
        class:list={[
          'prediction-badge',
          favorite ? 'prediction-badge-calm' : 'prediction-badge-hot',
        ]}
      >
        {favorite ? `Favorito · ${favorite.boxer.name}` : 'A cara de perro'}
      </span>
    </header>

    <div class="fight-stage">
      <PredictionOption battleId={battle.id} option={optionA} selectedBoxerId={selectedBoxerId} />
      <PredictionOption battleId={battle.id} option={optionB} selectedBoxerId={selectedBoxerId} />

      <div class="fight-vs" aria-hidden="true"><span>VS</span></div>
    </div>

    <div
      class="fight-bar"
      data-prediction-bar
      role="img"
      aria-label={`${optionA.boxer.name}: ${formatPredictionPercent(optionA.percentage)}. ${optionB.boxer.name}: ${formatPredictionPercent(optionB.percentage)}.`}
      style={`--share-a: ${optionA.percentage.toFixed(2)}%; --share-b: ${optionB.percentage.toFixed(2)}%;`}
    >
      <span class="fight-bar-a"></span><span class="fight-bar-b"></span>
    </div>

    <footer class="fight-foot">
      <a href={battle.url} class="fight-link group">
        Ver combate
        <ArrowRightIcon
          class="size-3 transition-transform duration-300 group-hover:translate-x-0.5"
          aria-hidden="true"
        />
      </a>
    </footer>
  </article>
</li>

<style>
  .prediction-fight {
    transition:
      border-color 320ms ease,
      box-shadow 320ms ease;
  }

  .prediction-fight:hover {
    border-color: color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
  }

  /* Brillos rojo/dorado de ambiente. */
  .fight-glow {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 36% 60% at 0% 72%,
        color-mix(in srgb, #c63030 26%, transparent),
        transparent 70%
      ),
      radial-gradient(
        ellipse 36% 60% at 100% 72%,
        color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
        transparent 70%
      ),
      radial-gradient(
        ellipse 50% 38% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 12%, transparent),
        transparent 60%
      );
  }

  .fight-head {
    position: absolute;
    inset: 0 0 auto;
    z-index: 6;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.85rem 1.1rem;
    pointer-events: none;
  }

  .fight-combat {
    font-family: var(--font-cinzel);
    font-size: 0.6rem;
    font-weight: 800;
    letter-spacing: 0.32em;
    color: var(--color-theme-gold);
  }

  /* Badge: clases que el JS alterna (prediction-badge-hot / -calm). */
  .prediction-badge {
    font-family: var(--font-cinzel);
    font-size: 0.52rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-theme-cream);
    border: 1px solid transparent;
    border-radius: 9999px;
    padding: 0.3rem 0.75rem;
    backdrop-filter: blur(4px);
    white-space: nowrap;
  }

  .prediction-badge-hot {
    border-color: color-mix(in srgb, #c63030 55%, transparent);
    background: color-mix(in srgb, #c63030 22%, transparent);
  }

  .prediction-badge-calm {
    color: var(--color-theme-gold);
    border-color: color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
    background: color-mix(in srgb, var(--color-theme-gold) 12%, transparent);
  }

  .fight-stage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: clamp(19rem, 42vw, 25rem);
  }

  /* Medallón VS centrado sobre la junta (no captura clics). */
  .fight-vs {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 5;
    translate: -50% -50%;
    pointer-events: none;
    display: grid;
    width: 3.6rem;
    height: 3.6rem;
    place-items: center;
    border-radius: 9999px;
    border: 1px solid var(--color-theme-gold);
    background: color-mix(in srgb, var(--color-theme-midnight) 82%, black);
    font-family: var(--font-cinzel);
    font-size: 1rem;
    font-weight: 900;
    color: var(--color-theme-gold);
    box-shadow:
      0 0 0 8px color-mix(in srgb, var(--color-theme-midnight) 55%, transparent),
      0 0 28px color-mix(in srgb, var(--color-theme-gold) 28%, transparent);
  }

  @media (min-width: 640px) {
    .fight-vs {
      width: 4rem;
      height: 4rem;
      font-size: 1.05rem;
    }
  }

  /* Barra única tira y afloja. */
  .fight-bar {
    position: relative;
    z-index: 6;
    display: flex;
    height: 0.55rem;
  }

  .fight-bar-a,
  .fight-bar-b {
    transition: width 640ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .fight-bar-a {
    width: var(--share-a, 0%);
    background: #c63030;
    box-shadow: 0 0 16px color-mix(in srgb, #c63030 55%, transparent);
  }

  .fight-bar-b {
    width: var(--share-b, 0%);
    margin-left: auto;
    background: var(--color-theme-gold);
    box-shadow: 0 0 16px color-mix(in srgb, var(--color-theme-gold) 50%, transparent);
  }

  /* Pie con botón a la vista del combate. */
  .fight-foot {
    display: flex;
    justify-content: center;
    border-top: 1px solid color-mix(in srgb, var(--color-theme-gold) 14%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 92%, black);
    padding: 0.55rem 1rem;
  }

  .fight-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    min-height: 2.25rem;
    padding: 0.35rem 1.2rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 32%, transparent);
    font-family: var(--font-cinzel);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    white-space: nowrap;
    color: var(--color-theme-gold);
    transition:
      color 260ms ease,
      border-color 260ms ease,
      background-color 260ms ease;
  }

  /* La flecha mantiene su tamaño y queda alineada con el texto (la separación
     visual del tracking en mayúsculas se compensa con un margen negativo). */
  .fight-link :global(svg) {
    flex-shrink: 0;
    margin-inline-start: -0.12em;
    transform: translateY(0.02em);
  }

  .fight-link:hover {
    color: var(--color-theme-midnight);
    background: var(--color-theme-gold);
    border-color: var(--color-theme-gold);
  }

  .fight-link:focus-visible {
    outline: 2px solid var(--color-theme-gold);
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-fight,
    .fight-bar-a,
    .fight-bar-b {
      transition: none;
    }
  }
</style>
