---
import PredictionOption from '@/components/PredictionOption.astro'
import type { PredictionBattle } from '@/consts/predictions'

interface Props {
  prediction: PredictionBattle
  selectedBoxerId?: string
  index?: number
}

const { prediction, selectedBoxerId, index = 0 } = Astro.props
// Entrada escalonada (mismo patrón que /combates).
const animationDelay = `${index * 60}ms`
const { battle, options } = prediction
const [optionA, optionB] = options

// Líder solo si hay votos y no es empate (si no, sin halo).
const hasLeader = prediction.totalVotes > 0 && optionA.percentage !== optionB.percentage
const leaderBoxerId = hasLeader ? prediction.leader.boxer.id : undefined
---

<li
  class="tow-item scroll-mt-28 not-motion-reduce:animate-fade-in-up"
  style={`animation-delay:${animationDelay}`}
>
  <article data-battle-id={battle.id} data-prediction-fight>
    <h2 class="sr-only">
      Combate {battle.number}: {optionA.boxer.name} ({optionA.countryName}) contra {
        optionB.boxer.name
      } ({optionB.countryName})
    </h2>

    <div class="tow-stage">
      <span class="tow-tag font-cinzel">Combate {String(battle.number).padStart(2, '0')}</span>

      <PredictionOption
        battleId={battle.id}
        option={optionA}
        selectedBoxerId={selectedBoxerId}
        leaderBoxerId={leaderBoxerId}
      />
      <PredictionOption
        battleId={battle.id}
        option={optionB}
        selectedBoxerId={selectedBoxerId}
        leaderBoxerId={leaderBoxerId}
      />

      <span aria-hidden="true" class="tow-seam"></span>

      <div class="tow-vs" aria-hidden="true">
        <span class="tow-vs-medal font-cinzel"><b>VS</b></span>
      </div>

      <span aria-hidden="true" class="tow-track"></span>
    </div>
  </article>
</li>

<style>
  .tow-stage {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    border-radius: 10px;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 20%, transparent),
      0 22px 60px rgba(0, 0, 0, 0.55);
  }

  /* Etiqueta del número de combate, anclada a la esquina superior izquierda. */
  .tow-tag {
    position: absolute;
    top: 0.6rem;
    left: 0.6rem;
    z-index: 7;
    padding: 0.28rem 0.62rem;
    font-size: 0.5rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 90%, white);
    background: color-mix(in srgb, var(--color-theme-midnight) 52%, transparent);
    backdrop-filter: blur(5px);
    -webkit-backdrop-filter: blur(5px);
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 32%, transparent);
    border-radius: 0.3rem;
  }

  /* Línea divisora central (queda por DEBAJO del VS, z-index 6 < 7). */
  .tow-seam {
    position: absolute;
    top: 0;
    bottom: 14px;
    left: 50%;
    z-index: 6;
    width: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      180deg,
      transparent,
      color-mix(in srgb, var(--color-theme-gold) 38%, transparent) 30%,
      color-mix(in srgb, var(--color-theme-gold) 38%, transparent) 70%,
      transparent
    );
    pointer-events: none;
  }

  /* Carril de fondo de la barra tug-of-war. */
  .tow-track {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    z-index: 2;
    height: 14px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.5));
    box-shadow: inset 0 1px 2px rgba(0, 0, 0, 0.5);
    pointer-events: none;
  }

  /* Medalla VS centrada entre los combatientes (en la costura, a media
     altura de las fotos, por encima de la barra). */
  .tow-vs {
    position: absolute;
    left: 50%;
    top: calc((100% - 14px) / 2);
    z-index: 7;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .tow-vs-medal {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    transform: rotate(45deg);
    border: 1px solid var(--color-theme-gold);
    /* Base sólida opaca + tinte dorado encima: oculta la línea que pasa detrás. */
    background:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--color-theme-gold) 26%, transparent),
        transparent 70%
      ),
      #0a1024;
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.55),
      0 0 24px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
  }
  .tow-vs-medal b {
    transform: rotate(-45deg);
    font-weight: 900;
    font-size: 1rem;
    letter-spacing: 0.06em;
    color: color-mix(in srgb, var(--color-theme-gold) 92%, white);
  }
  .tow-item:hover .tow-vs-medal {
    background:
      radial-gradient(
        circle,
        color-mix(in srgb, var(--color-theme-gold) 40%, transparent),
        transparent 70%
      ),
      #0a1024;
  }

  @media (max-width: 480px) {
    .tow-vs-medal {
      width: 44px;
      height: 44px;
    }
    .tow-vs-medal b {
      font-size: 0.8rem;
    }
  }
</style>
