---
import PredictionShareModal from './PredictionShareModal.astro'
import ShareIcon from '@/assets/svg/share.svg'

interface Props {
  isLoggedIn: boolean
  totalFights: number
}

const { isLoggedIn, totalFights } = Astro.props
---

{isLoggedIn && <PredictionShareModal totalFights={totalFights} />}
{
  isLoggedIn && (
    <button type="button" class="prediction-share-fab" data-prediction-share-fab hidden>
      <ShareIcon aria-hidden="true" />
      <span>Compartir pronóstico</span>
    </button>
  )
}

<style>
  .prediction-share-fab {
    position: fixed;
    right: 1rem;
    bottom: 1.25rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.75rem 1.15rem;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 65%,
      color-mix(in srgb, var(--color-theme-gold) 75%, black) 100%
    );
    color: var(--color-theme-midnight);
    font-family: var(--font-cinzel);
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white)
    transition:
      transform 250ms,
      box-shadow 250ms;
    animation: prediction-fab-enter 500ms cubic-bezier(0.34, 1.42, 0.5, 1) both;
  }

  .prediction-share-fab:hover,
  .prediction-share-fab:focus-visible {
    transform: translateY(-2px);
    outline: none;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
  }

  @media (min-width: 640px) {
    .prediction-share-fab {
      right: 1.5rem;
      bottom: 1.5rem;
      padding: 0.85rem 1.4rem;
      font-size: 0.78rem;
    }
  }

  @keyframes prediction-fab-enter {
    from {
      opacity: 0;
      transform: translateY(20px) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-fab {
      animation: none;
      transition: none;
    }
    .prediction-share-fab:hover,
    .prediction-share-fab:focus-visible {
      transform: none;
    }
  }
</style>

<script>
  import { $ } from '@/lib/dom-selector'
  import { areAllPredictionsComplete, openPredictionShare } from '@/lib/prediction-completion'

  function setupShareFab() {
    const fab = $<HTMLButtonElement>('[data-prediction-share-fab]')
    if (!fab) return

    if (areAllPredictionsComplete()) {
      fab.hidden = false
    }

    fab.addEventListener('click', openPredictionShare)
  }

  document.addEventListener('astro:page-load', setupShareFab)
</script>
