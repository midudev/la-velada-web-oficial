---
import PredictionShareModal from './PredictionShareModal.astro'
import ShareIcon from '@/assets/svg/share.svg'

interface Props {
  isLoggedIn: boolean
  totalFights: number
}

const { isLoggedIn, totalFights } = Astro.props
---

{isLoggedIn && <PredictionShareModal totalFights={totalFights} />}
{
  isLoggedIn && (
    <button
      type="button"
      class="prediction-share-fab"
      data-prediction-share-fab
      aria-label="Compartir pronóstico"
    >
      <span aria-hidden="true" class="prediction-share-fab-corner prediction-share-fab-corner-tl" />
      <span aria-hidden="true" class="prediction-share-fab-corner prediction-share-fab-corner-tr" />
      <span aria-hidden="true" class="prediction-share-fab-corner prediction-share-fab-corner-bl" />
      <span aria-hidden="true" class="prediction-share-fab-corner prediction-share-fab-corner-br" />
      <span class="prediction-share-fab-content">
        <ShareIcon aria-hidden="true" class="prediction-share-fab-icon" />
        <span>Compartir pronóstico</span>
      </span>
    </button>
  )
}

<style>
  .prediction-share-fab {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    z-index: 60;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.75rem;
    padding: 0.5rem 1.15rem;
    border-radius: 9999px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 65%,
      color-mix(in srgb, var(--color-theme-gold) 75%, black) 100%
    );
    color: var(--color-theme-midnight);
    font-family: var(--font-cinzel);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transform: translateX(-50%);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 12px 32px color-mix(in srgb, var(--color-theme-gold) 38%, transparent),
      0 0 24px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    transition:
      transform 250ms ease,
      box-shadow 250ms ease;
    animation: prediction-fab-enter 500ms cubic-bezier(0.34, 1.42, 0.5, 1) both;
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .prediction-share-fab {
      bottom: 1.5rem;
      min-height: 3rem;
      padding: 0.65rem 1.4rem;
      font-size: 0.68rem;
    }
  }

  @media (min-width: 1024px) {
    .prediction-share-fab {
      position: static;
      left: auto;
      bottom: auto;
      transform: none;
      min-height: 3rem;
      padding: 0.65rem 1.4rem;
      font-size: 0.68rem;
      animation: prediction-fab-enter-desktop 500ms cubic-bezier(0.34, 1.42, 0.5, 1) both;
    }
  }

  .prediction-share-fab:hover,
  .prediction-share-fab:focus-visible {
    transform: translate(-50%, -2px);
    outline: none;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 16px 40px color-mix(in srgb, var(--color-theme-gold) 45%, transparent),
      0 0 32px color-mix(in srgb, var(--color-theme-gold) 25%, transparent);
  }

  .prediction-share-fab:active {
    transform: translate(-50%, -1px);
  }

  @media (min-width: 1024px) {
    .prediction-share-fab:hover,
    .prediction-share-fab:focus-visible {
      transform: translateY(-2px);
    }

    .prediction-share-fab:active {
      transform: translateY(-1px);
    }
  }

  .prediction-share-fab-content {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .prediction-share-fab-icon {
    width: 0.95rem;
    height: 0.95rem;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .prediction-share-fab-icon {
      width: 1rem;
      height: 1rem;
    }
  }

  /* Esquinas doradas decorativas (mismo lenguaje que el modal y los
     paneles de boxeadores.astro). Refuerzan la identidad del sitio. */
  .prediction-share-fab-corner {
    position: absolute;
    width: 7px;
    height: 7px;
    border: 1px solid color-mix(in srgb, var(--color-theme-midnight) 65%, transparent);
    pointer-events: none;
  }
  .prediction-share-fab-corner-tl {
    top: -1px;
    left: 1rem;
    border-right: 0;
    border-bottom: 0;
  }
  .prediction-share-fab-corner-tr {
    top: -1px;
    right: 1rem;
    border-left: 0;
    border-bottom: 0;
  }
  .prediction-share-fab-corner-bl {
    bottom: -1px;
    left: 1rem;
    border-right: 0;
    border-top: 0;
  }
  .prediction-share-fab-corner-br {
    bottom: -1px;
    right: 1rem;
    border-left: 0;
    border-top: 0;
  }

  @keyframes prediction-fab-enter {
    from {
      opacity: 0;
      transform: translate(-50%, 20px) scale(0.94);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0) scale(1);
    }
  }

  @keyframes prediction-fab-enter-desktop {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-fab {
      animation: none;
      transition: none;
    }
    .prediction-share-fab:hover,
    .prediction-share-fab:focus-visible,
    .prediction-share-fab:active {
      transform: none;
    }
  }
</style>

<script>
  import { $ } from '@/lib/dom-selector'
  import { openPredictionShare } from '@/lib/prediction-completion'

  function setupShareFab() {
    const fab = $<HTMLButtonElement>('[data-prediction-share-fab]')
    if (!fab) return

    fab.addEventListener('click', openPredictionShare)
  }

  document.addEventListener('astro:page-load', setupShareFab)
</script>
