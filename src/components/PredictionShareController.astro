---
import PredictionShareModal from './PredictionShareModal.astro'
import ShareIcon from '@/assets/svg/share.svg'

interface Props {
  isLoggedIn: boolean
  totalFights: number
  // 'fab' (por defecto): botón flotante + modal. 'top': botón en línea que solo
  // aparece arriba cuando ya se han completado todos los pronósticos.
  variant?: 'fab' | 'top'
}

const { isLoggedIn, totalFights, variant = 'fab' } = Astro.props
---

{variant === 'fab' && isLoggedIn && <PredictionShareModal totalFights={totalFights} />}
{
  isLoggedIn && variant === 'fab' && (
    <button
      type="button"
      class="prediction-share-btn prediction-share-fab"
      data-prediction-share-fab
      data-prediction-share-trigger
      data-has-vote="false"
      aria-label="Compartir pronóstico"
    >
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tl" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tr" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-bl" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-br" />
      <span class="prediction-share-content">
        <ShareIcon aria-hidden="true" class="prediction-share-icon" />
        <span>Compartir pronóstico</span>
      </span>
    </button>
  )
}
{
  isLoggedIn && variant === 'top' && (
    <button
      type="button"
      class="prediction-share-btn prediction-share-top"
      data-prediction-share-top
      data-prediction-share-trigger
      data-complete="false"
      aria-label="Compartir pronóstico"
    >
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tl" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tr" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-bl" />
      <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-br" />
      <span class="prediction-share-content">
        <ShareIcon aria-hidden="true" class="prediction-share-icon" />
        <span>Compartir pronóstico</span>
      </span>
    </button>
  )
}

<style>
  .prediction-share-fab[data-has-vote='false'] {
    display: none;
  }

  /* Variante superior: solo visible cuando se han completado todos los
     pronósticos. En línea (no flotante), centrada por su contenedor. */
  .prediction-share-top[data-complete='false'] {
    display: none;
  }

  /* Skin compartido — mismo lenguaje que AuthButton y las trading cards de
     boxeadores: vidrio oscuro con tinte dorado, borde dorado fino, esquinas
     decorativas y tipografía Cinzel. Sin gradiente brillante ni glow, para
     integrarse con el resto de la web en lugar de competir con ella. */
  .prediction-share-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.7rem 1.6rem;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
    border-radius: var(--radius-card);
    background: color-mix(in srgb, var(--color-theme-gold) 12%, transparent);
    color: var(--color-theme-cream);
    font-family: var(--font-cinzel);
    font-size: 0.66rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    cursor: pointer;
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 12%, transparent);
    transition:
      transform 250ms ease,
      border-color 250ms ease,
      background-color 250ms ease,
      box-shadow 250ms ease,
      color 250ms ease;
  }

  .prediction-share-btn:hover,
  .prediction-share-btn:focus-visible {
    outline: none;
    border-color: var(--color-theme-gold);
    background: color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    color: white;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 30%, transparent),
      0 8px 22px color-mix(in srgb, var(--color-theme-gold) 20%, transparent);
  }

  .prediction-share-btn:focus-visible {
    outline: 2px solid var(--color-theme-gold);
    outline-offset: 4px;
  }

  /* Posicionamiento del FAB: flotante centrado abajo en móvil/tablet, en línea
     en escritorio (queda dentro del contenedor del final de la lista). */
  .prediction-share-fab {
    position: fixed;
    left: 50%;
    bottom: 1.25rem;
    z-index: 60;
    transform: translateX(-50%);
    animation: prediction-share-enter 500ms cubic-bezier(0.34, 1.42, 0.5, 1) both;
  }

  @media (min-width: 640px) and (max-width: 1023px) {
    .prediction-share-fab {
      bottom: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .prediction-share-fab {
      position: relative;
      left: auto;
      bottom: auto;
      transform: none;
    }
  }

  .prediction-share-top {
    animation: prediction-share-enter-inline 500ms cubic-bezier(0.34, 1.42, 0.5, 1) both;
  }

  /* Elevación sutil en hover/focus (sin alterar el centrado del FAB). */
  .prediction-share-top:hover,
  .prediction-share-top:focus-visible {
    transform: translateY(-2px);
  }
  .prediction-share-top:active {
    transform: translateY(-1px);
  }

  .prediction-share-fab:hover,
  .prediction-share-fab:focus-visible {
    transform: translate(-50%, -2px);
  }
  .prediction-share-fab:active {
    transform: translate(-50%, -1px);
  }

  @media (min-width: 1024px) {
    .prediction-share-fab:hover,
    .prediction-share-fab:focus-visible {
      transform: translateY(-2px);
    }
    .prediction-share-fab:active {
      transform: translateY(-1px);
    }
  }

  .prediction-share-content {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  .prediction-share-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
    color: var(--color-theme-gold);
    transition: color 250ms ease;
  }

  .prediction-share-btn:hover .prediction-share-icon,
  .prediction-share-btn:focus-visible .prediction-share-icon {
    color: var(--color-theme-cream);
  }

  /* Esquinas doradas decorativas — mismo lenguaje que el modal y las trading
     cards de boxeadores. Refuerzan la identidad del sitio. */
  .prediction-share-corner {
    position: absolute;
    width: 8px;
    height: 8px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
    pointer-events: none;
    transition: border-color 250ms ease;
  }
  .prediction-share-btn:hover .prediction-share-corner,
  .prediction-share-btn:focus-visible .prediction-share-corner {
    border-color: var(--color-theme-gold);
  }
  .prediction-share-corner-tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-tr {
    top: -1px;
    right: -1px;
    border-left: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-bl {
    bottom: -1px;
    left: -1px;
    border-right: 0;
    border-top: 0;
  }
  .prediction-share-corner-br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  @keyframes prediction-share-enter {
    from {
      opacity: 0;
      transform: translate(-50%, 16px);
    }
    to {
      opacity: 1;
      transform: translate(-50%, 0);
    }
  }

  @keyframes prediction-share-enter-inline {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-btn {
      animation: none;
      transition: none;
    }
    .prediction-share-btn:hover,
    .prediction-share-btn:focus-visible,
    .prediction-share-btn:active {
      transform: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import {
    areAllPredictionsComplete,
    getUserVotesFromDOM,
    openPredictionShare,
  } from '@/lib/prediction-completion'

  function setupShareFab() {
    const triggers = $$<HTMLButtonElement>('[data-prediction-share-trigger]')
    if (triggers.length === 0) return

    triggers.forEach((trigger) => trigger.addEventListener('click', openPredictionShare))

    // El FAB aparece en cuanto hay algún voto; el botón superior solo cuando
    // están los 10 pronósticos completos.
    const fab = $<HTMLButtonElement>('[data-prediction-share-fab]')
    const topButton = $<HTMLButtonElement>('[data-prediction-share-top]')

    const refreshVisibility = () => {
      const votes = getUserVotesFromDOM()
      if (fab) fab.dataset.hasVote = String(Object.keys(votes).length > 0)
      if (topButton) topButton.dataset.complete = String(areAllPredictionsComplete())
    }

    refreshVisibility()

    const observer = new MutationObserver(refreshVisibility)
    $$<HTMLButtonElement>('[data-prediction-option]').forEach((option) => {
      observer.observe(option, { attributes: true, attributeFilter: ['data-selected'] })
    })
  }

  document.addEventListener('astro:page-load', setupShareFab)
</script>
