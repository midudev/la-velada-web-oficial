---
import { EVENT_ZONED_ISO } from '@/consts/event'

const tipId = 'event-local-time-tip'
---

<span class="event-local-time">
  <time
    datetime={EVENT_ZONED_ISO}
    tabindex="0"
    class="event-local-time__trigger cursor-help font-medium underline decoration-theme-gold/35 decoration-dotted underline-offset-[0.2em] transition-[text-decoration-color] duration-200 hover:decoration-theme-gold/80"
  >
    20:00H (españa peninsular)
  </time>
  <span id={tipId} popover="manual" role="tooltip" class="event-local-time__tooltip">
    <span class="event-local-time__tooltip-primary"></span>
    <span class="event-local-time__tooltip-secondary" hidden></span>
  </span>
</span>

<style is:global>
  .event-local-time__trigger {
    anchor-name: --event-local-time-trigger;
  }

  .event-local-time__tooltip {
    --event-time-ease-out: cubic-bezier(0.23, 1, 0.32, 1);

    position: fixed;
    position-anchor: --event-local-time-trigger;
    position-try-fallbacks: none;
    inset: auto;
    top: auto;
    left: auto;
    right: anchor(right);
    bottom: anchor(top);
    margin: 0;
    width: max-content;
    --event-time-tooltip-gap: 0.75rem;
    translate: 0 calc(-100% - var(--event-time-tooltip-gap) - 6px);
    flex-direction: column;
    gap: 0.2rem;
    min-width: 10.5rem;
    max-width: min(20rem, 78vw);
    padding: 0.55rem 0.85rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-theme-midnight) 96%, transparent);
    backdrop-filter: blur(12px);
    box-shadow:
      0 4px 12px color-mix(in srgb, black 28%, transparent),
      0 12px 28px color-mix(in srgb, black 38%, transparent);
    font-family: inherit;
    text-align: center;
    text-wrap: balance;
    color: var(--color-theme-cream);
    transform-origin: 100% 100%;
    opacity: 0;
    transform: scale(0.96);
    pointer-events: none;
    transition:
      opacity 200ms var(--event-time-ease-out),
      transform 200ms var(--event-time-ease-out),
      translate 200ms var(--event-time-ease-out),
      overlay 200ms allow-discrete,
      display 200ms allow-discrete;
  }

  .event-local-time__tooltip-primary {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
  }

  .event-local-time__tooltip-secondary {
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--color-theme-cream) 72%, var(--color-theme-gold));
  }

  .event-local-time__tooltip:popover-open {
    display: flex;
    opacity: 1;
    translate: 0 calc(-100% - var(--event-time-tooltip-gap));
    transform: scale(1);
    pointer-events: auto;
  }

  @starting-style {
    .event-local-time__tooltip:popover-open {
      opacity: 0;
      translate: 0 calc(-100% - var(--event-time-tooltip-gap) - 6px);
      transform: scale(0.96);
    }
  }

  .event-local-time__tooltip.is-hiding {
    opacity: 0;
    translate: 0 calc(-100% - var(--event-time-tooltip-gap) - 4px);
    transform: scale(0.97);
    pointer-events: none;
    transition-duration: 160ms;
  }

  .event-local-time__tooltip.is-instant {
    transition: none;
  }

  @media (min-width: 640px) {
    .event-local-time__tooltip {
      --event-time-tooltip-gap: 0.875rem;
      gap: 0.25rem;
      padding: 0.65rem 1rem 0.75rem;
    }

    .event-local-time__tooltip-primary {
      font-size: 1.0625rem;
    }

    .event-local-time__tooltip-secondary {
      font-size: 0.8125rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .event-local-time__tooltip {
      translate: 0 calc(-100% - var(--event-time-tooltip-gap));
      transform: none;
      transition: none;
    }

    .event-local-time__tooltip:popover-open,
    .event-local-time__tooltip.is-hiding {
      translate: 0 calc(-100% - var(--event-time-tooltip-gap));
      transform: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import { resolveEventLocalTime } from '@/lib/event-local-time'
  import { afterTransition, prefersReducedMotion } from '@/lib/transition'

  const TOOLTIP_EXIT_MS = 160

  let eventTimeAbort: AbortController | undefined

  function bindEventLocalTime(root: HTMLElement, signal: AbortSignal) {
    const trigger = $('time', root)
    const tooltip = $('.event-local-time__tooltip', root)
    const primary = $('.event-local-time__tooltip-primary', tooltip)
    const secondary = $('.event-local-time__tooltip-secondary', tooltip)
    if (!trigger || !tooltip || !primary) return

    let view: ReturnType<typeof resolveEventLocalTime>
    try {
      view = resolveEventLocalTime()
    } catch (error) {
      console.error('[EventLocalTime] No se pudo calcular la hora local:', error)
      return
    }

    primary.textContent = view.tooltipPrimary

    if (secondary) {
      if (view.tooltipSecondary) {
        secondary.textContent = view.tooltipSecondary
        secondary.hidden = false
      } else {
        secondary.textContent = ''
        secondary.hidden = true
      }
    }

    trigger.setAttribute('aria-describedby', tooltip.id)

    let isOpen = false
    let isHiding = false

    const show = () => {
      isHiding = false
      tooltip.classList.remove('is-hiding')

      if (!tooltip.matches(':popover-open')) {
        tooltip.classList.remove('is-instant')
        tooltip.showPopover()
      }

      isOpen = true
    }

    const hide = async () => {
      if (!tooltip.matches(':popover-open')) return
      if (isHiding) return

      isOpen = false

      if (prefersReducedMotion()) {
        tooltip.hidePopover()
        tooltip.classList.remove('is-hiding', 'is-instant')
        return
      }

      isHiding = true
      tooltip.classList.remove('is-instant')
      tooltip.classList.add('is-hiding')
      await afterTransition(tooltip, TOOLTIP_EXIT_MS)
      tooltip.hidePopover()
      tooltip.classList.remove('is-hiding')
      isHiding = false
    }

    const hoverable = matchMedia('(hover: hover) and (pointer: fine)').matches

    if (hoverable) {
      trigger.addEventListener('mouseenter', show, { signal })
      trigger.addEventListener('mouseleave', () => void hide(), { signal })
    }

    trigger.addEventListener('focus', show, { signal })
    trigger.addEventListener('blur', () => void hide(), { signal })

    if (!hoverable) {
      trigger.addEventListener(
        'click',
        (event) => {
          event.preventDefault()
          if (isOpen || tooltip.matches(':popover-open')) void hide()
          else show()
        },
        { signal },
      )
    }
  }

  function setupEventLocalTimes() {
    eventTimeAbort?.abort()
    eventTimeAbort = new AbortController()

    $$('.event-local-time').forEach((root) => {
      bindEventLocalTime(root, eventTimeAbort!.signal)
    })
  }

  document.addEventListener('astro:page-load', setupEventLocalTimes)
  setupEventLocalTimes()
</script>
