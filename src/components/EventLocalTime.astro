---
import { EVENT_ZONED_ISO } from '@/consts/event'
---

<span class="event-local-time">
  <time
    datetime={EVENT_ZONED_ISO}
    tabindex="0"
    class="event-local-time__trigger cursor-help font-medium underline decoration-theme-gold/35 decoration-dotted underline-offset-[0.2em] transition-[text-decoration-color] duration-200 hover:decoration-theme-gold/80"
  >
    20:00H (españa peninsular)
  </time>
  <span popover="manual" role="tooltip" class="event-local-time__tooltip">
    <span class="event-local-time__tooltip-primary"></span>
    <span class="event-local-time__tooltip-secondary" hidden></span>
  </span>
</span>

<style is:global>
  .event-local-time__trigger {
    anchor-name: --event-local-time-trigger;
  }

  .event-local-time__tooltip {
    position: fixed;
    position-anchor: --event-local-time-trigger;
    position-try-fallbacks: none;
    inset: auto;
    top: auto;
    right: anchor(right);
    left: auto;
    bottom: anchor(top);
    margin: 0;
    width: max-content;
    translate: 0 -0.35rem;
    display: none;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 10.5rem;
    max-width: min(20rem, 78vw);
    padding: 0.55rem 0.85rem 0.65rem;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    border-radius: 0.25rem;
    background: color-mix(in srgb, var(--color-theme-midnight) 96%, transparent);
    backdrop-filter: blur(12px);
    box-shadow:
      0 4px 12px color-mix(in srgb, black 28%, transparent),
      0 12px 28px color-mix(in srgb, black 38%, transparent);
    font-family: inherit;
    text-align: left;
    text-wrap: balance;
    color: var(--color-theme-cream);
    transform-origin: 100% 100%;
    opacity: 0;
    transform: scale(0.96);
    pointer-events: none;
  }

  .event-local-time__tooltip-primary {
    font-size: 0.9375rem;
    font-weight: 600;
    line-height: 1.35;
    letter-spacing: 0.01em;
    font-variant-numeric: tabular-nums;
  }

  .event-local-time__tooltip-secondary {
    font-size: 0.75rem;
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: 0.03em;
    color: color-mix(in srgb, var(--color-theme-cream) 72%, var(--color-theme-gold));
  }

  .event-local-time__tooltip:popover-open {
    display: flex;
    opacity: 1;
    transform: scale(1);
    pointer-events: auto;
  }

  @starting-style {
    .event-local-time__tooltip:popover-open {
      opacity: 0;
      transform: scale(0.96);
    }
  }

  @media (min-width: 640px) {
    .event-local-time__tooltip {
      gap: 0.25rem;
      padding: 0.65rem 1rem 0.75rem;
    }

    .event-local-time__tooltip-primary {
      font-size: 1.0625rem;
    }

    .event-local-time__tooltip-secondary {
      font-size: 0.8125rem;
    }
  }

  @media (max-width: 639px) {
    .event-local-time__tooltip {
      right: auto;
      left: anchor(left);
      max-width: calc(100vw - 2rem);
      transform-origin: 0 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .event-local-time__tooltip {
      transform: none;
    }

    .event-local-time__tooltip:popover-open {
      transform: none;
    }
  }

  @supports not (anchor-name: --x) {
    .event-local-time__tooltip {
      position: fixed;
      left: 50%;
      right: auto;
      bottom: auto;
      top: 50%;
      translate: -50% -50%;
      transform: none;
      transform-origin: 50% 50%;
      text-align: center;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import { resolveEventLocalTime } from '@/lib/event-local-time'
  import type { EventLocalTimeView } from '@/lib/event-local-time'
  import { animate } from 'motion'

  const ROOT_SELECTOR = '.event-local-time'
  const TOOLTIP_ID_PREFIX = 'event-local-time-tip'
  const TRIGGER_SELECTOR = 'time'
  const TOOLTIP_SELECTOR = '.event-local-time__tooltip'
  const PRIMARY_SELECTOR = '.event-local-time__tooltip-primary'
  const SECONDARY_SELECTOR = '.event-local-time__tooltip-secondary'
  const TOOLTIP_LINE_SELECTOR = '.event-local-time__tooltip > span:not([hidden])'
  const POPOVER_OPEN_SELECTOR = ':popover-open'
  const HOVER_SELECTOR = ':hover'
  const TOOLTIP_EXIT_MS = 200
  const TOOLTIP_EASE = [0.23, 1, 0.32, 1] as const
  const SHOW_TOOLTIP_ANIMATION = { duration: 0.18, ease: TOOLTIP_EASE }
  const HIDE_TOOLTIP_ANIMATION = { duration: 0.16, ease: TOOLTIP_EASE }
  const TEXT_STAGGER_MS = 40
  const ANCHOR_POSITION_SUPPORTED = CSS.supports('anchor-name', '--x')
  const REDUCED_MOTION_QUERY = matchMedia('(prefers-reduced-motion: reduce)')
  const HOVER_QUERY = matchMedia('(hover: hover) and (pointer: fine)')

  let eventTimeAbort: AbortController | undefined

  function canAnimateTooltip(): boolean {
    return ANCHOR_POSITION_SUPPORTED && !REDUCED_MOTION_QUERY.matches
  }

  function canHover(): boolean {
    return HOVER_QUERY.matches
  }

  function isPopoverOpen(tooltip: HTMLElement): boolean {
    return tooltip.matches(POPOVER_OPEN_SELECTOR)
  }

  function isTouchPointer(event: PointerEvent): boolean {
    return event.pointerType === 'touch'
  }

  function waitForTooltipExit(playback: ReturnType<typeof animate>) {
    return Promise.race([
      playback.finished.catch(() => undefined),
      new Promise<void>((resolve) => window.setTimeout(resolve, TOOLTIP_EXIT_MS)),
    ])
  }

  function bindEventLocalTime(
    root: HTMLElement,
    view: EventLocalTimeView,
    index: number,
    signal: AbortSignal,
  ) {
    const trigger = $(TRIGGER_SELECTOR, root)
    const tooltip = $(TOOLTIP_SELECTOR, root)
    const primary = $(PRIMARY_SELECTOR, tooltip)
    const secondary = $(SECONDARY_SELECTOR, tooltip)
    if (!trigger || !tooltip || !primary) return
    tooltip.id ||= `${TOOLTIP_ID_PREFIX}-${index}`

    primary.textContent = view.tooltipPrimary

    if (secondary) {
      secondary.textContent = view.tooltipSecondary ?? ''
      secondary.hidden = !view.tooltipSecondary
    }

    trigger.setAttribute('aria-describedby', tooltip.id)

    let hidePlayback: ReturnType<typeof animate> | null = null
    let hideToken = 0

    const show = () => {
      hideToken += 1
      hidePlayback?.cancel()
      hidePlayback = null

      if (!isPopoverOpen(tooltip)) {
        tooltip.showPopover()
      }

      if (!canAnimateTooltip()) return

      void animate(
        tooltip,
        { opacity: [0, 1], scale: [0.96, 1] },
        SHOW_TOOLTIP_ANIMATION,
      )

      const lines = $$<HTMLElement>(TOOLTIP_LINE_SELECTOR, tooltip)
      lines.forEach((line, index) => {
        void animate(
          line,
          { opacity: [0, 1], transform: ['translateY(0.25rem)', 'translateY(0)'] },
          {
            duration: 0.18,
            delay: (index * TEXT_STAGGER_MS) / 1000,
            ease: TOOLTIP_EASE,
          },
        )
      })
    }

    const hide = async () => {
      if (!isPopoverOpen(tooltip)) return

      if (!canAnimateTooltip()) {
        tooltip.hidePopover()
        return
      }

      const token = hideToken + 1
      hideToken = token
      hidePlayback?.cancel()

      const opacity = Number.parseFloat(getComputedStyle(tooltip).opacity) || 1
      hidePlayback = animate(
        tooltip,
        { opacity: [opacity, 0], scale: [1, 0.96] },
        HIDE_TOOLTIP_ANIMATION,
      )

      await waitForTooltipExit(hidePlayback)

      if (hideToken !== token) return

      tooltip.hidePopover()
      tooltip.style.opacity = ''
      tooltip.style.transform = ''
      hidePlayback = null
    }

    const hideAfterPointerSettles = () => {
      window.requestAnimationFrame(() => {
        if (trigger.matches(HOVER_SELECTOR) || tooltip.matches(HOVER_SELECTOR)) return
        void hide()
      })
    }

    trigger.addEventListener(
      'pointerenter',
      (event) => {
        if (!isTouchPointer(event)) show()
      },
      { signal },
    )
    trigger.addEventListener(
      'pointerleave',
      (event) => {
        if (!isTouchPointer(event)) hideAfterPointerSettles()
      },
      { signal },
    )

    trigger.addEventListener(
      'focus',
      () => {
        if (canHover()) show()
      },
      { signal },
    )
    trigger.addEventListener(
      'blur',
      () => {
        if (canHover()) void hide()
      },
      { signal },
    )
    trigger.addEventListener(
      'click',
      (event) => {
        const touchClick = event instanceof PointerEvent && isTouchPointer(event)
        if (canHover() && !touchClick) {
          return
        }

        event.preventDefault()
        if (isPopoverOpen(tooltip)) void hide()
        else show()
      },
      { signal },
    )
  }

  function setupEventLocalTimes() {
    eventTimeAbort?.abort()
    eventTimeAbort = new AbortController()
    const signal = eventTimeAbort.signal

    const roots = $$(ROOT_SELECTOR)
    if (roots.length === 0) return

    let view: EventLocalTimeView
    try {
      view = resolveEventLocalTime()
    } catch (error) {
      console.error('[EventLocalTime] No se pudo calcular la hora local:', error)
      return
    }

    roots.forEach((root, index) => {
      bindEventLocalTime(root, view, index, signal)
    })
  }

  document.addEventListener('astro:page-load', setupEventLocalTimes)
  setupEventLocalTimes()
</script>
