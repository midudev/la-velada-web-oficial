---
import ShareIcon from '@/assets/svg/share.svg'
import ResetIcon from '@/assets/svg/reset.svg'
import InstagramIcon from '@/assets/svg/instagram.svg'
import XIcon from '@/assets/svg/x.svg'
import {
  DEFAULT_TEMPLATE_ID,
  TIER_TEMPLATES,
  TIER_TEMPLATES_BY_ID,
  type TierTemplate,
} from '@/consts/tier-list'
import { BOXERS, getBoxerSelectImage } from '@/consts/boxers'

interface BoxerPayload {
  id: string
  name: string
  imageUrl: string
}

const boxers: BoxerPayload[] = BOXERS.map((b) => ({
  id: b.id,
  name: b.name,
  imageUrl: getBoxerSelectImage(b),
}))

const defaultTemplateId = DEFAULT_TEMPLATE_ID
const defaultTemplate: TierTemplate =
  TIER_TEMPLATES_BY_ID[defaultTemplateId] ?? TIER_TEMPLATES[0]!
---

<div class="tier-list-app" data-tier-list-app data-default-template={defaultTemplateId}>
  <!-- Selector de plantillas -->
  <div class="tier-templates" role="tablist" aria-label="Plantillas de tier list">
    {
      TIER_TEMPLATES.map((template: TierTemplate) => (
        <button
          type="button"
          class="tier-template-chip"
          role="tab"
          data-template-id={template.id}
          aria-selected={template.id === defaultTemplateId ? 'true' : 'false'}
        >
          <span class="tier-template-emoji" aria-hidden="true">
            {template.emoji}
          </span>
          <span class="tier-template-label">{template.shortLabel}</span>
        </button>
      ))
    }
  </div>

  <p class="tier-template-desc" data-template-desc aria-live="polite">
    {defaultTemplate.description}
  </p>

  <!-- Título editable -->
  <div class="tier-title-wrap">
    <label class="sr-only" for="tier-list-title">Título del tier list</label>
    <input
      id="tier-list-title"
      class="tier-title-input"
      type="text"
      data-tier-title
      value={defaultTemplate.title}
      maxlength="48"
      autocomplete="off"
      spellcheck="false"
    />
  </div>

  <!-- Board de tiers (SSR: visible sin JS; el script rehidrata / reordena) -->
  <div class="tier-board" data-tier-board role="list" aria-label="Filas del tier list">
    {
      defaultTemplate.tiers.map((tier) => (
        <div class="tier-row" role="listitem" data-tier-id={tier.id}>
          <div
            class="tier-row-label"
            style={`background:${tier.color};color:${tier.textColor ?? '#1a1208'}`}
          >
            <span class="tier-row-label-text">{tier.label}</span>
            {tier.hint && <span class="tier-row-hint">{tier.hint}</span>}
          </div>
          <div
            class="tier-row-drop"
            data-drop-zone={tier.id}
            role="list"
            aria-label={`Tier ${tier.label}${tier.hint ? `: ${tier.hint}` : ''}`}
          />
        </div>
      ))
    }
  </div>

  <!-- Pool de luchadores -->
  <section class="tier-pool-section" aria-labelledby="tier-pool-title">
    <div class="tier-pool-header">
      <h2 id="tier-pool-title" class="tier-pool-title">Luchadores</h2>
      <p class="tier-pool-hint" data-pool-hint>
        Arrastra a una fila o tócalo y elige el tier
      </p>
    </div>
    <div
      class="tier-pool"
      data-tier-pool
      data-drop-zone="pool"
      role="list"
      aria-label="Luchadores sin clasificar"
    >
      {
        boxers.map((boxer) => (
          <button
            type="button"
            class="tier-fighter"
            draggable="true"
            data-boxer-id={boxer.id}
            aria-label={boxer.name}
            role="listitem"
          >
            <img src={boxer.imageUrl} alt="" loading="lazy" draggable="false" />
            <span class="tier-fighter-name">{boxer.name}</span>
          </button>
        ))
      }
    </div>
  </section>

  <!-- Acciones -->
  <div class="tier-actions">
    <button type="button" class="tier-btn tier-btn-ghost" data-tier-reset>
      <ResetIcon class="tier-btn-icon" aria-hidden="true" />
      Reiniciar
    </button>
    <button type="button" class="tier-btn tier-btn-primary" data-tier-share>
      <ShareIcon class="tier-btn-icon" aria-hidden="true" />
      Compartir imagen
    </button>
  </div>

  <!-- Selector de tier (móvil / click) -->
  <div class="tier-pick" data-tier-pick hidden>
    <div class="tier-pick-panel" role="dialog" aria-modal="true" aria-labelledby="tier-pick-title">
      <p id="tier-pick-title" class="tier-pick-title">
        ¿Dónde va <strong data-tier-pick-name></strong>?
      </p>
      <div class="tier-pick-options" data-tier-pick-options></div>
      <button type="button" class="tier-btn tier-btn-ghost tier-pick-cancel" data-tier-pick-cancel>
        Cancelar
      </button>
    </div>
  </div>

  <!-- Modal de compartir -->
  <dialog class="tier-share-modal" data-tier-share-modal>
    <div class="tier-share-backdrop" data-share-close></div>
    <div class="tier-share-content">
      <button type="button" class="tier-share-close" data-share-close aria-label="Cerrar">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12"></path>
        </svg>
      </button>

      <header class="tier-share-header">
        <h2 class="tier-share-heading">Compartir tier list</h2>
        <div class="tier-share-formats" role="group" aria-label="Formato de imagen">
          <button type="button" class="tier-format-btn" data-share-format="instagram" aria-pressed="true">
            <InstagramIcon class="tier-format-icon" aria-hidden="true" />
            <span class="tier-format-label">Instagram</span>
            <span class="tier-format-ratio">4:5</span>
          </button>
          <button
            type="button"
            class="tier-format-btn tier-format-btn-x"
            data-share-format="x"
            aria-pressed="false"
            aria-label="Formato X 16:9"
          >
            <XIcon class="tier-format-icon tier-format-icon-x" aria-hidden="true" />
            <span class="tier-format-ratio">16:9</span>
          </button>
          <button type="button" class="tier-format-btn" data-share-format="square" aria-pressed="false">
            <span class="tier-format-icon tier-format-icon-square" aria-hidden="true"></span>
            <span class="tier-format-label">Cuadrado</span>
            <span class="tier-format-ratio">1:1</span>
          </button>
        </div>
      </header>

      <figure class="tier-share-figure" data-share-figure>
        <div class="tier-share-frame">
          <img class="tier-share-preview" data-share-preview alt="Vista previa del tier list" />
          <span class="tier-share-loading" data-share-loading>Generando imagen…</span>
        </div>
      </figure>

      <div class="tier-share-toolbar">
        <div class="tier-share-actions" data-share-steps>
          <button type="button" class="tier-btn tier-btn-primary tier-share-main" data-native-share-btn data-native-share hidden>
            <ShareIcon class="tier-btn-icon" aria-hidden="true" />
            Compartir
          </button>
          <button
            type="button"
            class="tier-btn tier-btn-ghost tier-share-x"
            data-share-x
            aria-label="Compartir en X"
            title="Compartir en X"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
          </button>
          <button type="button" class="tier-btn tier-btn-ghost" data-share-download>
            Descargar
          </button>
          <button type="button" class="tier-btn tier-btn-ghost" data-share-copy>
            Copiar
          </button>
        </div>
        <p class="tier-share-hint">
          Copiada al portapapeles · pega con <kbd data-paste-shortcut>Ctrl + V</kbd>
        </p>
        <p class="tier-share-status" data-share-status aria-live="polite"></p>
      </div>
    </div>
  </dialog>
</div>

<style is:inline>
  .tier-list-app {
    width: 100%;
    max-width: 56rem;
    margin-inline: auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ── Templates ── */
  .tier-templates {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 0.85rem;
  }

  .tier-template-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.85rem;
    border-radius: 9999px;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 28%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 70%, black);
    color: color-mix(in srgb, var(--color-theme-cream) 78%, transparent);
    font-family: var(--font-cinzel);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      border-color 200ms,
      background 200ms,
      color 200ms,
      box-shadow 200ms;
  }

  .tier-template-chip:hover,
  .tier-template-chip:focus-visible {
    border-color: color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
    color: var(--color-theme-cream);
    outline: none;
  }

  .tier-template-chip[aria-selected='true'] {
    border-color: color-mix(in srgb, var(--color-theme-gold) 70%, transparent);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 22%, var(--color-theme-midnight)),
      color-mix(in srgb, var(--color-theme-midnight) 90%, black)
    );
    color: var(--color-theme-gold);
    box-shadow: 0 0 20px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
  }

  .tier-template-emoji {
    font-size: 0.9rem;
    line-height: 1;
  }

  .tier-template-desc {
    margin: 0 0 1.25rem;
    text-align: center;
    font-family: var(--font-fallback);
    font-size: 0.85rem;
    line-height: 1.45;
    color: color-mix(in srgb, var(--color-theme-cream) 58%, transparent);
    min-height: 1.3em;
  }

  /* ── Title ── */
  .tier-title-wrap {
    display: flex;
    justify-content: center;
    margin-bottom: 1.25rem;
  }

  .tier-title-input {
    width: min(100%, 28rem);
    padding: 0.55rem 1rem;
    border: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
    background: transparent;
    color: var(--color-theme-cream);
    font-family: var(--font-cinzel);
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-align: center;
    text-transform: uppercase;
    outline: none;
    transition: border-color 200ms, box-shadow 200ms;
  }

  .tier-title-input:focus {
    border-bottom-color: var(--color-theme-gold);
    box-shadow: 0 1px 0 0 var(--color-theme-gold);
  }

  @media (min-width: 640px) {
    .tier-title-input {
      font-size: 1.4rem;
    }
  }

  /* ── Board ── */
  .tier-board {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1.5rem;
    border-radius: 0.35rem;
    overflow: hidden;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 18%, transparent),
      0 18px 48px rgba(0, 0, 0, 0.35);
  }

  .tier-row {
    display: grid;
    grid-template-columns: 4.25rem 1fr;
    min-height: 3.75rem;
    align-items: stretch;
    background: color-mix(in srgb, var(--color-velada-navy) 55%, var(--color-theme-midnight));
  }

  @media (min-width: 640px) {
    .tier-row {
      grid-template-columns: 5.25rem 1fr;
      min-height: 4.25rem;
    }
  }

  /* En personalizado la columna de etiqueta se ensancha si el texto es largo. */
  .tier-row[data-editable-labels='true'] {
    grid-template-columns: minmax(4.5rem, 6.75rem) 1fr;
  }

  @media (min-width: 640px) {
    .tier-row[data-editable-labels='true'] {
      grid-template-columns: minmax(5.25rem, 7.5rem) 1fr;
    }
  }

  .tier-row-label {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    gap: 0.1rem;
    padding: 0.25rem 0.2rem;
    font-family: var(--font-cinzel);
    font-weight: 900;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    color: #1a1208;
    text-align: center;
    user-select: none;
    word-break: break-word;
    line-height: 1.05;
    min-width: 0;
    height: 100%;
  }

  @media (min-width: 640px) {
    .tier-row-label {
      font-size: 1.4rem;
    }
  }

  /* Con subtítulo: letra un poco más compacta, bloque siempre centrado en vertical. */
  .tier-row-label:has(.tier-row-hint) .tier-row-label-text {
    font-size: 1rem;
    line-height: 1;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .tier-row-label:has(.tier-row-hint) .tier-row-label-text {
      font-size: 1.2rem;
    }
  }

  /* Texto libre largo (plantilla personalizado sin letra): 2 líneas, más pequeño. */
  .tier-row-label[data-long='true'] {
    font-size: 0.62rem;
    letter-spacing: 0.02em;
    line-height: 1.15;
  }

  @media (min-width: 640px) {
    .tier-row-label[data-long='true'] {
      font-size: 0.72rem;
    }
  }

  .tier-row-label-text {
    display: block;
    max-width: 100%;
    overflow-wrap: anywhere;
    hyphens: auto;
  }

  .tier-row-label[data-long='true'] .tier-row-label-text {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
  }

  button.tier-row-label {
    border: none;
    appearance: none;
    -webkit-appearance: none;
  }

  .tier-row-label--editable {
    cursor: pointer;
    transition:
      filter 150ms ease,
      box-shadow 150ms ease;
  }

  .tier-row-label--editable:hover,
  .tier-row-label--editable:focus-visible {
    filter: brightness(1.06);
    box-shadow: inset 0 0 0 2px rgba(26, 18, 8, 0.28);
    outline: none;
  }

  .tier-row-label-input {
    width: 100%;
    min-width: 0;
    max-width: 100%;
    margin: 0;
    padding: 0.15rem 0.2rem;
    border: none;
    border-radius: 0.2rem;
    background: rgba(255, 255, 255, 0.55);
    box-shadow: inset 0 0 0 1px rgba(26, 18, 8, 0.25);
    color: #1a1208;
    font-family: var(--font-cinzel);
    font-weight: 900;
    font-size: 0.72rem;
    letter-spacing: 0.02em;
    text-align: center;
    line-height: 1.15;
    outline: none;
  }

  @media (min-width: 640px) {
    .tier-row-label-input {
      font-size: 0.82rem;
    }
  }

  .tier-row-hint {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    overflow: hidden;
    font-family: var(--font-fallback);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    opacity: 0.82;
    line-height: 1.15;
    max-width: 100%;
    width: 100%;
    padding-inline: 0.1rem;
    overflow-wrap: anywhere;
    word-break: break-word;
    white-space: normal;
    text-overflow: unset;
  }

  @media (min-width: 640px) {
    .tier-row-hint {
      font-size: 0.55rem;
    }
  }

  .tier-row-drop {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    align-content: center;
    gap: 0.3rem;
    padding: 0.3rem;
    min-height: 100%;
    border-left: 1px solid color-mix(in srgb, var(--color-theme-gold) 12%, transparent);
    transition: background 150ms, box-shadow 150ms;
  }

  .tier-row-drop[data-drag-over='true'] {
    background: color-mix(in srgb, var(--color-theme-gold) 12%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
  }

  /* ── Fighter chip ── */
  .tier-fighter {
    position: relative;
    width: 3.35rem;
    height: 3.35rem;
    flex-shrink: 0;
    border-radius: 0.3rem;
    overflow: hidden;
    cursor: grab;
    touch-action: none;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 30%, transparent),
      0 4px 12px rgba(0, 0, 0, 0.35);
    transition:
      transform 150ms ease,
      box-shadow 150ms ease,
      opacity 150ms ease;
    background: var(--color-theme-midnight);
  }

  @media (min-width: 640px) {
    .tier-fighter {
      width: 3.75rem;
      height: 3.75rem;
    }
  }

  @media (min-width: 1024px) {
    .tier-fighter {
      width: 4rem;
      height: 4rem;
    }
  }

  .tier-fighter:hover,
  .tier-fighter:focus-visible {
    transform: translateY(-2px) scale(1.04);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 60%, transparent),
      0 8px 20px color-mix(in srgb, var(--color-theme-gold) 25%, transparent);
    outline: none;
    z-index: 1;
  }

  .tier-fighter:active {
    cursor: grabbing;
  }

  .tier-fighter[data-dragging='true'] {
    opacity: 0.45;
    transform: scale(0.95);
  }

  .tier-fighter img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    pointer-events: none;
    user-select: none;
  }

  .tier-fighter-name {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 0.75rem 0.15rem 0.15rem;
    background: linear-gradient(to top, rgba(5, 8, 18, 0.94), transparent);
    color: var(--color-theme-cream);
    font-family: var(--font-cinzel);
    font-size: 0.45rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
    line-height: 1.1;
    pointer-events: none;
  }

  @media (min-width: 640px) {
    .tier-fighter-name {
      font-size: 0.5rem;
      padding-top: 0.9rem;
    }
  }

  @media (min-width: 1024px) {
    .tier-fighter-name {
      font-size: 0.52rem;
    }
  }

  /* En el pool las celdas del grid ya marcan el tamaño; el nombre crece un poco. */
  .tier-pool .tier-fighter-name {
    font-size: 0.5rem;
    padding-top: 1rem;
  }

  @media (min-width: 640px) {
    .tier-pool .tier-fighter-name {
      font-size: 0.55rem;
    }
  }

  /* ── Pool ── */
  .tier-pool-section {
    margin-bottom: 1.5rem;
  }

  .tier-pool-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.35rem 1rem;
    margin-bottom: 0.65rem;
  }

  .tier-pool-title {
    margin: 0;
    font-family: var(--font-cinzel);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-theme-gold);
  }

  .tier-pool-hint {
    margin: 0;
    font-family: var(--font-fallback);
    font-size: 0.75rem;
    color: color-mix(in srgb, var(--color-theme-cream) 50%, transparent);
  }

  /*
   * Grid fija para repartir 20 luchadores en filas iguales:
   *  - móvil: 5 por fila (4 filas)
   *  - desktop: 10 por fila (2 filas)
   * Las miniaturas ocupan todo el hueco → más grandes y simétricas.
   */
  .tier-pool {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.5rem;
    min-height: 5rem;
    padding: 0.85rem;
    border-radius: 0.35rem;
    background: color-mix(in srgb, var(--color-theme-midnight) 60%, black);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 16%, transparent);
    transition: background 150ms, box-shadow 150ms;
  }

  @media (min-width: 640px) {
    .tier-pool {
      grid-template-columns: repeat(10, minmax(0, 1fr));
      gap: 0.55rem;
      padding: 1rem;
    }
  }

  .tier-pool[data-drag-over='true'] {
    background: color-mix(in srgb, var(--color-theme-gold) 8%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 40%, transparent);
  }

  /* En el pool, la miniatura crece al 100% de la celda del grid. */
  .tier-pool .tier-fighter {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    max-width: none;
  }

  .tier-pool:empty::after {
    content: '¡Todos clasificados! 🥊';
    grid-column: 1 / -1;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: 3.5rem;
    font-family: var(--font-cinzel);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 70%, transparent);
  }

  /* ── Actions ── */
  .tier-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
  }

  .tier-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
    min-height: 2.75rem;
    padding: 0.55rem 1.15rem;
    border-radius: 9999px;
    border: none;
    font-family: var(--font-cinzel);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 200ms ease,
      box-shadow 200ms ease,
      background 200ms ease,
      color 200ms ease;
  }

