</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import {
    DEFAULT_TEMPLATE_ID,
    POOL_ID,
    TIER_TEMPLATES,
    createEmptyPlacement,
    createPlacementFromPreset,
    type TierDefinition,
    type TierPlacement,
    type TierTemplate,
  } from '@/consts/tier-list'
  import { BOXERS, getBoxerSelectImage } from '@/consts/boxers'
  import {
    buildTierListBlob,
    placementForImage,
    type ShareFormat,
    type TierListImageBoxer,
  } from '@/lib/tier-list-image'
  import {
    canShareImageFile,
    copyImageToClipboard,
    downloadBlob,
    isShareAbort,
    openXIntent,
    shareImageFile,
  } from '@/lib/share-image'

  interface BoxerPayload {
    id: string
    name: string
    imageUrl: string
  }

  const STORAGE_KEY = 'velada-tier-list-v1'
  const SHARE_URL = 'https://www.infolavelada.com/tier-list'
  const FILE_NAME = 'tier-list-la-velada-vi.png'

  // Datos importados directamente (sin embebido JSON en el HTML, que fallaba
  // al parsear y dejaba currentTemplate en undefined).
  const templates: TierTemplate[] = TIER_TEMPLATES
  const boxers: BoxerPayload[] = BOXERS.map((b) => ({
    id: b.id,
    name: b.name,
    imageUrl: getBoxerSelectImage(b),
  }))

  /** macOS / iOS → ⌘; Windows y Linux → Ctrl. */
  function isApplePlatform(): boolean {
    const nav = navigator as Navigator & { userAgentData?: { platform?: string } }
    const platform = nav.userAgentData?.platform ?? nav.platform ?? ''
    if (/mac|iphone|ipad|ipod/i.test(platform)) return true
    // Safari a veces deja platform genérico; el UA sigue siendo fiable.
    return /Mac OS X|Macintosh|iPhone|iPad|iPod/i.test(nav.userAgent)
  }

  const PASTE_SHORTCUT = isApplePlatform() ? 'Cmd + V' : 'Ctrl + V'

  let appAbort: AbortController | null = null
  let bootstrappedRoot: HTMLElement | null = null

  function inContext<T extends Element>(selector: string, ctx: Element | null): T | null {
    if (!ctx) return null
    return $<T>(selector, ctx)
  }

  function resolveTemplate(id: string | undefined): TierTemplate {
    const fromId = id ? templates.find((t) => t.id === id) : undefined
    const fallback = templates[0]
    if (!fromId && !fallback) {
      throw new Error('[tier-list] No hay plantillas definidas')
    }
    return fromId ?? fallback!
  }

  function setupApp() {
    const root = $<HTMLElement>('[data-tier-list-app]')
    if (!root) return

    // Evita re-inicializar el mismo nodo tras un page-load duplicado.
    if (bootstrappedRoot === root && root.dataset.tierReady === 'true') return

    if (!templates.length || !boxers.length) {
      console.error('[tier-list] Faltan plantillas o luchadores')
      return
    }

    appAbort?.abort()
    appAbort = null

    const boxerIds = boxers.map((b) => b.id)
    const boxersById = Object.fromEntries(boxers.map((b) => [b.id, b]))
    const defaultTemplateId = root.dataset.defaultTemplate || DEFAULT_TEMPLATE_ID

    appAbort = new AbortController()
    const { signal } = appAbort

    const board = inContext<HTMLElement>('[data-tier-board]', root)
    const pool = inContext<HTMLElement>('[data-tier-pool]', root)
    const titleInput = inContext<HTMLInputElement>('[data-tier-title]', root)
    const descEl = inContext<HTMLElement>('[data-template-desc]', root)
    const pickOverlay = inContext<HTMLElement>('[data-tier-pick]', root)
    const pickName = inContext<HTMLElement>('[data-tier-pick-name]', root)
    const pickOptions = inContext<HTMLElement>('[data-tier-pick-options]', root)
    const shareModal = inContext<HTMLDialogElement>('[data-tier-share-modal]', root)
    const shareFigure = inContext<HTMLElement>('[data-share-figure]', shareModal)
    const sharePreview = inContext<HTMLImageElement>('[data-share-preview]', shareModal)
    const shareFrame = inContext<HTMLElement>('.tier-share-frame', shareModal)
    const shareStatus = inContext<HTMLElement>('[data-share-status]', shareModal)
    const nativeShareBtn = inContext<HTMLButtonElement>('[data-native-share-btn]', shareModal)
    const pasteShortcutEl = inContext<HTMLElement>('[data-paste-shortcut]', shareModal)
    if (pasteShortcutEl) pasteShortcutEl.textContent = PASTE_SHORTCUT

    if (!board || !pool || !titleInput) return

    let currentTemplate: TierTemplate = resolveTemplate(defaultTemplateId)
    let placement: TierPlacement = createEmptyPlacement(
      boxerIds,
      currentTemplate.tiers.map((t) => t.id),
    )
    let dragBoxerId: string | null = null
    /** Tras un drag, ignoramos el click residual. Se limpia siempre en drop/dragend. */
    let suppressClickUntil = 0
    let pickBoxerId: string | null = null
    let shareFormat: ShareFormat = 'instagram'
    let cachedBlob: Blob | null = null
    let previewUrl: string | null = null
    let blobCacheKey = ''

    const CUSTOM_TEMPLATE_ID = 'custom'
    const LABEL_MAX_LEN = 18

    function isCustomTemplate(): boolean {
      return currentTemplate.id === CUSTOM_TEMPLATE_ID
    }

    /** Clona la plantilla para poder editar labels sin mutar las constantes. */
    function cloneTemplate(template: TierTemplate): TierTemplate {
      return {
        ...template,
        tiers: template.tiers.map((t) => ({ ...t })),
      }
    }

    function applyTierLabels(
      template: TierTemplate,
      labels?: Record<string, string> | null,
    ): TierTemplate {
      const next = cloneTemplate(template)
      if (!labels) return next
      for (const tier of next.tiers) {
        const custom = labels[tier.id]
        if (typeof custom === 'string' && custom.trim()) {
          tier.label = custom.trim().slice(0, LABEL_MAX_LEN)
          tier.hint = undefined
        }
      }
      return next
    }

    // ── Persistence ──
    function saveState() {
      try {
        const tierLabels = isCustomTemplate()
          ? Object.fromEntries(currentTemplate.tiers.map((t) => [t.id, t.label]))
          : undefined
        localStorage.setItem(
          STORAGE_KEY,
          JSON.stringify({
            templateId: currentTemplate.id,
            title: titleInput!.value,
            placement,
            tierLabels,
          }),
        )
      } catch {
        // ignore quota / private mode
      }
    }

    function loadState(): boolean {
      try {
        const raw = localStorage.getItem(STORAGE_KEY)
        if (!raw) return false
        const data = JSON.parse(raw) as {
          templateId?: string
          title?: string
          placement?: TierPlacement
          tierLabels?: Record<string, string>
        }
        const tpl = templates.find((t) => t.id === data.templateId)
        if (!tpl || !data.placement) return false
        currentTemplate = applyTierLabels(tpl, data.tierLabels)
        titleInput!.value = data.title || tpl.title
        // Reconciliar ids por si cambió el cartel
        const tierIds = currentTemplate.tiers.map((t) => t.id)
        const next = createEmptyPlacement(boxerIds, tierIds)
        const seen = new Set<string>()
        for (const tierId of [...tierIds, POOL_ID]) {
          const ids = (data.placement[tierId] ?? []).filter(
            (id) => boxerIds.includes(id) && !seen.has(id),
          )
          next[tierId] = ids
          for (const id of ids) seen.add(id)
        }
        next[POOL_ID] = boxerIds.filter((id) => !seen.has(id))
        placement = next
        return true
      } catch {
        return false
      }
    }

    // ── DOM builders ──
    function fighterEl(id: string): HTMLElement {
      const boxer = boxersById[id]!
      const btn = document.createElement('button')
      btn.type = 'button'
      btn.className = 'tier-fighter'
      btn.draggable = true
      btn.dataset.boxerId = id
      btn.setAttribute('aria-label', boxer.name)
      btn.setAttribute('role', 'listitem')

      const img = document.createElement('img')
      img.src = boxer.imageUrl
      img.alt = ''
      img.loading = 'lazy'
      img.draggable = false
      btn.appendChild(img)

      const name = document.createElement('span')
      name.className = 'tier-fighter-name'
      name.textContent = boxer.name
      btn.appendChild(name)

      return btn
    }

    function escapeHtml(text: string): string {
      return text
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
    }

    function renderBoard() {
      board!.replaceChildren()
      const editable = isCustomTemplate()

      for (const tier of currentTemplate.tiers) {
        const row = document.createElement('div')
        row.className = 'tier-row'
        row.setAttribute('role', 'listitem')
        row.dataset.tierId = tier.id
        if (editable) row.dataset.editableLabels = 'true'

        const label = document.createElement(editable ? 'button' : 'div')
        label.className = 'tier-row-label'
        if (editable) {
          ;(label as HTMLButtonElement).type = 'button'
          label.classList.add('tier-row-label--editable')
          label.setAttribute('data-edit-tier-label', tier.id)
          label.setAttribute(
            'aria-label',
            `Editar nombre del tier ${tier.label}. Clic para cambiar el texto.`,
          )
          label.title = 'Clic para editar el texto'
        }
        label.style.background = tier.color
        label.style.color = tier.textColor ?? '#1a1208'
        if (tier.label.length > 2) label.dataset.long = 'true'
        label.innerHTML = `<span class="tier-row-label-text">${escapeHtml(tier.label)}</span>${
          tier.hint ? `<span class="tier-row-hint">${escapeHtml(tier.hint)}</span>` : ''
        }`

        const drop = document.createElement('div')
        drop.className = 'tier-row-drop'
        drop.dataset.dropZone = tier.id
        drop.setAttribute('role', 'list')
        drop.setAttribute('aria-label', `Tier ${tier.label}${tier.hint ? `: ${tier.hint}` : ''}`)

        for (const id of placement[tier.id] ?? []) {
          drop.appendChild(fighterEl(id))
        }

        row.append(label, drop)
        board!.appendChild(row)
      }
    }

    function renderPool() {
      pool!.replaceChildren()
      for (const id of placement[POOL_ID] ?? []) {
        pool!.appendChild(fighterEl(id))
      }
    }

    function renderAll() {
      renderBoard()
      renderPool()
      updateTemplateChips()
      if (descEl) descEl.textContent = currentTemplate.description
      saveState()
      cachedBlob = null
    }

    function updateTemplateChips() {
      $$<HTMLButtonElement>('[data-template-id]', root).forEach((chip) => {
        chip.setAttribute(
          'aria-selected',
          chip.dataset.templateId === currentTemplate.id ? 'true' : 'false',
        )
      })
    }

    function applyTemplate(template: TierTemplate, resetPlacement = true) {
      currentTemplate = cloneTemplate(template)
      titleInput!.value = template.title
      if (resetPlacement) {
        placement = createPlacementFromPreset(
          boxerIds,
          currentTemplate.tiers.map((t) => t.id),
          template.preset,
        )
      }
      renderAll()
    }

    function setTierLabel(tierId: string, nextLabel: string) {
      const tier = currentTemplate.tiers.find((t) => t.id === tierId)
      if (!tier) return
      const cleaned = nextLabel.trim().slice(0, LABEL_MAX_LEN) || tier.label
      tier.label = cleaned
      tier.hint = undefined
      renderAll()
    }

    function beginEditTierLabel(tierId: string, labelEl: HTMLElement) {
      if (!isCustomTemplate()) return
      if (labelEl.dataset.editing === 'true') return

      const tier = currentTemplate.tiers.find((t) => t.id === tierId)
      if (!tier) return

      labelEl.dataset.editing = 'true'
      labelEl.replaceChildren()

      const input = document.createElement('input')
      input.type = 'text'
      input.className = 'tier-row-label-input'
      input.value = tier.label
      input.maxLength = LABEL_MAX_LEN
      input.setAttribute('aria-label', 'Nombre del tier')
      input.autocomplete = 'off'
      input.spellcheck = false

      let finished = false
      const finish = (commit: boolean) => {
        if (finished) return
        finished = true
        if (commit) setTierLabel(tierId, input.value)
        else renderBoard()
      }

      input.addEventListener('keydown', (ev) => {
        if (ev.key === 'Enter') {
          ev.preventDefault()
          finish(true)
        } else if (ev.key === 'Escape') {
          ev.preventDefault()
          finish(false)
        }
      })
      input.addEventListener('blur', () => finish(true))

      labelEl.appendChild(input)
      input.focus()
      input.select()
    }

    // ── Placement mutations ──
    function findZoneOf(boxerId: string): string | null {
      for (const [zone, ids] of Object.entries(placement)) {
        if (ids.includes(boxerId)) return zone
      }
      return null
    }

    function moveBoxer(boxerId: string, toZone: string, beforeId?: string | null) {
      const fromZone = findZoneOf(boxerId)
      if (!fromZone) return
      placement[fromZone] = (placement[fromZone] ?? []).filter((id) => id !== boxerId)

      const target = [...(placement[toZone] ?? [])].filter((id) => id !== boxerId)
      if (beforeId && target.includes(beforeId)) {
        const idx = target.indexOf(beforeId)
        target.splice(idx, 0, boxerId)
      } else {
        target.push(boxerId)
      }
      placement[toZone] = target
      renderAll()
    }

    // ── Drag & drop ──
    function getDropZone(el: EventTarget | null): HTMLElement | null {
      if (!(el instanceof Element)) return null
      return el.closest<HTMLElement>('[data-drop-zone]')
    }

    function markDragJustFinished() {
      // Ventana corta para tragar el click residual del drop.
      // Importante: no usar un booleano sticky — si `dragend` no llega
      // (el nodo se destruye en `renderAll`), el flag quedaría true para siempre.
      suppressClickUntil = Date.now() + 150
      dragBoxerId = null
    }

    function onDragStart(e: DragEvent) {
      const fighter = (e.target as Element).closest<HTMLElement>('.tier-fighter')
      if (!fighter?.dataset.boxerId || !e.dataTransfer) return
      dragBoxerId = fighter.dataset.boxerId
      fighter.dataset.dragging = 'true'
      e.dataTransfer.effectAllowed = 'move'
      e.dataTransfer.setData('text/plain', dragBoxerId)
      // Fantasma más limpio
      try {
        e.dataTransfer.setDragImage(fighter, fighter.offsetWidth / 2, fighter.offsetHeight / 2)
      } catch {
        // algunos navegadores son estrictos
      }
    }

    function onDragEnd() {
      $$<HTMLElement>('.tier-fighter[data-dragging]', root).forEach((el) => {
        el.removeAttribute('data-dragging')
      })
      $$<HTMLElement>('[data-drag-over]', root).forEach((el) => {
        el.removeAttribute('data-drag-over')
      })
      markDragJustFinished()
    }

    function onDragOver(e: DragEvent) {
      const zone = getDropZone(e.target)
      if (!zone || !dragBoxerId) return
      e.preventDefault()
      e.dataTransfer && (e.dataTransfer.dropEffect = 'move')
      $$<HTMLElement>('[data-drag-over]', root).forEach((el) => {
        if (el !== zone) el.removeAttribute('data-drag-over')
      })
      zone.dataset.dragOver = 'true'
    }

    function onDragLeave(e: DragEvent) {
      const zone = getDropZone(e.target)
      if (!zone) return
      const related = e.relatedTarget as Node | null
      if (related && zone.contains(related)) return
      zone.removeAttribute('data-drag-over')
    }

    function onDrop(e: DragEvent) {
      e.preventDefault()
      const zone = getDropZone(e.target)
      const boxerId = dragBoxerId ?? e.dataTransfer?.getData('text/plain')
      if (!zone || !boxerId) return
      zone.removeAttribute('data-drag-over')

      const overFighter = (e.target as Element).closest<HTMLElement>('.tier-fighter')
      const beforeId =
        overFighter?.dataset.boxerId && overFighter.dataset.boxerId !== boxerId
          ? overFighter.dataset.boxerId
          : null

      // Marcar ANTES de re-render: al reemplazar el DOM, `dragend` a veces no llega.
      markDragJustFinished()
      moveBoxer(boxerId, zone.dataset.dropZone!, beforeId)
    }

    // ── Click-to-place (móvil / teclado) ──
    function openPick(boxerId: string) {
      pickBoxerId = boxerId
      if (pickName) pickName.textContent = boxersById[boxerId]?.name ?? boxerId
      if (pickOptions) {
        pickOptions.replaceChildren()
        for (const tier of currentTemplate.tiers) {
          const btn = document.createElement('button')
          btn.type = 'button'
          btn.className = 'tier-pick-option'
          btn.style.background = tier.color
          btn.dataset.pickZone = tier.id
          btn.innerHTML = `<span>${tier.label}</span>${
            tier.hint ? `<span class="tier-pick-option-hint">${tier.hint}</span>` : ''
          }`
          pickOptions.appendChild(btn)
        }
        const poolBtn = document.createElement('button')
        poolBtn.type = 'button'
        poolBtn.className = 'tier-pick-option tier-pick-option-pool'
        poolBtn.dataset.pickZone = POOL_ID
        poolBtn.textContent = 'Volver al pool'
        pickOptions.appendChild(poolBtn)
      }
      pickOverlay?.removeAttribute('hidden')
      if (pickOverlay) $<HTMLButtonElement>('.tier-pick-option', pickOverlay)?.focus()
    }

    function closePick() {
      pickBoxerId = null
      pickOverlay?.setAttribute('hidden', '')
    }

    function onFighterActivate(e: Event) {
      const fighter = (e.target as Element).closest<HTMLElement>('.tier-fighter')
      if (!fighter?.dataset.boxerId) return
      // En drag real (o el click residual al soltar) no disparamos el pick
      if (dragBoxerId || Date.now() < suppressClickUntil) return
      e.preventDefault()
      openPick(fighter.dataset.boxerId)
    }

    // ── Share ──
    function setStatus(text: string, kind: 'info' | 'success' | 'error' = 'info') {
      if (!shareStatus) return
      shareStatus.textContent = text
      if (kind === 'info') shareStatus.removeAttribute('data-status')
      else shareStatus.dataset.status = kind
    }

    function rankedCount(): number {
      return boxerIds.length - (placement[POOL_ID]?.length ?? 0)
    }

    function shareText(): string {
      const title = titleInput!.value.trim() || currentTemplate.title
      return `Mi tier list «${title}» de #LaVeladaDelAñoVI 🥊\n${SHARE_URL}`
    }

    function imageInput() {
      return {
        title: titleInput!.value.trim() || currentTemplate.title,
        tiers: currentTemplate.tiers as TierDefinition[],
        placement: placementForImage(placement),
        boxers: boxers as TierListImageBoxer[],
        format: shareFormat,
      }
    }

    async function getBlob(): Promise<Blob> {
      const key = JSON.stringify({
        t: titleInput!.value,
        p: placement,
        f: shareFormat,
        tpl: currentTemplate.id,
      })
      if (cachedBlob && blobCacheKey === key) return cachedBlob
      cachedBlob = await buildTierListBlob(imageInput())
      blobCacheKey = key
      return cachedBlob
    }

    async function renderPreview() {
      if (!sharePreview || !shareFigure) return
      shareFigure.removeAttribute('data-ready')
      try {
        const blob = await getBlob()
        if (previewUrl) URL.revokeObjectURL(previewUrl)
        previewUrl = URL.createObjectURL(blob)
        sharePreview.src = previewUrl
        shareFigure.setAttribute('data-ready', '')
      } catch (err) {
        setStatus('No se pudo generar la imagen.', 'error')
        console.error(err)
      }
    }

    function openShareModal() {
      if (!shareModal) return
      if (rankedCount() === 0) {
        // Permitimos compartir vacío pero avisamos
        setStatus('Coloca al menos un luchador para un mejor resultado.', 'info')
      } else {
        setStatus('', 'info')
      }
      shareFigure?.removeAttribute('data-ready')
      shareModal.showModal()
      if (canShareImageFile()) nativeShareBtn?.removeAttribute('hidden')
      else nativeShareBtn?.setAttribute('hidden', '')
      void renderPreview()
    }

    function closeShareModal() {
      shareModal?.close()
      setStatus('', 'info')
    }

    async function handleDownload() {
      setStatus('Descargando…', 'info')
      try {
        const blob = await getBlob()
        downloadBlob(blob, FILE_NAME)
        setStatus('¡Imagen descargada!', 'success')
      } catch (err) {
        setStatus('Error al descargar.', 'error')
        console.error(err)
      }
    }

    async function handleCopy() {
      setStatus('Copiando…', 'info')
      try {
        const blob = await getBlob()
        const ok = await copyImageToClipboard(blob)
        if (!ok) throw new Error('clipboard')
        setStatus('¡Imagen copiada! Pégala donde quieras.', 'success')
      } catch (err) {
        setStatus('No se pudo copiar. Prueba a descargar.', 'error')
        console.error(err)
      }
    }

    async function handleShareX() {
      setStatus('Preparando para X…', 'info')
      try {
        const blob = await getBlob()
        const ok = await copyImageToClipboard(blob)
        openXIntent(shareText())
        if (ok) setStatus(`Imagen copiada ✓ Pégala en X con ${PASTE_SHORTCUT}.`, 'success')
        else {
          downloadBlob(blob, FILE_NAME)
          setStatus('Descargamos la imagen: adjúntala en tu post de X.', 'success')
        }
      } catch (err) {
        setStatus('Error al compartir en X.', 'error')
        console.error(err)
      }
    }

    async function handleNativeShare() {
      setStatus('Preparando…', 'info')
      try {
        const blob = await getBlob()
        await shareImageFile(blob, FILE_NAME, shareText())
        setStatus('¡Gracias por compartir!', 'success')
      } catch (err) {
        if (isShareAbort(err)) setStatus('', 'info')
        else {
          setStatus('No se pudo compartir. Prueba a descargar.', 'error')
          console.error(err)
        }
      }
    }

    // ── Events ──
    root.addEventListener('dragstart', onDragStart, { signal })
    root.addEventListener('dragend', onDragEnd, { signal })
    root.addEventListener('dragover', onDragOver, { signal })
    root.addEventListener('dragleave', onDragLeave, { signal })
    root.addEventListener('drop', onDrop, { signal })

    root.addEventListener(
      'click',
      (e) => {
        const target = e.target as Element

        const templateBtn = target.closest<HTMLButtonElement>('[data-template-id]')
        if (templateBtn?.dataset.templateId) {
          const tpl = templates.find((t) => t.id === templateBtn.dataset.templateId)
          if (tpl && tpl.id !== currentTemplate.id) {
            const hasWork = rankedCount() > 0
            if (
              hasWork &&
              !confirm('¿Cambiar de plantilla? Se reiniciará la clasificación actual.')
            ) {
              return
            }
            applyTemplate(tpl, true)
          }
          return
        }

        const editLabelBtn = target.closest<HTMLElement>('[data-edit-tier-label]')
        if (editLabelBtn?.dataset.editTierLabel) {
          beginEditTierLabel(editLabelBtn.dataset.editTierLabel, editLabelBtn)
          return
        }

        if (target.closest('[data-tier-reset]')) {
          if (rankedCount() > 0 && !confirm('¿Reiniciar el tier list?')) return
          // Al reiniciar en personalizado también restauramos las letras S–F.
          if (isCustomTemplate()) {
            const base = templates.find((t) => t.id === CUSTOM_TEMPLATE_ID)
            if (base) currentTemplate = cloneTemplate(base)
          }
          placement = createEmptyPlacement(
            boxerIds,
            currentTemplate.tiers.map((t) => t.id),
          )
          titleInput!.value = currentTemplate.title
          renderAll()
          return
        }

        if (target.closest('[data-tier-share]')) {
          openShareModal()
          return
        }

        if (target.closest('.tier-fighter')) {
          onFighterActivate(e)
          return
        }

        // Pick options
        const pickZone = target.closest<HTMLElement>('[data-pick-zone]')
        if (pickZone?.dataset.pickZone && pickBoxerId) {
          moveBoxer(pickBoxerId, pickZone.dataset.pickZone)
          closePick()
          return
        }

        if (target.closest('[data-tier-pick-cancel]') || target === pickOverlay) {
          closePick()
          return
        }

        // Share modal
        if (target.closest('[data-share-close]')) {
          closeShareModal()
          return
        }

        const formatBtn = target.closest<HTMLButtonElement>('[data-share-format]')
        if (formatBtn?.dataset.shareFormat) {
          shareFormat = formatBtn.dataset.shareFormat as ShareFormat
          if (shareModal) {
            $$<HTMLButtonElement>('[data-share-format]', shareModal).forEach((b) => {
              b.setAttribute(
                'aria-pressed',
                b.dataset.shareFormat === shareFormat ? 'true' : 'false',
              )
            })
          }
          shareFrame?.setAttribute('data-format', shareFormat)
          cachedBlob = null
          void renderPreview()
          return
        }

        if (target.closest('[data-share-download]')) {
          void handleDownload()
          return
        }
        if (target.closest('[data-share-copy]')) {
          void handleCopy()
          return
        }
        if (target.closest('[data-share-x]')) {
          void handleShareX()
          return
        }
        if (target.closest('[data-native-share-btn]')) {
          void handleNativeShare()
          return
        }
      },
      { signal },
    )

    titleInput.addEventListener(
      'input',
      () => {
        saveState()
        cachedBlob = null
      },
      { signal },
    )

    shareModal?.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          e.preventDefault()
          closeShareModal()
        }
      },
      { signal, capture: true },
    )

    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape' && pickOverlay && !pickOverlay.hasAttribute('hidden')) {
          closePick()
        }
      },
      { signal },
    )

    // Init
    if (!loadState()) {
      applyTemplate(currentTemplate, true)
    } else {
      renderAll()
    }

    bootstrappedRoot = root
    root.dataset.tierReady = 'true'
  }

  // Con ClientRouter, el listener de page-load cubre la 1ª carga y las
  // navegaciones SPA. Además, invocamos al cargar el módulo por si el evento
  // ya se disparó antes de que el script se evaluara (race en SPA).
  document.addEventListener('astro:page-load', setupApp)
  setupApp()
</script>
