---
import VeladaLogo from '@/assets/svg/logo.svg'

interface Props {
  class?: string
  /** Permite agrandar el logo cuando la tarjeta ocupa más espacio (p. ej. a ancho completo en desktop). */
  iconClass?: string
}

const { class: className, iconClass = 'size-16 sm:size-20' } = Astro.props
---

<div
  class:list={[
    'absolute inset-0 -z-10 flex items-center justify-center overflow-hidden bg-theme-midnight',
    className,
  ]}
  aria-hidden="true"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(199,168,107,0.14),_transparent_58%)]"
  >
  </div>
  <div
    class="absolute inset-0 bg-linear-to-br from-theme-navy/70 via-theme-midnight to-black"
  >
  </div>
  <VeladaLogo
    class:list={[
      'relative text-theme-cream/75 drop-shadow-[0_0_28px_rgba(247,238,211,0.14)]',
      iconClass,
    ]}
  />
</div>
