---
import { COUNTRY_NAMES } from '@/consts/boxers'

interface Props {
  /** Código de país alpha-2 (ISO 3166-1). */
  country: string
  /** Tamaño en píxeles. Los SVG son cuadrados 32×32, así que se usa para
   *  el atributo `width`/`height` y como referencia base. */
  size?: number
  /** Clases extra (border-radius, drop-shadow, escalado responsive, …). */
  class?: string
  /** Si la bandera es puramente decorativa (porque junto a ella ya se
   *  muestra el nombre del país como texto), pasa `decorative` para
   *  ocultarla a lectores de pantalla. */
  decorative?: boolean
}

const {
  country,
  size = 16,
  class: className,
  decorative = false,
} = Astro.props

const name = COUNTRY_NAMES[country] ?? country
---

<img
  src={`/flags/${country}.svg`}
  alt={decorative ? '' : `Bandera de ${name}`}
  width={size}
  height={size}
  loading="lazy"
  decoding="async"
  class:list={['country-flag inline-block', className]}
  aria-hidden={decorative ? 'true' : undefined}
/>

<style>
  .country-flag {
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.4));
  }
</style>
