---
interface Props {
  variant: 'desktop' | 'mobile'
}

const { variant } = Astro.props
const currentPathname = Astro.url.pathname

const NAV_ITEMS = [
  { label: 'Boxeadores', href: '/boxeadores', disabled: false },
  { label: 'Combates', href: '/combates', disabled: false },
  { label: 'Artistas', href: '/artistas', disabled: false },
  { label: 'Pronósticos', href: '/pronosticos', disabled: false },
] as const

const shouldReloadNavItem = (href: string) => currentPathname === '/' && href === '/boxeadores'
const isCurrentNavItem = (href: string) =>
  currentPathname === href || currentPathname.startsWith(href + '/')
---

{
  variant === 'desktop' ? (
    <nav class="hidden md:block" aria-label="Navegación principal">
      <ul class="flex items-stretch gap-1 sm:gap-2">
        {NAV_ITEMS.map((item) => (
          <li>
            {item.disabled ? (
              <div class="flex flex-col items-center justify-center gap-1 px-3 sm:px-4">
                <span
                  role="link"
                  aria-disabled="true"
                  class="relative inline-flex items-center font-cinzel text-[0.65rem] leading-none font-black tracking-[0.16em] text-white/55 select-none sm:text-xs"
                  title="Próximamente"
                >
                  {item.label}
                </span>
                {item.note && (
                  <span class="inline-flex items-center rounded-pill border border-theme-gold/55 bg-theme-midnight/90 px-2 py-0.5 font-cinzel text-[0.5rem] leading-none font-black tracking-[0.16em] whitespace-nowrap text-theme-gold sm:text-[0.55rem]">
                    {item.note}
                  </span>
                )}
              </div>
            ) : (
              <a
                href={item.href}
                data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                aria-current={isCurrentNavItem(item.href) ? 'page' : undefined}
                class="group/nav relative inline-flex h-full flex-col items-center justify-center px-3 font-cinzel text-[0.65rem] leading-none font-black tracking-[0.16em] text-white/85 transition-colors duration-150 ease-out outline-none focus-visible:text-theme-cream sm:px-4 sm:text-xs [@media(hover:hover)_and_(pointer:fine)]:hover:text-theme-cream [@media(hover:hover)_and_(pointer:fine)]:hover:delay-125"
              >
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-theme-gold to-transparent opacity-0 transition-opacity [a[aria-current=page]_&]:opacity-100"
                />
                <span
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-x-0 bottom-0 h-px origin-center scale-x-0 bg-linear-to-r from-transparent via-theme-gold to-transparent transition-transform delay-0 duration-150 ease-out group-focus-visible/nav:scale-x-100 [@media(hover:hover)_and_(pointer:fine)]:group-hover/nav:scale-x-100 [@media(hover:hover)_and_(pointer:fine)]:group-hover/nav:delay-125"
                />
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  ) : (
    <nav aria-label="Menú principal móvil" class="relative w-full max-w-sm">
      <ul class="flex flex-col items-center gap-6">
        {NAV_ITEMS.map((item) => (
          <li class="w-full">
            {item.disabled ? (
              <span
                role="link"
                aria-disabled="true"
                class="flex flex-col items-center gap-2 rounded-2xl border border-white/10 bg-white/3 px-5 py-5 text-center font-cinzel text-lg font-black tracking-[0.16em] text-white/55"
                title="Próximamente"
              >
                {item.label}
                {item.note && (
                  <span class="rounded-pill border border-theme-gold/55 bg-theme-midnight/90 px-3 py-1 text-[0.55rem] font-black tracking-[0.16em] text-theme-gold">
                    {item.note}
                  </span>
                )}
              </span>
            ) : (
              <a
                href={item.href}
                data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                aria-current={isCurrentNavItem(item.href) ? 'page' : undefined}
                data-mobile-menu-link
                class="relative flex items-center justify-center rounded-2xl border border-theme-gold/40 bg-theme-midnight/80 px-5 py-5 text-center font-cinzel text-lg font-black tracking-[0.16em] text-theme-cream transition duration-300 outline-none focus-visible:outline focus-visible:outline-offset-4 focus-visible:outline-theme-gold active:border-theme-gold active:bg-theme-midnight [a[aria-current=page]]:border-theme-gold/75"
              >
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute inset-x-0 bottom-0 -z-1 h-full bg-[radial-gradient(ellipse_at_bottom,var(--color-theme-gold)_0%,transparent_70%)] opacity-0 [a[aria-current=page]_&]:opacity-[0.5]"
                />
                {item.label}
              </a>
            )}
          </li>
        ))}
      </ul>
    </nav>
  )
}
