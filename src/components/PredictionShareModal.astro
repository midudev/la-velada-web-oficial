---
import ShareIcon from '@/assets/svg/share.svg'

interface Props {
  totalFights: number
}

const { totalFights } = Astro.props
---

<dialog id="prediction-share-modal" class="prediction-share-modal" data-prediction-share-modal>
  <div class="prediction-share-backdrop animate-fade-in" data-modal-close></div>

  <div class="prediction-share-content animate-fade-in-up animate-delay-100">
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tl"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tr"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-bl"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-br"></span>

    <div class="prediction-share-eyebrow animate-fade-in animate-delay-200" aria-hidden="true">
      <span class="prediction-share-eyebrow-mark"></span>
      <span>PRONÓSTICO COMPLETO</span>
      <span class="prediction-share-eyebrow-mark"></span>
    </div>

    <button type="button" class="prediction-share-close" data-modal-close aria-label="Cerrar modal">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <figure class="prediction-share-figure" data-share-figure aria-hidden="true">
      <div class="prediction-share-figure-frame">
        <img class="prediction-share-figure-img" data-share-preview-img alt="" />
        <span class="prediction-share-figure-loading">Preparando tu imagen…</span>
      </div>
      <figcaption class="prediction-share-figure-caption">Así se verá tu pronóstico</figcaption>
    </figure>

    <div class="prediction-share-main">
      <h2 class="prediction-share-title animate-fade-in-up animate-delay-300">
        ¡Hiciste tu pronóstico para la velada!
      </h2>

      <p
        class="prediction-share-description animate-fade-in animate-delay-500"
        data-share-description
        data-total-fights={totalFights}
      >
        Generamos una imagen con tus {totalFights} votos. Compártela en X o WhatsApp.
      </p>

      <!-- Camino nativo (Web Share API nivel 2): imagen + texto en un solo toque.
         Oculto por defecto; el script lo revela solo donde el navegador soporta
         compartir ficheros (móvil moderno) y oculta el flujo de pasos. -->
      <div
        class="prediction-share-native animate-fade-in-up animate-delay-700"
        data-native-share
        hidden
      >
        <button
          type="button"
          class="prediction-share-pill prediction-share-pill-primary prediction-share-pill-rounded prediction-share-native-btn"
          data-native-share-btn
        >
          <ShareIcon class="prediction-share-pill-icon" aria-hidden="true" />
          Compartir pronóstico
        </button>
        <p class="prediction-share-native-hint" data-native-share-hint>
          Imagen y texto juntos, en un solo toque.
        </p>
      </div>

      <!-- Camino manual (escritorio o navegadores sin Web Share de ficheros):
         botones de compartir directo. X y WhatsApp copian la imagen al
         portapapeles y abren la app con el texto listo en un clic. -->
      <div class="prediction-share-actions" data-share-steps>
        <div class="prediction-share-actions-row">
          <button
            type="button"
            class="prediction-share-pill prediction-share-pill-rounded prediction-share-pill-primary prediction-share-pill-x animate-fade-in-up animate-delay-700"
            data-share-x
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
            Compartir en X
          </button>

          <button
            type="button"
            class="prediction-share-pill prediction-share-pill-rounded prediction-share-pill-whatsapp animate-fade-in-up animate-delay-900"
            data-share-whatsapp
          >
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            WhatsApp
          </button>
        </div>

        <div class="prediction-share-actions-secondary animate-fade-in animate-delay-1100">
          <button
            type="button"
            class="prediction-share-pill prediction-share-pill-rounded"
            data-download-btn
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
            </svg>
            Descargar
          </button>

          <button
            type="button"
            class="prediction-share-pill prediction-share-pill-rounded"
            data-copy-btn
            aria-label="Copiar imagen al portapapeles"
          >
            <svg
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
            </svg>
            Copiar
          </button>
        </div>

        <p class="prediction-share-actions-hint">
          Copiamos la imagen a tu portapapeles: pégala en el post con
          <kbd class="prediction-share-kbd">Ctrl/Cmd&nbsp;+&nbsp;V</kbd>.
        </p>
      </div>

      <p
        class="prediction-share-status animate-fade-in animate-delay-1100"
        data-share-status
        aria-live="polite"
      >
      </p>
    </div>
  </div>
</dialog>

<style>
  .prediction-share-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    align-items: center;
    justify-content: center;
  }

  .prediction-share-modal::backdrop {
    background: transparent;
  }

  .prediction-share-modal[open] {
    display: flex;
  }

  /* ── Exit animation ──
     Cuando el modal tiene data-closing, reemplazamos las clases de
     entrada por las de salida y acortamos la duración para que
     la transición de cierre sea ágil (no espejamos los delays:
     el cierre se siente como una sola ráfaga). */
  .prediction-share-modal[data-closing] .prediction-share-backdrop {
    animation: fade-out 220ms ease-out both;
  }
  .prediction-share-modal[data-closing] .prediction-share-content {
    animation: fade-out-up 280ms ease-out both;
  }
  .prediction-share-modal[data-closing] .prediction-share-eyebrow,
  .prediction-share-modal[data-closing] .prediction-share-title,
  .prediction-share-modal[data-closing] .prediction-share-description,
  .prediction-share-modal[data-closing] .prediction-share-actions,
  .prediction-share-modal[data-closing] .prediction-share-status {
    animation: fade-out 200ms ease-out both;
  }

  .prediction-share-modal[data-closing] {
    scale: 0;
    transition: scale 280ms ease-out;
  }

  .prediction-share-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 16, 36, 0.88);
    backdrop-filter: blur(10px);
  }

  .prediction-share-content {
    position: relative;
    z-index: 1;
    width: calc(100% - 2rem);
    max-width: 28rem;
    margin: 1rem;
    padding: 2.5rem 1.5rem 1.75rem;
    border-radius: var(--radius-sharp);
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 10%, transparent),
        transparent 70%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-velada-navy) 35%, var(--color-theme-midnight)) 0%,
        color-mix(in srgb, var(--color-theme-midnight) 94%, black) 100%
      );
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 30%, transparent),
      0 32px 80px rgba(0, 0, 0, 0.6),
      0 0 60px color-mix(in srgb, var(--color-theme-gold) 10%, transparent);
  }

  @media (min-width: 640px) {
    .prediction-share-content {
      padding: 2.75rem 2rem 2rem;
    }
  }

  /* ── Vista previa de la imagen a compartir ──
     Oculta en móvil (el modal ya es alto); en escritorio se muestra en un
     lateral para que se vea exactamente lo que se va a compartir. */
  .prediction-share-figure {
    display: none;
  }

  @media (min-width: 1024px) {
    .prediction-share-content {
      max-width: 52rem;
      display: grid;
      grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
      gap: 2.25rem;
      align-items: center;
    }

    .prediction-share-figure {
      display: flex;
      flex-direction: column;
      gap: 0.7rem;
    }
  }

  .prediction-share-figure-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 718 / 828;
    border-radius: 0.4rem;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-theme-midnight) 85%, black);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 30%, transparent),
      0 18px 44px rgba(0, 0, 0, 0.5);
  }

  .prediction-share-figure-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0;
    transition: opacity 400ms ease;
  }

  .prediction-share-figure[data-ready] .prediction-share-figure-img {
    opacity: 1;
  }

  .prediction-share-figure-loading {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    padding: 1rem;
    text-align: center;
    font-family: var(--font-cinzel);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
    animation: prediction-share-pulse 1.4s ease-in-out infinite;
  }

  .prediction-share-figure[data-ready] .prediction-share-figure-loading,
  .prediction-share-figure[data-error] .prediction-share-figure-loading {
    display: none;
  }

  .prediction-share-figure-caption {
    margin: 0;
    text-align: center;
    font-family: var(--font-cinzel);
    font-size: 0.55rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--color-theme-gold) 72%, transparent);
  }

  @keyframes prediction-share-pulse {
    0%,
    100% {
      opacity: 0.5;
    }
    50% {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-figure-img {
      transition: none;
    }
    .prediction-share-figure-loading {
      animation: none;
    }
  }

  .prediction-share-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid color-mix(in srgb, var(--color-theme-gold) 80%, transparent);
    pointer-events: none;
  }
  .prediction-share-corner-tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-tr {
    top: -1px;
    right: -1px;
    border-left: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-bl {
    bottom: -1px;
    left: -1px;
    border-right: 0;
    border-top: 0;
  }
  .prediction-share-corner-br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  .prediction-share-eyebrow {
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.85rem;
    border-radius: var(--radius-pill);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-velada-navy) 35%, var(--color-theme-midnight)) 0%,
      color-mix(in srgb, var(--color-theme-midnight) 95%, black) 100%
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 40%, transparent);
    color: color-mix(in srgb, var(--color-theme-gold) 92%, var(--color-theme-cream));
    font-family: var(--font-cinzel);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .prediction-share-eyebrow-mark {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: var(--color-theme-gold);
    transform: rotate(45deg);
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
  }

  .prediction-share-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-sharp);
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 20%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 80%, transparent);
    color: var(--color-theme-cream);
    opacity: 0.6;
    cursor: pointer;
    transition:
      opacity 200ms,
      border-color 200ms;
  }

  .prediction-share-close:hover,
  .prediction-share-close:focus-visible {
    opacity: 1;
    border-color: color-mix(in srgb, var(--color-theme-gold) 50%, transparent);
  }

  .prediction-share-title {
    margin: 0.5rem 0 0.6rem;
    font-family: var(--font-cinzel);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    color: var(--color-theme-cream);
  }

  @media (min-width: 640px) {
    .prediction-share-title {
      font-size: 1.25rem;
    }
  }

  .prediction-share-description {
    margin: 0 0 1.5rem;
    font-family: var(--font-fallback);
    font-size: 0.88rem;
    line-height: 1.5;
    text-transform: none;
    text-align: center;
    color: color-mix(in srgb, var(--color-theme-cream) 72%, transparent);
  }

  .prediction-share-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .prediction-share-actions-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .prediction-share-actions-row .prediction-share-pill {
    flex: 1 1 0;
    min-width: 8.5rem;
    padding: 0.8rem 1rem;
    font-size: 0.68rem;
  }

  .prediction-share-actions-secondary {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
  }

  .prediction-share-actions-secondary .prediction-share-pill {
    flex: 1 1 0;
    min-width: 7rem;
  }

  .prediction-share-actions-hint {
    margin: 0.15rem 0 0;
    font-family: var(--font-fallback);
    font-size: 0.75rem;
    line-height: 1.4;
    text-transform: none;
    text-align: center;
    color: color-mix(in srgb, var(--color-theme-cream) 58%, transparent);
  }

  .prediction-share-kbd {
    display: inline-block;
    padding: 0.05rem 0.4rem;
    border-radius: 0.3rem;
    background: color-mix(in srgb, var(--color-theme-midnight) 70%, black);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 28%, transparent);
    color: color-mix(in srgb, var(--color-theme-cream) 82%, transparent);
    font-family: var(--font-fallback);
    font-size: 0.72rem;
    white-space: nowrap;
  }

  .prediction-share-native {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .prediction-share-native[hidden] {
    display: none;
  }

  .prediction-share-native-btn {
    width: 100%;
    padding: 0.85rem 1rem;
    font-size: 0.72rem;
  }

  .prediction-share-pill-icon {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .prediction-share-native-hint {
    margin: 0;
    font-family: var(--font-fallback);
    font-size: 0.78rem;
    text-transform: none;
    text-align: center;
    color: color-mix(in srgb, var(--color-theme-cream) 62%, transparent);
  }

  .prediction-share-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    border-radius: var(--radius-sharp);
    background: color-mix(in srgb, var(--color-theme-midnight) 78%, black);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    color: color-mix(in srgb, var(--color-theme-cream) 86%, transparent);
    font-family: var(--font-cinzel);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 250ms,
      box-shadow 250ms,
      background-color 250ms,
      color 250ms;
  }

  .prediction-share-pill:hover:not(:disabled),
  .prediction-share-pill:focus-visible:not(:disabled) {
    color: var(--color-theme-cream);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 6px 18px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    transform: translateY(-1px);
    outline: none;
  }

  .prediction-share-pill:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .prediction-share-pill-primary {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 65%,
      color-mix(in srgb, var(--color-theme-gold) 75%, black) 100%
    );
    color: var(--color-theme-midnight);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 8px 24px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .prediction-share-pill-primary:hover:not(:disabled),
  .prediction-share-pill-primary:focus-visible:not(:disabled) {
    color: var(--color-theme-midnight);
    transform: translateY(-1px);
  }

  /* Mismo lenguaje de "píldora" redondeada que el botón de la página de
     Pronósticos (PredictionShareController), para que compartir se vea
     idéntico en todo el sitio. */
  .prediction-share-pill-rounded {
    border-radius: 9999px;
  }

  /* Botón de X: pastilla dorada (acción principal de escritorio, un clic copia
     la imagen y abre X) con el logotipo de la marca en oscuro. */
  .prediction-share-pill-x svg {
    /* El logo de X ocupa todo su viewBox, así que lo agrandamos un pelín. */
    width: 17px;
    height: 17px;
  }

  /* Botón de WhatsApp: pastilla oscura con un acento verde de marca (anillo +
     icono) para que sea reconocible sin romper la estética dorada del sitio. */
  .prediction-share-pill-whatsapp {
    color: var(--color-theme-cream);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, #25d366 55%, transparent);
  }

  .prediction-share-pill-whatsapp svg {
    color: #25d366;
  }

  .prediction-share-pill-whatsapp:hover:not(:disabled),
  .prediction-share-pill-whatsapp:focus-visible:not(:disabled) {
    color: var(--color-theme-cream);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, #25d366 90%, white),
      0 6px 18px color-mix(in srgb, #25d366 30%, transparent);
  }

  .prediction-share-status {
    margin: 1rem 0 0;
    font-family: var(--font-fallback);
    font-size: 0.82rem;
    text-transform: none;
    text-align: center;
    color: var(--color-theme-gold);
    min-height: 1.25rem;
  }

  .prediction-share-status[data-status='error'] {
    color: #ff6b6b;
  }

  .prediction-share-status[data-status='success'] {
    color: color-mix(in srgb, var(--color-theme-gold) 92%, white);
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-pill,
    .prediction-share-close {
      transition: none;
    }

    .prediction-share-pill:hover:not(:disabled),
    .prediction-share-pill:focus-visible:not(:disabled) {
      transform: none;
    }

    /* Sin movimiento: el cierre es instantáneo. */
    .prediction-share-modal[data-closing] .prediction-share-backdrop,
    .prediction-share-modal[data-closing] .prediction-share-content,
    .prediction-share-modal[data-closing] .prediction-share-eyebrow,
    .prediction-share-modal[data-closing] .prediction-share-title,
    .prediction-share-modal[data-closing] .prediction-share-description,
    .prediction-share-modal[data-closing] .prediction-share-actions,
    .prediction-share-modal[data-closing] .prediction-share-status {
      animation: none;
    }

    .prediction-share-modal[data-closing] {
      transition: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import {
    buildPredictionBlob,
    canShareImageFile,
    copyImageToClipboard,
    downloadBlob,
    isShareAbort,
    openWhatsAppIntent,
    openXIntent,
    shareImageFile,
  } from '@/lib/share-image'
  import {
    PREDICTION_SHARE_OPEN_EVENT,
    PREDICTION_COMPLETE_EVENT,
    getUserVotesFromDOM,
  } from '@/lib/prediction-completion'

  const SHARE_TEXT = 'Estas son mis predicciones para #LaVeladaDelAñoVI 🥊'
  const SHARE_URL = 'https://www.infolavelada.com/pronosticos'
  // WhatsApp muestra preview del enlace, así que añadimos la URL para que el
  // mensaje sea clicable; X se queda solo con el texto (la imagen es la estrella).
  const WHATSAPP_TEXT = `${SHARE_TEXT}\n${SHARE_URL}`
  const FILE_NAME = 'mis-predicciones-velada.png'
  const EXIT_ANIM_MS = 320

  type StatusKind = 'info' | 'success' | 'error'

  interface ModalRefs {
    downloadBtn: HTMLButtonElement | null
    copyBtn: HTMLButtonElement | null
    shareXBtn: HTMLButtonElement | null
    whatsappBtn: HTMLButtonElement | null
    status: HTMLElement | null
    content: HTMLElement | null
    nativeShare: HTMLElement | null
    nativeShareBtn: HTMLButtonElement | null
    shareSteps: HTMLElement | null
    description: HTMLElement | null
    figure: HTMLElement | null
    previewImg: HTMLImageElement | null
  }

  function collectRefs(modal: HTMLDialogElement): ModalRefs {
    return {
      downloadBtn: $<HTMLButtonElement>('[data-download-btn]', modal),
      copyBtn: $<HTMLButtonElement>('[data-copy-btn]', modal),
      shareXBtn: $<HTMLButtonElement>('[data-share-x]', modal),
      whatsappBtn: $<HTMLButtonElement>('[data-share-whatsapp]', modal),
      status: $<HTMLElement>('[data-share-status]', modal),
      content: $<HTMLElement>('.prediction-share-content', modal),
      nativeShare: $<HTMLElement>('[data-native-share]', modal),
      nativeShareBtn: $<HTMLButtonElement>('[data-native-share-btn]', modal),
      shareSteps: $<HTMLElement>('[data-share-steps]', modal),
      description: $<HTMLElement>('[data-share-description]', modal),
      figure: $<HTMLElement>('[data-share-figure]', modal),
      previewImg: $<HTMLImageElement>('[data-share-preview-img]', modal),
    }
  }

  function createStatusController(status: HTMLElement | null) {
    return function setStatus(text: string, kind: StatusKind = 'info') {
      if (!status) return
      status.textContent = text
      if (kind === 'info') status.removeAttribute('data-status')
      else status.dataset.status = kind
    }
  }

  function setBusy(button: HTMLButtonElement | null, busy: boolean) {
    if (button) button.disabled = busy
  }

  function createModalCloser(modal: HTMLDialogElement, content: HTMLElement | null) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    let isClosing = false

    return function close() {
      if (isClosing || !modal.open) return
      isClosing = true

      if (prefersReducedMotion) {
        modal.close()
        return
      }

      modal.dataset.closing = ''

      let done = false
      const finish = () => {
        if (done) return
        done = true
        content?.removeEventListener('animationend', finish)
        modal.removeAttribute('data-closing')
        isClosing = false
        modal.close()
      }
      content?.addEventListener('animationend', finish, { once: true })
      window.setTimeout(finish, EXIT_ANIM_MS)
    }
  }

  function wireCloseHandlers(modal: HTMLDialogElement, close: () => void) {
    const closeButtons = $$<HTMLElement>('[data-modal-close]', modal)
    closeButtons.forEach((btn) => btn.addEventListener('click', close))

    modal.addEventListener('click', (e) => {
      if (e.target === modal) close()
    })

    // El <dialog> cierra nativamente con Escape. Capturamos la tecla en
    // fase de captura para evitarlo y disparar nuestra animación de salida.
    modal.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          e.preventDefault()
          e.stopPropagation()
          close()
        }
      },
      true,
    )
  }

  function setupModal() {
    const modal = $<HTMLDialogElement>('[data-prediction-share-modal]')
    if (!modal) return

    const refs = collectRefs(modal)
    if (!refs.content) return

    const setStatus = createStatusController(refs.status)
    const close = createModalCloser(modal, refs.content)

    let cachedBlob: Blob | null = null
    let previewObjectUrl: string | null = null

    function resetModalState() {
      cachedBlob = null
      // Volvemos el preview a su estado de carga para regenerarlo al abrir.
      refs.figure?.removeAttribute('data-ready')
      refs.figure?.removeAttribute('data-error')
      setStatus('', 'info')
    }

    // Genera la imagen real y la muestra en el lateral del modal (escritorio),
    // así se ve exactamente lo que se va a compartir. Reutiliza el mismo blob
    // cacheado que usan descargar/copiar, por lo que no duplica trabajo.
    async function renderPreview() {
      if (!refs.previewImg || !refs.figure) return
      try {
        const blob = await getImageBlob()
        if (previewObjectUrl) URL.revokeObjectURL(previewObjectUrl)
        previewObjectUrl = URL.createObjectURL(blob)
        refs.previewImg.src = previewObjectUrl
        refs.figure.setAttribute('data-ready', '')
      } catch (err) {
        refs.figure.setAttribute('data-error', '')
        console.error(err)
      }
    }

    async function getImageBlob(): Promise<Blob> {
      if (cachedBlob) return cachedBlob
      cachedBlob = await buildPredictionBlob(getUserVotesFromDOM())
      return cachedBlob
    }

    async function handleDownload() {
      setBusy(refs.downloadBtn, true)
      setBusy(refs.copyBtn, true)
      setStatus('Descargando...', 'info')
      try {
        const blob = await getImageBlob()
        downloadBlob(blob, FILE_NAME)
        setStatus('¡Imagen descargada! Ya podés compartirla.', 'success')
      } catch (err) {
        setStatus('Hubo un error descargando la imagen.', 'error')
        console.error(err)
      } finally {
        setBusy(refs.downloadBtn, false)
        setBusy(refs.copyBtn, false)
      }
    }

    async function handleCopy() {
      setBusy(refs.downloadBtn, true)
      setBusy(refs.copyBtn, true)
      setStatus('Copiando imagen...', 'info')
      try {
        const blob = await getImageBlob()
        const copied = await copyImageToClipboard(blob)
        if (!copied) throw new Error('Portapapeles no soportado')
        setStatus('¡Imagen copiada! Pegala donde quieras.', 'success')
      } catch (err) {
        setStatus('No se pudo copiar. Descargá la imagen manualmente.', 'error')
        console.error(err)
      } finally {
        setBusy(refs.downloadBtn, false)
        setBusy(refs.copyBtn, false)
      }
    }

    // Compartir directo de escritorio: copiamos la imagen al portapapeles para
    // que el usuario solo tenga que pegarla y abrimos la plataforma con el
    // texto ya escrito. Si el portapapeles no está disponible, descargamos la
    // imagen como respaldo para que no se quede sin ella.
    async function shareToPlatform(
      button: HTMLButtonElement | null,
      openIntent: () => void,
      label: string,
    ) {
      setBusy(button, true)
      setStatus(`Preparando para compartir en ${label}...`, 'info')
      try {
        const blob = await getImageBlob()
        const copied = await copyImageToClipboard(blob)
        // El intent se abre tras copiar (la activación de usuario sigue viva).
        openIntent()
        if (copied) {
          setStatus(`Imagen copiada ✓ Pégala en ${label} con Ctrl/Cmd + V.`, 'success')
        } else {
          downloadBlob(blob, FILE_NAME)
          setStatus(`Descargamos la imagen: adjúntala en tu post de ${label}.`, 'success')
        }
      } catch (err) {
        setStatus(`Hubo un error abriendo ${label}.`, 'error')
        console.error(err)
      } finally {
        setBusy(button, false)
      }
    }

    const handleShareX = () => shareToPlatform(refs.shareXBtn, () => openXIntent(SHARE_TEXT), 'X')
    const handleShareWhatsApp = () =>
      shareToPlatform(refs.whatsappBtn, () => openWhatsAppIntent(WHATSAPP_TEXT), 'WhatsApp')

    async function handleNativeShare() {
      setBusy(refs.nativeShareBtn, true)
      setStatus('Preparando para compartir...', 'info')
      try {
        const blob = await getImageBlob()
        await shareImageFile(blob, FILE_NAME, SHARE_TEXT)
        setStatus('¡Listo! Gracias por compartir tu pronóstico.', 'success')
      } catch (err) {
        // Cancelar la hoja de compartir no es un error: limpiamos el estado.
        if (isShareAbort(err)) {
          setStatus('', 'info')
        } else {
          setStatus('No se pudo compartir. Probá descargando la imagen.', 'error')
          console.error(err)
        }
      } finally {
        setBusy(refs.nativeShareBtn, false)
      }
    }

    // En navegadores con Web Share API nivel 2 (móvil moderno) ofrecemos el
    // camino de un solo toque y ocultamos el flujo manual de descarga + X.
    function enableNativeShareIfSupported() {
      if (!canShareImageFile()) return
      refs.nativeShare?.removeAttribute('hidden')
      if (refs.shareSteps) refs.shareSteps.hidden = true
      if (refs.description) {
        refs.description.textContent = `Generamos una imagen con tus votos. ¡Compártela donde quieras!`
      }
    }

    function openModal() {
      if (modal?.open) return
      resetModalState()
      modal?.showModal()
      // El foco inicial debe aterrizar en un control real, no en el backdrop
      // (SC 2.4.3). El botón de cierre es el primer paso lógico del modal.
      $<HTMLButtonElement>('.prediction-share-close', modal)?.focus()
      // Generamos la vista previa en cuanto se abre (también precalienta el
      // blob, dejando la descarga lista al instante).
      void renderPreview()
    }

    refs.downloadBtn?.addEventListener('click', () => void handleDownload())
    refs.copyBtn?.addEventListener('click', () => void handleCopy())
    refs.shareXBtn?.addEventListener('click', () => void handleShareX())
    refs.whatsappBtn?.addEventListener('click', () => void handleShareWhatsApp())
    refs.nativeShareBtn?.addEventListener('click', () => void handleNativeShare())

    enableNativeShareIfSupported()

    document.addEventListener(PREDICTION_COMPLETE_EVENT, openModal)
    document.addEventListener(PREDICTION_SHARE_OPEN_EVENT, openModal)

    wireCloseHandlers(modal, close)
  }

  document.addEventListener('astro:page-load', setupModal)
</script>
