---
interface Props {
  totalFights: number
}

const { totalFights } = Astro.props
---

<dialog id="prediction-share-modal" class="prediction-share-modal" data-prediction-share-modal>
  <div class="prediction-share-backdrop animate-fade-in" data-modal-close></div>

  <div class="prediction-share-content animate-fade-in-up animate-delay-100">
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tl"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-tr"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-bl"></span>
    <span aria-hidden="true" class="prediction-share-corner prediction-share-corner-br"></span>

    <div class="prediction-share-eyebrow animate-fade-in animate-delay-200" aria-hidden="true">
      <span class="prediction-share-eyebrow-mark"></span>
      <span>PRONÓSTICO COMPLETO</span>
      <span class="prediction-share-eyebrow-mark"></span>
    </div>

    <button type="button" class="prediction-share-close" data-modal-close aria-label="Cerrar modal">
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <h2 class="prediction-share-title animate-fade-in-up animate-delay-300">
      ¡Hiciste tu pronóstico para la velada!
    </h2>

    <p class="prediction-share-description animate-fade-in animate-delay-500">
      Generamos una imagen con tus {totalFights} votos. Descárgala y compártela en X.
    </p>

    <div class="prediction-share-steps" data-share-steps>
      <div
        class="prediction-share-step animate-fade-in-up animate-delay-700"
        data-step="1"
        data-state="active"
      >
        <div class="prediction-share-step-header">
          <span class="prediction-share-step-number">1</span>
          <span class="prediction-share-step-label">Guarda la imagen</span>
        </div>

        <div class="prediction-share-step-actions">
          <button
            type="button"
            class="prediction-share-pill prediction-share-pill-primary"
            data-download-btn
          >
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"></path>
            </svg>
            Descargar imagen
          </button>

          <button
            type="button"
            class="prediction-share-pill"
            data-copy-btn
            aria-label="Copiar imagen al portapapeles"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
            </svg>
            Copiar
          </button>
        </div>
      </div>

      <div
        class="prediction-share-step animate-fade-in-up animate-delay-900"
        data-step="2"
        data-state="locked"
      >
        <div class="prediction-share-step-header">
          <span class="prediction-share-step-number">2</span>
          <span class="prediction-share-step-label">Compartí en X</span>
          <span class="prediction-share-step-lock" data-step-lock-badge aria-hidden="true">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
              <path d="M7 11V7a5 5 0 0110 0v4"></path>
            </svg>
            Descarga primero
          </span>
        </div>

        <div class="prediction-share-preview" data-share-preview>
          <div class="prediction-share-preview-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
              ></path>
            </svg>
            <span>X / Twitter</span>
          </div>

          <p class="prediction-share-preview-text" data-share-text>
            Estas son mis predicciones para <strong>#LaVeladaDelAñoVI</strong> 🥊
          </p>

          <div class="prediction-share-preview-hint" aria-hidden="true">
            <span class="prediction-share-preview-attachment">
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  d="M21.44 11.05l-9.19 9.19a6 6 0 01-8.49-8.49l9.19-9.19a4 4 0 015.66 5.66l-9.2 9.19a2 2 0 01-2.83-2.83l8.49-8.48"
                ></path>
              </svg>
              <span data-attachment-label>Adjunta la imagen descargada</span>
            </span>
          </div>
        </div>

        <button
          type="button"
          class="prediction-share-pill prediction-share-pill-x"
          data-share-btn
          disabled
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
            ></path>
          </svg>
          Abrir X con el texto listo
        </button>
      </div>
    </div>

    <p
      class="prediction-share-status animate-fade-in animate-delay-1100"
      data-share-status
      aria-live="polite"
    >
    </p>
  </div>
</dialog>

<style>
  .prediction-share-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    margin: 0;
    padding: 0;
    border: none;
    background: transparent;
    align-items: center;
    justify-content: center;
  }

  .prediction-share-modal::backdrop {
    background: transparent;
  }

  .prediction-share-modal[open] {
    display: flex;
  }

  /* ── Exit animation ──
     Cuando el modal tiene data-closing, reemplazamos las clases de
     entrada por las de salida y acortamos la duración para que
     la transición de cierre sea ágil (no espejamos los delays:
     el cierre se siente como una sola ráfaga). */
  .prediction-share-modal[data-closing] .prediction-share-backdrop {
    animation: fade-out 220ms ease-out both;
  }
  .prediction-share-modal[data-closing] .prediction-share-content {
    animation: fade-out-up 280ms ease-out both;
  }
  .prediction-share-modal[data-closing] .prediction-share-eyebrow,
  .prediction-share-modal[data-closing] .prediction-share-title,
  .prediction-share-modal[data-closing] .prediction-share-description,
  .prediction-share-modal[data-closing] .prediction-share-step,
  .prediction-share-modal[data-closing] .prediction-share-status {
    animation: fade-out 200ms ease-out both;
  }

  .prediction-share-modal[data-closing] {
    scale: 0;
    transition: scale 280ms ease-out;
  }

  .prediction-share-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(10, 16, 36, 0.88);
    backdrop-filter: blur(10px);
  }

  .prediction-share-content {
    position: relative;
    z-index: 1;
    width: calc(100% - 2rem);
    max-width: 28rem;
    margin: 1rem;
    padding: 2.5rem 1.5rem 1.75rem;
    border-radius: 0;
    background:
      radial-gradient(
        ellipse 80% 50% at 50% 0%,
        color-mix(in srgb, var(--color-theme-gold) 10%, transparent),
        transparent 70%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-velada-navy) 35%, var(--color-theme-midnight)) 0%,
        color-mix(in srgb, var(--color-theme-midnight) 94%, black) 100%
      );
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 30%, transparent),
      0 32px 80px rgba(0, 0, 0, 0.6),
      0 0 60px color-mix(in srgb, var(--color-theme-gold) 10%, transparent);
  }

  @media (min-width: 640px) {
    .prediction-share-content {
      padding: 2.75rem 2rem 2rem;
    }
  }

  .prediction-share-corner {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid color-mix(in srgb, var(--color-theme-gold) 80%, transparent);
    pointer-events: none;
  }
  .prediction-share-corner-tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-tr {
    top: -1px;
    right: -1px;
    border-left: 0;
    border-bottom: 0;
  }
  .prediction-share-corner-bl {
    bottom: -1px;
    left: -1px;
    border-right: 0;
    border-top: 0;
  }
  .prediction-share-corner-br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  .prediction-share-eyebrow {
    position: absolute;
    top: -0.7rem;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.25rem 0.85rem;
    border-radius: 9999px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-velada-navy) 35%, var(--color-theme-midnight)) 0%,
      color-mix(in srgb, var(--color-theme-midnight) 95%, black) 100%
    );
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 40%, transparent);
    color: color-mix(in srgb, var(--color-theme-gold) 92%, var(--color-theme-cream));
    font-family: var(--font-cinzel);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    white-space: nowrap;
    text-shadow: 0 0 12px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .prediction-share-eyebrow-mark {
    display: inline-block;
    width: 4px;
    height: 4px;
    background: var(--color-theme-gold);
    transform: rotate(45deg);
    box-shadow: 0 0 6px color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
  }

  .prediction-share-close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    display: grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 20%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 80%, transparent);
    color: var(--color-theme-cream);
    opacity: 0.6;
    cursor: pointer;
    transition:
      opacity 200ms,
      border-color 200ms;
  }

  .prediction-share-close:hover,
  .prediction-share-close:focus-visible {
    opacity: 1;
    border-color: color-mix(in srgb, var(--color-theme-gold) 50%, transparent);
  }

  .prediction-share-title {
    margin: 0.5rem 0 0.6rem;
    font-family: var(--font-cinzel);
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    color: var(--color-theme-cream);
  }

  @media (min-width: 640px) {
    .prediction-share-title {
      font-size: 1.25rem;
    }
  }

  .prediction-share-description {
    margin: 0 0 1.5rem;
    font-family: var(--font-fallback);
    font-size: 0.88rem;
    line-height: 1.5;
    text-transform: none;
    text-align: center;
    color: color-mix(in srgb, var(--color-theme-cream) 72%, transparent);
  }

  .prediction-share-steps {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .prediction-share-step {
    position: relative;
    border-radius: 0;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 60%, transparent);
    padding: 0.9rem 1rem;
    transition:
      border-color 300ms,
      opacity 300ms;
  }

  .prediction-share-step[data-state='unlocked'] {
    border-color: color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
    box-shadow: 0 0 24px color-mix(in srgb, var(--color-theme-gold) 10%, transparent);
  }

  .prediction-share-step-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }

  .prediction-share-step-number {
    display: grid;
    place-items: center;
    width: 1.5rem;
    height: 1.5rem;
    border-radius: 9999px;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 65%,
      color-mix(in srgb, var(--color-theme-gold) 75%, black) 100%
    );
    color: var(--color-theme-midnight);
    font-family: var(--font-cinzel);
    font-size: 0.7rem;
    font-weight: 900;
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      0 4px 12px color-mix(in srgb, var(--color-theme-gold) 30%, transparent);
  }

  .prediction-share-step[data-state='locked'] .prediction-share-step-number {
    background: color-mix(in srgb, var(--color-theme-midnight) 78%, black);
    color: color-mix(in srgb, var(--color-theme-cream) 55%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
  }

  .prediction-share-step-label {
    font-family: var(--font-cinzel);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-theme-cream);
  }

  .prediction-share-step-lock {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-theme-maroon) 35%, transparent);
    color: color-mix(in srgb, var(--color-theme-gold) 88%, var(--color-theme-cream));
    font-family: var(--font-cinzel);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 20%, transparent);
  }

  .prediction-share-step[data-state='unlocked'] .prediction-share-step-lock {
    display: none;
  }

  .prediction-share-step-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .prediction-share-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.55rem 0.95rem;
    border-radius: 0;
    background: color-mix(in srgb, var(--color-theme-midnight) 78%, black);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    color: color-mix(in srgb, var(--color-theme-cream) 86%, transparent);
    font-family: var(--font-cinzel);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      transform 250ms,
      box-shadow 250ms,
      background-color 250ms,
      color 250ms;
  }

  .prediction-share-pill:hover:not(:disabled),
  .prediction-share-pill:focus-visible:not(:disabled) {
    color: var(--color-theme-cream);
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 6px 18px color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    transform: translateY(-1px);
    outline: none;
  }

  .prediction-share-pill:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .prediction-share-pill-primary {
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 65%,
      color-mix(in srgb, var(--color-theme-gold) 75%, black) 100%
    );
    color: var(--color-theme-midnight);
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, white 35%, transparent),
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 100%, white),
      0 8px 24px color-mix(in srgb, var(--color-theme-gold) 35%, transparent);
  }

  .prediction-share-pill-primary:hover:not(:disabled),
  .prediction-share-pill-primary:focus-visible:not(:disabled) {
    color: var(--color-theme-midnight);
    transform: translateY(-1px);
  }

  .prediction-share-preview {
    margin-bottom: 0.85rem;
    border-radius: 0;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 14%, transparent);
    background: color-mix(in srgb, var(--color-theme-midnight) 85%, black);
    padding: 0.75rem 0.85rem;
  }

  .prediction-share-preview-header {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
    padding: 0.15rem 0.5rem;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-theme-midnight) 60%, transparent);
    box-shadow: inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
    color: color-mix(in srgb, var(--color-theme-cream) 80%, transparent);
    font-family: var(--font-cinzel);
    font-size: 0.5rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  .prediction-share-preview-text {
    margin: 0 0 0.6rem;
    font-family: var(--font-fallback);
    font-size: 0.88rem;
    line-height: 1.45;
    text-transform: none;
    color: var(--color-theme-cream);
  }

  .prediction-share-preview-text strong {
    color: var(--color-theme-gold);
    font-weight: 700;
  }

  .prediction-share-preview-hint {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding-top: 0.55rem;
    border-top: 1px dashed color-mix(in srgb, var(--color-theme-gold) 18%, transparent);
  }

  .prediction-share-preview-attachment {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-fallback);
    font-size: 0.72rem;
    text-transform: none;
    color: color-mix(in srgb, var(--color-theme-cream) 60%, transparent);
  }

  .prediction-share-pill-x {
    width: 100%;
    padding: 0.7rem 1rem;
    font-size: 0.7rem;
  }

  .prediction-share-status {
    margin: 1rem 0 0;
    font-family: var(--font-fallback);
    font-size: 0.82rem;
    text-transform: none;
    text-align: center;
    color: var(--color-theme-gold);
    min-height: 1.25rem;
  }

  .prediction-share-status[data-status='error'] {
    color: #ff6b6b;
  }

  .prediction-share-status[data-status='success'] {
    color: color-mix(in srgb, var(--color-theme-gold) 92%, white);
  }

  @media (prefers-reduced-motion: reduce) {
    .prediction-share-pill,
    .prediction-share-step,
    .prediction-share-close {
      transition: none;
    }

    .prediction-share-pill:hover:not(:disabled),
    .prediction-share-pill:focus-visible:not(:disabled) {
      transform: none;
    }

    /* Sin movimiento: el cierre es instantáneo. */
    .prediction-share-modal[data-closing] .prediction-share-backdrop,
    .prediction-share-modal[data-closing] .prediction-share-content,
    .prediction-share-modal[data-closing] .prediction-share-eyebrow,
    .prediction-share-modal[data-closing] .prediction-share-title,
    .prediction-share-modal[data-closing] .prediction-share-description,
    .prediction-share-modal[data-closing] .prediction-share-step,
    .prediction-share-modal[data-closing] .prediction-share-status {
      animation: none;
    }

    .prediction-share-modal[data-closing] {
      transition: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'
  import { buildPredictionBlob, downloadBlob, openXIntent } from '@/lib/share-image'
  import {
    PREDICTION_SHARE_OPEN_EVENT,
    PREDICTION_COMPLETE_EVENT,
    getUserVotesFromDOM,
  } from '@/lib/prediction-completion'

  const SHARE_TEXT = 'Estas son mis predicciones para #LaVeladaDelAñoVI 🥊'
  const FILE_NAME = 'mis-predicciones-velada.png'
  const EXIT_ANIM_MS = 320

  type StatusKind = 'info' | 'success' | 'error'

  interface ModalRefs {
    downloadBtn: HTMLButtonElement | null
    copyBtn: HTMLButtonElement | null
    shareBtn: HTMLButtonElement | null
    status: HTMLElement | null
    step2: HTMLElement | null
    content: HTMLElement | null
    attachmentLabel: HTMLElement | null
  }

  function collectRefs(modal: HTMLDialogElement): ModalRefs {
    return {
      downloadBtn: $<HTMLButtonElement>('[data-download-btn]', modal),
      copyBtn: $<HTMLButtonElement>('[data-copy-btn]', modal),
      shareBtn: $<HTMLButtonElement>('[data-share-btn]', modal),
      status: $<HTMLElement>('[data-share-status]', modal),
      step2: $<HTMLElement>('[data-step="2"]', modal),
      content: $<HTMLElement>('.prediction-share-content', modal),
      attachmentLabel: $<HTMLElement>('[data-attachment-label]', modal),
    }
  }

  function createStatusController(status: HTMLElement | null) {
    return function setStatus(text: string, kind: StatusKind = 'info') {
      if (!status) return
      status.textContent = text
      if (kind === 'info') status.removeAttribute('data-status')
      else status.dataset.status = kind
    }
  }

  function setBusy(button: HTMLButtonElement | null, busy: boolean) {
    if (button) button.disabled = busy
  }

  function createModalCloser(modal: HTMLDialogElement, content: HTMLElement | null) {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches
    let isClosing = false

    return function close() {
      if (isClosing || !modal.open) return
      isClosing = true

      if (prefersReducedMotion) {
        modal.close()
        return
      }

      modal.dataset.closing = ''

      let done = false
      const finish = () => {
        if (done) return
        done = true
        content?.removeEventListener('animationend', finish)
        modal.removeAttribute('data-closing')
        isClosing = false
        modal.close()
      }
      content?.addEventListener('animationend', finish, { once: true })
      window.setTimeout(finish, EXIT_ANIM_MS)
    }
  }

  function wireCloseHandlers(modal: HTMLDialogElement, close: () => void) {
    const closeButtons = $$<HTMLElement>('[data-modal-close]', modal)
    closeButtons.forEach((btn) => btn.addEventListener('click', close))

    modal.addEventListener('click', (e) => {
      if (e.target === modal) close()
    })

    // El <dialog> cierra nativamente con Escape. Capturamos la tecla en
    // fase de captura para evitarlo y disparar nuestra animación de salida.
    modal.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') {
          e.preventDefault()
          e.stopPropagation()
          close()
        }
      },
      true,
    )
  }

  function setupModal() {
    const modal = $<HTMLDialogElement>('[data-prediction-share-modal]')
    if (!modal) return

    const refs = collectRefs(modal)
    if (!refs.content) return

    const setStatus = createStatusController(refs.status)
    const close = createModalCloser(modal, refs.content)

    let cachedBlob: Blob | null = null

    function resetModalState() {
      cachedBlob = null
      if (refs.step2) refs.step2.dataset.state = 'locked'
      if (refs.shareBtn) refs.shareBtn.disabled = true
      setStatus('', 'info')
    }

    function unlockStep2(attachmentLabel: string) {
      if (refs.step2) refs.step2.dataset.state = 'unlocked'
      if (refs.shareBtn) refs.shareBtn.disabled = false
      if (refs.attachmentLabel) refs.attachmentLabel.textContent = attachmentLabel
    }

    async function getImageBlob(): Promise<Blob> {
      if (cachedBlob) return cachedBlob
      cachedBlob = await buildPredictionBlob(getUserVotesFromDOM())
      return cachedBlob
    }

    async function handleDownload() {
      setBusy(refs.downloadBtn, true)
      setBusy(refs.copyBtn, true)
      setStatus('Descargando...', 'info')
      try {
        const blob = await getImageBlob()
        downloadBlob(blob, FILE_NAME)
        unlockStep2('Imagen descargada ✓')
        setStatus('¡Imagen descargada! Ahora podés compartirla.', 'success')
      } catch (err) {
        setStatus('Hubo un error descargando la imagen.', 'error')
        console.error(err)
      } finally {
        setBusy(refs.downloadBtn, false)
        setBusy(refs.copyBtn, false)
      }
    }

    async function handleCopy() {
      setBusy(refs.downloadBtn, true)
      setBusy(refs.copyBtn, true)
      setStatus('Copiando imagen...', 'info')
      try {
        const blob = await getImageBlob()
        if (!('ClipboardItem' in window)) {
          throw new Error('ClipboardItem no soportado')
        }
        await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })])
        unlockStep2('Imagen copiada al portapapeles ✓')
        setStatus('¡Imagen copiada! Pegala directo en X.', 'success')
      } catch (err) {
        setStatus('No se pudo copiar. Descargá la imagen manualmente.', 'error')
        console.error(err)
      } finally {
        setBusy(refs.downloadBtn, false)
        setBusy(refs.copyBtn, false)
      }
    }

    function handleShare() {
      setBusy(refs.shareBtn, true)
      try {
        openXIntent(SHARE_TEXT)
        setStatus('X abierto. Pegá la imagen descargada en el post.', 'success')
      } catch (err) {
        setStatus('Hubo un error abriendo X.', 'error')
        console.error(err)
      } finally {
        setBusy(refs.shareBtn, false)
      }
    }

    function openModal() {
      if (modal?.open) return
      resetModalState()
      modal?.showModal()
      // El foco inicial debe aterrizar en un control real, no en el backdrop
      // (SC 2.4.3). El botón de cierre es el primer paso lógico del modal.
      $<HTMLButtonElement>('.prediction-share-close', modal)?.focus()
    }

    refs.downloadBtn?.addEventListener('click', () => void handleDownload())
    refs.copyBtn?.addEventListener('click', () => void handleCopy())
    refs.shareBtn?.addEventListener('click', handleShare)

    document.addEventListener(PREDICTION_COMPLETE_EVENT, openModal)
    document.addEventListener(PREDICTION_SHARE_OPEN_EVENT, openModal)

    wireCloseHandlers(modal, close)
  }

  document.addEventListener('astro:page-load', setupModal)
</script>
