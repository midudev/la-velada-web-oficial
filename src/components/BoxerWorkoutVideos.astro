              data-workout-video-dialog-close
              aria-label="Cerrar vídeo"
              class="inline-flex size-10 items-center justify-center rounded-full border border-white/20 bg-black/40 text-white transition outline-none hover:border-theme-gold/70 hover:bg-theme-gold/15 focus-visible:border-theme-gold/70 focus-visible:ring-2 focus-visible:ring-theme-gold/60 sm:size-11"
            >
              <CloseIcon class="size-5" aria-hidden="true" />
            </button>
          </div>
          <div class="relative aspect-video w-full overflow-hidden rounded-xl border border-white/10 bg-black shadow-[0_30px_80px_-20px_rgba(0,0,0,0.8)]">
            <div data-workout-video-dialog-frame class="absolute inset-0 h-full w-full" />
          </div>
        </div>
      </dialog>
    </section>
  )
}

<script>
  import { $, $$ } from '@/lib/dom-selector'

  function initWorkoutVideoDialogs() {
    const sections = $$<HTMLElement>('[data-boxer-workout-root]')

    sections.forEach((section) => {
      if (section.dataset.workoutVideoReady === 'true') return
      section.dataset.workoutVideoReady = 'true'

      const dialog = $<HTMLDialogElement>('[data-workout-video-dialog]', section)
      const tiles = $$<HTMLElement>('[data-workout-video-tile]', section)
      const closeBtn = $<HTMLButtonElement>('[data-workout-video-dialog-close]', section)
      const titleEl = $<HTMLElement>('[data-workout-video-dialog-title]', section)
      const frame = $<HTMLElement>('[data-workout-video-dialog-frame]', section)
      if (!dialog || !frame) return

      function openVideo(videoId: string, title: string) {
        if (titleEl) titleEl.textContent = title
        const iframe = document.createElement('iframe')
        iframe.src = `https://www.youtube-nocookie.com/embed/${encodeURIComponent(videoId)}?autoplay=1&rel=0&playsinline=1`
        iframe.allow =
          'accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; fullscreen'
        iframe.setAttribute('allowfullscreen', '')
        iframe.title = title
        iframe.className = 'h-full w-full border-0'
        frame.replaceChildren(iframe)
        if (dialog.open) return
        dialog.showModal()
      }

      function closeVideo() {
        if (!dialog.open) return
        dialog.close()
      }

      tiles.forEach((tile) => {
        tile.addEventListener('click', () => {
          const videoId = tile.getAttribute('data-video-id')
          const title = tile.getAttribute('data-video-title') ?? ''
          if (!videoId) return
          openVideo(videoId, title)
        })
      })

      closeBtn?.addEventListener('click', closeVideo)

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) closeVideo()
      })

      dialog.addEventListener('close', () => {
        frame.replaceChildren()
      })
    })
  }

  document.addEventListener('astro:page-load', initWorkoutVideoDialogs)
</script>

<style>
  .boxer-workout-scroll {
    scrollbar-width: thin;
    scrollbar-color: var(--color-theme-gold) transparent;
    scrollbar-gutter: stable;
  }

  .boxer-workout-scroll::-webkit-scrollbar {
    width: 10px;
  }

  .boxer-workout-scroll::-webkit-scrollbar-track {
    background: transparent;
    border-left: 1px solid color-mix(in srgb, white 6%, transparent);
  }

  .boxer-workout-scroll::-webkit-scrollbar-thumb {
    background-color: var(--color-theme-gold);
    border-radius: 999px;
    border: 2px solid transparent;
    background-clip: content-box;
  }

  .boxer-workout-scroll::-webkit-scrollbar-thumb:hover {
    background-color: var(--color-theme-cream);
  }
</style>
