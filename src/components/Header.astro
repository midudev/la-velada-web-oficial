---
interface Props {
  timestamp: number
}

const { timestamp } = Astro.props
---

<header
  class="relative z-10 mx-auto flex w-full max-w-3xl flex-1 flex-col items-center justify-start px-4 pt-20 text-center sm:justify-center sm:pt-12"
>
  <h1 class="sr-only">
    La Velada del Año VI — Evento de boxeo de Ibai Llanos el 25 de julio de 2026
  </h1>

  <div class="animate-fade-in animate-delay-500 -mt-4" role="img" aria-label="Logo de La Velada del Año VI">
    <picture>
      <source srcset="/logo.avif" type="image/avif" />
      <source srcset="/logo.webp" type="image/webp" />
      <img
        src="/logo.png"
        alt="La Velada del Año VI"
        class="h-auto w-56 sm:w-72 md:w-80 lg:w-96"
        width="384"
        height="384"
        fetchpriority="high"
        decoding="async"
      />
    </picture>
  </div>

  <div
    data-event-info
    class="animate-fade-in animate-delay-800 mt-6 flex flex-col items-center gap-2 sm:flex-row sm:gap-0"
  >
    <time
      datetime="2026-07-25"
      class="font-cinzel text-xs font-bold tracking-[0.2em] text-white sm:text-sm md:text-base"
    >
      25 DE JULIO
    </time>
    <span class="hidden px-4 text-white/40 sm:inline" aria-hidden="true">|</span>
    <time
      datetime="2026-07-25T20:00:00+02:00"
      class="font-cinzel text-xs font-bold tracking-[0.2em] text-white sm:text-sm md:text-base"
    >
      20:00H CET
    </time>
    <span class="hidden px-4 text-white/40 sm:inline" aria-hidden="true">|</span>
    <span class="font-cinzel text-xs font-bold tracking-[0.2em] text-white sm:text-sm md:text-base">
      ESTADIO DE LA CARTUJA, SEVILLA
    </span>
  </div>

  <div
    class="animate-fade-in animate-delay-900 mt-8 flex select-none items-center justify-center gap-3 sm:gap-5 md:gap-7"
    id="countdown-hero"
    data-date={timestamp}
    role="timer"
    aria-label="Cuenta atrás para La Velada del Año VI"
  >
    <div class="flex flex-col items-center gap-1">
      <span
        data-days
        class="countdown-digit font-cinzel text-theme-cream text-3xl font-bold tabular-nums sm:text-4xl md:text-5xl"
        >---</span
      >
      <span class="font-cinzel text-[0.55rem] font-semibold tracking-[0.3em] text-white/40 sm:text-[0.65rem]">DÍAS</span>
    </div>
    <span
      class="font-cinzel text-theme-gold/30 mt-1 self-start text-2xl font-light sm:text-3xl md:text-4xl"
      aria-hidden="true">:</span
    >
    <div class="flex flex-col items-center gap-1">
      <span
        data-hours
        class="countdown-digit font-cinzel text-theme-cream text-3xl font-bold tabular-nums sm:text-4xl md:text-5xl"
        >--</span
      >
      <span class="font-cinzel text-[0.55rem] font-semibold tracking-[0.3em] text-white/40 sm:text-[0.65rem]">HORAS</span>
    </div>
    <span
      class="font-cinzel text-theme-gold/30 mt-1 self-start text-2xl font-light sm:text-3xl md:text-4xl"
      aria-hidden="true">:</span
    >
    <div class="flex flex-col items-center gap-1">
      <span
        data-minutes
        class="countdown-digit font-cinzel text-theme-cream text-3xl font-bold tabular-nums sm:text-4xl md:text-5xl"
        >--</span
      >
      <span class="font-cinzel text-[0.55rem] font-semibold tracking-[0.3em] text-white/40 sm:text-[0.65rem]">MIN</span>
    </div>
    <span
      class="font-cinzel text-theme-gold/30 mt-1 self-start text-2xl font-light sm:text-3xl md:text-4xl"
      aria-hidden="true">:</span
    >
    <div class="flex flex-col items-center gap-1">
      <span
        data-seconds
        class="countdown-digit font-cinzel text-theme-cream text-3xl font-bold tabular-nums sm:text-4xl md:text-5xl"
        >--</span
      >
      <span class="font-cinzel text-[0.55rem] font-semibold tracking-[0.3em] text-white/40 sm:text-[0.65rem]">SEG</span>
    </div>
  </div>

  <span
    class="animate-fade-in animate-delay-1000 font-cinzel text-theme-cream mt-8 inline-flex cursor-not-allowed items-center justify-center rounded border border-white/20 bg-white/5 px-8 py-3 text-sm font-bold tracking-[0.2em] sm:text-base"
    aria-disabled="true"
  >
    ENTRADAS AGOTADAS
  </span>
</header>

<style>
  .countdown-digit {
    text-shadow: 0 0 30px rgba(199, 168, 107, 0.2);
    min-width: 1.8em;
    text-align: center;
  }
</style>

<script>
  import createCountdown, { type TimeParts } from '@/lib/countdown'

  function initCountdown() {
    const $countdown = document.getElementById('countdown-hero')
    if (!$countdown) return

    const $days = $countdown.querySelector('[data-days]')
    const $hours = $countdown.querySelector('[data-hours]')
    const $minutes = $countdown.querySelector('[data-minutes]')
    const $seconds = $countdown.querySelector('[data-seconds]')

    const timestamp = Number($countdown.getAttribute('data-date') ?? 0)
    return createCountdown(timestamp, {
      onTick({ days, hours, minutes, seconds }: TimeParts) {
        if ($days) $days.textContent = days
        if ($hours) $hours.textContent = hours
        if ($minutes) $minutes.textContent = minutes
        if ($seconds) $seconds.textContent = seconds
      },
      onComplete() {},
    })
  }

  document.addEventListener('astro:page-load', () => {
    initCountdown()?.start()
  })
</script>
