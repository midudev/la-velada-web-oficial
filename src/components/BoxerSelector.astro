---
import CountryFlag from '@/components/CountryFlag.astro'
import SectionDivider from '@/components/SectionDivider.astro'
import { battles } from '@/consts/battles'
import { EVENT_DATE_DAY, EVENT_DATE_TIME, EVENT_DISPLAY_TIME_SHORT } from '@/consts/event'
import {
  BOXERS,
  BOXERS_BY_ID,
  COUNTRY_NAMES,
  getBoxerHeroImages,
  getBoxerSelectImages,
  type Boxer,
} from '@/consts/boxers'

// Posicionamos a cada boxeador en el grid de manera SIMÉTRICA respecto a su
// contrincante: si el primero de la pareja está en la columna N, el segundo
// está en la columna opuesta de la misma fila (espejo horizontal).
//
//   Móvil (4 cols / 5 filas):
//     Fila 1 → par A cols 1 y 4, par B cols 2 y 3
//     Fila 2 → par C cols 1 y 4, par D cols 2 y 3
//     ... 10 parejas en 5 filas
//
//   Tablet (8 cols / 3 filas):
//     La fila incompleta queda arriba para que el hueco central no cierre
//     visualmente la parrilla por abajo.
//
//   Desktop (10 cols / 2 filas):
//     Fila 1 → 5 parejas, par k en cols k y 11-k
//     Fila 2 → otras 5 parejas con el mismo patrón
const MOBILE_COLS = 4
const TABLET_COLS = 8
const DESKTOP_COLS = 10

// IDs de boxeadores cuya miniatura está mirando hacia el lado contrario
// al de su contrincante en el grid; se voltean horizontalmente para que
// "miren" al rival.
const MIRRORED_BOXER_IDS = new Set<string>(['clersss', 'alondrissa'])

// Mapa boxerId → id del contrincante, usado para iluminar el rival al hacer
// hover sobre una miniatura.
const opponentById: Record<string, string> = {}
for (const { boxerIds } of battles) {
  const [a, b] = boxerIds
  opponentById[a] = b
  opponentById[b] = a
}

const positionedBoxers: Array<{
  boxer: Boxer
  opponentId: string
  colMobile: number
  rowMobile: number
  colTablet: number
  rowTablet: number
  colDesktop: number
  rowDesktop: number
}> = battles.flatMap(({ boxerIds }, pairIndex) =>
  boxerIds.map((id, indexInPair) => {
    const isFirstInPair = indexInPair === 0

    // Móvil
    const pairsPerRowMobile = MOBILE_COLS / 2
    const rowMobile = Math.floor(pairIndex / pairsPerRowMobile) + 1
    const pairInRowMobile = pairIndex % pairsPerRowMobile
    const colMobileLeft = pairInRowMobile + 1
    const colMobileRight = MOBILE_COLS - pairInRowMobile
    const colMobile = isFirstInPair ? colMobileLeft : colMobileRight

    // Tablet
    const pairsPerRowTablet = TABLET_COLS / 2
    const tabletRows = Math.ceil(battles.length / pairsPerRowTablet)
    const naturalRowTablet = Math.floor(pairIndex / pairsPerRowTablet) + 1
    const rowTablet = naturalRowTablet === tabletRows ? 1 : naturalRowTablet + 1
    const pairInRowTablet = pairIndex % pairsPerRowTablet
    const colTabletLeft = pairInRowTablet + 1
    const colTabletRight = TABLET_COLS - pairInRowTablet
    const colTablet = isFirstInPair ? colTabletLeft : colTabletRight

    // Desktop
    const pairsPerRowDesktop = DESKTOP_COLS / 2
    const rowDesktop = Math.floor(pairIndex / pairsPerRowDesktop) + 1
    const pairInRowDesktop = pairIndex % pairsPerRowDesktop
    const colDesktopLeft = pairInRowDesktop + 1
    const colDesktopRight = DESKTOP_COLS - pairInRowDesktop
    const colDesktop = isFirstInPair ? colDesktopLeft : colDesktopRight

    return {
      boxer: BOXERS_BY_ID[id]!,
      opponentId: opponentById[id]!,
      colMobile,
      rowMobile,
      colTablet,
      rowTablet,
      colDesktop,
      rowDesktop,
    }
  }),
)

// Primer boxeador usado como contenido pre-renderizado del panel del boxeador
// (sirve para que la primera imagen ya esté cargada en el primer hover y para
// no dejar el panel vacío antes de que el JS reaccione a una interacción).
const fallback = BOXERS[0]
const fallbackHero = getBoxerHeroImages(fallback)
const fallbackCountry = COUNTRY_NAMES[fallback.country] ?? fallback.country
const MOBILE_SLIDER_SETS = ['previous', 'current', 'next'] as const
---

<section
  data-boxer-selector
  data-state="default"
  class="relative mx-auto flex w-full max-w-7xl flex-1 flex-col items-center"
  aria-label="Selector de boxeadores de La Velada del Año VI"
>
  <div class="boxer-stage relative w-full flex-1">
    <div
      data-default-panel
      class="boxer-default-panel relative flex w-full flex-col items-center justify-start text-center"
    >
      <div class="boxer-default-aura pointer-events-none absolute inset-0 -z-1" aria-hidden="true"></div>

      <div class="boxer-default-lockup flex w-full max-w-full flex-col items-center">
        <div class="animate-blurred-fade-in animate-delay-300 relative leading-none">
          <picture class="block">
            <source srcset="/logo.avif" type="image/avif" />
            <source srcset="/logo.webp" type="image/webp" />
            <img
              src="/logo.webp"
              alt="Logo de La Velada del Año VI"
              class="boxer-default-logo relative block h-auto w-[58vw] max-w-[360px] sm:w-[44vw] md:w-[36vw] lg:w-[28vw]"
              width="512"
              height="512"
              decoding="async"
              fetchpriority="high"
            />
          </picture>
        </div>

      <ul
        class="boxer-default-info animate-fade-in-up animate-delay-500 flex flex-col items-center justify-center gap-1 -mt-8 md:-mt-12"
      >
        <li class="flex items-baseline">
          <time
            datetime={EVENT_DATE_DAY}
            class="font-cinzel text-xs font-black tracking-[0.16em] text-theme-cream sm:text-sm"
          >
            25 DE JULIO
          </time>
        </li>
        <li class="flex items-baseline">
          <time
            datetime={EVENT_DATE_TIME}
            class="font-cinzel text-xs font-black tracking-[0.16em] text-theme-cream sm:text-sm"
          >
            {EVENT_DISPLAY_TIME_SHORT}
          </time>
        </li>
        <li class="flex items-baseline">
          <span
            class="font-cinzel text-xs font-black tracking-[0.16em] text-theme-cream sm:text-sm"
          >
            <a
              href="#sede"
              class="group/edition relative cursor-pointer focus-visible:outline-none"
            >
              <span
                aria-hidden="true"
                class="pointer-events-none absolute inset-x-0 -bottom-1 h-px origin-center scale-x-0 bg-theme-gold transition-transform duration-150 ease-out delay-0 [@media(hover:hover)_and_(pointer:fine)]:group-hover/edition:scale-x-100 [@media(hover:hover)_and_(pointer:fine)]:group-hover/edition:delay-125 group-focus-visible/edition:scale-x-100 group-focus-visible/edition:delay-125"
              />
              Estadio de la Cartuja, Sevilla
            </a>
          </span>
        </li>
        </ul>
      </div>

    </div>

    <div
      data-boxer-panel
      aria-hidden="true"
      class="boxer-panel relative flex w-full flex-col items-center"
    >
      <span data-hero-glow class="boxer-hero-glow" aria-hidden="true"></span>
      <span
        aria-hidden="true"
        data-active-watermark
        class="boxer-watermark pointer-events-none absolute left-1/2 top-2 z-0 w-screen -translate-x-1/2 select-none overflow-hidden font-cinzel text-[18vw] font-black leading-[0.85] tracking-[-0.04em] text-theme-cream sm:text-[14vw] md:top-4 md:text-[11rem] lg:text-[13rem]"
      >
        <span class="boxer-watermark-track">
          {
            [0, 1].map(() => (
              <span class="boxer-watermark-set">
                <span data-active-watermark-text>{fallback.name}</span>
                <span data-active-watermark-text>{fallback.name}</span>
                <span data-active-watermark-text>{fallback.name}</span>
              </span>
            ))
          }
        </span>
      </span>

      <div class="boxer-portrait-layer pointer-events-none relative z-10 flex min-h-0 w-full flex-1 items-end justify-center">
        <picture class="boxer-portrait-wrap relative block h-full">
          <source
            data-active-source-avif
            type="image/avif"
            srcset={fallbackHero.avif}
          />
          <source
            data-active-source-webp
            type="image/webp"
            srcset={fallbackHero.webp}
          />
          <img
            data-active-image
            src={fallbackHero.webp}
            alt={`Foto principal de ${fallback.name}`}
            class="boxer-portrait relative z-10 h-full max-h-full w-auto max-w-full object-contain object-bottom transition-opacity duration-300"
            decoding="async"
            fetchpriority="high"
          />
          {/*
            La capa de la imagen se posiciona por CSS como absolute para
            poder extenderse por debajo del stage, hasta la franja de
            selección, sin mover el resto de elementos del panel.
          */}
        </picture>
      </div>

      <div class="relative z-20 flex flex-col items-center sm:-mt-6 md:-mt-8 lg:-mt-10 top-7">
        <h2
          data-active-name
          class="boxer-name relative font-cinzel text-3xl font-black leading-none tracking-[0.08em] text-theme-cream sm:text-5xl md:text-6xl lg:text-7xl"
        >{fallback.name}</h2>

        <p
          class="boxer-country mt-1 flex items-center gap-x-2 font-cinzel text-[0.6rem] font-black tracking-[0.16em] text-theme-cream sm:mt-1.5 sm:text-[0.7rem] md:mt-2 md:text-xs"
          aria-live="polite"
        >
          <img
            data-active-flag
            src={`/flags/${fallback.country}.svg`}
            alt=""
            aria-hidden="true"
            width="20"
            height="20"
            class="boxer-country-flag"
          />
          <span data-active-country-name>{fallbackCountry}</span>
        </p>

        <p data-vs-line class="boxer-vs-line" aria-hidden="true">
          <span class="boxer-vs-tag">VS</span>
          <span data-vs-name class="boxer-vs-name"></span>
        </p>
      </div>
    </div>
  </div>

  <div class="boxer-selector-foot mt-auto flex w-full shrink-0 flex-col items-center gap-1.5 md:gap-3">
    <div
      class="boxer-cta-bar relative z-20 flex w-full flex-col items-center gap-3 transition-opacity duration-300 ease-out md:gap-4"
    >
      <SectionDivider class="boxer-default-divider" />

      <p class="boxer-default-cta font-cinzel text-sm font-black tracking-[0.16em] text-[color-mix(in_srgb,var(--color-theme-cream),white_30%)] uppercase">
        ¡Selecciona tu boxeador o boxeadora!
      </p>
    </div>

    <div class="boxer-grid-frame relative z-10 w-full">
    <div class="boxer-mobile-slider-shell md:hidden">
      <div
        class="boxer-mobile-slider"
        data-mobile-slider
        aria-label="Carrusel de boxeadores. Desliza horizontalmente y pulsa uno para ver su perfil"
      >
        <div class="boxer-mobile-track" data-mobile-track>
          {
            MOBILE_SLIDER_SETS.flatMap((setName) =>
              positionedBoxers.map(({ boxer }, index) => {
                const selectImages = getBoxerSelectImages(boxer)
                const isAccessibleSet = setName === 'current'

                return (
                  <a
                    href={`/boxeadores/${boxer.id}`}
                    data-mobile-thumb
                    data-mobile-slide
                    data-mobile-set={setName}
                    data-id={boxer.id}
                    aria-label={`Ver perfil de ${boxer.name}`}
                    aria-hidden={isAccessibleSet ? undefined : 'true'}
                    tabindex={isAccessibleSet ? undefined : -1}
                    class="boxer-mobile-slide group relative aspect-[3/4] shrink-0 snap-center border border-theme-gold/35 bg-theme-midnight outline-none"
                    style={`animation-delay: ${650 + index * 20}ms`}
                  >
                    <span class="boxer-mobile-slide-media absolute inset-0 overflow-hidden">
                      <picture>
                        <source type="image/avif" srcset={selectImages.avif} />
                        <source type="image/webp" srcset={selectImages.webp} />
                        <img
                          src={selectImages.webp}
                          alt=""
                          role="presentation"
                          loading="lazy"
                          decoding="async"
                          width="180"
                          height="240"
                          data-mirrored={MIRRORED_BOXER_IDS.has(boxer.id) ? 'true' : 'false'}
                          class="boxer-mobile-slide-img absolute inset-0 h-full w-full object-cover object-top transition duration-500 group-active:scale-[1.03]"
                        />
                      </picture>
                      <span
                        aria-hidden="true"
                        class="boxer-mobile-slide-name-bar pointer-events-none absolute inset-x-0 bottom-0 flex items-end justify-center px-2 pb-2.5 pt-10"
                      >
                        <span class="boxer-mobile-slide-name font-cinzel text-[0.66rem] font-black uppercase leading-[1.05] tracking-[0.08em] text-theme-cream text-balance">
                          {boxer.name}
                        </span>
                      </span>
                    </span>
                    <span aria-hidden="true" class="boxer-mobile-frame">
                      <span class="bmf-corner bmf-tl" />
                      <span class="bmf-corner bmf-tr" />
                      <span class="bmf-corner bmf-bl" />
                      <span class="bmf-corner bmf-br" />
                    </span>
                  </a>
                )
              }),
            )
          }
        </div>
      </div>
    </div>

    <div
      data-boxer-grid
      class="boxer-grid hidden md:grid md:grid-cols-8 md:grid-rows-3 lg:grid-cols-10 lg:grid-rows-2"
      aria-label="Lista de boxeadores. Pulsa uno para ver su perfil"
    >
      {/* Cursor de selección estilo "character select": se desliza a la
          casilla activa (ver positionFrame en el script). */}
      <span data-selector-frame class="boxer-selector-frame" aria-hidden="true">
        <span class="bsf-corner bsf-tl"></span>
        <span class="bsf-corner bsf-tr"></span>
        <span class="bsf-corner bsf-bl"></span>
        <span class="bsf-corner bsf-br"></span>
      </span>
      {
        positionedBoxers.map(
          (
            {
              boxer,
              opponentId,
              colMobile,
              rowMobile,
              colTablet,
              rowTablet,
              colDesktop,
              rowDesktop,
            },
            index,
          ) => {
            const countryName = COUNTRY_NAMES[boxer.country] ?? boxer.country
            const selectImages = getBoxerSelectImages(boxer)
            const heroImages = getBoxerHeroImages(boxer)
            return (
              <a
                href={`/boxeadores/${boxer.id}`}
                data-thumb
                data-id={boxer.id}
                data-opponent-id={opponentId}
                data-name={boxer.name}
                data-photo-avif={heroImages.avif}
                data-photo-webp={heroImages.webp}
                data-country-code={boxer.country}
                data-country={countryName}
                aria-label={`Ver perfil de ${boxer.name}`}
                data-active="false"
                class="boxer-cell boxer-cell-enter group relative aspect-square cursor-pointer overflow-hidden focus-visible:outline-none"
                style={`--col-mobile: ${colMobile}; --row-mobile: ${rowMobile}; --col-tablet: ${colTablet}; --row-tablet: ${rowTablet}; --col-desktop: ${colDesktop}; --row-desktop: ${rowDesktop}; animation-delay: ${1000 + index * 25}ms`}
                tabindex={index === 0 ? 0 : -1}
              >
                <picture>
                  <source type="image/avif" srcset={selectImages.avif} />
                  <source type="image/webp" srcset={selectImages.webp} />
                  <img
                    src={selectImages.webp}
                    alt=""
                    role="presentation"
                    loading="lazy"
                    decoding="async"
                    width="160"
                    height="160"
                    data-mirrored={MIRRORED_BOXER_IDS.has(boxer.id) ? 'true' : 'false'}
                    class="boxer-thumb-img absolute inset-0 h-full w-full object-cover object-top group-hover:scale-[1.05] group-focus-visible:scale-[1.05]"
                  />
                </picture>
                <span
                  aria-hidden="true"
                  class="boxer-thumb-name-bar pointer-events-none absolute inset-x-0 bottom-0 flex items-end justify-center px-1 pb-1 pt-4 sm:px-1.5 sm:pb-1.5 sm:pt-5"
                >
                  <span class="boxer-thumb-name font-cinzel text-[0.5rem] font-black uppercase leading-[1.05] tracking-[0.08em] text-theme-cream text-balance sm:text-[0.6rem] md:text-[0.7rem]">
                    {boxer.name}
                  </span>
                </span>
              </a>
            )
          },
        )
      }
    </div>
    </div>
  </div>
</section>

<style>
  /* El stage es un rectángulo de altura controlada por `flex-1`. Los dos
     paneles (default y boxer) se apilan con `position: absolute` para que
     NO afecten al alto del stage: si fueran grid items, su min-content
     (en particular la imagen `h-full` del boxer) empujaría al stage muy
     por debajo del espacio que le toca, sacando la cuadrícula fuera del
     viewport. Con absolute, el stage respeta exactamente el alto que le
     da el flex container del BoxerSelector. */
  .boxer-stage {
    position: relative;
  }

  .boxer-stage > [data-default-panel],
  .boxer-stage > [data-boxer-panel] {
    position: absolute;
    inset: 0;
    transition: opacity 350ms ease;
  }

  [data-boxer-selector][data-state='default'] [data-default-panel] {
    opacity: 1;
    pointer-events: auto;
  }
  [data-boxer-selector][data-state='default'] [data-boxer-panel] {
    opacity: 0;
    pointer-events: none;
  }

  [data-boxer-selector][data-state='boxer'] [data-default-panel] {
    opacity: 0;
    pointer-events: none;
  }
  [data-boxer-selector][data-state='boxer'] [data-boxer-panel] {
    opacity: 1;
    pointer-events: auto;
  }

  @media (max-width: 767px) {
    [data-default-panel]{
      justify-content: center;
    }

    /* En móvil la primera vista mete logo + fecha + CTA + carrusel en una
       sola pantalla (svh). Reducimos un punto el logo y damos respiro al
       carrusel para que entre todo sin amontonarse ni cortarse abajo. */
    .boxer-default-logo {
      width: 50vw;
    }

    .boxer-selector-foot {
      padding-bottom: max(0.5rem, env(safe-area-inset-bottom));
    }

    [data-boxer-selector][data-state='boxer'] [data-default-panel] {
      opacity: 1;
      pointer-events: auto;
    }

    [data-boxer-selector][data-state='boxer'] [data-boxer-panel] {
      opacity: 0;
      pointer-events: none;
    }

    [data-boxer-selector][data-state='boxer'] .boxer-cta-bar {
      opacity: 1;
      pointer-events: auto;
    }
  }

  [data-boxer-selector][data-state='boxer'] .boxer-cta-bar {
    opacity: 0;
    pointer-events: none;
  }

  .boxer-default-logo {
    filter:
      drop-shadow(0 12px 30px color-mix(in srgb, var(--color-theme-gold) 22%, transparent))
      drop-shadow(0 2px 0 rgba(0, 0, 0, 0.25));
    animation: boxer-default-logo-float 6s ease-in-out infinite;
  }

  @media screen and (height <= 767px) and (width >= 768px) {
    [data-boxer-selector]{
      min-height: 590px;
    }

    .boxer-default-logo{
      width: 24vw;
    }

    .boxer-default-panel{
      margin-top: -2rem;
    }

    .boxer-default-cta{
      font-size: 0.75rem;
      max-width: 50ch;
    }
  }

  .boxer-default-aura {
    /* Halo dorado sutil detrás del logo, en línea con el del boxeador */
    background:
      radial-gradient(
        ellipse 55% 45% at 50% 38%,
        color-mix(in srgb, var(--color-theme-gold) 22%, transparent) 0%,
        transparent 70%
      );
    mask-image: linear-gradient(to bottom, black 0%, black 80%, transparent 100%);
  }

  .boxer-default-info {
    text-shadow:
      0 0 1px color-mix(in srgb, var(--color-theme-cream) 60%, transparent),
      0 2px 14px color-mix(in srgb, var(--color-theme-gold) 45%, transparent),
      0 0 24px color-mix(in srgb, var(--color-theme-midnight) 70%, transparent);
  }

  /* La cuadrícula del selector entra escalonada con un delay base de
     1000ms + 25ms por celda (ver `animation-delay` inline en el HTML).
     La última celda empieza a aparecer ~1475ms desde el inicio, así
     que sincronizamos el divider y el CTA con ese momento. */
  .boxer-default-divider {
    opacity: 0;
    animation: boxer-default-cta-fade-in 600ms ease-out 1350ms forwards;
  }

  .boxer-default-cta {
    /* Mezcla de cream con dorado al fondo para que destaque sobre el
       background del hero (que puede tener mucho contraste) y un punto
       de pulso muy sutil para llamar la atención. */
    text-shadow:
      0 0 1px color-mix(in srgb, var(--color-theme-cream) 60%, transparent),
      0 2px 12px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 0 28px color-mix(in srgb, var(--color-theme-midnight) 70%, transparent);
    opacity: 0;
    animation:
      boxer-default-cta-fade-in 700ms cubic-bezier(0.16, 1, 0.3, 1) 1500ms
        forwards,
      boxer-default-cta-pulse 2.4s ease-in-out 2300ms infinite;
  }

  @keyframes boxer-default-cta-fade-in {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes boxer-default-cta-pulse {
    0%, 100% {
      filter: brightness(1);
    }
    50% {
      filter: brightness(1.2);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-default-divider,
    .boxer-default-cta {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  @keyframes boxer-default-logo-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  .boxer-watermark {
    text-transform: uppercase;
    color: transparent;

    background-image: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-cream) 14%, transparent) 0%,
      color-mix(in srgb, var(--color-theme-gold) 10%, transparent) 55%,
      transparent 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;

    text-shadow:
      0 0 24px color-mix(in srgb, var(--color-theme-gold) 14%, transparent),
      0 1px 0 color-mix(in srgb, var(--color-theme-cream) 3%, transparent);

    mask-image: linear-gradient(
      180deg,
      transparent 0%,
      #000 28%,
      #000 65%,
      transparent 100%
    );

    transition: opacity 400ms ease;
  }

  .boxer-watermark-track {
    display: flex;
    width: max-content;
    animation: boxer-watermark-marquee 32s linear infinite;
    will-change: transform;
  }

  .boxer-watermark-set {
    display: flex;
    align-items: center;
    gap: 0.22em;
    padding-right: 0.22em;
    white-space: nowrap;
  }

  @keyframes boxer-watermark-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .boxer-name {
    text-transform: uppercase;
    color: var(--color-theme-cream);
    text-shadow:
      0 0 1px color-mix(in srgb, var(--color-theme-cream) 60%, transparent),
      0 2px 18px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 6px 40px color-mix(in srgb, var(--color-theme-gold) 25%, transparent);
    filter:
      drop-shadow(0 2px 2px rgba(0, 0, 0, 0.78))
      drop-shadow(0 0 10px rgba(0, 0, 0, 0.58));
    background: linear-gradient(
      180deg,
      var(--color-theme-cream) 0%,
      var(--color-theme-cream) 45%,
      color-mix(in srgb, var(--color-theme-gold) 95%, var(--color-theme-cream)) 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    transition: opacity 400ms ease;
  }

  /* País del boxer: una sombra suave para garantizar contraste sobre
     la cuadrícula de cards sin que se sienta exagerado. */
  .boxer-country {
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 0.55),
      0 2px 16px rgba(0, 0, 0, 0.35);
    transition: opacity 400ms ease;
  }

  .boxer-country-flag {
    width: 0.875rem;
    height: 0.875rem;
    flex-shrink: 0;
    filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.4));
  }

  @media (min-width: 640px) {
    .boxer-country-flag {
      width: 1rem;
      height: 1rem;
    }
  }

  @media (min-width: 768px) {
    .boxer-country-flag {
      width: 1.125rem;
      height: 1.125rem;
    }
  }

  .boxer-portrait-layer {
    --boxer-portrait-drop: 140px;
  }

  .boxer-portrait-wrap {
    position: absolute;
    left: 50%;
    bottom: calc(-1 * var(--boxer-portrait-drop));
    height: calc(100% + var(--boxer-portrait-drop));
    transform: translateX(-50%);
    width: max-content;
    max-width: 100%;
  }

  /* La imagen del boxer ocupa todo el espacio vertical disponible del
     stage (mediante `flex-1` en el wrapper) para verse lo más grande
     posible. Aplicamos un fade hacia transparente en el extremo inferior
     para que el recorte de la silueta se funda visualmente con el nombre
     y la bandera que aparecen justo debajo. */
  .boxer-portrait {
    mask-image: linear-gradient(
      to bottom,
      black 0%,
      black 82%,
      rgba(0, 0, 0, 0.65) 94%,
      transparent 100%
    );
  }

  .boxer-grid-frame {
    margin-inline: auto;
    max-width: 100%;
  }

  @media (min-width: 768px) {
    .boxer-grid-frame {
      max-width: min(100%, 44rem);
    }
  }

  @media (min-width: 1024px) {
    .boxer-grid-frame {
      max-width: 64rem;
    }
  }

  .boxer-mobile-slider-shell {
    --mobile-slide-width: clamp(7.25rem, 34vw, 9.25rem);
    --mobile-slider-gap: 0.625rem;
    position: relative;
    left: 50%;
    width: 100vw;
    transform: translateX(-50%);
  }

  .boxer-mobile-slider {
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-padding-inline: 0;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    /* Más aire vertical para que la tarjeta central, al agrandarse, no se
       recorte arriba/abajo (overflow-x:auto fuerza overflow-y a recortar). */
    padding-block: 1rem 1.1rem;
  }

  .boxer-mobile-slider::-webkit-scrollbar {
    display: none;
  }

  .boxer-mobile-track {
    display: flex;
    width: max-content;
    gap: var(--mobile-slider-gap);
  }

  .boxer-mobile-slide {
    /* Aísla el stacking context de cada slide: sin esto, el z-index del
       nombre (2) y de la imagen (1) se resuelven en el shell (que es
       stacking context por su transform). Durante el scroll la imagen se
       promociona a capa GPU (transition + filter) y se pinta sobre el
       nombre hasta que la capa se degrada. `isolation` lo confina. */
    isolation: isolate;
    width: var(--mobile-slide-width);
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
      0 12px 28px rgba(0, 0, 0, 0.35);
    opacity: 0;
    /* La animación de entrada usa `translate`/`opacity` (no `transform`) para
       dejar libre `transform` al efecto de foco del carrusel. */
    animation: boxer-mobile-slide-in 520ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    /* Foco "character select": el JS escribe --focus-* según la distancia al
       centro. Defaults a 1 para que sin JS (o SSR) se vean normales. */
    transform: scale(var(--focus-scale, 1));
    transform-origin: center center;
    filter: brightness(var(--focus-bright, 1)) saturate(var(--focus-sat, 1));
    will-change: transform, filter;
  }

  /* Marco de esquinas estilo "character select" (igual que el cursor de la
     versión escritorio). Aparece FUERA de la card y su opacidad la controla el
     JS de forma continua (--focus-frame) según la cercanía al centro, con una
     transición que amortigua el snap: se funde de a poco, sin cortes. */
  .boxer-mobile-frame {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    opacity: var(--focus-frame, 0);
    transition: opacity 320ms cubic-bezier(0.33, 1, 0.68, 1);
    box-shadow:
      inset 0 0 0 1.5px color-mix(in srgb, var(--color-theme-gold) 62%, transparent),
      0 0 26px color-mix(in srgb, var(--color-theme-gold) 32%, transparent),
      0 18px 38px rgba(0, 0, 0, 0.4);
  }

  /* Durante el reajuste de set (normalize) refrescamos el foco sin transición
     para que el nuevo slide central herede el marco al instante, sin parpadeo. */
  .boxer-mobile-slider.is-normalizing .boxer-mobile-frame {
    transition: none;
  }

  .bmf-corner {
    position: absolute;
    width: 26%;
    height: 22%;
    border: 2px solid var(--color-theme-gold);
    filter: drop-shadow(0 0 4px color-mix(in srgb, var(--color-theme-gold) 70%, transparent));
    animation: boxer-mobile-frame-breathe 1.9s ease-in-out infinite;
  }

  .bmf-tl {
    top: -6px;
    left: -6px;
    border-right: 0;
    border-bottom: 0;
  }
  .bmf-tr {
    top: -6px;
    right: -6px;
    border-left: 0;
    border-bottom: 0;
  }
  .bmf-bl {
    bottom: -6px;
    left: -6px;
    border-right: 0;
    border-top: 0;
  }
  .bmf-br {
    bottom: -6px;
    right: -6px;
    border-left: 0;
    border-top: 0;
  }

  @keyframes boxer-mobile-frame-breathe {
    0%,
    100% {
      filter: drop-shadow(0 0 4px color-mix(in srgb, var(--color-theme-gold) 55%, transparent));
    }
    50% {
      filter: drop-shadow(0 0 8px color-mix(in srgb, var(--color-theme-gold) 80%, transparent));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-mobile-slide {
      transform: none;
    }
    .bmf-corner {
      animation: none;
    }
  }

  .boxer-mobile-slide::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0.32;
    background:
      radial-gradient(
        ellipse 80% 70% at 50% 22%,
        color-mix(in srgb, var(--color-theme-gold) 45%, transparent) 0%,
        transparent 64%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-theme-navy) 84%, black) 0%,
        color-mix(in srgb, var(--color-theme-midnight) 96%, black) 100%
      );
  }

  .boxer-mobile-slide:focus-visible {
    border-color: color-mix(in srgb, var(--color-theme-gold) 80%, white);
    box-shadow:
      0 0 0 2px color-mix(in srgb, var(--color-theme-cream) 82%, transparent),
      0 0 22px color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
  }

  .boxer-mobile-slide-img {
    z-index: 1;
    filter: saturate(1.04) contrast(1.02);
  }

  .boxer-mobile-slide-img[data-mirrored='true'] {
    transform: scaleX(-1);
  }

  .boxer-mobile-slide-name-bar {
    z-index: 2;
    /* ponytail: translateZ(0) fuerza al nombre a su propia capa GPU. Sin esto,
       iOS recompone la imagen (capa por filter+transition) sobre el nombre al
       cambiar el --focus-scale del slide durante el scroll, y el nombre
       parpadea detrás de la foto. Con su capa propia, el z-index se respeta. */
    transform: translateZ(0);
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.94) 0%,
      rgba(0, 0, 0, 0.72) 46%,
      transparent 100%
    );
  }

  .boxer-mobile-slide-name {
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.95),
      0 1px 2px rgba(0, 0, 0, 0.9),
      0 2px 10px rgba(0, 0, 0, 0.72);
  }

  @keyframes boxer-mobile-slide-in {
    from {
      opacity: 0;
      translate: 0 10px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .boxer-grid {
    gap: 0;
    background: transparent;
  }

  .boxer-cell {
    /* Mismo motivo que .boxer-mobile-slide: aislar para que la imagen
       promocionada en hover/activo nunca pinte sobre su propio nombre. */
    isolation: isolate;
    background: color-mix(in srgb, var(--color-theme-midnight) 92%, var(--color-theme-navy));
    /* Cada celda lleva su propio borde dorado para que, al estar opacity:0
       durante el cascade inicial, no quede ningún "bloque" visible debajo.
       Los box-shadows de celdas adyacentes se solapan formando las líneas
       internas del grid, y el contorno exterior del bloque completo. */
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 32%, transparent);
  }

  .boxer-thumb-img {
    transition:
      opacity 500ms ease,
      filter 500ms ease,
      transform 500ms ease,
      scale 500ms ease;
  }

  /* Flip horizontal puntual para las miniaturas cuya imagen original mira
     hacia el lado contrario al de su contrincante en el grid. Usamos
     `transform` (no la propiedad `scale`) para no entrar en conflicto con
     el `scale-[1.05]` del hover, que sí usa la propiedad `scale`. */
  .boxer-thumb-img[data-mirrored='true'] {
    transform: scaleX(-1);
  }

  /* Posicionamiento simétrico: cada celda usa sus propias variables CSS
     (definidas inline desde el render) para situarse en el grid de modo
     que cada pareja quede en columnas opuestas de la misma fila. */
  .boxer-cell {
    grid-column-start: var(--col-mobile);
    grid-row-start: var(--row-mobile);
  }

  @media (min-width: 768px) {
    .boxer-cell {
      grid-column-start: var(--col-tablet);
      grid-row-start: var(--row-tablet);
    }
  }

  @media (min-width: 1024px) {
    .boxer-cell {
      grid-column-start: var(--col-desktop);
      grid-row-start: var(--row-desktop);
    }
  }

  /* La celda transita box-shadow y transform; los acentos de color
     (dorado y rojo) se aplican vía pseudo-elementos con opacity para
     que la transición sea suave (los radial-gradients no se interpolan,
     pero la opacity sí). */
  .boxer-cell {
    transition:
      box-shadow 500ms ease,
      transform 500ms ease;
  }

  .boxer-cell::before,
  .boxer-cell::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 500ms ease;
  }

  .boxer-cell::before {
    /* Acento dorado: visible cuando el boxer está activo, en hover o en
       focus-visible. */
    background: radial-gradient(
      ellipse 90% 90% at 50% 35%,
      color-mix(in srgb, var(--color-theme-gold) 95%, white) 0%,
      var(--color-theme-gold) 45%,
      color-mix(in srgb, var(--color-theme-gold) 55%, var(--color-theme-midnight)) 100%
    );
  }

  .boxer-cell::after {
    /* Acento rojo sangre: visible cuando este boxer es el contrincante
       del activo. */
    background: radial-gradient(
      ellipse 90% 90% at 50% 35%,
      #c63030 0%,
      #9c1f1f 50%,
      #5a1414 100%
    );
  }

  /* La imagen va sobre los pseudo-elementos para que el recorte del
     boxer no quede tapado por el acento de color. */
  .boxer-thumb-img {
    z-index: 1;
  }

  /* Barra inferior con el nombre del boxeador sobre cada miniatura.
     Sube bastante la opacidad para garantizar contraste con el texto
     cream incluso cuando el cell se ilumina en dorado o rojo. */
  .boxer-thumb-name-bar {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.7) 45%,
      transparent 95%
    );
    z-index: 2;
  }

  /* Color y sombras del nombre. Lo dejamos siempre cream con varias
     capas de sombra negra para que sea legible sobre cualquier estado
     (base oscuro, dorado del hover/activo o rojo del contrincante)
     sin tener que animar el color del texto. */
  .boxer-thumb-name {
    color: var(--color-theme-cream);
    text-shadow:
      0 0 2px rgba(0, 0, 0, 0.95),
      0 1px 2px rgba(0, 0, 0, 0.9),
      0 2px 8px rgba(0, 0, 0, 0.65);
  }

  @media (max-width: 1023px) {
    .boxer-default-divider {
      transform: scaleX(0.75);
    }

    .boxer-default-cta {
      font-size: clamp(0.7rem, 2.6vw, 0.9rem);
      letter-spacing: 0.16em;
      line-height: 1.2;
    }

    .boxer-thumb-name {
      font-size: clamp(0.48rem, 1.8vw, 0.62rem);
      letter-spacing: 0.08em;
    }
  }

  @media (max-width: 639px) and (max-height: 680px) {
    .boxer-mobile-slider-shell {
      --mobile-slide-width: clamp(6.75rem, 31vw, 8.25rem);
    }
  }

  @media (max-width: 639px) and (max-height: 560px) {
    .boxer-mobile-slider-shell {
      --mobile-slide-width: clamp(6rem, 28vw, 7.25rem);
    }
  }

  @media (min-width: 640px) and (max-width: 767px) and (max-height: 820px) {
    .boxer-mobile-slider-shell {
      --mobile-slide-width: clamp(7rem, 27vw, 8.75rem);
    }
  }

  @media (min-width: 640px) and (max-width: 767px) and (max-height: 680px) {
    .boxer-mobile-slider-shell {
      --mobile-slide-width: clamp(6.25rem, 24vw, 7.75rem);
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) and (max-height: 820px) {
    .boxer-grid-frame {
      max-width: min(100%, 40rem);
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) and (max-height: 680px) {
    .boxer-grid-frame {
      max-width: min(100%, 34rem);
    }
  }

  /* Boxeador seleccionado / hover / focus: activamos el acento dorado
     del pseudo ::before, levantamos el z-index y reforzamos el glow. */
  .boxer-cell[data-active='true'],
  .boxer-cell:hover:not([data-active='true']),
  .boxer-cell:focus-visible:not([data-active='true']) {
    z-index: 3;
    box-shadow:
      0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 70%, transparent),
      0 0 18px 0 color-mix(in srgb, var(--color-theme-gold) 55%, transparent);
  }

  .boxer-cell[data-active='true']::before,
  .boxer-cell:hover:not([data-active='true'])::before,
  .boxer-cell:focus-visible:not([data-active='true'])::before {
    opacity: 1;
  }

  /* Contrincante del boxer seleccionado: activamos el acento rojo del
     pseudo ::after. */
  .boxer-cell[data-opponent='true']:not([data-active='true']):not(:hover):not(:focus-visible) {
    z-index: 2;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #c63030 55%, transparent),
      0 0 14px 0 color-mix(in srgb, #c63030 45%, transparent);
  }

  .boxer-cell[data-opponent='true']:not([data-active='true']):not(:hover):not(:focus-visible)::after {
    opacity: 1;
  }

  .boxer-cell[data-opponent='true']:not([data-active='true']):not(:hover):not(:focus-visible) .boxer-thumb-img {
    opacity: 1;
    filter: saturate(1.05);
  }

  .boxer-cell:not([data-active='true']):not([data-opponent='true']):not(:hover):not(:focus-visible) .boxer-thumb-img {
    opacity: 0.85;
  }

  /* Cuando hay un boxeador seleccionado/hover, atenuamos los thumbs que no
     son ni el activo ni el contrincante para resaltar el combate. */
  [data-boxer-selector][data-state='boxer'] .boxer-cell:not([data-active='true']):not([data-opponent='true']):not(:hover):not(:focus-visible) .boxer-thumb-img {
    opacity: 0.55;
  }

  [data-active-image].is-switching,
  [data-active-name].is-switching,
  [data-active-watermark].is-switching {
    opacity: 0;
  }

  /* ───────────────────────────────────────────────────────────────────
     Mejoras "selector de combate" (character select).
     Todo basado en transform/opacity y conducido por la máquina de
     data-state existente; sin runtime de animación adicional.
     ─────────────────────────────────────────────────────────────────── */

  /* La rejilla necesita ser contenedor de posicionamiento para el frame. */
  .boxer-grid {
    position: relative;
  }

  /* 1 · Frame/cursor de selección que se desliza a la casilla activa. */
  .boxer-selector-frame {
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 0;
    z-index: 4;
    pointer-events: none;
    opacity: 0;
    will-change: transform;
    transition:
      transform 260ms cubic-bezier(0.16, 1, 0.3, 1),
      opacity 200ms ease;
  }

  .boxer-selector-frame.is-visible {
    opacity: 1;
    animation: boxer-frame-pop 240ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  @keyframes boxer-frame-pop {
    0% {
      opacity: 0;
    }
    100% {
      opacity: 1;
    }
  }

  /* Halo interior con "respiración" sutil mientras hay selección activa:
     refuerza la sensación de casilla bloqueada (estilo character select). */
  .boxer-selector-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    box-shadow:
      inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 55%, transparent),
      0 0 18px 0 color-mix(in srgb, var(--color-theme-gold) 50%, transparent);
  }

  .boxer-selector-frame.is-visible::before {
    animation: boxer-frame-breathe 1.9s ease-in-out infinite;
  }

  @keyframes boxer-frame-breathe {
    0%,
    100% {
      box-shadow:
        inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 50%, transparent),
        0 0 14px 0 color-mix(in srgb, var(--color-theme-gold) 38%, transparent);
    }
    50% {
      box-shadow:
        inset 0 0 0 1px color-mix(in srgb, var(--color-theme-gold) 75%, transparent),
        0 0 26px 2px color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
    }
  }

  .bsf-corner {
    position: absolute;
    width: 30%;
    height: 27%;
    border: 2px solid var(--color-theme-gold);
    filter: drop-shadow(0 0 4px color-mix(in srgb, var(--color-theme-gold) 70%, transparent));
  }

  .bsf-tl {
    top: -1px;
    left: -1px;
    border-right: 0;
    border-bottom: 0;
  }
  .bsf-tr {
    top: -1px;
    right: -1px;
    border-left: 0;
    border-bottom: 0;
  }
  .bsf-bl {
    bottom: -1px;
    left: -1px;
    border-right: 0;
    border-top: 0;
  }
  .bsf-br {
    bottom: -1px;
    right: -1px;
    border-left: 0;
    border-top: 0;
  }

  /* ── 2 · Reveal cinematográfico COORDINADO ────────────────────────────
     Una sola línea de tiempo con easing expo-out común y stagger; gestos
     editoriales (wipe de máscara), sin rebotes "arcade". ─────────────── */

  /* Foco/atmósfera dorada tras el fighter: aporta profundidad y enfoque. */
  .boxer-hero-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    background: radial-gradient(
      56% 50% at 50% 40%,
      color-mix(in srgb, var(--color-theme-gold) 22%, transparent) 0%,
      color-mix(in srgb, var(--color-theme-gold) 7%, transparent) 42%,
      transparent 72%
    );
    transition: opacity 520ms ease;
  }

  [data-boxer-selector][data-state='boxer'] .boxer-hero-glow {
    opacity: 1;
  }

  .boxer-panel.is-revealing .boxer-hero-glow {
    animation: boxer-glow-in 720ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  @keyframes boxer-glow-in {
    from {
      opacity: 0;
      transform: scale(1.07);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  /* Retrato: wipe vertical + asentamiento de escala (sin rebote). */
  .boxer-panel.is-revealing .boxer-portrait {
    animation: boxer-hero-reveal 600ms cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  @keyframes boxer-hero-reveal {
    from {
      opacity: 0;
      clip-path: inset(20% 0 0 0);
      transform: translateY(12px) scale(0.985);
    }
    to {
      opacity: 1;
      clip-path: inset(0 0 0 0);
      transform: none;
    }
  }

  /* Nombre: reveal de máscara editorial, ligeramente retrasado. */
  .boxer-panel.is-revealing .boxer-name {
    animation: boxer-name-reveal 560ms cubic-bezier(0.16, 1, 0.3, 1) 110ms backwards;
  }

  @keyframes boxer-name-reveal {
    from {
      opacity: 0;
      /* El wipe se hace por la derecha (100% → 0). En el resto de lados
         expandimos la región con insets negativos para que el clip-path no
         recorte la text-shadow/drop-shadow del nombre durante la animación. */
      clip-path: inset(-3rem 100% -3rem -3rem);
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      clip-path: inset(-3rem 0 -3rem -3rem);
      transform: none;
    }
  }

  /* ── 3 · Entrada del roster ──────────────────────────────────────────
     La CELDA (que lleva el borde por box-shadow) se funde SOLO en opacidad,
     con los mismos parámetros que el `animate-fade-in` de producción
     (0.6s ease-in). Así las líneas del grid se dibujan continuas y alineadas,
     idénticas a "Actual": nunca se escala el recuadro con el borde. */
  .boxer-cell-enter {
    animation: boxer-cell-enter 600ms ease-in both;
  }

  @keyframes boxer-cell-enter {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  /* ── 4 · VS del rival: fade+slide limpio (sin pop), al final de la
     timeline. El rival se resalta con su glow rojo (ramp por la transición
     de opacidad del ::after existente), sin pulso de escala. ── */
  .boxer-vs-line {
    display: flex;
    align-items: center;
    gap: 0.5em;
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 320ms ease,
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
    font-family: 'Cinzel', serif;
    text-transform: uppercase;
  }

  [data-boxer-selector][data-state='boxer'] .boxer-vs-line[data-has-opponent='true'] {
    opacity: 1;
    transform: none;
    transition-delay: 0.24s;
  }

  .boxer-vs-tag {
    font-size: 0.7rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    line-height: 1;
    color: var(--color-theme-cream);
    background: linear-gradient(
      135deg,
      color-mix(in srgb, #c63030 85%, black) 0%,
      var(--color-velada-maroon) 100%
    );
    padding: 0.28em 0.5em;
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 60%, transparent);
    border-radius: 0.25rem;
    box-shadow: 0 0 12px color-mix(in srgb, #c63030 45%, transparent);
  }

  .boxer-vs-name {
    font-size: 0.62rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    color: color-mix(in srgb, var(--color-theme-cream) 88%, transparent);
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
  }

  @media (min-width: 768px) {
    .boxer-vs-tag {
      font-size: 0.8rem;
    }
    .boxer-vs-name {
      font-size: 0.72rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .boxer-portrait,
    .boxer-name,
    .boxer-watermark,
    .boxer-watermark-track,
    .boxer-default-logo {
      transition: none;
      animation: none;
    }

    /* Las mejoras de selector también se desactivan: estados sin movimiento. */
    .boxer-selector-frame {
      transition: opacity 200ms ease;
    }
    .boxer-cell-enter,
    .boxer-selector-frame.is-visible,
    .boxer-selector-frame.is-visible::before,
    .boxer-panel.is-revealing .boxer-hero-glow,
    .boxer-panel.is-revealing .boxer-portrait,
    .boxer-panel.is-revealing .boxer-name {
      animation: none;
    }
    .boxer-panel.is-revealing .boxer-portrait,
    .boxer-panel.is-revealing .boxer-name {
      clip-path: none;
    }
    .boxer-vs-line {
      transition: opacity 200ms ease;
      transform: none;
    }
  }
</style>

<script>
  import { $, $$ } from '@/lib/dom-selector'

  // Data URIs muy pequeñas (2×2) usadas para detectar soporte de cada
  // formato en el browser. Si la imagen carga sin error, el browser
  // soporta ese formato.
  const AVIF_TEST =
    'data:image/avif;base64,'
  const WEBP_TEST =
    'data:image/webp;base64,UklGRiQAAABXRUJQVlA4IBgAAAAwAQCdASoBAAEAAwA0JaQAA3AA/vuUAAA='

  function detectFormat(dataUrl: string): Promise<boolean> {
    return new Promise((resolve) => {
      const img = new Image()
      img.onload = () => resolve(img.naturalWidth > 0)
      img.onerror = () => resolve(false)
      img.src = dataUrl
    })
  }

  /** Devuelve la URL del mejor formato soportado para un thumb. */
  function pickPhoto(
    thumb: HTMLAnchorElement,
    formats: { avif: boolean; webp: boolean },
  ): string | undefined {
    if (formats.avif && thumb.dataset.photoAvif) return thumb.dataset.photoAvif
    if (formats.webp && thumb.dataset.photoWebp) return thumb.dataset.photoWebp
    return thumb.dataset.photoWebp
  }

  function setupMobileInfiniteSlider(root: HTMLElement) {
    const slider = $<HTMLElement>('[data-mobile-slider]', root)
    const track = $<HTMLElement>('[data-mobile-track]', root)
    if (!slider || !track || slider.dataset.initialized === 'true') return

    const slides = Array.from($$<HTMLElement>('[data-mobile-slide]', track))
    const realSlideCount = slides.filter(
      (slide) => slide.dataset.mobileSet === 'current',
    ).length
    if (slides.length < 2 || realSlideCount === 0) return

    slider.dataset.initialized = 'true'

    const getSetWidth = () => {
      const pitch = slides[1].offsetLeft - slides[0].offsetLeft
      return pitch > 0 ? pitch * realSlideCount : track.scrollWidth / 3
    }

    // Coloca al usuario en el set central conservando el offset relativo
    // dentro del set. Como los 3 sets son idénticos, el salto es invisible.
    const moveToMiddleSet = () => {
      const setWidth = getSetWidth()
      if (setWidth <= 0) return
      const offsetInSet = ((slider.scrollLeft % setWidth) + setWidth) % setWidth
      slider.scrollLeft = setWidth + offsetInSet
    }

    // Reposiciona al usuario al set central cuando ha cruzado el umbral.
    // CLAVE: solo lo hacemos cuando el scroll YA ha parado, no durante el
    // momentum. Reasignar `scrollLeft` mientras hay inercia en iOS la corta
    // bruscamente y se percibe como un parpadeo/reset.
    const normalize = () => {
      const setWidth = getSetWidth()
      if (setWidth <= 0) return

      if (slider.scrollLeft < setWidth * 0.5) {
        slider.scrollLeft += setWidth
      } else if (slider.scrollLeft >= setWidth * 1.5) {
        slider.scrollLeft -= setWidth
      }
    }

    // Efecto "character select": la tarjeta más centrada en el viewport del
    // carrusel se agranda y brilla, y las laterales se encogen/atenúan según su
    // distancia al centro. Además, el marco de esquinas se funde de forma
    // continua (--focus-frame) para que no aparezca de golpe. Se recalcula en
    // cada frame de scroll (rAF) usando offsets (no getBoundingClientRect) para
    // no forzar reflows por slide.
    let focusRaf = 0
    const updateFocus = () => {
      focusRaf = 0
      const half = slider.clientWidth / 2 || 1
      const viewportCenter = slider.scrollLeft + half
      for (const slide of slides) {
        const slideCenter = slide.offsetLeft + slide.offsetWidth / 2
        const ratio = Math.min(Math.abs(slideCenter - viewportCenter) / half, 1)
        slide.style.setProperty('--focus-scale', (1.12 - ratio * 0.24).toFixed(3))
        slide.style.setProperty('--focus-bright', (1.05 - ratio * 0.4).toFixed(3))
        slide.style.setProperty('--focus-sat', (1.05 - ratio * 0.25).toFixed(3))
        // Rango ancho (0.55) + smoothstep para que el marco entre/salga suave.
        const t = Math.max(0, 1 - ratio / 0.55)
        slide.style.setProperty('--focus-frame', (t * t * (3 - 2 * t)).toFixed(3))
      }
    }
    const requestFocus = () => {
      if (!focusRaf) focusRaf = requestAnimationFrame(updateFocus)
    }

    // Tras normalize() el scrollLeft salta un set completo, así que el slide
    // centrado pasa a ser OTRO elemento (idéntico). Refrescamos las vars de
    // foco al instante y sin transición, para que el nuevo slide central herede
    // el realce sin parpadeo (el salto es invisible porque los sets son iguales).
    const refreshFocusInstant = () => {
      slider.classList.add('is-normalizing')
      updateFocus()
      requestAnimationFrame(() => slider.classList.remove('is-normalizing'))
    }

    slider.addEventListener('scroll', requestFocus, { passive: true })

    requestAnimationFrame(() => {
      moveToMiddleSet()
      updateFocus()
    })

    // `scrollend` está disponible en Safari iOS 18.2+, Chrome 114+ y
    // Firefox 109+. Cuando exista, normalizamos solo cuando todo el scroll
    // (incluido el snap) ha terminado, evitando cualquier corte visual.
    // Como fallback, debounce manual: ejecutamos `normalize` ~160ms después
    // del último evento de scroll, tiempo de sobra para que termine el snap.
    const normalizeAndRefresh = () => {
      normalize()
      refreshFocusInstant()
    }

    const supportsScrollEnd = 'onscrollend' in window
    if (supportsScrollEnd) {
      slider.addEventListener('scrollend', normalizeAndRefresh, { passive: true })
    } else {
      let scrollEndTimer: ReturnType<typeof setTimeout> | null = null
      slider.addEventListener(
        'scroll',
        () => {
          if (scrollEndTimer) clearTimeout(scrollEndTimer)
          scrollEndTimer = setTimeout(normalizeAndRefresh, 160)
        },
        { passive: true },
      )
    }

    window.addEventListener('resize', () =>
      requestAnimationFrame(() => {
        moveToMiddleSet()
        updateFocus()
      }),
    )
  }

  function initBoxerSelector() {
    const root = $<HTMLElement>('[data-boxer-selector]')
    if (!root) return

    setupMobileInfiniteSlider(root)

    const image = $<HTMLImageElement>('[data-active-image]', root)
    const sourceAvif = $<HTMLSourceElement>(
      '[data-active-source-avif]',
      root,
    )
    const sourceWebp = $<HTMLSourceElement>(
      '[data-active-source-webp]',
      root,
    )
    const nameNode = $<HTMLElement>('[data-active-name]', root)
    const watermark = $<HTMLElement>('[data-active-watermark]', root)
    const watermarkTexts = Array.from(
      $$<HTMLElement>('[data-active-watermark-text]', root),
    )
    const flagNode = $<HTMLImageElement>('[data-active-flag]', root)
    const countryNode = $<HTMLElement>('[data-active-country-name]', root)
    const defaultPanel = $<HTMLElement>('[data-default-panel]', root)
    const boxerPanel = $<HTMLElement>('[data-boxer-panel]', root)
    const selectorFrame = $<HTMLElement>('[data-selector-frame]', root)
    const vsLine = $<HTMLElement>('[data-vs-line]', root)
    const vsName = $<HTMLElement>('[data-vs-name]', root)
    const grid = $<HTMLElement>('[data-boxer-grid]', root)
    const thumbs = Array.from($$<HTMLAnchorElement>('[data-thumb]', root))
    const mobileThumbs = Array.from($$<HTMLAnchorElement>('[data-mobile-thumb]', root))
    if (!image || !nameNode || !grid || thumbs.length === 0) return

    // Detección de formato + precarga en segundo plano. No bloqueamos
    // el atado de listeners (un hover inmediato debe funcionar aunque
    // todavía no sepamos qué formato usar para la precarga).
    const idle =
      (window as Window & { requestIdleCallback?: (cb: () => void) => number })
        .requestIdleCallback ?? ((cb: () => void) => setTimeout(cb, 800))
    void (async () => {
      const [avifOk, webpOk] = await Promise.all([
        detectFormat(AVIF_TEST),
        detectFormat(WEBP_TEST),
      ])
      const formats = { avif: avifOk, webp: webpOk }
      idle(() => {
        thumbs.forEach((btn) => {
          const url = pickPhoto(btn, formats)
          if (!url) return
          const img = new Image()
          img.decoding = 'async'
          img.src = url
        })
      })
    })()

    const thumbsById = new Map<string, HTMLAnchorElement>()
    thumbs.forEach((btn) => {
      const id = btn.dataset.id
      if (id) thumbsById.set(id, btn)
    })

    // Desliza el frame de selección sobre la casilla activa. Todas las
    // celdas son cuadradas e iguales, así que solo necesitamos trasladar
    // (sin animar width/height): leemos el tamaño real del thumb en cada
    // llamada para ser robustos ante cambios de breakpoint.
    function moveFrameTo(thumb: HTMLElement) {
      if (!selectorFrame) return
      // En la PRIMERA aparición colocamos el frame SIN transición para que
      // no se deslice desde la esquina (0,0): solo aparece con fade+pop.
      // En selecciones posteriores sí se desliza entre casillas.
      const wasHidden = !selectorFrame.classList.contains('is-visible')
      if (wasHidden) selectorFrame.style.transition = 'none'
      selectorFrame.style.width = `${thumb.offsetWidth}px`
      selectorFrame.style.height = `${thumb.offsetHeight}px`
      selectorFrame.style.transform = `translate(${thumb.offsetLeft}px, ${thumb.offsetTop}px)`
      if (wasHidden) {
        void selectorFrame.offsetWidth // reflow para fijar la posición sin animar
        selectorFrame.style.transition = '' // restaura la transición del CSS
      }
      selectorFrame.classList.add('is-visible')
    }

    function hideFrame() {
      selectorFrame?.classList.remove('is-visible')
    }

    // Re-dispara las animaciones de reveal (retrato, nombre, barrido, VS).
    function playReveal() {
      if (!boxerPanel) return
      boxerPanel.classList.remove('is-revealing')
      // Forzar reflow para reiniciar las animaciones CSS.
      void boxerPanel.offsetWidth
      boxerPanel.classList.add('is-revealing')
    }

    // Actualiza la línea "VS {rival}" a partir del thumb del contrincante.
    function updateVsLine(opponentThumb: HTMLAnchorElement | null) {
      if (!vsLine) return
      const opponentName = opponentThumb?.dataset.name
      if (opponentName && vsName) {
        vsName.textContent = opponentName
        vsLine.dataset.hasOpponent = 'true'
      } else {
        vsLine.dataset.hasOpponent = 'false'
      }
    }

    function showDefault() {
      if (root!.dataset.state === 'default') return
      root!.dataset.state = 'default'
      delete root!.dataset.activeId
      thumbs.forEach((btn) => {
        btn.dataset.active = 'false'
        btn.dataset.opponent = 'false'
      })
      defaultPanel?.setAttribute('aria-hidden', 'false')
      boxerPanel?.setAttribute('aria-hidden', 'true')
      hideFrame()
      boxerPanel?.classList.remove('is-revealing')
    }

    /** Aplica el contenido (imagen, nombre, watermark, bandera, país) al
     *  panel del boxer. No toca el state ni las clases is-switching. */
    function applyBoxerContent(thumb: HTMLAnchorElement) {
      const { name, photoAvif, photoWebp, countryCode, country } = thumb.dataset
      if (!name || !photoWebp) return

      // Actualizamos las sources del <picture> antes del src del <img>
      // para que el browser re-evalúe y use el mejor formato disponible.
      if (sourceAvif && photoAvif) sourceAvif.srcset = photoAvif
      if (sourceWebp && photoWebp) sourceWebp.srcset = photoWebp
      image!.src = photoWebp
      image!.alt = `Foto principal de ${name}`

      nameNode!.textContent = name
      watermarkTexts.forEach((node) => {
        node.textContent = name
      })

      if (flagNode && countryCode) flagNode.src = `/flags/${countryCode}.svg`
      if (countryNode && country) countryNode.textContent = country
    }

    function select(thumb: HTMLAnchorElement) {
      if (!image || !nameNode) return

      const { id, opponentId } = thumb.dataset
      if (!id || !thumb.dataset.photoWebp) return

      const wasDefault = root!.dataset.state === 'default'

      const opponentThumb = opponentId ? thumbsById.get(opponentId) : null

      thumbs.forEach((btn) => {
        const isActive = btn === thumb
        const isOpponent = btn === opponentThumb
        btn.dataset.active = String(isActive)
        btn.dataset.opponent = String(isOpponent)
        btn.tabIndex = isActive ? 0 : -1
      })

      // Desliza el frame de selección a la casilla activa y refresca el VS.
      moveFrameTo(thumb)
      updateVsLine(opponentThumb ?? null)

      // Si veníamos del estado por defecto, aplicamos el contenido
      // ANTES de hacer visible el panel para evitar el "flash" del
      // boxer pre-renderizado (fallback Alondrissa). Como no hay nada
      // visible que sustituir, tampoco usamos el efecto is-switching.
      if (wasDefault) {
        if (root!.dataset.activeId !== id) {
          applyBoxerContent(thumb)
          root!.dataset.activeId = id
        }
        root!.dataset.state = 'boxer'
        defaultPanel?.setAttribute('aria-hidden', 'true')
        boxerPanel?.setAttribute('aria-hidden', 'false')
        playReveal()
        return
      }

      // Ya estábamos en estado 'boxer'. Reaseguramos el panel visible
      // (puede haberse perdido si se reseteó a default entre eventos).
      root!.dataset.state = 'boxer'
      defaultPanel?.setAttribute('aria-hidden', 'true')
      boxerPanel?.setAttribute('aria-hidden', 'false')

      if (root!.dataset.activeId === id) return
      root!.dataset.activeId = id

      // Cross-fade clásico entre boxers: fade out → swap → fade in.
      image.classList.add('is-switching')
      nameNode!.classList.add('is-switching')
      watermark?.classList.add('is-switching')

      const swap = () => {
        applyBoxerContent(thumb)

        const onLoaded = () => {
          image.classList.remove('is-switching')
          nameNode!.classList.remove('is-switching')
          watermark?.classList.remove('is-switching')
          playReveal()
        }
        if (image.complete && image.naturalHeight > 0) {
          requestAnimationFrame(onLoaded)
        } else {
          image.addEventListener('load', onLoaded, { once: true })
          image.addEventListener('error', onLoaded, { once: true })
        }
      }
      setTimeout(swap, 140)
    }

    // El click en cada thumb lo gestiona nativamente el <a> (navegación
    // a /boxeadores/<id>). Aquí solo enganchamos hover/focus para que se
    // actualice el preview del hero antes de que el usuario decida.
    //
    // En `click` además marcamos con `view-transition-name` el elemento
    // que será origen del morph hacia el retrato grande del perfil:
    //   - Desktop (≥1024px): la imagen grande del hero, que en este
    //     breakpoint ya está visible por el hover/focus previo. El
    //     morph es de retrato a retrato.
    //   - Mobile/tablet (<1024px): la miniatura clicada, porque el
    //     panel del hero suele estar oculto al pulsar sin hover previo
    //     y necesitamos un origen visible que la View Transitions API
    //     pueda capturar como snapshot.
    thumbs.forEach((thumb) => {
      thumb.addEventListener('mouseenter', () => select(thumb))
      thumb.addEventListener('focus', () => select(thumb))
      thumb.addEventListener('click', () => {
        const id = thumb.dataset.id
        if (!id) return
        const isDesktop = window.matchMedia('(min-width: 1024px)').matches

        if (isDesktop && image) {
          // Saltamos el cross-fade pendiente para que la imagen del hero
          // refleje al boxeador clicado en el momento del snapshot.
          image.classList.remove('is-switching')
          nameNode?.classList.remove('is-switching')
          watermark?.classList.remove('is-switching')
          applyBoxerContent(thumb)
          image.style.viewTransitionName = `boxer-hero-${id}`
          return
        }

        const thumbImg = $<HTMLImageElement>(
          '.boxer-thumb-img',
          thumb,
        )
        if (thumbImg) {
          thumbImg.style.viewTransitionName = `boxer-hero-${id}`
        }
      })
    })

    mobileThumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const id = thumb.dataset.id
        if (!id) return

        const thumbImg = $<HTMLImageElement>(
          '.boxer-mobile-slide-img',
          thumb,
        )
        if (thumbImg) {
          thumbImg.style.viewTransitionName = `boxer-hero-${id}`
        }
      })
    })

    // Al salir con el ratón del grid, volvemos al estado por defecto,
    // salvo que haya un thumb con foco de teclado.
    grid.addEventListener('mouseleave', () => {
      const keyboardFocused = $<HTMLElement>(
        '[data-thumb]:focus-visible',
        root,
      )
      if (keyboardFocused) return
      showDefault()
    })

    // Al perder el foco de teclado (tab fuera del selector) volvemos al
    // estado por defecto si tampoco hay hover.
    grid.addEventListener('focusout', () => {
      // Esperamos al siguiente frame para que document.activeElement esté ya
      // actualizado al nuevo elemento que recibe el foco.
      requestAnimationFrame(() => {
        const stillInside = root!.contains(document.activeElement)
        const hovering = grid.matches(':hover')
        if (!stillInside && !hovering) showDefault()
      })
    })

    // Tap/click fuera de la sección (especialmente útil en móvil/táctil):
    // resetea al estado por defecto.
    document.addEventListener('pointerdown', (event) => {
      const target = event.target as Node | null
      if (target && root!.contains(target)) return
      showDefault()
    })

    root.addEventListener('keydown', (event) => {
      const target = event.target as HTMLElement | null
      if (!target?.matches('[data-thumb]')) return

      const currentIndex = thumbs.indexOf(target as HTMLAnchorElement)
      if (currentIndex < 0) return

      if (event.key === 'Escape') {
        event.preventDefault()
        target.blur()
        showDefault()
        return
      }

      if (event.key === 'ArrowRight' || event.key === 'ArrowDown') {
        event.preventDefault()
        const next = thumbs[(currentIndex + 1) % thumbs.length]
        next.focus()
      } else if (event.key === 'ArrowLeft' || event.key === 'ArrowUp') {
        event.preventDefault()
        const prev = thumbs[(currentIndex - 1 + thumbs.length) % thumbs.length]
        prev.focus()
      } else if (event.key === 'Home') {
        event.preventDefault()
        thumbs[0].focus()
      } else if (event.key === 'End') {
        event.preventDefault()
        thumbs[thumbs.length - 1].focus()
      }
    })
  }

  document.addEventListener('astro:page-load', initBoxerSelector)
</script>
