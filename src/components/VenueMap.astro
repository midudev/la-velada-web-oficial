---
import 'leaflet/dist/leaflet.css'

interface Props {
  mapId?: string
}

const { mapId = 'faq-venue-map' } = Astro.props
---

<div class="venue-map" data-venue-map>
  <div class="venue-map__reveal">
    <div id={mapId} class="venue-map__canvas" role="img" aria-label="Mapa del Estadio de La Cartuja, Sevilla"></div>
  </div>
</div>

<style>
  .venue-map {
    margin-top: 1.125rem;
    width: 100%;
  }

  .venue-map__reveal {
    position: relative;
    overflow: hidden;
    height: clamp(11rem, 42vw, 16.5rem);
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 22%, transparent);
    border-radius: 0.125rem;
    background: var(--color-theme-navy);
    clip-path: inset(0 0 100% 0);
    transition: clip-path 320ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  .venue-map__reveal--open {
    clip-path: inset(0 0 0 0);
  }

  @media (prefers-reduced-motion: reduce) {
    .venue-map__reveal {
      transition: none;
    }
  }

  .venue-map__reveal::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 500;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-theme-midnight) 12%, transparent) 0%,
      color-mix(in srgb, var(--color-theme-gold) 8%, transparent) 45%,
      color-mix(in srgb, var(--color-theme-midnight) 28%, transparent) 100%
    );
  }

  .venue-map__canvas {
    position: relative;
    z-index: 0;
    width: 100%;
    height: 100%;
    border-radius: 0;
    background: var(--color-theme-navy);
  }

  .venue-map__canvas:global(.leaflet-container) {
    font-family: inherit;
    background: var(--color-theme-midnight);
  }

  .venue-map :global(.leaflet-tile-pane) {
    filter: sepia(0.42) hue-rotate(8deg) saturate(1.15) brightness(1.12) contrast(0.82);
  }

  .venue-map :global(.leaflet-control-attribution) {
    margin: 0;
    padding: 0.2rem 0.45rem;
    background: color-mix(in srgb, var(--color-theme-midnight) 88%, transparent) !important;
    color: color-mix(in srgb, var(--color-theme-cream) 45%, transparent) !important;
    font-size: 0.625rem;
    letter-spacing: 0.04em;
  }

  .venue-map :global(.leaflet-control-attribution a) {
    color: color-mix(in srgb, var(--color-theme-gold) 70%, transparent) !important;
  }

  .venue-map :global(.leaflet-control-zoom) {
    border: 1px solid color-mix(in srgb, var(--color-theme-gold) 22%, transparent) !important;
    overflow: hidden;
  }

  .venue-map :global(.leaflet-control-zoom a) {
    background: color-mix(in srgb, var(--color-theme-midnight) 92%, transparent) !important;
    color: var(--color-theme-gold) !important;
    border-bottom-color: color-mix(in srgb, var(--color-theme-gold) 18%, transparent) !important;
  }

  .venue-map :global(.leaflet-control-zoom a:hover) {
    background: color-mix(in srgb, var(--color-theme-navy) 88%, transparent) !important;
    color: var(--color-theme-cream) !important;
  }

  .venue-map :global(.venue-map-marker) {
    background: transparent;
    border: none;
  }

  .venue-map :global(.venue-map-marker__dot) {
    display: block;
    width: 0.75rem;
    height: 0.75rem;
    border: 2px solid var(--color-theme-gold);
    border-radius: 50%;
    background: var(--color-theme-midnight);
    box-shadow:
      0 0 0 4px color-mix(in srgb, var(--color-theme-gold) 22%, transparent),
      0 0 14px color-mix(in srgb, var(--color-theme-gold) 45%, transparent);
  }

  @media (min-width: 640px) {
    .venue-map {
      margin-top: 1.25rem;
    }

    .venue-map__reveal {
      height: clamp(12rem, 28vw, 18rem);
    }
  }
</style>

<script>
  import L from 'leaflet'
  import { $, $$ } from '@/lib/dom-selector'
  import { EVENT_VENUE_LAT, EVENT_VENUE_LNG, FAQ_PANEL_TOGGLE } from '@/consts/event'

  const TILE_URL = 'https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png'
  const TILE_ATTRIBUTION =
    '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/attributions">CARTO</a>'

  const MAP_OPEN_MS = 320
  const MAP_CLOSE_MS = 220

  let venueMapAbort: AbortController | undefined
  const mapInstances = new WeakMap<HTMLElement, L.Map>()

  function afterTransition(
    element: HTMLElement,
    ms: number,
    property?: string,
  ): Promise<void> {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      return Promise.resolve()
    }

    return new Promise((resolve) => {
      let settled = false

      const finish = () => {
        if (settled) return
        settled = true
        element.removeEventListener('transitionend', onEnd)
        window.clearTimeout(timer)
        resolve()
      }

      const onEnd = (event: TransitionEvent) => {
        if (event.target !== element) return
        if (property && event.propertyName !== property) return
        finish()
      }

      element.addEventListener('transitionend', onEnd)
      const timer = window.setTimeout(finish, ms + 40)
    })
  }

  function initLeafletMap(canvas: HTMLElement) {
    if (mapInstances.has(canvas)) return

    const map = L.map(canvas, {
      center: [EVENT_VENUE_LAT, EVENT_VENUE_LNG],
      zoom: 14,
      scrollWheelZoom: false,
      attributionControl: true,
      zoomControl: true,
    })

    L.tileLayer(TILE_URL, {
      attribution: TILE_ATTRIBUTION,
      subdomains: 'abcd',
      maxZoom: 19,
    }).addTo(map)

    const icon = L.divIcon({
      className: 'venue-map-marker',
      html: '<span class="venue-map-marker__dot"></span>',
      iconSize: [12, 12],
      iconAnchor: [6, 6],
    })

    L.marker([EVENT_VENUE_LAT, EVENT_VENUE_LNG], { icon }).addTo(map)
    mapInstances.set(canvas, map)
  }

  function teardownLeafletMap(canvas: HTMLElement) {
    mapInstances.get(canvas)?.remove()
    mapInstances.delete(canvas)
  }

  async function syncVenueMap(root: HTMLElement, open: boolean) {
    const canvas = $('.venue-map__canvas', root)
    const reveal = $('.venue-map__reveal', root)
    if (!canvas || !reveal) return

    if (open) {
      initLeafletMap(canvas)
      reveal.classList.add('venue-map__reveal--open')
      await afterTransition(reveal, MAP_OPEN_MS, 'clip-path')
      mapInstances.get(canvas)?.invalidateSize()
      return
    }

    reveal.classList.remove('venue-map__reveal--open')
    await afterTransition(reveal, MAP_CLOSE_MS, 'clip-path')
    teardownLeafletMap(canvas)
  }

  function onFaqPanelToggle(event: Event) {
    if (!(event instanceof CustomEvent)) return
    const details = event.target
    if (!(details instanceof HTMLDetailsElement)) return

    const root = $('[data-venue-map]', details)
    if (!root) return

    void syncVenueMap(root, Boolean(event.detail?.open))
  }

  function setupVenueMaps() {
    venueMapAbort?.abort()
    venueMapAbort = new AbortController()
    const { signal } = venueMapAbort

    document.addEventListener(FAQ_PANEL_TOGGLE, onFaqPanelToggle, { signal })

    for (const root of $$('[data-venue-map]')) {
      if (root.closest('details')?.open) {
        void syncVenueMap(root, true)
      }
    }
  }

  document.addEventListener('astro:page-load', setupVenueMaps)
  setupVenueMaps()
</script>
