---
import VeladaLogo from '@/assets/svg/logo.svg'

interface Props {
  titleId: string
  title: string
  subtitle: string
  eyebrow?: string
  dividerClass?: string
  titleClass?: string
  subtitleClass?: string
  eyebrowClass?: string
}

const {
  titleId,
  title,
  subtitle,
  eyebrow,
  dividerClass = 'sm:mb-12',
  titleClass = 'mb-3',
  subtitleClass = 'mb-10 max-w-xl tracking-[0.25em] sm:text-sm',
  eyebrowClass,
} = Astro.props
---

<div class:list={['mb-8 flex items-center gap-4', dividerClass]} aria-hidden="true">
  <span class="h-px w-12 bg-linear-to-r from-transparent to-theme-gold/40 sm:w-24"></span>
  <VeladaLogo class="h-[1.125rem] w-[1.125rem] shrink-0 text-theme-gold [&_path]:stroke-current [&_path]:stroke-[9] [&_path]:stroke-linejoin-round" />
  <span class="h-px w-12 bg-linear-to-l from-transparent to-theme-gold/40 sm:w-24"></span>
</div>

{
  eyebrow && (
    <p
      class:list={[
        'mb-3 font-cinzel text-[0.6rem] font-bold tracking-[0.45em] text-theme-gold/80 sm:text-xs',
        eyebrowClass,
      ]}
    >
      {eyebrow}
    </p>
  )
}

<h2
  id={titleId}
  class:list={[
    'text-center font-cinzel text-3xl font-bold tracking-[0.18em] text-theme-cream sm:text-4xl md:text-5xl',
    titleClass,
  ]}
>
  {title}
</h2>

<p
  class:list={[
    'text-center font-cinzel text-xs font-medium text-balance text-white/55',
    subtitleClass,
  ]}
>
  {subtitle}
</p>
