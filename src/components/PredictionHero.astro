---
import PredictionStats from '@/components/PredictionStats.astro'
import SectionDivider from '@/components/SectionDivider.astro'

interface Props {
  totalCombats: number
  totalVotes: number
  closeBattles: number
}

const { totalCombats, totalVotes, closeBattles } = Astro.props
---

<header class="predictions-hero mx-auto flex w-full max-w-3xl flex-col items-center text-center">
  <SectionDivider size="lg" class="mb-7 sm:mb-9" />

  <p class="mb-3 font-cinzel text-[0.6rem] font-black tracking-[0.24em] text-theme-gold/80 sm:text-xs">
    La Velada del Año VI
  </p>

  <h1
    id="predictions-title"
    class="font-cinzel text-4xl leading-[0.95] font-black tracking-[0.12em] text-theme-cream uppercase sm:text-5xl md:text-6xl"
  >
    Pronósticos
  </h1>

  <p
    class="mt-4 max-w-xl font-cinzel text-xs font-medium tracking-[0.08em] text-balance text-white/55 sm:text-sm"
  >
    Vota tu ganador en cada combate y sigue en directo lo que pronostica la comunidad.
  </p>

  <PredictionStats
    totalCombats={totalCombats}
    totalVotes={totalVotes}
    closeBattles={closeBattles}
  />
</header>
