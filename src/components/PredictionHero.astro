---
import PredictionStats from '@/components/PredictionStats.astro'

interface Props {
  totalCombats: number
  totalVotes: number
  closeBattles: number
}

const { totalCombats, totalVotes, closeBattles } = Astro.props
---

<header class="predictions-hero mx-auto flex w-full max-w-5xl flex-col items-center text-center">
  <p
    class="mb-2 font-cinzel text-[0.55rem] font-bold tracking-[0.45em] text-theme-gold/85 sm:text-[0.65rem]"
  >
    LA VELADA VI
  </p>
  <h1
    id="predictions-title"
    class="font-cinzel text-3xl leading-[0.95] font-black tracking-[0.14em] text-theme-cream uppercase sm:text-4xl md:text-5xl"
  >
    Pronósticos
  </h1>

  <PredictionStats
    totalCombats={totalCombats}
    totalVotes={totalVotes}
    closeBattles={closeBattles}
  />
</header>
