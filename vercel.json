{
  "redirects": [
    {
      "source": "/((?!^/?$).+)/",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/2024",
      "destination": "https://2024.infolavelada.com"
    },
    {
      "source": "/2024/:path*",
      "destination": "https://2024.infolavelada.com/:path*"
    },
    {
      "source": "/2025",
      "destination": "https://2025.infolavelada.com"
    },
    {
      "source": "/2025/:path*",
      "destination": "https://2025.infolavelada.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://va.vercel-scripts.com https://vercel.live; style-src 'self' 'unsafe-inline' https://unpkg.com; img-src 'self' data: blob: https:; font-src 'self' data: https://cdn.infolavelada.com; media-src 'self' https://cdn.infolavelada.com; connect-src 'self' https://*.vercel-insights.com https://va.vercel-scripts.com; frame-src 'self' https://www.youtube-nocookie.com https://vercel.live; frame-ancestors 'none'; base-uri 'self'; object-src 'none'"
        }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
