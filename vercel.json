{
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)\\.(?:avif|webp|png|jpg|jpeg|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "private, max-age=10, stale-while-revalidate=30"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/((?!^/?$).+)/",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/2024",
      "destination": "https://2024.infolavelada.com"
    },
    {
      "source": "/2024/:path*",
      "destination": "https://2024.infolavelada.com/:path*"
    },
    {
      "source": "/2025",
      "destination": "https://2025.infolavelada.com"
    },
    {
      "source": "/2025/:path*",
      "destination": "https://2025.infolavelada.com/:path*"
    }
  ]
}
